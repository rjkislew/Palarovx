public void Dispose()
{
_refreshTimer?.Dispose();
_autoTimer?.Dispose();
_lock.Dispose();
}

private string GetCategoryShort(string cat)
{
if (string.IsNullOrWhiteSpace(cat)) return "GYMNASTICS";
if (cat.Contains("Rhythmic", StringComparison.OrdinalIgnoreCase)) return "RHYTHMIC GYMNASTICS";
if (cat.Contains("Aerobic", StringComparison.OrdinalIgnoreCase)) return "AEROBIC GYMNASTICS";
if (cat.Contains("Women's Artistic", StringComparison.OrdinalIgnoreCase)) return "WOMEN'S ARTISTIC GYMNASTICS";
if (cat.Contains("Men's Artistic", StringComparison.OrdinalIgnoreCase)) return "MEN'S ARTISTIC GYMNASTICS";
return "GYMNASTICS";
}

private string GetSchoolLevelName(int? id) => id switch
{
1 => "ELEMENTARY",
2 => "SECONDARY",
_ => "OPEN"
};

private string GetGenderName(int? id) => id switch
{
1 => "MALE",
2 => "FEMALE",
3 => "MIXED",
_ => "GENDER"
};

private string GetEventStageName(int? id) => id switch
{
4 => "FINALS",
3 => "SEMI-FINALS",
_ => "QUALIFIERS"
};

private string GetRegionName(int regionId)
{
var r = _regions.FirstOrDefault(x => x.ID == regionId);
return r?.Abbreviation ?? r?.Region ?? $"Region {regionId}";
}

private static int GetMedalSortOrder(string? rank) => rank switch
{
"Gold" => 0,
"Silver" => 1,
"Bronze" => 2,
_ => 99
};

private static int GetNumericRankOrMax(string? rank)
{
if (int.TryParse(rank, out var n) && n > 0) return n;
return int.MaxValue;
}

private string GetRegionLogo(string regionName)
{
if (string.IsNullOrWhiteSpace(regionName))
return "/images/region-placeholder.png";

var r = _regions.FirstOrDefault(x =>
(x.Abbreviation ?? "").Equals(regionName, StringComparison.OrdinalIgnoreCase) ||
(x.Region ?? "").Equals(regionName, StringComparison.OrdinalIgnoreCase)
);

var actual = (r?.Region ?? regionName).Trim();
var encoded = Uri.EscapeDataString(actual);

return $"https://palarongpambansa2026.com/attachments/media/regions/team_logo/{encoded}.webp";
}
