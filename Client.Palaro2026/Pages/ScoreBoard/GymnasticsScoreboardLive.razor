@page "/scoreboard/gymnastics/details/{EventID:int}"
@layout ClientLayout
@using System.Threading
@using System.Linq
@using Client.Palaro2026.Services
@inject APIService apiService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Gymnastics Event Details | Palaro tu AgSur 2026</PageTitle>

<style>
    @@import url('https://fonts.cdnfonts.com/css/evil-empire');
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&family=Chakra+Petch:wght@600;700;800&display=swap');

    :root {
        --pal-blue: #023E8A;
        --pal-dark-blue: #001845;
        --pal-gold: #FFB400;
        --pal-red: #EA0000;
        --font-header: 'Evil Empire', sans-serif;
        --font-subheader: 'Chakra Petch', sans-serif;
        --font-body: 'Nunito', sans-serif;
        --wrapMax: 2400px;
    }

    body {
        background: #f8f9fa;
        margin: 0;
        overflow-x: hidden;
        font-family: var(--font-body);
    }

    .tv-screen-bg {
        min-height: 100vh;
        width: 100vw;
        background: radial-gradient(circle at 50% 30%, #ffffff 0%, #e0e7ff 100%);
        padding: 26px 0 12vh 0;
        position: relative;
    }

    .wrap, .page-footer {
        width: min(var(--wrapMax), 96vw);
        margin-left: auto;
        margin-right: auto;
    }

    .back-button {
        position: fixed;
        top: 16px;
        left: 16px;
        z-index: 3000;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: white;
        color: var(--pal-dark-blue);
        border: 2px solid #e9ecef;
        padding: 10px 16px;
        border-radius: 999px;
        cursor: pointer;
        font-weight: 900;
        letter-spacing: 1px;
        text-transform: uppercase;
        box-shadow: 0 6px 18px rgba(0,0,0,0.08);
        transition: all .2s ease;
        font-size: 0.95rem;
    }

        .back-button:hover {
            border-color: var(--pal-gold);
            box-shadow: 0 10px 25px rgba(0,0,0,0.12);
            transform: translateY(-1px);
        }

    .dashboard-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin: 15px 0 18px 0;
    }

    .header-pill {
        background: var(--pal-dark-blue);
        border: 4px solid var(--pal-gold);
        padding: 18px 50px;
        border-radius: 50px;
        text-align: center;
        box-shadow: 0 12px 28px rgba(0,0,0,0.2);
        max-width: calc(100% - 60px);
    }

    .main-event-title {
        font-family: var(--font-header);
        color: white;
        font-size: 40px;
        letter-spacing: 3px;
        margin: 0;
        line-height: 1;
        text-shadow: 3px 3px 0px black;
        text-transform: uppercase;
    }

    .sub-header-text {
        color: var(--pal-gold);
        font-size: 14px;
        letter-spacing: 4px;
        font-weight: 900;
        text-transform: uppercase;
        margin-top: 10px;
        opacity: 0.98;
        font-family: var(--font-subheader);
    }

    .cards-grid {
        margin-top: 14px;
        display: grid;
        grid-template-columns: repeat(12, minmax(0, 1fr));
        gap: 16px;
        align-items: stretch;
    }

    .dance-card {
        grid-column: span 3;
        background: white;
        border-radius: 18px;
        border: 1px solid #e9ecef;
        box-shadow: 0 10px 22px rgba(0,0,0,0.06);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        min-width: 0;
        height: 100%;
    }

        .dance-card.wide {
            grid-column: span 12;
        }

    .dance-card-head {
        padding: 12px;
        background: #fbfbfd;
        border-bottom: 3px solid var(--pal-gold);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    .dance-title {
        font-family: var(--font-header);
        color: var(--pal-dark-blue);
        letter-spacing: 2px;
        text-transform: uppercase;
        font-size: 16px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        min-width: 0;
    }

    .dance-card-body {
        padding: 0px 12px 12px 12px;
        flex: 1 1 auto;
        display: flex;
        flex-direction: column;
        min-height: 0;
    }

    .card-carousel-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 8px 0;
    }

    .card-page {
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #6c757d;
        font-size: 10px;
        white-space: nowrap;
        font-family: var(--font-subheader);
    }

    /* keep only ONE dot definition (used by both gymnastics cards + aerobic TV view) */
    .dot {
        width: 9px;
        height: 9px;
        border-radius: 999px;
        background: #dee2e6;
        display: inline-block;
        margin: 0 3px;
    }

        .dot.active {
            background: var(--pal-gold);
            box-shadow: 0 0 0 3px rgba(255, 180, 0, 0.18);
        }

    .dance-table thead th {
        font-weight: 900 !important;
        text-transform: uppercase !important;
        letter-spacing: 2px !important;
        color: var(--pal-dark-blue) !important;
        background: #ffffff !important;
        border-bottom: 1px solid #f1f1f1 !important;
        padding: 12px 12px !important;
        font-size: 0.9rem !important;
        white-space: nowrap;
        font-family: var(--font-subheader) !important;
    }

    .dance-table tbody td {
        border-bottom: 1px solid #f1f1f1 !important;
        padding: 12px 12px !important;
        vertical-align: middle;
        font-size: 1.05rem !important;
        font-weight: 800;
    }

    .rank-pill {
        min-width: 64px;
        height: 34px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        color: var(--pal-dark-blue);
        background: #fff;
        border: 2px solid #e9ecef;
        font-family: var(--font-subheader);
        font-weight: 900;
        padding: 6px 12px;
    }

    .rank-pills {
        min-width: 44px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        color: var(--pal-dark-blue);
        background: #fff;
        font-family: var(--font-subheader);
        font-weight: 900;
    }

    .rank1 {
        border-color: #FFD700;
        box-shadow: 0 0 12px rgba(255,215,0,.45);
    }

    .rank2 {
        border-color: #C0C0C0;
        box-shadow: 0 0 10px rgba(192,192,192,.35);
    }

    .rank3 {
        border-color: #CD7F32;
        box-shadow: 0 0 10px rgba(205,127,50,.35);
    }

    /* swimming-like rank classes (used for aerobic TV table) */
    .rank-1 {
        border-color: #FFD700;
        box-shadow: 0 0 0 3px rgba(255,215,0,0.18);
    }

    .rank-2 {
        border-color: #C0C0C0;
        box-shadow: 0 0 0 3px rgba(192,192,192,0.16);
    }

    .rank-3 {
        border-color: #CD7F32;
        box-shadow: 0 0 0 3px rgba(205,127,50,0.16);
    }

    .couple-cell {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
    }

    .mini-logo {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: #fff;
        border: 2px solid #e9ecef;
        padding: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 10px rgba(0,0,0,.08);
        flex: 0 0 auto;
    }

    .couple-text {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .couple-name {
        font-weight: 900;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-size: 14px;
    }

    .couple-region {
        font-weight: 900;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #6c757d;
        font-size: 12px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-family: var(--font-subheader);
    }

    /* championships */
    .medal-grid {
        display: grid;
        grid-template-columns: repeat(12, minmax(0, 1fr));
        gap: 12px;
    }

    .medal-row {
        grid-column: span 6;
        border: 1px solid #e9ecef;
        border-radius: 14px;
        overflow: hidden;
        background: #fff;
    }

    .medal-row-head {
        padding: 12px 14px;
        background: #fbfbfd;
        border-bottom: 1px solid #f1f1f1;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--pal-dark-blue);
        font-size: 1.05rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        flex-wrap: wrap;
        font-family: var(--font-subheader);
    }

    .medal-row-body {
        padding: 12px 14px 14px 14px;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
    }

    .medal-box {
        border: 1px solid #e9ecef;
        border-radius: 14px;
        padding: 12px 12px;
        background: white;
        min-width: 0;
    }

    .medal-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 10px;
    }

        .medal-top .m {
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 0.95rem;
            color: #6c757d;
            white-space: nowrap;
            font-family: var(--font-subheader);
        }

    .medal-box.gold {
        border-color: rgba(255,215,0,0.55);
    }

    .medal-box.silver {
        border-color: rgba(192,192,192,0.55);
    }

    .medal-box.bronze {
        border-color: rgba(205,127,50,0.55);
    }

    .winner-row {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
    }

    .winner-logo {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: #fff;
        border: 2px solid #e9ecef;
        padding: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 10px rgba(0,0,0,.08);
        flex: 0 0 auto;
    }

    .winner-info {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .winner-name {
        font-weight: 900;
        font-size: 1.05rem;
        color: #212529;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 520px;
        line-height: 1.05;
    }

    .winner-region {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-weight: 900;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #6c757d;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 520px;
        font-family: var(--font-subheader);
    }

    .winner-members {
        margin-top: 8px;
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .member-chip {
        border: 1px solid #e9ecef;
        background: #fff;
        border-radius: 999px;
        padding: 6px 10px;
        font-weight: 900;
        letter-spacing: 1px;
        font-size: 0.82rem;
        color: #495057;
        max-width: 220px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-family: var(--font-subheader);
    }

    @@media (max-width: 1400px) {
        .dance-card {
            grid-column: span 6;
        }

            .dance-card.wide {
                grid-column: span 12;
            }

        .medal-row {
            grid-column: span 12;
        }
    }

    @@media (max-width: 800px) {
        .dance-card {
            grid-column: span 12;
        }

            .dance-card.wide {
                grid-column: span 12;
            }

        .medal-row {
            grid-column: span 12;
        }
    }

    /* --- Medal placeholder (Waiting for scores) --- */
    .medal-wait {
        width: 100%;
        min-height: 92px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 14px 10px;
        text-align: center;
    }

        .medal-wait .wait-icon {
            color: #dee2e6;
            width: 56px;
            height: 56px;
        }

        .medal-wait .wait-text {
            color: #adb5bd;
            font-family: var(--font-header);
            font-weight: 900;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

    /* ==========================
               SWIMMING-LIKE TV TABLE (AEROBIC)
               ========================== */

    .results-wrap {
        width: min(1400px, calc(100% - 40px));
        margin: 0 auto;
        background: white;
        border-radius: 20px;
        border: 1px solid #e9ecef;
        box-shadow: 0 8px 18px rgba(0,0,0,0.06);
        overflow: hidden;
    }

    .results-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 14px 16px;
        border-bottom: 2px solid var(--pal-gold);
        flex-wrap: wrap;
    }

    .results-title {
        font-family: var(--font-header);
        font-size: 1.6rem;
        color: var(--pal-dark-blue);
        text-transform: uppercase;
        letter-spacing: 1px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .results-note {
        font-family: var(--font-subheader);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #6c757d;
        font-size: 0.78rem;
    }

    .pager-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 10px 12px;
        border-bottom: 1px solid #f1f1f1;
        background: #ffffff;
    }

    .pager-dots {
        display: inline-flex;
        gap: 6px;
        align-items: center;
        flex-wrap: wrap;
        justify-content: center;
    }

    .tv-table .mud-table-container {
        background: white !important;
    }

    .tv-table thead th {
        font-family: var(--font-subheader) !important;
        font-weight: 900 !important;
        text-transform: uppercase !important;
        letter-spacing: 1px !important;
        color: var(--pal-dark-blue) !important;
        background: #fbfbfd !important;
        border-bottom: 1px solid #f1f1f1 !important;
        padding-top: 14px !important;
        padding-bottom: 14px !important;
        font-size: 0.82rem !important;
        white-space: nowrap;
    }

    .tv-table tbody td {
        border-bottom: 1px solid #f1f1f1 !important;
        padding-top: 14px !important;
        padding-bottom: 14px !important;
    }

    .athlete-name {
        font-family: var(--font-body);
        font-weight: 900;
        color: #212529;
        font-size: 1rem;
        line-height: 1.1;
    }

    .best-result {
        font-family: var(--font-subheader);
        font-weight: 900;
        text-align: right;
        color: var(--pal-gold);
        white-space: nowrap;
        font-size: 1.15rem;
    }
</style>

<div class="tv-screen-bg">
    <button class="back-button" @onclick="GoBack">← Back</button>

    @if (_isLoading)
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height:70vh;">
            <MudProgressCircular Indeterminate Color="Color.Primary" Size="Size.Large" />
            <MudText Typo="Typo.h6" Class="mt-4" Style="font-family:var(--font-header); color:var(--pal-blue);">
                LOADING GYMNASTICS EVENT...
            </MudText>
        </MudStack>
    }
    else if (_event == null)
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height:70vh;">
            <MudText Typo="Typo.h4" Style="font-family:var(--font-header); color: var(--pal-red);">
                EVENT NOT FOUND
            </MudText>
        </MudStack>
    }
    else
    {
        <div class="dashboard-header">
            <div class="header-pill">
                <h1 class="main-event-title">GYMNASTICS</h1>
                <div class="sub-header-text">
                    @GetSchoolLevelName(_event.LevelID) • @_event.MainCategory • @GetEventStageName(_event.StageID)
                </div>
            </div>
        </div>

        <div class="wrap">
            <div class="cards-grid">

                @* ✅ AEROBIC = SWIMMING-LIKE SINGLE TV TABLE (NO REGION COLUMN) *@
                @if (IsAerobicEvent())
                {
                    var full = GetAerobicRows();
                    var pageRows = GetAerobicPageRows(full);

                    <div class="dance-card wide" style="background:transparent; border:none; box-shadow:none; padding:0;">
                        <div class="results-wrap">
                            <div class="results-header">
                                <div class="results-title">
                                    <MudIcon Icon="@Icons.Material.Filled.FitnessCenter" Style="color: var(--pal-gold);" />
                                    RESULTS
                                </div>

                                <div class="results-note">
                                    PAGE @(GetAerobicPageIndex() + 1) / @Math.Max(1, GetAerobicPageCount(full)) • AUTO SLIDE
                                </div>
                            </div>

                            @if (full.Count == 0)
                            {
                                <MudStack AlignItems="AlignItems.Center" Class="pa-10">
                                    <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty"
                                             Size="Size.Large"
                                             Style="color:#dee2e6; width:70px; height:70px;" />
                                    <MudText Typo="Typo.h6" Style="color:#adb5bd; font-family:var(--font-header);">
                                        WAITING FOR RESULTS...
                                    </MudText>
                                </MudStack>
                            }
                            else
                            {
                                <div class="pager-bar">
                                    <MudStack Row Spacing="1" AlignItems="AlignItems.Center">
                                        <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                                                       Color="Color.Primary"
                                                       Variant="Variant.Outlined"
                                                       Size="Size.Small"
                                                       OnClick="@PrevAerobicPage" />

                                        <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                                                       Color="Color.Primary"
                                                       Variant="Variant.Outlined"
                                                       Size="Size.Small"
                                                       OnClick="@NextAerobicPage" />
                                    </MudStack>
                                </div>

                                <MudTable Class="tv-table"
                                          Items="pageRows"
                                          Dense="true"
                                          Hover="true"
                                          Elevation="0">
                                    <HeaderContent>
                                        <MudTh>Rank</MudTh>
                                        <MudTh>Athlete</MudTh>
                                        <MudTh style="text-align:center;">Score</MudTh>
                                    </HeaderContent>

                                    <RowTemplate>
                                        @{
                                            var rankClass = context.Rank switch
                                            {
                                                1 => "rank-1",
                                                2 => "rank-2",
                                                3 => "rank-3",
                                                _ => ""
                                            };
                                        }

                                        <MudTd>
                                            @if (context.Rank > 0)
                                            {
                                                <span class="rank-pill @rankClass">#@context.Rank</span>
                                            }
                                            else
                                            {
                                                <span class="rank-pill" style="opacity:.55;">-</span>
                                            }
                                        </MudTd>

                                        <MudTd>
                                            <div class="athlete-name">@context.PlayerName</div>
                                        </MudTd>

                                        <MudTd style="text-align:center;" Class="best-result">
                                            @context.Score.ToString("0.00")
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>

                                <MudStack Row Justify="Justify.Center" Class="pa-3">
                                    <div class="pager-dots">
                                        @for (int i = 0; i < Math.Max(1, GetAerobicPageCount(full)); i++)
                                        {
                                            <span class="dot @(i == GetAerobicPageIndex() ? "active" : "")"></span>
                                        }
                                    </div>
                                </MudStack>
                            }
                        </div>
                    </div>
                }
                else
                {
                    @* ✅ MAG / WAG / RHYTHMIC = 4 CARDS *@
                    @foreach (var ak in GetActiveOrder())
                    {
                        var full = GetRowsForApparatus(ak);
                        var pageRows = GetPageRows(ak, full);

                        <div class="dance-card">
                            <div class="dance-card-head">
                                <div class="dance-title">@ApparatusLabel(ak)</div>
                            </div>

                            <div class="dance-card-body">
                                @if (full.Count == 0)
                                {
                                    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="padding:22px 10px;">
                                        <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty" Style="color:#dee2e6; width:56px; height:56px;" />
                                        <MudText Typo="Typo.subtitle1" Style="color:#adb5bd; font-family:var(--font-header);">
                                            WAITING FOR SCORES
                                        </MudText>
                                    </MudStack>
                                }
                                else
                                {
                                    <div class="card-carousel-bar">
                                        <div class="card-page"></div>
                                        <div>
                                            @for (int i = 0; i < Math.Max(1, GetPageCount(full)); i++)
                                            {
                                                <span class="dot @(i == GetPageIndex(ak) ? "active" : "")"></span>
                                            }
                                        </div>
                                    </div>

                                    <MudTable Class="dance-table" Items="pageRows" Dense="false" Hover="true" Elevation="0">
                                        <HeaderContent>
                                            <MudTh Style="width: 22%;font-size:14px">Rank</MudTh>
                                            <MudTh Style="width: 78%;font-size:14px">Player</MudTh>
                                        </HeaderContent>

                                        <RowTemplate>
                                            <MudTd>
                                                @if (context.Rank is 1 or 2 or 3)
                                                {
                                                    var cls = context.Rank switch { 1 => "rank1", 2 => "rank2", 3 => "rank3", _ => "" };
                                                    <span class="rank-pill @cls">@context.Rank</span>
                                                }
                                                else
                                                {
                                                    <span class="rank-pills">@context.Rank</span>
                                                }
                                            </MudTd>

                                            <MudTd>
                                                <div class="couple-cell">
                                                    <div class="mini-logo">
                                                        <MudImage Src="@GetRegionLogo(context.RegionName)" Alt="@context.RegionName"
                                                                  ObjectFit="ObjectFit.Contain" Style="width:100%; height:100%;" />
                                                    </div>
                                                    <div class="couple-text">
                                                        <div class="couple-name">@context.PlayerName</div>
                                                        <div class="couple-region">@context.RegionName</div>
                                                    </div>
                                                </div>
