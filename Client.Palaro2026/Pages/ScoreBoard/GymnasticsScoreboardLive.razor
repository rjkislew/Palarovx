@page "/scoreboard/gymnastics/details/{EventID:int}"
@layout ClientLayout
@using System.Threading
@using System.Linq
@using Client.Palaro2026.Services
@inject APIService apiService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Gymnastics Event Details | Palaro tu AgSur 2026</PageTitle>

<style>
    /* --- FONTS & VARS (SAME AS DANCESPORT THEME) --- */
    @@import url('https://fonts.cdnfonts.com/css/evil-empire');
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&family=Chakra+Petch:wght@600;700;800&display=swap');

    :root {
        --pal-blue: #023E8A;
        --pal-dark-blue: #001845;
        --pal-gold: #FFB400;
        --pal-red: #EA0000;
        --bg-gradient-start: #f8f9fa;
        --card-bg: #ffffff;
        --font-header: 'Evil Empire', sans-serif;
        --font-score: 'Chakra Petch', sans-serif;
        --font-body: 'Nunito', sans-serif;
    }

    html, body {
        height: 100vh;
        width: 100vw;
        margin: 0;
        padding: 0;
        background-color: var(--bg-gradient-start);
        font-family: var(--font-body);
        overflow-x: hidden;
    }

    .tv-screen {
        min-height: 100vh;
        width: 100vw;
        background: radial-gradient(circle at 50% 30%, #ffffff 0%, #e0e7ff 100%);
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-bottom: 12vh; /* space for footer */
    }

    /* --- HEADER --- */
    .event-header {
        text-align: center;
        margin-top: 4vh;
        margin-bottom: 3vh;
        padding: 25px 60px;
        border-radius: 50px;
        background: var(--pal-dark-blue);
        border: 3px solid var(--pal-gold);
        box-shadow: 0 10px 25px rgba(0,0,0,0.3);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        z-index: 10;
        min-width: min(980px, 92vw);
        position: relative;
    }

    .back-button {
        position: absolute;
        top: 20px;
        left: 20px;
        background: var(--pal-gold);
        color: var(--pal-dark-blue);
        border: none;
        padding: 10px 20px;
        border-radius: 25px;
        font-family: var(--font-score);
        font-weight: 700;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.3s;
    }

        .back-button:hover {
            background: white;
            transform: scale(1.05);
        }

    .sport-title {
        font-family: var(--font-header);
        font-size: clamp(2.5rem, 5vw, 4rem);
        color: white;
        text-transform: uppercase;
        letter-spacing: 2px;
        line-height: 1;
        text-shadow: 3px 3px 0px #000000;
    }

    .event-meta {
        font-family: var(--font-score);
        font-size: clamp(1rem, 1.5vw, 1.2rem);
        color: var(--pal-gold);
        letter-spacing: 2px;
        font-weight: 900;
        text-transform: uppercase;
        margin-top: 5px;
    }

    .status-badge {
        margin-top: 8px;
        padding: 6px 20px;
        border-radius: 20px;
        font-family: var(--font-score);
        font-weight: 900;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .badge-live {
        background: var(--pal-red);
        color: white;
        animation: pulse 2s infinite;
    }

    .badge-final {
        background: var(--pal-gold);
        color: var(--pal-dark-blue);
    }

    .badge-upcoming {
        background: #e9ecef;
        color: #444;
        border: 1px solid #d8dde3;
    }

    @@keyframes pulse {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0.7;
        }
    }

    /* --- CONTENT WRAP --- */
    .content-wrap {
        width: 90%;
        max-width: 1400px;
        background: var(--card-bg);
        border-radius: 30px;
        padding: 40px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.1);
        border-top: 6px solid var(--pal-gold);
        border-bottom: 6px solid var(--pal-blue);
    }

    .section-title {
        font-family: var(--font-header);
        font-size: 2rem;
        color: var(--pal-dark-blue);
        margin-bottom: 18px;
        text-align: center;
        text-transform: uppercase;
    }

    /* --- TABLE --- */
    .results-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 12px;
    }

        .results-table thead th {
            font-family: var(--font-score);
            color: #777;
            font-weight: 900;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 15px 20px;
            text-align: left;
        }

        .results-table tbody tr {
            background: white;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            transition: all 0.3s;
        }

            .results-table tbody tr:hover {
                transform: translateX(5px);
                box-shadow: 0 4px 15px rgba(2, 62, 138, 0.15);
            }

        .results-table tbody td {
            padding: 18px 20px;
            font-family: var(--font-body);
            font-weight: 700;
            color: var(--pal-dark-blue);
            border-top: 1px solid #f0f0f0;
            border-bottom: 1px solid #f0f0f0;
            vertical-align: middle;
        }

            .results-table tbody td:first-child {
                border-left: 1px solid #f0f0f0;
                border-radius: 15px 0 0 15px;
                text-align: center;
                width: 90px;
            }

            .results-table tbody td:last-child {
                border-right: 1px solid #f0f0f0;
                border-radius: 0 15px 15px 0;
                text-align: center;
                width: 160px;
            }

    .rank-circle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        font-family: var(--font-header);
        font-size: 1.8rem;
        font-weight: 900;
        background: #e9ecef;
        color: #555;
    }

    .rank-1-circle {
        background: var(--pal-gold);
        color: white;
        box-shadow: 0 5px 15px rgba(255, 180, 0, 0.4);
        transform: scale(1.06);
    }

    .rank-2-circle {
        background: #C0C0C0;
        color: white;
        box-shadow: 0 3px 10px rgba(192, 192, 192, 0.4);
    }

    .rank-3-circle {
        background: #CD7F32;
        color: white;
        box-shadow: 0 3px 10px rgba(205, 127, 50, 0.4);
    }

    .name-cell {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .player-name {
        font-family: var(--font-score);
        font-size: 1.25rem;
        font-weight: 900;
        color: var(--pal-blue);
        line-height: 1.1;
    }

    .region-badge {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        padding: 4px 10px;
        border-radius: 999px;
        background: rgba(2, 62, 138, 0.08);
        border: 1px solid rgba(2, 62, 138, 0.18);
        color: var(--pal-blue);
        font-family: var(--font-score);
        font-weight: 900;
        font-size: 0.75rem;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .score-cell {
        font-family: var(--font-score);
        font-size: 2rem;
        font-weight: 900;
        color: var(--pal-blue);
        text-align: center;
        line-height: 1;
    }

    .score-sub {
        font-size: 0.85rem;
        color: #777;
        font-weight: 700;
        margin-top: 6px;
    }

    /* Apparatus */
    .apparatus-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(120px, 1fr));
        gap: 10px;
        margin-top: 10px;
    }

    .app-card {
        background: #fff;
        border: 1px solid #f0f0f0;
        border-radius: 14px;
        padding: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        text-align: center;
    }

    .app-name {
        font-family: var(--font-score);
        font-weight: 900;
        font-size: 0.75rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #666;
        margin-bottom: 4px;
    }

    .app-score {
        font-family: var(--font-score);
        font-weight: 900;
        color: var(--pal-blue);
        font-size: 1.1rem;
        line-height: 1.1;
    }

    .app-rank {
        margin-top: 4px;
        font-weight: 700;
        font-size: 0.8rem;
        color: #777;
    }

    /* Empty */
    .no-data {
        text-align: center;
        padding: 60px 20px;
        color: #999;
    }

    .no-data-icon {
        font-size: 4rem;
        margin-bottom: 20px;
    }

    .no-data-text {
        font-family: var(--font-header);
        font-size: 1.5rem;
        text-transform: uppercase;
        color: var(--pal-dark-blue);
    }

  
</style>

<div class="tv-screen">
    <button class="back-button" @onclick="GoBack">⬅ BACK</button>
    <!-- HEADER -->
    <div class="event-header">


        @if (_isLoading)
        {
            <div class="sport-title" style="font-size:2rem;">LOADING...</div>
        }
        else if (_event == null)
        {
            <div class="sport-title" style="font-size:2rem; color:var(--pal-red);">EVENT NOT FOUND</div>
        }
        else
        {
            <div class="sport-title">@GetCategoryShort(_event.MainCategory)</div>
            <div class="event-meta">
                @GetSchoolLevelName(_event.LevelID) • @GetGenderName(_event.GenderID) • @GetEventStageName(_event.StageID)
            </div>
            <div class="status-badge @(_event.IsFinished ? "badge-final" : "badge-live")">
                @(_event.IsFinished ? "FINAL RESULTS" : "🔥 LIVE")
            </div>
        }
    </div>

    @if (!_isLoading && _event != null)
    {
        <div class="content-wrap">
            <div class="section-title">OFFICIAL LEADERBOARD</div>

            @if (!_results.Any())
            {
                <div class="no-data">
                    <div class="no-data-icon">⏳</div>
                    <div class="no-data-text">WAITING FOR SCORES...</div>
                </div>
            }
            else
            {
                <table class="results-table">
                    <thead>
                        <tr>
                            <th >RANK</th>
                            <th>GYMNAST</th>
                            <th >TOTAL SCORE</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _results)
                        {
                            <tr>
                                <td>
                                    <span class="rank-circle @(r.Rank == 1 ? "rank-1-circle" : r.Rank == 2 ? "rank-2-circle" : r.Rank == 3 ? "rank-3-circle" : "")">
                                        @r.Rank
                                    </span>
                                </td>
                                <td>
                                    <div class="name-cell">
                                        <div class="player-name">@r.PlayerName</div>
                                        <span class="region-badge">@r.RegionName</span>

                                    @*     @if (r.Apparatus.Any())
                                        {
                                            <div class="apparatus-grid">
                                                @foreach (var a in r.Apparatus)
                                                {
                                                    <div class="app-card">
                                                        <div class="app-name">@a.Name</div>
                                                        <div class="app-score">@a.Score.ToString("0.00")</div>
                                                        <div class="app-rank">Rank: @a.Rank</div>
                                                    </div>
                                                }
                                            </div>
                                        } *@
                                    </div>
                                </td>
                                <td>
                                    <div class="score-cell">@r.Total.ToString("0.00")</div>
                                    @if (r.ScoreDetails.Any())
                                    {
                                        <div class="score-sub">
                                            @string.Join(" | ", r.ScoreDetails.Select(s => s.ToString("0.00")))
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }

  

</div>

@code {
    [Parameter] public int EventID { get; set; }

    // ===== Models (match your gymnastics DTOs) =====
    public class PerformanceEvent
    {
        public int ID { get; set; }
        public int? SportID { get; set; }
        public string MainCategory { get; set; } = "";
        public int? LevelID { get; set; }
        public int? GenderID { get; set; }
        public int StageID { get; set; }
        public bool IsFinished { get; set; } // optional (we'll infer if not provided)
    }

    public class PerformanceTeam
    {
        public int ID { get; set; }
        public int PerformanceID { get; set; }
        public int? TeamID { get; set; }
        public int RegionID { get; set; }
        public string PlayerID { get; set; } = "";
    }

    public class PerformanceScore
    {
        public int ID { get; set; }
        public int PerformanceID { get; set; }
        public int? PerformanceTeamID { get; set; }
        public int SportSubcategoryID { get; set; }
        public decimal Score { get; set; }
        public int Rank { get; set; }
        public int? TeamID { get; set; }
    }

    public class SchoolRegion
    {
        public int? ID { get; set; }
        public string Region { get; set; } = "";
        public string? Abbreviation { get; set; }
    }

    public class Player
    {
        public string ID { get; set; } = "";
        public string? FirstName { get; set; }
        public string? LastName { get; set; }
    }

    // View models
    public class ApparatusResult
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public decimal Score { get; set; }
        public int Rank { get; set; }
    }

    public class GymnastResult
    {
        public int Rank { get; set; }
        public int RegionID { get; set; }
        public string PlayerID { get; set; } = "";
        public string PlayerName { get; set; } = "";
        public string RegionName { get; set; } = "";
        public decimal Total { get; set; }
        public List<decimal> ScoreDetails { get; set; } = new();
        public List<ApparatusResult> Apparatus { get; set; } = new();
    }

    // ===== State =====
    private bool _isLoading = true;
    private Timer? _timer;

    private PerformanceEvent? _event;
    private List<PerformanceTeam> _opposingTeams = new();
    private List<PerformanceScore> _scoresForEvent = new();
    private List<SchoolRegion> _regions = new();
    private List<Player> _players = new();

    private List<GymnastResult> _results = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadInitialData();
        _timer = new Timer(async _ => await InvokeAsync(RefreshScoresOnly), null, 8000, 8000);
    }

    private async Task LoadInitialData()
    {
        _isLoading = true;
        try
        {
            // 1) Event details (sportID=13)
            var events = await apiService.GetAsync<PerformanceEvent>("/PerformanceBased/PerformanceEvents?sportID=13");
            _event = events?.FirstOrDefault(e => e.ID == EventID);

            if (_event == null)
            {
                _isLoading = false;
                return;
            }

            // 2) Static data in parallel
            var regionsTask = apiService.GetAsync<SchoolRegion>("/Schools/Regions");
            var playersTask = apiService.GetAsync<Player>("/Profiles/Player");
            var teamsTask = apiService.GetAsync<PerformanceTeam>("/PerformanceBased/OpposingTeams");

            await Task.WhenAll(regionsTask, playersTask, teamsTask);

            _regions = (await regionsTask) ?? new();
            _players = (await playersTask) ?? new();

            var allTeams = await teamsTask;
            if (allTeams != null)
                _opposingTeams = allTeams.Where(t => t.PerformanceID == EventID).ToList();

            // 3) Load scores + build table
            await RefreshScoresOnly();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading event: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task RefreshScoresOnly()
    {
        if (_event == null) return;

        try
        {
            // Your gymnastics scoreboard loads scores per eventId
            var url = $"/PerformanceScore/Score/{EventID}";
            var scores = await apiService.GetAsync<PerformanceScore>(url);
            _scoresForEvent = scores ?? new();

            BuildGymnastResults();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error refreshing scores: {ex.Message}");
        }
    }

    private void BuildGymnastResults()
    {
        _results.Clear();

        // Only individual (no TeamID)
        var individualEntries = _opposingTeams
            .Where(t => !t.TeamID.HasValue)
            .GroupBy(t => new { t.RegionID, t.PlayerID })
            .Select(g => g.First())
            .ToList();

        foreach (var entry in individualEntries)
        {
            var region = _regions.FirstOrDefault(r => r.ID == entry.RegionID);
            var player = _players.FirstOrDefault(p => p.ID == entry.PlayerID);

            if (region == null || player == null) continue;

            // All scores for this gymnast = scores where PerformanceTeamID matches opposing team ID
            var playerScores = _scoresForEvent
                .Where(s => s.PerformanceTeamID == entry.ID && !s.TeamID.HasValue)
                .ToList();

            var total = playerScores.Sum(s => s.Score);

            // Apparatus list (best-effort names from your mappings)
            var apparatus = playerScores
                .OrderBy(s => s.SportSubcategoryID)
                .Select(s => new ApparatusResult
                {
                    Id = s.SportSubcategoryID,
                    Name = GetApparatusName(s.SportSubcategoryID),
                    Score = s.Score,
                    Rank = s.Rank
                })
                .ToList();

            _results.Add(new GymnastResult
            {
                RegionID = entry.RegionID,
                PlayerID = entry.PlayerID,
                PlayerName = $"{player.FirstName} {player.LastName}".Trim(),
                RegionName = region.Abbreviation ?? region.Region ?? "REGION",
                Total = total,
                ScoreDetails = playerScores.Select(x => x.Score).ToList(),
                Apparatus = apparatus
            });
        }

        // Rank by total desc
        _results = _results
            .OrderByDescending(r => r.Total)
            .Select((r, idx) => { r.Rank = idx + 1; return r; })
            .ToList();
    }

    private void GoBack() => Navigation.NavigateTo("/scoreboard/gymnastics");

    public void Dispose() => _timer?.Dispose();

    // ===== helpers =====
    private string GetCategoryShort(string cat)
    {
        if (string.IsNullOrWhiteSpace(cat)) return "GYMNASTICS";
        if (cat.Contains("Rhythmic", StringComparison.OrdinalIgnoreCase)) return "RHYTHMIC";
        if (cat.Contains("Aerobic", StringComparison.OrdinalIgnoreCase)) return "AEROBIC";
        if (cat.Contains("Women's Artistic", StringComparison.OrdinalIgnoreCase)) return "WAG";
        if (cat.Contains("Men's Artistic", StringComparison.OrdinalIgnoreCase)) return "MAG";
        return "GYMNASTICS";
    }

    // You can replace these switch helpers with your real lookups if you want
    private string GetSchoolLevelName(int? id) => id switch { 1 => "ELEMENTARY", 2 => "SECONDARY", _ => "OPEN" };
    private string GetGenderName(int? id) => id switch { 1 => "MALE", 2 => "FEMALE", 3 => "MIXED", _ => "" };
    private string GetEventStageName(int? id) => id switch { 4 => "FINALS", 3 => "SEMI-FINALS", _ => "QUALIFIERS" };

    // Best-effort mapping (based on your scoreboard page apparatus IDs)
    private string GetApparatusName(int sportSubcategoryId) => sportSubcategoryId switch
    {
        // WAG
        214 or 215 or 243 => "BEAM",
        216 or 217 or 244 => "FLOOR",
        220 or 221 or 247 => "BARS",
        223 or 224 or 248 => "VAULT",

        // MAG
        197 or 203 or 231 => "FLOOR",
        198 or 204 or 232 => "BAR",
        200 or 205 or 234 => "HORSE",
        201 or 206 or 236 => "VAULT",

        // Rhythmic
        209 or 238 => "BALL",
        210 => "FREE",
        211 or 240 => "HOOP",
        212 => "ROPE",
        239 => "CLUBS",
        241 => "RIBBON",

        // Aerobic
        192 or 226 => "MEN",
        193 or 227 => "WOMEN",

        _ => $"APP {sportSubcategoryId}"
    };
}