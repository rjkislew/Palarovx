@page "/scoreboard/gymnastics/details/{EventID:int}"
@layout ClientLayout
@using System.Threading
@using System.Linq
@using Client.Palaro2026.Services
@inject APIService apiService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Gymnastics Event Details | Palaro tu AgSur 2026</PageTitle>

<style>
    @@import url('https://fonts.cdnfonts.com/css/evil-empire');
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&family=Chakra+Petch:wght@600;700;800&display=swap');

    :root {
        --pal-blue: #023E8A;
        --pal-dark-blue: #001845;
        --pal-gold: #FFB400;
        --pal-red: #EA0000;
        --font-header: 'Evil Empire', sans-serif;
        --font-subheader: 'Chakra Petch', sans-serif;
        --font-body: 'Nunito', sans-serif;
        --wrapMax: 2400px;
    }

    body {
        background: #f8f9fa;
        margin: 0;
        font-family: var(--font-body);
        overflow-x: hidden;
    }

    .tv-screen-bg {
        min-height: 100vh;
        width: 100vw;
        background: radial-gradient(circle at 50% 30%, #ffffff 0%, #e0e7ff 100%);
        padding: 26px 0 12vh 0;
        position: relative;
    }

    .wrap, .page-footer {
        width: min(var(--wrapMax), 96vw);
        margin-left: auto;
        margin-right: auto;
    }

    .back-button {
        position: fixed;
        top: 16px;
        left: 16px;
        z-index: 3000;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: white;
        color: var(--pal-dark-blue);
        border: 2px solid #e9ecef;
        padding: 10px 16px;
        border-radius: 999px;
        cursor: pointer;
        font-family: var(--font-subheader);
        font-weight: 900;
        letter-spacing: 1px;
        text-transform: uppercase;
        box-shadow: 0 6px 18px rgba(0,0,0,0.08);
        transition: all .2s ease;
        font-size: 0.95rem;
    }

        .back-button:hover {
            border-color: var(--pal-gold);
            box-shadow: 0 10px 25px rgba(0,0,0,0.12);
            transform: translateY(-1px);
        }

    /* HEADER (same dancesport) */
    .dashboard-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin: 60px 0 18px 0;
    }

    .header-pill {
        background: var(--pal-dark-blue);
        border: 4px solid var(--pal-gold);
        padding: 18px 64px;
        border-radius: 50px;
        text-align: center;
        box-shadow: 0 12px 28px rgba(0,0,0,0.2);
        max-width: calc(100% - 60px);
    }

    .main-event-title {
        font-family: var(--font-header);
        color: white;
        font-size: clamp(2.6rem, 3.6vw, 4.6rem);
        letter-spacing: 3px;
        margin: 0;
        line-height: 1;
        text-shadow: 3px 3px 0px black;
        text-transform: uppercase;
    }

    .sub-header-text {
        font-family: var(--font-subheader);
        color: var(--pal-gold);
        font-size: clamp(0.95rem, 1.2vw, 1.35rem);
        letter-spacing: 4px;
        font-weight: 900;
        text-transform: uppercase;
        margin-top: 10px;
        opacity: 0.98;
    }

    /* ===== CARDS GRID (same dancesport) ===== */
    .cards-grid {
        margin-top: 14px;
        display: grid;
        grid-template-columns: repeat(12, minmax(0, 1fr));
        gap: 16px;
        align-items: stretch;
    }

    .dance-card {
        grid-column: span 3; /* 4 per row */
        background: white;
        border-radius: 18px;
        border: 1px solid #e9ecef;
        box-shadow: 0 10px 22px rgba(0,0,0,0.06);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        min-width: 0;
        height: 100%;
    }

        /* championships card spans full width */
        .dance-card.wide {
            grid-column: span 12;
        }

    .dance-card-head {
        padding: 14px 16px;
        background: #fbfbfd;
        border-bottom: 3px solid var(--pal-gold);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    .dance-title {
        font-family: var(--font-header);
        color: var(--pal-dark-blue);
        letter-spacing: 2px;
        text-transform: uppercase;
        font-size: 1.4rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        min-width: 0;
    }

    .badge-final, .badge-live {
        font-family: var(--font-subheader);
        font-weight: 900;
        font-size: 0.9rem;
        padding: 6px 12px;
        color: white;
        border-radius: 999px;
        letter-spacing: 1px;
        text-transform: uppercase;
        white-space: nowrap;
        flex: 0 0 auto;
    }

    .badge-live {
        background: var(--pal-red);
    }

    .badge-final {
        background: #343a40;
    }

    .dance-card-body {
        padding: 10px 12px 12px 12px;
        flex: 1 1 auto;
        display: flex;
        flex-direction: column;
        min-height: 0;
    }

    .card-carousel-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 6px 4px 10px 4px;
    }

    .card-page {
        font-family: var(--font-subheader);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #6c757d;
        font-size: 0.78rem;
        white-space: nowrap;
    }

    .dot {
        width: 9px;
        height: 9px;
        border-radius: 999px;
        background: #dee2e6;
        display: inline-block;
        margin: 0 3px;
    }

        .dot.active {
            background: var(--pal-gold);
            box-shadow: 0 0 0 4px rgba(255, 180, 0, 0.14);
        }

    /* ===== TABLE (same dancesport) ===== */
    .dance-table thead th {
        font-family: var(--font-subheader) !important;
        font-weight: 900 !important;
        text-transform: uppercase !important;
        letter-spacing: 2px !important;
        color: var(--pal-dark-blue) !important;
        background: #ffffff !important;
        border-bottom: 1px solid #f1f1f1 !important;
        padding: 12px 12px !important;
        font-size: 0.9rem !important;
        white-space: nowrap;
    }

    .dance-table tbody td {
        border-bottom: 1px solid #f1f1f1 !important;
        padding: 12px 12px !important;
        vertical-align: middle;
        font-size: 1.05rem !important;
        font-weight: 800;
    }

    .rank-pill {
        min-width: 44px;
        height: 34px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-header);
        font-size: 1.2rem;
        color: var(--pal-dark-blue);
        background: #fff;
        border: 2px solid #e9ecef;
    }

    .rank1 {
        border-color: #FFD700;
        box-shadow: 0 0 12px rgba(255,215,0,.45);
    }

    .rank2 {
        border-color: #C0C0C0;
        box-shadow: 0 0 10px rgba(192,192,192,.35);
    }

    .rank3 {
        border-color: #CD7F32;
        box-shadow: 0 0 10px rgba(205,127,50,.35);
    }

    .couple-cell {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
    }

    .mini-logo {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: #fff;
        border: 2px solid #e9ecef;
        padding: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 10px rgba(0,0,0,.08);
        flex: 0 0 auto;
    }

    .couple-text {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .couple-name {
        font-weight: 900;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .couple-region {
        font-family: var(--font-subheader);
        font-weight: 900;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #6c757d;
        font-size: 0.8rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* ===== CHAMPIONSHIPS GRID (keeps your content but in dancesport card style) ===== */
    .medal-grid {
        display: grid;
        grid-template-columns: repeat(12, minmax(0, 1fr));
        gap: 12px;
    }

    .medal-row {
        grid-column: span 6;
        border: 1px solid #e9ecef;
        border-radius: 14px;
        overflow: hidden;
        background: #fff;
    }

    .medal-row-head {
        padding: 12px 14px;
        background: #fbfbfd;
        border-bottom: 1px solid #f1f1f1;
        font-family: var(--font-subheader);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--pal-dark-blue);
        font-size: 1.05rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        flex-wrap: wrap;
    }

    .medal-row-body {
        padding: 12px 14px 14px 14px;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
    }

    .medal-box {
        border: 1px solid #e9ecef;
        border-radius: 14px;
        padding: 12px 12px;
        background: white;
        min-width: 0;
    }

    .medal-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 10px;
    }

        .medal-top .m {
            font-family: var(--font-subheader);
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 0.95rem;
            color: #6c757d;
            white-space: nowrap;
        }

    .medal-box.gold {
        border-color: rgba(255,215,0,0.55);
    }

    .medal-box.silver {
        border-color: rgba(192,192,192,0.55);
    }

    .medal-box.bronze {
        border-color: rgba(205,127,50,0.55);
    }

    .winner-row {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
    }

    .winner-logo {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: #fff;
        border: 2px solid #e9ecef;
        padding: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 10px rgba(0,0,0,.08);
        flex: 0 0 auto;
    }

    .winner-info {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .winner-name {
        font-family: var(--font-body);
        font-weight: 900;
        font-size: 1.05rem;
        color: #212529;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 520px;
        line-height: 1.05;
    }

    .winner-region {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-family: var(--font-subheader);
        font-weight: 900;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #6c757d;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 520px;
    }

    .winner-members {
        margin-top: 8px;
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .member-chip {
        border: 1px solid #e9ecef;
        background: #fff;
        border-radius: 999px;
        padding: 6px 10px;
        font-family: var(--font-subheader);
        font-weight: 900;
        letter-spacing: 1px;
        font-size: 0.82rem;
        color: #495057;
        max-width: 220px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .page-footer {
        margin: 16px auto 0 auto;
        text-align: center;
        color: #6c757d;
        font-family: var(--font-subheader);
        font-size: 1.0rem;
        font-weight: 900;
        text-transform: uppercase;
        border-top: 1px solid #f1f1f1;
        padding-top: 14px;
        letter-spacing: 2px;
    }

    @@media (max-width: 1400px) {
        .dance-card {
            grid-column: span 6;
        }

            .dance-card.wide {
                grid-column: span 12;
            }

        .medal-row {
            grid-column: span 12;
        }
    }

    @@media (max-width: 800px) {
        .dance-card {
            grid-column: span 12;
        }

            .dance-card.wide {
                grid-column: span 12;
            }

        .medal-row {
            grid-column: span 12;
        }
    }
</style>

<div class="tv-screen-bg">
    <button class="back-button" @onclick="GoBack">← Back</button>

    @if (_isLoading)
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height:70vh;">
            <MudProgressCircular Indeterminate Color="Color.Primary" Size="Size.Large" />
            <MudText Typo="Typo.h6" Class="mt-4" Style="font-family:var(--font-header); color:var(--pal-blue);">
                LOADING GYMNASTICS EVENT...
            </MudText>
        </MudStack>
    }
    else if (_event == null)
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height:70vh;">
            <MudText Typo="Typo.h4" Style="font-family:var(--font-header); color: var(--pal-red);">
                EVENT NOT FOUND
            </MudText>
        </MudStack>
    }
    else
    {
        <div class="dashboard-header">
            <div class="header-pill">
                <h1 class="main-event-title">GYMNASTICS</h1>
                <div class="sub-header-text">
                    @GetSchoolLevelName(_event.LevelID) - @_event.MainCategory  - @GetEventStageName(_event.StageID)
                </div>
            </div>
        </div>

        <div class="wrap">
            <div class="cards-grid">
                @foreach (var ak in _apparatusOrder)
                {
                    var full = GetRowsForApparatus(ak);
                    var pageRows = GetPageRows(ak, full);

                    <div class="dance-card">
                        <div class="dance-card-head">
                            <div class="dance-title">@ApparatusLabel(ak)</div>
                           @*  <div class="@(_event.IsFinished ? "badge-final" : "badge-live")">
                                @(_event.IsFinished ? "FINAL" : "LIVE")
                            </div> *@
                        </div>

                        <div class="dance-card-body">
                            @if (full.Count == 0)
                            {
                                <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="padding:22px 10px;">
                                    <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty" Style="color:#dee2e6; width:56px; height:56px;" />
                                    <MudText Typo="Typo.subtitle1" Style="color:#adb5bd; font-family:var(--font-header);">
                                        WAITING FOR SCORES
                                    </MudText>
                                </MudStack>
                            }
                            else
                            {
                                <div class="card-carousel-bar">
                                    <div class="card-page">
                                        PAGE @(GetPageIndex(ak) + 1) / @Math.Max(1, GetPageCount(full))
                                    </div>
                                    <div>
                                        @for (int i = 0; i < Math.Max(1, GetPageCount(full)); i++)
                                        {
                                            <span class="dot @(i == GetPageIndex(ak) ? "active" : "")"></span>
                                        }
                                    </div>
                                </div>

                                <MudTable Class="dance-table"
                                          Items="pageRows"
                                          Dense="false"
                                          Hover="true"
                                          Elevation="0">
                                    <HeaderContent>
                                        <MudTh Style="width: 22%;">Rank</MudTh>
                                        <MudTh Style="width: 78%;">Player</MudTh>
                                    </HeaderContent>

                                    <RowTemplate>
                                        @{
                                            var cls = context.Rank switch
                                            {
                                                1 => "rank1",
                                                2 => "rank2",
                                                3 => "rank3",
                                                _ => ""
                                            };
                                        }

                                        <MudTd>
                                            <span class="rank-pill @cls">@context.Rank</span>
                                        </MudTd>

                                        <MudTd>
                                            <div class="couple-cell">
                                                <div class="mini-logo">
                                                    <MudImage Src="@GetRegionLogo(context.RegionName)"
                                                              Alt="@context.RegionName"
                                                              ObjectFit="ObjectFit.Contain"
                                                              Style="width:100%; height:100%;" />
                                                </div>

                                                <div class="couple-text">
                                                    <div class="couple-name">@context.PlayerName</div>
                                                    <div class="couple-region">@context.RegionName</div>
                                                </div>
                                            </div>
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                        </div>
                    </div>
                }

                <!-- ✅ CHAMPIONSHIPS (same card style + same colors) -->
                <div class="dance-card wide">
                    <div class="dance-card-head">
                        <div class="dance-title">
                            <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Style="color: var(--pal-gold);" />
                            &nbsp;CHAMPIONSHIPS
                        </div>
                        <div class="card-page">
                            @GetSchoolLevelName(_event.LevelID) • @GetGenderName(_event.GenderID) • @GetEventStageName(_event.StageID)
                        </div>
                    </div>

                    <div class="dance-card-body">
                        <div class="medal-grid">
                            <div class="medal-row">
                                <div class="medal-row-head">
                                    <span>
                                        <MudIcon Icon="@Icons.Material.Filled.Groups" Style="color: var(--pal-blue);" />
                                        &nbsp;TEAM CHAMPIONSHIP
                                    </span>
                                </div>
                                <div class="medal-row-body">
                                    @MedalBox("Gold", "gold", _teamGold)
                                    @MedalBox("Silver", "silver", _teamSilver)
                                    @MedalBox("Bronze", "bronze", _teamBronze)
                                </div>
                            </div>

                            <div class="medal-row">
                                <div class="medal-row-head">
                                    <span>
                                        <MudIcon Icon="@Icons.Material.Filled.Person" Style="color: var(--pal-blue);" />
                                        &nbsp;INDIVIDUAL ALL-AROUND
                                    </span>
                                </div>
                                <div class="medal-row-body">
                                    @MedalBox("Gold", "gold", _aaGold)
                                    @MedalBox("Silver", "silver", _aaSilver)
                                    @MedalBox("Bronze", "bronze", _aaBronze)
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

           
        </div>
    }
</div>

<Brand />

@code {
    [Parameter] public int EventID { get; set; }

    private const int RowsPerPage = 4;
    private const int AutoMs = 4500;
    private const int RefreshMs = 8000;

    private Timer? _autoTimer;
    private Timer? _refreshTimer;
    private readonly SemaphoreSlim _lock = new(1, 1);

    private bool _isLoading = true;
    private string _medalDebug = "";

    // ===== API Models =====
    public class PerformanceEvent
    {
        public int ID { get; set; }
        public int? SportID { get; set; }
        public string MainCategory { get; set; } = "";
        public int? LevelID { get; set; }
        public int? GenderID { get; set; }
        public int StageID { get; set; }
        public bool IsFinished { get; set; }
    }

    public class PerformanceTeam
    {
        public int ID { get; set; }
        public int PerformanceID { get; set; }
        public int? TeamID { get; set; }
        public int RegionID { get; set; }
        public string PlayerID { get; set; } = "";
    }

    public class PerformanceScore
    {
        public int ID { get; set; }
        public int PerformanceID { get; set; }
        public int? PerformanceTeamID { get; set; }
        public int SportSubcategoryID { get; set; }
        public decimal Score { get; set; }
        public int Rank { get; set; }
        public int? TeamID { get; set; }
    }

    public class SchoolRegion
    {
        public int? ID { get; set; }
        public string Region { get; set; } = "";
        public string? Abbreviation { get; set; }
    }

    public class Player
    {
        public string ID { get; set; } = "";
        public string? FirstName { get; set; }
        public string? LastName { get; set; }
    }

    public class ApparatusRow
    {
        public int Rank { get; set; }
        public string PlayerID { get; set; } = "";
        public string PlayerName { get; set; } = "";
        public int RegionID { get; set; }
        public string RegionName { get; set; } = "";
        public decimal Score { get; set; }
    }

    // ===== Tabulation models (medals) =====
    public class TabulationResultDTO
    {
        public string SourceType { get; set; } = "";
        public string? EventID { get; set; }
        public int? EventStageID { get; set; }
        public int SportSubcategoryID { get; set; }
        public string? SportMainCat { get; set; }

        public int? PerformanceID { get; set; }
        public int? TeamID { get; set; }

        public int? EventVersusTeamID { get; set; }
        public int? SchoolRegionID { get; set; }
        public string? TeamRank { get; set; }

        public string PlayerID { get; set; } = "";
        public string? FirstName { get; set; }
        public string? LastName { get; set; }
        public string? MiddleInitial { get; set; }
        public int? SportID { get; set; }
    }

    public class MedalDisplay
    {
        public string Medal { get; set; } = "Waiting for result";
        public int RegionID { get; set; }
        public string RegionName { get; set; } = "Waiting for result";
        public string DisplayName { get; set; } = "Waiting for result";
        public bool IsTeam { get; set; }
        public List<string> Members { get; set; } = new();
    }

    public class TallyDisplayRow
    {
        public TabulationResultDTO Head { get; set; } = new();
        public List<TabulationResultDTO> Members { get; set; } = new();
        public bool IsTeam => Members.Select(m => m.PlayerID).Distinct().Count() > 1;
    }

    public class SportsSubcatDTO
    {
        public int ID { get; set; }
        public string? Subcategory { get; set; }
        public int? SportID { get; set; }
        public int? SportGenderCategoryID { get; set; }
        public int? SchoolLevelID { get; set; }
        public string? MainCategory { get; set; }
    }

    // ===== State =====
    private PerformanceEvent? _event;
    private List<PerformanceTeam> _opposingTeams = new();
    private List<PerformanceScore> _scoresForEvent = new();
    private List<SchoolRegion> _regions = new();
    private List<Player> _players = new();

    // ===== Medal state =====
    private MedalDisplay _teamGold = new() { Medal = "Gold" };
    private MedalDisplay _teamSilver = new() { Medal = "Silver" };
    private MedalDisplay _teamBronze = new() { Medal = "Bronze" };

    private MedalDisplay _aaGold = new() { Medal = "Gold" };
    private MedalDisplay _aaSilver = new() { Medal = "Silver" };
    private MedalDisplay _aaBronze = new() { Medal = "Bronze" };

    // ===== Apparatus carousel =====
    private enum ApparatusKey
    {
        FloorExercise,
        HorizontalBar,
        PommelHorse,
        VaultingTable
    }

    private readonly List<ApparatusKey> _apparatusOrder = new()
    {
        ApparatusKey.FloorExercise,
        ApparatusKey.HorizontalBar,
        ApparatusKey.PommelHorse,
        ApparatusKey.VaultingTable
    };

    private Dictionary<ApparatusKey, List<ApparatusRow>> _apparatusRows = new();
    private Dictionary<ApparatusKey, int> _pageIndex = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadInitialData();

        _refreshTimer = new Timer(async _ => await InvokeAsync(RefreshScoresOnly), null, RefreshMs, RefreshMs);

        _autoTimer = new Timer(async _ =>
        {
            if (_event == null) return;

            await InvokeAsync(() =>
            {
                foreach (var ak in _apparatusOrder)
                {
                    var full = GetRowsForApparatus(ak);
                    var pages = Math.Max(1, GetPageCount(full));
                    var idx = GetPageIndex(ak);
                    _pageIndex[ak] = (idx + 1) % pages;
                }

                StateHasChanged();
            });
        }, null, AutoMs, AutoMs);
    }

    private async Task LoadInitialData()
    {
        _isLoading = true;
        _medalDebug = "";

        try
        {
            var events = await apiService.GetAsync<PerformanceEvent>("/PerformanceBased/PerformanceEvents?sportID=13");
            _event = events?.FirstOrDefault(e => e.ID == EventID);

            if (_event == null)
            {
                _isLoading = false;
                return;
            }

            var regionsTask = apiService.GetAsync<SchoolRegion>("/Schools/Regions");
            var playersTask = apiService.GetAsync<Player>("/Profiles/Player");
            var teamsTask = apiService.GetAsync<PerformanceTeam>("/PerformanceBased/OpposingTeams");

            await Task.WhenAll(regionsTask, playersTask, teamsTask);

            _regions = (await regionsTask) ?? new();
            _players = (await playersTask) ?? new();

            var allTeams = await teamsTask;
            _opposingTeams = allTeams?.Where(t => t.PerformanceID == EventID).ToList() ?? new();

            _pageIndex = _apparatusOrder.ToDictionary(a => a, _ => 0);

            await LoadChampionshipMedalsFromTabulation();
            await RefreshScoresOnly();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading event: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task RefreshScoresOnly()
    {
        if (_event == null) return;

        await _lock.WaitAsync();
        try
        {
            var url = $"/PerformanceScore/Score/{EventID}";
            _scoresForEvent = await apiService.GetAsync<PerformanceScore>(url) ?? new();

            _apparatusRows = new();
            foreach (var ak in _apparatusOrder)
                _apparatusRows[ak] = BuildTop8ForApparatus(ak);

            foreach (var ak in _apparatusOrder)
            {
                var pages = Math.Max(1, GetPageCount(GetRowsForApparatus(ak)));
                if (GetPageIndex(ak) >= pages) _pageIndex[ak] = 0;
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error refreshing scores: {ex.Message}");
        }
        finally
        {
            _lock.Release();
        }
    }

    // ===== Paging (same pattern as dancesport) =====
    private int GetPageIndex(ApparatusKey ak) => _pageIndex.TryGetValue(ak, out var v) ? v : 0;

    private int GetPageCount(List<ApparatusRow> full)
        => (int)Math.Ceiling((full.Count == 0 ? 1 : full.Count) / (double)RowsPerPage);

    private List<ApparatusRow> GetPageRows(ApparatusKey ak, List<ApparatusRow> full)
    {
        if (full.Count == 0) return new();
        var idx = GetPageIndex(ak);
        return full.Skip(idx * RowsPerPage).Take(RowsPerPage).ToList();
    }

    private List<ApparatusRow> GetRowsForApparatus(ApparatusKey key)
    {
        if (_apparatusRows.TryGetValue(key, out var list)) return list;
        var built = BuildTop8ForApparatus(key);
        _apparatusRows[key] = built;
        return built;
    }

    private string ApparatusLabel(ApparatusKey k) => k switch
    {
        ApparatusKey.FloorExercise => "FLOOR EXERCISE",
        ApparatusKey.HorizontalBar => "HORIZONTAL BAR",
        ApparatusKey.PommelHorse => "POMMEL HORSE",
        ApparatusKey.VaultingTable => "VAULTING TABLE",
        _ => "APPARATUS"
    };

    // ✅ Apparatus Top 8 (individual only)
    private List<ApparatusRow> BuildTop8ForApparatus(ApparatusKey key)
    {
        var individualEntries = _opposingTeams
            .Where(t => !t.TeamID.HasValue)
            .GroupBy(t => new { t.RegionID, t.PlayerID })
            .Select(g => g.First())
            .ToList();

        var ids = GetSubcategoryIds(key);
        var rows = new List<ApparatusRow>();

        foreach (var entry in individualEntries)
        {
            var region = _regions.FirstOrDefault(r => r.ID == entry.RegionID);
            var player = _players.FirstOrDefault(p => p.ID == entry.PlayerID);
            if (region == null || player == null) continue;

            var score = _scoresForEvent
                .Where(s =>
                    s.PerformanceTeamID == entry.ID &&
                    !s.TeamID.HasValue &&
                    ids.Contains(s.SportSubcategoryID))
                .Sum(s => s.Score);

            if (score <= 0) continue;

            rows.Add(new ApparatusRow
            {
                RegionID = entry.RegionID,
                PlayerID = entry.PlayerID,
                PlayerName = $"{(player.FirstName ?? "").Trim()} {(player.LastName ?? "").Trim()}".Trim(),
                RegionName = region.Abbreviation ?? region.Region ?? "REGION",
                Score = score
            });
        }

        return rows
            .OrderByDescending(r => r.Score)
            .Take(8)
            .Select((r, idx) => { r.Rank = idx + 1; return r; })
            .ToList();
    }

    // ✅ IDs based on your mapping
    private HashSet<int> GetSubcategoryIds(ApparatusKey key) => key switch
    {
        ApparatusKey.FloorExercise => new HashSet<int> { 197, 203, 231 },
        ApparatusKey.HorizontalBar => new HashSet<int> { 198, 204, 232 },
        ApparatusKey.PommelHorse => new HashSet<int> { 200, 205, 234 },
        ApparatusKey.VaultingTable => new HashSet<int> { 201, 206, 236 },
        _ => new HashSet<int>()
    };

    // ==========================
    // ✅ CHAMPIONSHIP MEDALS (same logic you had)
    // ==========================
    private async Task LoadChampionshipMedalsFromTabulation()
    {
        try
        {
            if (_event == null) return;

            var tally = await apiService.GetAsync<TabulationResultDTO>("/Tabulation/result")
                       ?? new List<TabulationResultDTO>();

            tally = tally
                .Where(x => x.SportID == 13 && x.SchoolRegionID.HasValue)
                .ToList();

            tally = tally
                .GroupBy(x => new { x.PlayerID, x.SportSubcategoryID })
                .Select(g =>
                    g.OrderByDescending(x => x.EventStageID ?? 0)
                     .ThenBy(x => GetMedalSortOrder(x.TeamRank))
                     .ThenBy(x => GetNumericRankOrMax(x.TeamRank))
                     .ThenBy(x => x.LastName)
                     .First()
                )
                .ToList();

            var subcats = await apiService.GetAsync<SportsSubcatDTO>("/Sports/Subcategories?sportID=13")
                         ?? new List<SportsSubcatDTO>();

            int? teamChampSubcatId = FindBestSubcatId(subcats, "Team Championship", _event);
            int? aaSubcatId = FindBestSubcatId(subcats, "Individual All-Around", _event, allowAlt: true);

            _medalDebug =
                $"Tabulation: {tally.Count} rows • Subcat Team={teamChampSubcatId?.ToString() ?? "null"} • AA={aaSubcatId?.ToString() ?? "null"}";

            if (teamChampSubcatId == null || aaSubcatId == null)
                return;

            var teamRows = BuildDisplayRows(tally.Where(x => x.SportSubcategoryID == teamChampSubcatId.Value).ToList());
            var aaRows = BuildDisplayRows(tally.Where(x => x.SportSubcategoryID == aaSubcatId.Value).ToList());

            _teamGold = PickMedal(teamRows, "Gold");
            _teamSilver = PickMedal(teamRows, "Silver");
            _teamBronze = PickMedal(teamRows, "Bronze");

            _aaGold = PickMedal(aaRows, "Gold");
            _aaSilver = PickMedal(aaRows, "Silver");
            _aaBronze = PickMedal(aaRows, "Bronze");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Tabulation medal load error: {ex.Message}");
        }
    }

    private int? FindBestSubcatId(List<SportsSubcatDTO> subcats, string containsText, PerformanceEvent evt, bool allowAlt = false)
    {
        string alt = allowAlt ? "Individual All Around" : "";

        var candidates = subcats
            .Where(s =>
                !string.IsNullOrWhiteSpace(s.Subcategory) &&
                (s.Subcategory!.Contains(containsText, StringComparison.OrdinalIgnoreCase) ||
                 (!string.IsNullOrWhiteSpace(alt) && s.Subcategory!.Contains(alt, StringComparison.OrdinalIgnoreCase))))
            .ToList();

        if (!candidates.Any()) return null;

        int Score(SportsSubcatDTO s)
        {
            int sc = 0;
            if (s.SchoolLevelID.HasValue && evt.LevelID.HasValue && s.SchoolLevelID.Value == evt.LevelID.Value) sc += 5;
            if (s.SportGenderCategoryID.HasValue && evt.GenderID.HasValue && s.SportGenderCategoryID.Value == evt.GenderID.Value) sc += 5;

            if (!string.IsNullOrWhiteSpace(s.MainCategory) && !string.IsNullOrWhiteSpace(evt.MainCategory))
            {
                if (string.Equals(s.MainCategory.Trim(), evt.MainCategory.Trim(), StringComparison.OrdinalIgnoreCase)) sc += 5;
                else if (evt.MainCategory.Contains(s.MainCategory, StringComparison.OrdinalIgnoreCase) ||
                         s.MainCategory.Contains(evt.MainCategory, StringComparison.OrdinalIgnoreCase)) sc += 2;
            }

            if (s.Subcategory != null && s.Subcategory.Contains(containsText, StringComparison.OrdinalIgnoreCase)) sc += 1;

            return sc;
        }

        return candidates
            .OrderByDescending(Score)
            .ThenBy(s => s.ID)
            .Select(s => (int?)s.ID)
            .FirstOrDefault();
    }

    private List<TallyDisplayRow> BuildDisplayRows(List<TabulationResultDTO> rows)
    {
        return rows
            .GroupBy(BuildGroupKey)
            .Select(g =>
            {
                var head = g
                    .OrderBy(x => GetMedalSortOrder(x.TeamRank))
                    .ThenBy(x => GetNumericRankOrMax(x.TeamRank))
                    .ThenBy(x => x.LastName)
                    .First();

                return new TallyDisplayRow { Head = head, Members = g.ToList() };
            })
            .ToList();
    }

    private string BuildGroupKey(TabulationResultDTO r)
    {
        var sub = r.SportSubcategoryID;

        if (string.Equals(r.SourceType, "EVENT", StringComparison.OrdinalIgnoreCase))
            return r.EventVersusTeamID.HasValue
                ? $"E-{r.EventVersusTeamID.Value}-S{sub}"
                : $"E-IND-{r.PlayerID}-{r.EventID}-S{sub}";

        var perfId = r.PerformanceID ?? 0;
        var region = r.SchoolRegionID ?? 0;

        if (r.TeamID.HasValue)
            return $"P-{perfId}-{region}-T-{r.TeamID.Value}-S{sub}";

        return $"P-{perfId}-{region}-IND-{r.PlayerID}-S{sub}";
    }

    private MedalDisplay PickMedal(List<TallyDisplayRow> rows, string medal)
    {
        var hit = rows.FirstOrDefault(x => string.Equals(x.Head.TeamRank, medal, StringComparison.OrdinalIgnoreCase));
        if (hit == null)
            return new MedalDisplay { Medal = medal, RegionName = "—", DisplayName = "—", IsTeam = false };

        int regionId = hit.Head.SchoolRegionID ?? 0;
        string regionName = GetRegionName(regionId);

        string displayName;
        var members = new List<string>();

        if (hit.IsTeam)
        {
            displayName = "TEAM";
            members = hit.Members
                .Select(m => $"{m.FirstName} {m.LastName}".Trim())
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .Distinct()
                .OrderBy(x => x)
                .Take(8)
                .ToList();
        }
        else
        {
            var h = hit.Head;
            displayName = $"{h.FirstName} {h.LastName}".Trim();
        }

        return new MedalDisplay
        {
            Medal = medal,
            RegionID = regionId,
            RegionName = regionName,
            DisplayName = string.IsNullOrWhiteSpace(displayName) ? "—" : displayName,
            IsTeam = hit.IsTeam,
            Members = members
        };
    }

    // ===== UI fragments =====
    private RenderFragment MedalBox(string medalLabel, string css, MedalDisplay data) => @<div class="medal-box @css">
            <div class="medal-top">
                <div class="m">@medalLabel</div>
                <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Style="color: var(--pal-gold);" />
            </div>

        @if (data.RegionID != 0 && data.DisplayName != "—")
        {
                <div class="winner-row">
                    <div class="winner-logo">
                        <MudImage Src="@GetRegionLogo(data.RegionName)"
                                  Alt="@data.RegionName"
                                  ObjectFit="ObjectFit.Contain"
                                  Style="width:100%; height:100%;" />
                    </div>

                    <div class="winner-info">
                        <div class="winner-name">@data.DisplayName</div>
                        <div class="winner-region">
                            <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" />
                            <span>@data.RegionName</span>
                        </div>
                    </div>
                </div>

            @if (data.IsTeam && data.Members.Any())
            {
                    <div class="winner-members">
                        @foreach (var m in data.Members)
                        {
                            <span class="member-chip">@m</span>
                        }
                    </div>
            }
        }
        else
        {
                <div class="winner-row">
                    <div class="winner-info">
                        <div class="winner-name">—</div>
                        <div class="winner-region">No data</div>
                    </div>
                </div>
        }
    </div>;

