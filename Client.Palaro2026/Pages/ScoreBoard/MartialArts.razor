@page "/scoreboard/martialarts"
@using System.Threading
@using System.Linq
@using Client.Palaro2026.Services
@inject APIService apiService
@inject NavigationManager Navigation
@implements IDisposable
@layout NoMainLayout

<PageTitle>Martial Arts Dashboard | Palaro tu AgSur 2026</PageTitle>

<style>
    /* --- THEME IMPORTS --- */
    @@import url('https://fonts.cdnfonts.com/css/evil-empire');
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&display=swap');

    :root {
        /* PALARO COLOR PALETTE */
        --pal-blue: #023E8A;
        --pal-dark-blue: #001845;
        --pal-gold: #FFB400;
        --pal-red: #EA0000;
        --pal-white: #ffffff;
        /* LIGHT THEME VARS */
        --bg-gradient-start: #f8f9fa;
        --card-bg: rgba(255, 255, 255, 0.95);
        /* FONTS */
        --font-header: 'Evil Empire', sans-serif;
        --font-body: 'Nunito', Arial, Helvetica, sans-serif;
    }

    /* Scrollbar */
    ::-webkit-scrollbar {
        width: 8px;
    }

    ::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    ::-webkit-scrollbar-thumb {
        background: #ccc;
        border-radius: 4px;
    }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--pal-blue);
        }

    html, body {
        height: 100%;
        width: 100%;
        margin: 0;
        background-color: var(--bg-gradient-start);
        font-family: var(--font-body);
        overflow-x: hidden;
    }

    .tv-screen-bg {
        min-height: 100vh;
        width: 100vw;
        background: radial-gradient(circle at 50% 30%, #ffffff 0%, #e0e7ff 100%);
        padding-bottom: 50px;
    }

    /* --- HEADER (PILL STYLE) --- */
    .dashboard-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin: 10px 0 14px 0;
    }

    .header-pill {
        background: var(--pal-dark-blue);
        border: 3px solid var(--pal-gold);
        padding: 20px 60px;
        border-radius: 50px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        min-width: min(920px, 92vw);
    }

    .main-event-title {
        font-family: var(--font-header);
        color: white;
        font-size: clamp(2rem, 4vw, 3.5rem);
        letter-spacing: 2px;
        margin: 0;
        line-height: 1;
        text-shadow: 2px 2px 0px black;
        text-transform: uppercase;
    }

    .sub-header-text {
        font-family: var(--font-body);
        color: var(--pal-gold);
        font-size: 1.1rem;
        letter-spacing: 3px;
        font-weight: 800;
        text-transform: uppercase;
        margin-top: 6px;
        opacity: .95;
    }

    /* --- SEARCH --- */
    .search-wrapper {
        display: flex;
        justify-content: center;
        margin: 12px 0 18px;
        padding: 0 6px;
    }

    .tv-search-field {
        width: 100%;
        max-width: 720px;
    }

        .tv-search-field .mud-input-control-input-container {
            background-color: #fff !important;
            border-radius: 999px !important;
            box-shadow: 0 10px 22px rgba(0,0,0,0.06) !important;
            border: 1px solid rgba(2,62,138,0.10) !important;
            overflow: hidden;
        }

        .tv-search-field .mud-input-slot {
            font-family: var(--font-body);
            font-weight: 800;
            color: var(--pal-dark-blue) !important;
            padding-left: 12px;
        }

    /* --- TABS --- */
    .mud-tabs-tabbar {
        background: transparent !important;
    }

    .mud-tab {
        font-family: var(--font-body) !important;
        font-weight: 800;
        font-size: 1.2rem !important;
        letter-spacing: 1px;
        color: #adb5bd !important;
        text-transform: uppercase;
    }

    .mud-tab-active {
        color: var(--pal-blue) !important;
        text-shadow: 0 0 1px rgba(2, 62, 138, 0.5);
    }

    .mud-tabs-indicator {
        background-color: var(--pal-gold) !important;
        height: 4px;
        border-radius: 4px;
    }

    /* ✅ GRID: center nicely when few items */
    .mud-grid {
        justify-content: center;
    }

    .mud-grid-item {
        display: flex;
    }

    /* --- SPORT GROUP SECTION --- */
    .sport-section {
        margin-top: 18px;
        margin-bottom: 26px;
        background: #fff;
        border-radius: 20px;
        padding: 18px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        border: 1px solid #e9ecef;
        overflow: hidden;
    }

    .sport-title-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 0 0 16px;
        padding: 14px 16px;
        border-radius: 18px;
        border: 1px solid rgba(2, 62, 138, 0.10);
        background: linear-gradient(90deg, rgba(255,180,0,0.12), rgba(2,62,138,0.06));
    }

    .sport-name {
        font-family: var(--font-body);
        font-weight: 800;
        color: var(--pal-dark-blue);
        font-size: 1.55rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
    }

    /* --- CARD --- */
    .match-link {
        text-decoration: none;
        display: block;
        height: 100%;
        width: 100%;
    }

    .tv-card {
        width: 100%;
        background: #fff;
        border-radius: 15px;
        padding: 16px;
        border: 1px solid #dee2e6;
        border-top: 5px solid var(--pal-blue);
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        transition: transform 0.25s ease, box-shadow 0.25s ease, border-top-color 0.25s ease;
        position: relative;
        overflow: hidden;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .tv-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.15);
            border-top-color: var(--pal-gold);
        }

    .status-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 6px;
        margin-bottom: 12px;
        gap: 10px;
    }

    .live-badge, .final-badge {
        font-family: var(--font-body);
        font-weight: 800;
        font-size: 0.75rem;
        padding: 6px 12px;
        border-radius: 999px;
        letter-spacing: 1px;
        text-transform: uppercase;
        line-height: 1;
        white-space: nowrap;
    }

    .live-badge {
        background: var(--pal-red);
        color: #fff;
    }

    .final-badge {
        background: #343a40;
        color: #fff;
    }

    .phase-text {
        font-family: var(--font-body);
        color: rgba(0, 24, 69, 0.65);
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .card-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 10px;
        min-width: 0;
    }

    .sport-icon {
        width: 46px;
        height: 46px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #fff;
        border: 2px solid #e9ecef;
        box-shadow: 0 5px 15px rgba(255, 180, 0, 0.10);
        flex: 0 0 auto;
    }

    .title-block {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
        width: 100%;
    }

    .evt-title {
        font-family: var(--font-body);
        font-weight: 800;
        color: var(--pal-dark-blue);
        font-size: 1.05rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 100%;
    }

    .evt-sub {
        font-family: var(--font-body);
        font-weight: 800;
        color: #6b7280;
        font-size: 0.85rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 100%;
        text-transform: uppercase;
        letter-spacing: .5px;
    }

    .divider {
        height: 1px;
        background: #f0f0f0;
        margin: 12px 0 12px;
    }

    .ma-subcategory {
        font-family: var(--font-body);
        color: var(--pal-gold);
        font-size: 0.78rem;
        font-weight: 800;
        text-transform: uppercase;
        background: var(--pal-dark-blue);
        border-radius: 999px;
        padding: 6px 12px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin: 0 auto 10px auto;
        border: 2px solid rgba(255,180,0,.55);
        box-shadow: 0 8px 18px rgba(0,0,0,0.08);
        max-width: 100%;
    }

    /* UPDATED: Logos and Players Area */
    .ma-players-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 10px;
        background: linear-gradient(180deg, rgba(255, 180, 0, 0.10), rgba(2, 62, 138, 0.04));
        padding: 12px;
        border-radius: 16px;
        border: 1px solid rgba(2,62,138,0.12);
        min-height: 64px;
        width: 100%;
    }

    .ma-player {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: 42%;
        text-align: center;
    }

    .ma-logo-box {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        background: white;
        border: 2px solid #e9ecef;
        padding: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 6px;
        box-shadow: 0 3px 6px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    .ma-team-abbr {
        font-family: var(--font-header);
        font-size: 1.4rem;
        font-weight: normal;
        color: var(--pal-blue);
        line-height: 1;
        letter-spacing: 1px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 100%;
    }

    .ma-vs {
        font-family: var(--font-body);
        font-weight: 900;
        font-style: italic;
        color: #adb5bd;
        font-size: 1rem;
        width: 16%;
        text-align: center;
    }

    .card-footer {
        margin-top: auto;
        text-align: center;
        color: rgba(0, 24, 69, 0.65);
        font-family: var(--font-body);
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-top: 1px solid #f0f0f0;
        padding-top: 10px;
        margin-top: 14px;
    }

    /* --- PANELS --- */
    .panel-state {
        background-color: white;
        border-radius: 20px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        padding: 60px 20px;
        text-align: center;
        margin-top: 24px;
        border: 1px solid #e9ecef;
    }

    .panel-title {
        font-family: var(--font-body);
        font-size: 1.6rem;
        font-weight: 800;
        color: #adb5bd;
        text-transform: uppercase;
        margin-top: 12px;
    }

    .panel-sub {
        font-family: var(--font-body);
        font-weight: 800;
        color: #6c757d;
        margin-top: 8px;
    }

    @@media (max-width: 900px) {
        .header-pill {
            padding: 18px 20px;
        }

        .sport-name {
            font-size: 1.25rem;
        }
    }
</style>

<div class="tv-screen-bg">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge">

        <!-- HEADER -->
        <div class="dashboard-header">
            <div class="header-pill">
                <h1 class="main-event-title">MARTIAL ARTS</h1>
                <div class="sub-header-text">OFFICIAL DASHBOARD</div>
            </div>
        </div>

        @if (_isLoading)
        {
            <div class="panel-state">
                <MudProgressCircular Indeterminate="true" Size="Size.Large" Style="color: var(--pal-blue);" />
                <div class="panel-title">LOADING EVENTS...</div>
                <div class="panel-sub">Fetching live matches and results</div>
            </div>
        }
        else
        {
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="mt-2" Centered="true">

                <!-- LIVE MATCHES -->
                <MudTabPanel Text="LIVE MATCHES" Icon="@Icons.Material.Filled.LiveTv">
                    @{
                        var liveEvents = _martialArtsEvents
                        .Where(e => e.IsFinished != true)
                        .Where(e => FilterFunction(e))
                        .ToList();
                    }

                    @if (!liveEvents.Any())
                    {
                        <div class="panel-state">
                            <MudIcon Icon="@Icons.Material.Filled.SportsMma" Size="Size.Large" Style="font-size:80px;color:#dee2e6;" />
                            <div class="panel-title">@(_searchString == "" ? "NO LIVE EVENTS" : "NO MATCHES FOUND")</div>
                            <div class="panel-sub">Try searching by sport, category, or region abbreviation.</div>
                        </div>
                    }
                    else
                    {
                        @foreach (var sportGroup in liveEvents.GroupBy(e => e.Sport))
                        {
                            <div class="sport-section">
                                <div class="sport-title-row">
                                    <div class="sport-name" title="@sportGroup.Key">
                                        <MudIcon Icon="@GetMartialArtsIcon(sportGroup.Key)" Style="color: var(--pal-gold);" />
                                        <span style="min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                            @sportGroup.Key
                                        </span>
                                    </div>
                                </div>

                                <MudGrid Spacing="3">
                                    @foreach (var evt in sportGroup)
                                    {
                                        <MudItem xs="12" sm="6" lg="4" xl="3">
                                            <a href="@GetEventUrl(evt)" class="match-link" target="_blank">
                                                <div class="tv-card">
                                                    <div class="status-row">
                                                        <div class="live-badge">LIVE</div>
                                                        <div class="phase-text">@(evt.Gender ?? "MIXED")</div>
                                                    </div>

                                                    <div class="card-header">
                                                        <div class="sport-icon">
                                                            <MudIcon Icon="@GetMartialArtsIcon(evt.Sport)" />
                                                        </div>
                                                        <div class="title-block">
                                                            <div class="evt-title">@(evt.Category ?? evt.Level ?? "OPEN CATEGORY")</div>
                                                            <div class="evt-sub">@($"{evt.Sport} • {evt.Subcategory ?? "MATCH"}")</div>
                                                        </div>
                                                    </div>

                                                    <div class="divider"></div>

                                                    <div class="d-flex flex-column align-center">
                                                        <div class="ma-subcategory">
                                                            <MudIcon Icon="@Icons.Material.Filled.SportsMma" Size="Size.Small" />
                                                            @(evt.Subcategory ?? "MATCH")
                                                        </div>

                                                        @if (evt.EventVersusList != null && evt.EventVersusList.Count >= 2)
                                                        {
                                                            <div class="ma-players-container">
                                                                <!-- TEAM 1 -->
                                                                <div class="ma-player">
                                                                    <div class="ma-logo-box">
                                                                        @if (string.IsNullOrWhiteSpace(evt.EventVersusList[0].Region))
                                                                        {
                                                                            <MudIcon Icon="@Icons.Material.Filled.PersonOff" Style="color:#adb5bd;" />
                                                                        }
                                                                        else
                                                                        {
                                                                            <img src="@($"https://palarongpambansa2026.com/attachments/media/regions/team_logo/{evt.EventVersusList[0].Region}.webp")"
                                                                                 style="width:100%; height:100%; object-fit:contain;"
                                                                                 onerror="this.src='/media/images/2031.png'" />
                                                                        }
                                                                    </div>
                                                                    <div class="ma-team-abbr">@(evt.EventVersusList[0].Abbreviation ?? "BYE")</div>
                                                                </div>

                                                                <div class="ma-vs">VS</div>

                                                                <!-- TEAM 2 -->
                                                                <div class="ma-player">
                                                                    <div class="ma-logo-box">
                                                                        @if (string.IsNullOrWhiteSpace(evt.EventVersusList[1].Region))
                                                                        {
                                                                            <MudIcon Icon="@Icons.Material.Filled.PersonOff" Style="color:#adb5bd;" />
                                                                        }
                                                                        else
                                                                        {
                                                                            <img src="@($"https://palarongpambansa2026.com/attachments/media/regions/team_logo/{evt.EventVersusList[1].Region}.webp")"
                                                                                 style="width:100%; height:100%; object-fit:contain;"
                                                                                 onerror="this.src='/media/images/2031.png'" />
                                                                        }
                                                                    </div>
                                                                    <div class="ma-team-abbr">@(evt.EventVersusList[1].Abbreviation ?? "BYE")</div>
                                                                </div>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <div class="ma-players-container" style="justify-content:center;">
                                                                <span style="color:#adb5bd; font-size:0.8rem; font-weight:900; letter-spacing:.5px; text-transform:uppercase;">
                                                                    Click to view participants
                                                                </span>
                                                            </div>
                                                        }
                                                    </div>

                                                    <div class="card-footer">
                                                        @evt.EventStage • @(evt.Venue ?? "MAIN ARENA")
                                                    </div>
                                                </div>
                                            </a>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </div>
                        }
                    }
                </MudTabPanel>

                <!-- PARTIAL RESULTS -->
                <MudTabPanel Text="FINAL RESULTS" Icon="@Icons.Material.Filled.MilitaryTech">
                    @{
                        var finishedEvents = _martialArtsEvents
                        .Where(e => e.IsFinished == true)
                        .Where(e => FilterFunction(e))
                        .ToList();
                    }

                    @if (!finishedEvents.Any())
                    {
                        <div class="panel-state">
                            <MudIcon Icon="@Icons.Material.Filled.HistoryToggleOff" Size="Size.Large" Style="font-size:80px;color:#dee2e6;" />
                            <div class="panel-title">@(_searchString == "" ? "NO RESULTS" : "NO MATCHES FOUND")</div>
                            <div class="panel-sub">Final results will appear as soon as matches are completed.</div>
                        </div>
                    }
                    else
                    {
                        @foreach (var sportGroup in finishedEvents.GroupBy(e => e.Sport))
                        {
                            <div class="sport-section">
                                <div class="sport-title-row">
                                    <div class="sport-name" title="@sportGroup.Key">
                                        <MudIcon Icon="@GetMartialArtsIcon(sportGroup.Key)" Style="color: var(--pal-gold);" />
                                        <span style="min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                            @sportGroup.Key
                                        </span>
                                    </div>
                                </div>

                                <MudGrid Spacing="3">
                                    @foreach (var evt in sportGroup)
                                    {
                                        <MudItem xs="12" sm="6" lg="4" xl="3">
                                            <a href="@GetEventUrl(evt)" class="match-link" target="_blank">
                                                <div class="tv-card" style="opacity:.95; border-top-color:#6c757d;">
                                                    <div class="status-row">
                                                        <div class="final-badge">FINAL</div>
                                                        <div class="phase-text">@(evt.Gender ?? "MIXED")</div>
                                                    </div>

                                                    <div class="card-header">
                                                        <div class="sport-icon" style="border-color: rgba(0,0,0,.12);">
                                                            <MudIcon Icon="@Icons.Material.Filled.MilitaryTech" />
                                                        </div>
                                                        <div class="title-block">
                                                            <div class="evt-title">@(evt.Category ?? evt.Level ?? "OPEN")</div>
                                                            <div class="evt-sub">@($"{evt.Sport} • {evt.Subcategory ?? "MATCH"}")</div>
                                                        </div>
                                                    </div>

                                                    <div class="divider"></div>

                                                    <div class="d-flex flex-column align-center">
                                                        <div class="ma-subcategory" style="background:#343a40; border-color: rgba(0,0,0,.10);">
                                                            <MudIcon Icon="@Icons.Material.Filled.MilitaryTech" Size="Size.Small" />
                                                            @(evt.Subcategory ?? "MATCH")
                                                        </div>

                                                        @if (evt.EventVersusList != null && evt.EventVersusList.Count >= 2)
                                                        {
                                                            <div class="ma-players-container" style="background: linear-gradient(180deg, rgba(0, 0, 0, 0.05), rgba(0, 0, 0, 0.02)); border-color: #dee2e6;">
                                                                <!-- TEAM 1 (Grayscale) -->
                                                                <div class="ma-player">
                                                                    <div class="ma-logo-box" style="filter:grayscale(1); opacity:0.8;">
                                                                        @if (string.IsNullOrWhiteSpace(evt.EventVersusList[0].Region))
                                                                        {
                                                                            <MudIcon Icon="@Icons.Material.Filled.PersonOff" Style="color:#adb5bd;" />
                                                                        }
                                                                        else
                                                                        {
                                                                            <img src="@($"https://palarongpambansa2026.com/attachments/media/regions/team_logo/{evt.EventVersusList[0].Region}.webp")"
                                                                                 style="width:100%; height:100%; object-fit:contain;"
                                                                                 onerror="this.src='/media/images/2031.png'" />
                                                                        }
                                                                    </div>
                                                                    <div class="ma-team-abbr" style="color:#6c757d;">@(evt.EventVersusList[0].Abbreviation ?? "BYE")</div>
                                                                </div>

                                                                <div class="ma-vs">VS</div>

                                                                <!-- TEAM 2 (Grayscale) -->
                                                                <div class="ma-player">
                                                                    <div class="ma-logo-box" style="filter:grayscale(1); opacity:0.8;">
                                                                        @if (string.IsNullOrWhiteSpace(evt.EventVersusList[1].Region))
                                                                        {
                                                                            <MudIcon Icon="@Icons.Material.Filled.PersonOff" Style="color:#adb5bd;" />
                                                                        }
                                                                        else
                                                                        {
                                                                            <img src="@($"https://palarongpambansa2026.com/attachments/media/regions/team_logo/{evt.EventVersusList[1].Region}.webp")"
                                                                                 style="width:100%; height:100%; object-fit:contain;"
                                                                                 onerror="this.src='/media/images/2031.png'" />
                                                                        }
                                                                    </div>
                                                                    <div class="ma-team-abbr" style="color:#6c757d;">@(evt.EventVersusList[1].Abbreviation ?? "BYE")</div>
                                                                </div>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <MudText Typo="Typo.caption" Class="mt-2"
                                                                     Style="color:var(--pal-gold); font-weight:800; font-family:var(--font-body); letter-spacing:1px; text-transform:uppercase;">
                                                                RESULTS AVAILABLE
                                                            </MudText>
                                                        }
                                                    </div>

                                                    <div class="card-footer">
                                                        @evt.EventStage • @(evt.Venue ?? "MAIN ARENA")
                                                    </div>
                                                </div>
                                            </a>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </div>
                        }
                    }
                </MudTabPanel>

            </MudTabs>
        }

    </MudContainer>
</div>

@code {
    public class EventsDTO
    {
        public class EventDetails
        {
            public class Event
            {
                public string ID { get; set; } = null!;
                public string? EventStage { get; set; }
                public List<EventVersusTeams>? EventVersusList { get; set; }
                public string? SportMainCat { get; set; }
                public string? Category { get; set; }
                public string? Sport { get; set; }
                public string? GamePhase { get; set; }
                public string? Subcategory { get; set; }
                public string? Gender { get; set; }
                public string? Level { get; set; }
                public string? Venue { get; set; }
                public bool? IsFinished { get; set; }
            }

            public class EventVersusTeams
            {
                public int ID { get; set; }
                public string? Score { get; set; }
                public string? Region { get; set; }
                public string? Abbreviation { get; set; }
            }
        }
    }

    private string _searchString = "";
    private List<EventsDTO.EventDetails.Event> _martialArtsEvents = new();
    private bool _isLoading = true;
    private CancellationTokenSource _cts = new();

    private readonly string[] _martialArtsSports = new[]
    {
        "Arnis",
        "Judo",
        "Jujitsu",
        "Karatedo",
        "Kurash",
        "Pencak Silat",
        "Sambo",
        "Taekwondo",
        "Wushu"
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        _isLoading = false;

        // Auto-refresh every 5 seconds
        _ = Task.Run(async () =>
        {
            while (!_cts.Token.IsCancellationRequested)
            {
                await Task.Delay(5000, _cts.Token);
                try
                {
                    await InvokeAsync(async () =>
                    {
                        await LoadData();
                        StateHasChanged();
                    });
                }
                catch (TaskCanceledException)
                {
                    break;
                }
            }
        }, _cts.Token);
    }

    private async Task LoadData()
    {
        try
        {
            var allEvents = await apiService.GetAsync<EventsDTO.EventDetails.Event>("/Events/Details");
            if (allEvents != null)
            {
                _martialArtsEvents = allEvents
                    .Where(e => _martialArtsSports.Contains(e.Sport ?? "", StringComparer.OrdinalIgnoreCase))
                    .OrderBy(e => e.IsFinished == true)
                    .ThenBy(e => e.Sport)
                    .ThenBy(e => e.Category)
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading martial arts events: {ex.Message}");
        }
    }

    private bool FilterFunction(EventsDTO.EventDetails.Event evt)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        var search = _searchString.ToLower();

        return (evt.Sport?.ToLower().Contains(search) ?? false) ||
               (evt.Category?.ToLower().Contains(search) ?? false) ||
               (evt.Subcategory?.ToLower().Contains(search) ?? false) ||
               (evt.Level?.ToLower().Contains(search) ?? false) ||
               (evt.Gender?.ToLower().Contains(search) ?? false) ||
               (evt.EventStage?.ToLower().Contains(search) ?? false) ||
               (evt.EventVersusList?.Any(v => v.Abbreviation?.ToLower().Contains(search) ?? false) ?? false) ||
               (evt.EventVersusList?.Any(v => v.Region?.ToLower().Contains(search) ?? false) ?? false);
    }

    private string GetMartialArtsIcon(string? sport)
    {
        return sport?.ToLower() switch
        {
            "arnis" => Icons.Material.Filled.SportsMartialArts,
            "judo" => Icons.Material.Filled.SportsMartialArts,
            "jujitsu" => Icons.Material.Filled.SportsMartialArts,
            "karatedo" => Icons.Material.Filled.SportsMma,
            "kurash" => Icons.Material.Filled.SportsMartialArts,
            "pencak silat" => Icons.Material.Filled.SportsMartialArts,
            "sambo" => Icons.Material.Filled.SportsMartialArts,
            "taekwondo" => Icons.Material.Filled.SportsMma,
            "wushu" => Icons.Material.Filled.SportsMartialArts,
            _ => Icons.Material.Filled.SportsMma
        };
    }

    private string GetEventUrl(EventsDTO.EventDetails.Event evt)
    {
        // Return URL to specific scoring page based on sport
        return $"/scoreboard/martialarts/{evt.ID}";
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}