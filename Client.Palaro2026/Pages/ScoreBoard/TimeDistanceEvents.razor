@page "/scoreboard/track-events"
@using System.Threading
@using System.Linq
@using Client.Palaro2026.Services
@inject APIService apiService
@inject NavigationManager Navigation
@implements IDisposable
@layout NoMainLayout

<PageTitle>Track Events Scoreboard | Palaro tu AgSur 2026</PageTitle>

<style>
    /* --- THEME IMPORTS (MATCHING CHESS) --- */
    @@import url('https://fonts.cdnfonts.com/css/evil-empire');
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&family=Chakra+Petch:wght@600;700;800&display=swap');

    :root {
        /* PALARO COLOR PALETTE */
        --pal-blue: #023E8A;
        --pal-dark-blue: #001845;
        --pal-gold: #FFB400;
        --pal-red: #EA0000;
        --pal-white: #ffffff;
        /* LIGHT THEME VARS */
        --bg-gradient-start: #f8f9fa;
        --card-bg: rgba(255, 255, 255, 0.95);
        /* FONTS */
        --font-header: 'Evil Empire', sans-serif;
        --font-subheader: 'Chakra Petch', sans-serif;
        --font-body: 'Nunito', sans-serif;
    }

    ::-webkit-scrollbar {
        width: 8px;
    }

    ::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    ::-webkit-scrollbar-thumb {
        background: #ccc;
        border-radius: 4px;
    }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--pal-blue);
        }

    body {
        background-color: var(--bg-gradient-start);
        margin: 0;
        font-family: var(--font-body);
        overflow-x: hidden;
    }

    .tv-screen-bg {
        min-height: 100vh;
        width: 100vw;
        background: radial-gradient(circle at 50% 30%, #ffffff 0%, #e0e7ff 100%);
        padding-bottom: 50px;
    }

    /* --- HEADER (PILL STYLE) --- */
    .dashboard-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin: 10px 0 30px 0;
    }

    .header-pill {
        background: var(--pal-dark-blue);
        border: 3px solid var(--pal-gold);
        padding: 20px 60px;
        border-radius: 50px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    .main-event-title {
        font-family: var(--font-header);
        color: white;
        font-size: clamp(2rem, 4vw, 3.5rem);
        letter-spacing: 2px;
        margin: 0;
        line-height: 1;
        text-shadow: 2px 2px 0px black;
        text-transform: uppercase;
    }

    .sub-header-text {
        font-family: var(--font-subheader);
        color: var(--pal-gold);
        font-size: 1.1rem;
        letter-spacing: 3px;
        font-weight: 700;
        text-transform: uppercase;
        margin-top: 5px;
    }

    /* --- SEARCH BAR (same as chess) --- */
    .search-wrapper {
        display: flex;
        justify-content: center;
        margin-bottom: 30px;
        padding: 0 20px;
    }

    .tv-search-field {
        width: 100%;
        max-width: 600px;
    }

        .tv-search-field .mud-input-control-input-container {
            background-color: white !important;
            border-radius: 50px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }

        .tv-search-field .mud-input-slot {
            font-family: var(--font-body);
            font-weight: 700;
            color: var(--pal-dark-blue) !important;
            padding-left: 10px;
        }

        .tv-search-field .mud-icon-root {
            color: var(--pal-blue) !important;
        }

    /* --- TABS (same as chess) --- */
    .mud-tabs-tabbar {
        background: transparent !important;
    }

    .mud-tab {
        font-family: var(--font-header) !important;
        font-size: 1.5rem !important;
        letter-spacing: 1px;
        color: #adb5bd !important;
        text-transform: uppercase;
    }

    .mud-tab-active {
        color: var(--pal-blue) !important;
        text-shadow: 0 0 1px rgba(2, 62, 138, 0.5);
    }

    .mud-tabs-indicator {
        background-color: var(--pal-gold) !important;
        height: 4px;
        border-radius: 4px;
    }

    /* --- SECTION (same as chess sport-section) --- */
    .sport-section {
        margin-bottom: 40px;
        background: white;
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        border: 1px solid #e9ecef;
    }

    .sport-title-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 2px solid var(--pal-gold);
        gap: 12px;
    }

    .sport-name {
        font-family: var(--font-header);
        font-size: 1.8rem;
        color: var(--pal-dark-blue);
        display: flex;
        align-items: center;
        gap: 10px;
        letter-spacing: 1px;
        min-width: 0;
        width: 100%;
    }

    /* --- CARD (same as chess tv-card) --- */
    .event-link {
        text-decoration: none;
        display: block;
        height: 100%;
    }

    .tv-card {
        background-color: white;
        border: 1px solid #dee2e6;
        border-top: 5px solid var(--pal-blue);
        border-radius: 15px;
        padding: 15px;
        position: relative;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

        .tv-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.15);
            border-top-color: var(--pal-gold);
        }

    .card-status-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
        border-bottom: 1px solid #f1f1f1;
        padding-bottom: 8px;
        gap: 10px;
    }

    .live-badge {
        font-family: var(--font-subheader);
        font-weight: 800;
        font-size: 0.75rem;
        padding: 3px 12px;
        background: var(--pal-red);
        color: white;
        border-radius: 20px;
        letter-spacing: 1px;
        box-shadow: 0 2px 5px rgba(234, 0, 0, 0.3);
        white-space: nowrap;
    }

    .final-badge {
        font-family: var(--font-subheader);
        font-weight: 800;
        font-size: 0.75rem;
        padding: 3px 12px;
        background: #343a40;
        color: white;
        border-radius: 20px;
        letter-spacing: 1px;
        white-space: nowrap;
    }

    .upcoming-badge {
        font-family: var(--font-subheader);
        font-weight: 800;
        font-size: 0.75rem;
        padding: 3px 12px;
        background: var(--pal-gold);
        color: var(--pal-dark-blue);
        border-radius: 20px;
        letter-spacing: 1px;
        white-space: nowrap;
    }

    .phase-text {
        font-family: var(--font-subheader);
        color: #6c757d;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 70%;
        text-align: right;
        margin-left: auto;
    }

    .card-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 10px;
        min-width: 0;
    }

    .icon-circle {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: #fff;
        border: 2px solid #e9ecef;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 3px 8px rgba(0,0,0,0.06);
        flex: 0 0 auto;
    }

    .title-block {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
        width: 100%;
    }

    .evt-title {
        font-family: var(--font-subheader);
        font-size: 1.05rem;
        font-weight: 900;
        color: var(--pal-dark-blue);
        text-transform: uppercase;
        letter-spacing: .5px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .evt-sub {
        font-family: var(--font-body);
        font-weight: 800;
        color: #6b7280;
        font-size: 0.85rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        text-transform: uppercase;
        letter-spacing: .5px;
    }

    .divider {
        height: 1px;
        background: #f0f0f0;
        margin: 12px 0;
    }

    .meta-row {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 10px;
        width: 100%;
    }

    .meta-badge {
        display: inline-flex;
        align-items: center;
        padding: 4px 10px;
        border-radius: 999px;
        background: rgba(2, 62, 138, 0.08);
        border: 1px solid rgba(2, 62, 138, 0.18);
        color: var(--pal-blue);
        font-family: var(--font-subheader);
        font-weight: 900;
        font-size: 0.75rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        white-space: nowrap;
    }

    /* Stats block (keep your track info but styled to chess) */
    .track-stats {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        background: rgba(2, 62, 138, 0.05);
        border-radius: 14px;
        padding: 10px 12px;
        border: 1px solid rgba(2, 62, 138, 0.15);
    }

    .stat-item {
        text-align: center;
        flex: 1;
        min-width: 0;
    }

    .stat-value {
        font-family: var(--font-subheader);
        font-size: 1.35rem;
        font-weight: 900;
        color: var(--pal-blue);
        line-height: 1;
    }

    .stat-label {
        font-family: var(--font-body);
        font-size: 0.75rem;
        color: #6c757d;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-top: 4px;
        font-weight: 800;
    }

    /* Results list (same, just match chess look a bit) */
    .results-list {
        max-height: 200px;
        overflow-y: auto;
        margin-top: 10px;
        padding-right: 5px;
    }

        .results-list::-webkit-scrollbar {
            width: 4px;
        }

        .results-list::-webkit-scrollbar-thumb {
            background: var(--pal-gold);
            border-radius: 2px;
        }

            .results-list::-webkit-scrollbar-thumb:hover {
                background: var(--pal-blue);
            }

    .result-item {
        display: flex;
        align-items: center;
        padding: 8px 10px;
        background: #f8f9fa;
        border-radius: 10px;
        margin-bottom: 6px;
        border-left: 3px solid transparent;
    }

        .result-item:nth-child(1) {
            border-left-color: #FFD700;
            background: rgba(255, 215, 0, 0.10);
        }

        .result-item:nth-child(2) {
            border-left-color: #C0C0C0;
            background: rgba(192, 192, 192, 0.10);
        }

        .result-item:nth-child(3) {
            border-left-color: #CD7F32;
            background: rgba(205, 127, 50, 0.10);
        }

    .rank-badge {
        font-family: var(--font-subheader);
        font-weight: 900;
        font-size: 0.9rem;
        min-width: 34px;
        text-align: center;
        color: var(--pal-dark-blue);
    }

    .athlete-info {
        flex-grow: 1;
        padding: 0 10px;
        min-width: 0;
    }

    .athlete-name {
        font-family: var(--font-body);
        font-size: 0.9rem;
        font-weight: 800;
        color: var(--pal-dark-blue);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .athlete-region {
        font-size: 0.75rem;
        color: var(--pal-blue);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .6px;
        opacity: .85;
    }

    .time-display {
        font-family: var(--font-subheader);
        font-weight: 900;
        color: var(--pal-blue);
        font-variant-numeric: tabular-nums;
        white-space: nowrap;
    }

    .lane-info {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        background: #f8f9fa;
        border-radius: 10px;
        margin: 6px 0;
        border: 1px solid #dee2e6;
    }

    .lane-number {
        font-family: var(--font-subheader);
        font-weight: 900;
        color: var(--pal-blue);
        min-width: 42px;
        font-size: 0.85rem;
        text-transform: uppercase;
    }

    .panel-state {
        text-align: center;
        padding: 52px 18px;
        color: #999;
        border: 2px dashed rgba(2, 62, 138, 0.18);
        border-radius: 22px;
        background: rgba(255,255,255,0.6);
        margin-top: 10px;
    }

    .panel-title {
        font-family: var(--font-header);
        font-size: 1.6rem;
        color: var(--pal-dark-blue);
        text-transform: uppercase;
        margin-top: 10px;
    }

    .panel-sub {
        font-family: var(--font-body);
        font-weight: 700;
        color: #777;
        margin-top: 8px;
    }

    .loading-spinner {
        color: var(--pal-blue);
    }

    @@media (max-width: 900px) {
        .header-pill {
            padding: 18px 20px;
        }

        .track-stats {
            flex-direction: column;
        }
    }


    .card-footer {
        text-align: center;
        margin-top: 12px;
        color: #6c757d;
        font-family: var(--font-subheader);
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        border-top: 1px solid #f1f1f1;
        padding-top: 8px;
    }
</style>

<div class="tv-screen-bg">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge">

        <!-- HEADER -->
        <div class="dashboard-header">
            <div class="header-pill">
                <h1 class="main-event-title">TRACK EVENTS</h1>
            </div>
        </div>

      

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="mt-16">
                <MudProgressCircular Indeterminate="true" Class="loading-spinner" Size="Size.Large" />
                <MudText Typo="Typo.h6" Class="mt-4" Style="font-family:var(--font-header); color:var(--pal-blue);">
                    INITIALIZING SYSTEM...
                </MudText>
            </MudStack>
        }
        else if (_allEvents == null || !_allEvents.Any())
        {
            <MudPaper Class="pa-16 d-flex flex-column align-center justify-center mt-8"
                      Style="background-color:white; border-radius:20px; box-shadow:0 4px 10px rgba(0,0,0,0.05);">
                <MudIcon Icon="@Icons.Material.Filled.TimerOff" Size="Size.Large" Style="color:#dee2e6; width:80px; height:80px;" />
                <MudText Typo="Typo.h5" Class="mt-4" Style="color:#adb5bd; font-family:var(--font-header)">
                    NO TRACK EVENTS
                </MudText>
                <MudText Style="color:#9aa0a6; font-family:var(--font-body); font-weight:700;">
                    Waiting for event data to be available.
                </MudText>
            </MudPaper>
        }
        else
        {
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="mt-4" Centered="true">

                <!-- LIVE -->
                <MudTabPanel Text="LIVE EVENT">
                    @{
                        var liveEvents = _allEvents
                        .Where(e =>
                        e.EventStage?.Equals("Live", StringComparison.OrdinalIgnoreCase) == true ||
                        e.EventStage?.Equals("In Progress", StringComparison.OrdinalIgnoreCase) == true ||
                        e.EventStage?.Equals("Scheduled", StringComparison.OrdinalIgnoreCase) == true ||
                        ((e.EventStage ?? "") != "Completed" && (e.EventStage ?? "") != "Finished"))
                        .Where(e => FilterFunction(e))
                        .ToList();
                    }

                    @if (!liveEvents.Any())
                    {
                        <MudPaper Class="pa-16 d-flex flex-column align-center justify-center mt-8"
                                  Style="background-color:white; border-radius:20px; box-shadow:0 4px 10px rgba(0,0,0,0.05);">
                            <MudIcon Icon="@Icons.Material.Filled.HistoryToggleOff" Size="Size.Large" Style="color:#dee2e6; width:80px; height:80px;" />
                            <MudText Typo="Typo.h5" Class="mt-4" Style="color:#adb5bd; font-family:var(--font-header)">
                                @(_searchString == "" ? "NO LIVE EVENTS" : "NO EVENTS FOUND")
                            </MudText>
                        </MudPaper>
                    }
                    else
                    {
                        @foreach (var group in liveEvents.GroupBy(e => $"{(e.Gender ?? "Mixed")} • {(e.Level ?? "Open")}"))
                        {
                            <div class="sport-section">
                                <div class="sport-title-row">
                                    <div class="sport-name" title="@group.Key">
                                        <MudIcon Icon="@Icons.Material.Filled.TrackChanges" Style="color: var(--pal-gold);" />
                                        <span style="min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@group.Key</span>
                                    </div>
                                </div>

                                <MudGrid Spacing="3">
                                    @foreach (var evt in group.OrderBy(x => x.Subcategory))
                                    {
                                        var isLive = evt.EventStage?.Equals("Live", StringComparison.OrdinalIgnoreCase) == true
                                        || evt.EventStage?.Equals("In Progress", StringComparison.OrdinalIgnoreCase) == true;
                                        var isScheduled = evt.EventStage?.Equals("Scheduled", StringComparison.OrdinalIgnoreCase) == true;

                                        var eventResults = _eventRankings.ContainsKey(evt.ID) ? _eventRankings[evt.ID] : new List<RankingResult>();
                                        var participantCount = _eventParticipantCount.ContainsKey(evt.ID) ? _eventParticipantCount[evt.ID] : 0;
                                        var heatCount = _eventHeats.ContainsKey(evt.ID) ? _eventHeats[evt.ID].Count : 0;

                                        <MudItem xs="12" sm="6" lg="4" xl="3">
                                            <a href="/scoreboard/track-events/@evt.ID" class="event-link" target="_blank">
                                                <div class="tv-card">

                                                    <div class="card-status-bar">
                                                        <div class="@(isScheduled ? "upcoming-badge" : "live-badge")">
                                                            @(isScheduled ? "UPCOMING" : "LIVE")
                                                        </div>
                                                        <div class="phase-text">@($"{evt.Level ?? "OPEN"}")</div>
                                                    </div>

                                                    <div class="card-header">
                                                        <div class="icon-circle">
                                                            <MudIcon Icon="@GetTrackIcon(evt.Subcategory)" Style="color:var(--pal-blue)" />
                                                        </div>
                                                        <div class="title-block">
                                                            <div class="evt-title">@((evt.Subcategory ?? "TRACK EVENT").ToUpper())</div>
                                                            <div class="evt-sub">@((evt.Gender ?? "Mixed").ToUpper()) • @((evt.Level ?? "Open").ToUpper())</div>
                                                        </div>
                                                    </div>

                                                    <div class="divider"></div>

                                                    <div class="track-stats">
                                                        <div class="stat-item">
                                                            <div class="stat-value">@participantCount</div>
                                                            <div class="stat-label">Athletes</div>
                                                        </div>
                                                        <div class="stat-item">
                                                            <div class="stat-value">@heatCount</div>
                                                            <div class="stat-label">Heats</div>
                                                        </div>
                                                        <div class="stat-item">
                                                            <div class="stat-value">@eventResults.Count</div>
                                                            <div class="stat-label">Results</div>
                                                        </div>
                                                    </div>

                                                    @if (isScheduled)
                                                    {
                                                        <div class="divider"></div>
                                                        <div style="text-align:center;">
                                                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Style="color:var(--pal-blue)" />
                                                            <div style="font-family:var(--font-subheader); font-weight:900; color:var(--pal-blue); margin-top:6px;">
                                                                UPCOMING
                                                            </div>
                                                            @if (evt.Date.HasValue)
                                                            {
                                                                <div style="font-family:var(--font-body); font-weight:800; color:#6c757d; margin-top:6px;">
                                                                    @evt.Date.Value.ToString("MMM dd") @(!string.IsNullOrEmpty(evt.Time) ? $"• {evt.Time}" : "• Time TBD")
                                                                </div>
                                                            }
                                                            <div style="font-family:var(--font-body); color:#6c757d; margin-top:6px;">
                                                                @participantCount athletes registered
                                                            </div>
                                                        </div>
                                                    }
                                                    else if (eventResults.Any())
                                                    {
                                                        <div class="divider"></div>

                                                        <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px;">
                                                            <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Style="color:var(--pal-gold);" />
                                                            <div style="font-family:var(--font-subheader); font-weight:900; color:var(--pal-dark-blue); letter-spacing:1px; text-transform:uppercase; font-size:.8rem;">
                                                                Leaderboard
                                                            </div>
                                                        </div>

                                                        <div class="results-list">
                                                            @foreach (var result in eventResults.Take(3))
                                                            {
                                                                <div class="result-item">
                                                                    <div class="rank-badge">#@result.Rank</div>
                                                                    <div class="athlete-info">
                                                                        <div class="athlete-name">@result.PlayerName</div>
                                                                        <div class="athlete-region">@result.RegionName</div>
                                                                    </div>
                                                                    <div class="time-display">@FormatResultDisplay(result.Result, evt.Subcategory)</div>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="divider"></div>

                                                        <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px;">
                                                            <MudIcon Icon="@Icons.Material.Filled.FormatListNumbered" Style="color:var(--pal-gold);" />
                                                            <div style="font-family:var(--font-subheader); font-weight:900; color:var(--pal-dark-blue); letter-spacing:1px; text-transform:uppercase; font-size:.8rem;">
                                                                @(isLive ? "Heats in progress" : "Event in progress")
                                                            </div>
                                                        </div>

                                                        @if (_eventHeats.ContainsKey(evt.ID) && _eventHeats[evt.ID].Any())
                                                        {
                                                            @foreach (var heat in _eventHeats[evt.ID].Take(2))
                                                            {
                                                                <div class="lane-info">
                                                                    <div class="lane-number">H@heat.HeatOrder</div>
                                                                    <div style="flex-grow:1; font-weight:800; color:var(--pal-dark-blue); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                                                        @heat.HeatName
                                                                    </div>
                                                                    @if (!string.IsNullOrEmpty(heat.FastestTime))
                                                                    {
                                                                        <div class="time-display">@FormatResultDisplay(heat.FastestTime, evt.Subcategory)</div>
                                                                    }
                                                                </div>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <div style="text-align:center; padding:10px 0; color:#6c757d; font-style:italic;">
                                                                @(isLive ? "Live timing in progress" : "Event starting soon")
                                                            </div>
                                                        }
                                                    }

                                                    <div class="meta-row">
                                                        @if (evt.Date.HasValue)
                                                        {
                                                            <span class="meta-badge">@evt.Date.Value.ToString("MMM dd") @(!string.IsNullOrEmpty(evt.Time) ? $"• {evt.Time}" : "")</span>
                                                        }
                                                        <span class="meta-badge">@((evt.EventStage ?? "ONGOING").ToUpper())</span>
                                                    </div>

                                                    <div class="card-footer">
                                                        @(isScheduled ? "VIEW DETAILS" : "VIEW EVENT")
                                                    </div>

                                                </div>
                                            </a>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </div>
                        }
                    }
                </MudTabPanel>

                <!-- RESULTS -->
                <MudTabPanel Text="PARTIAL RESULTS">
                    @{
                        var completedEvents = _allEvents
                        .Where(e => e.EventStage?.Equals("Completed", StringComparison.OrdinalIgnoreCase) == true)
                        .Where(e => FilterFunction(e))
                        .ToList();
                    }

                    @if (!completedEvents.Any())
                    {
                        <MudPaper Class="pa-16 d-flex flex-column align-center justify-center mt-8"
                                  Style="background-color:white; border-radius:20px; box-shadow:0 4px 10px rgba(0,0,0,0.05);">
                            <MudIcon Icon="@Icons.Material.Filled.HistoryToggleOff" Size="Size.Large" Style="color:#dee2e6; width:80px; height:80px;" />
                            <MudText Typo="Typo.h5" Class="mt-4" Style="color:#adb5bd; font-family:var(--font-header)">
                                @(_searchString == "" ? "NO COMPLETED EVENTS YET" : "NO EVENTS FOUND")
                            </MudText>
                        </MudPaper>
                    }
                    else
                    {
                        @foreach (var group in completedEvents.GroupBy(e => $"{(e.Gender ?? "Mixed")} • {(e.Level ?? "Open")}"))
                        {
                            <div class="sport-section">
                                <div class="sport-title-row">
                                    <div class="sport-name" title="@group.Key">
                                        <MudIcon Icon="@Icons.Material.Filled.MilitaryTech" Style="color: var(--pal-gold);" />
                                        <span style="min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@group.Key</span>
                                    </div>
                                </div>

                                <MudGrid Spacing="3">
                                    @foreach (var evt in group.OrderBy(x => x.Subcategory))
                                    {
                                        var eventResults = _eventRankings.ContainsKey(evt.ID) ? _eventRankings[evt.ID] : new List<RankingResult>();
                                        var participantCount = _eventParticipantCount.ContainsKey(evt.ID) ? _eventParticipantCount[evt.ID] : 0;

                                        <MudItem xs="12" sm="6" lg="4" xl="3">
                                            <a href="/scoreboard/track-events/@evt.ID" class="event-link" target="_blank">
                                                <div class="tv-card" style="border-top-color:#6c757d; opacity:.92;">

                                                    <div class="card-status-bar">
                                                        <div class="final-badge">FINAL</div>
                                                        <div class="phase-text">@($"{evt.Level ?? "OPEN"}")</div>
                                                    </div>

                                                    <div class="card-header">
                                                        <div class="icon-circle" style="border-color: rgba(0,0,0,.12);">
                                                            <MudIcon Icon="@Icons.Material.Filled.MilitaryTech" Style="color:#6c757d" />
                                                        </div>
                                                        <div class="title-block">
                                                            <div class="evt-title">@((evt.Subcategory ?? "TRACK EVENT").ToUpper())</div>
                                                            <div class="evt-sub">@((evt.Gender ?? "Mixed").ToUpper()) • @((evt.Level ?? "Open").ToUpper())</div>
                                                        </div>
                                                    </div>

                                                    <div class="divider"></div>

                                                    <div class="track-stats">
                                                        <div class="stat-item">
                                                            <div class="stat-value">@participantCount</div>
                                                            <div class="stat-label">Athletes</div>
                                                        </div>
                                                        <div class="stat-item">
                                                            <div class="stat-value">@eventResults.Count</div>
                                                            <div class="stat-label">Finalists</div>
                                                        </div>
                                                        <div class="stat-item">
                                                            <div class="stat-value">🏅</div>
                                                            <div class="stat-label">Medals</div>
                                                        </div>
                                                    </div>

                                                    <div class="divider"></div>

                                                    @if (eventResults.Any())
                                                    {
                                                        var winner = eventResults.First();

                                                        <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px;">
                                                            <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Style="color:var(--pal-gold);" />
                                                            <div style="font-family:var(--font-subheader); font-weight:900; color:var(--pal-dark-blue); letter-spacing:1px; text-transform:uppercase; font-size:.8rem;">
                                                                Champion
                                                            </div>
                                                        </div>

                                                        <div class="result-item" style="border-left-color:#FFD700; background: rgba(255,215,0,0.10);">
                                                            <div class="rank-badge">#1</div>
                                                            <div class="athlete-info">
                                                                <div class="athlete-name">@winner.PlayerName</div>
                                                                <div class="athlete-region">@winner.RegionName</div>
                                                            </div>
                                                            <div class="time-display">@FormatResultDisplay(winner.Result, evt.Subcategory)</div>
                                                        </div>

                                                        @if (eventResults.Count > 1)
                                                        {
                                                            <div class="results-list" style="margin-top:10px;">
                                                                @foreach (var result in eventResults.Skip(1).Take(2))
                                                                {
                                                                    <div class="result-item">
                                                                        <div class="rank-badge">#@result.Rank</div>
                                                                        <div class="athlete-info">
                                                                            <div class="athlete-name">@result.PlayerName</div>
                                                                            <div class="athlete-region">@result.RegionName</div>
                                                                        </div>
                                                                        <div class="time-display">@FormatResultDisplay(result.Result, evt.Subcategory)</div>
                                                                    </div>
                                                                }
                                                            </div>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <div style="text-align:center; padding:10px 0; color:#6c757d; font-style:italic;">
                                                            Final results pending
                                                        </div>
                                                    }

                                                    <div class="meta-row">
                                                        @if (evt.Date.HasValue)
                                                        {
                                                            <span class="meta-badge">@evt.Date.Value.ToString("MMM dd") @(!string.IsNullOrEmpty(evt.Time) ? $"• {evt.Time}" : "")</span>
                                                        }
                                                        <span class="meta-badge">@((evt.EventStage ?? "COMPLETED").ToUpper())</span>
                                                    </div>

                                                    <div class="card-footer">VIEW RESULTS</div>
                                                </div>
                                            </a>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </div>
                        }
                    }
                </MudTabPanel>

            </MudTabs>
        }

    </MudContainer>
</div>

@code {
    // --- VARIABLES ---
    private string _searchString = "";
    private List<EventInfo> _allEvents = new();
    private Dictionary<string, List<HeatData>> _eventHeats = new();
    private Dictionary<string, List<RankingResult>> _eventRankings = new();
    private Dictionary<string, int> _eventParticipantCount = new();

    private bool _isLoading = true;      // ONLY for initial load
    private bool _isRefreshing = false;  // prevent overlap
    private Timer? _refreshTimer;

    // --- LIFECYCLE ---
    protected override async Task OnInitializedAsync()
    {
        await LoadData(showLoader: true);

        // Same behavior as Chess: refresh every 5 seconds, without toggling loader
        _refreshTimer = new Timer(async _ =>
        {
            await InvokeAsync(() => LoadData(showLoader: false));
        }, null, 5000, 5000);
    }

    // --- SEARCH FILTER ---
    private bool FilterFunction(EventInfo e)
    {
        if (string.IsNullOrWhiteSpace(_searchString)) return true;

        var combined = $"{e.Subcategory} {e.Gender} {e.Level} {e.EventStage} {e.SportMainCat}";
        return combined.Contains(_searchString, StringComparison.OrdinalIgnoreCase);
    }

    private async Task LoadData(bool showLoader)
    {
        // Prevent overlapping calls (important for heavy per-event loading)
        if (_isRefreshing) return;
        _isRefreshing = true;

        try
        {
            if (showLoader)
            {
                _isLoading = true;
                StateHasChanged();
            }

            var participants = await apiService.GetAsync<EventInfo>("TimeDistanceEvents/Sports/AthleticsSwimming");

            if (participants != null && participants.Any())
            {
                var trackEventsOnly = participants
                    .Where(p => !string.IsNullOrEmpty(p.SportMainCat) &&
                                p.SportMainCat.Equals("Track Events", StringComparison.OrdinalIgnoreCase))
                    .ToList();

                _allEvents = trackEventsOnly
                    .GroupBy(e => e.ID)
                    .Select(g =>
                    {
                        var first = g.First();
                        return new EventInfo
                        {
                            ID = first.ID,
                            Sport = first.Sport,
                            Subcategory = first.Subcategory,
                            Gender = first.Gender,
                            Level = first.Level,
                            EventStage = first.EventStage,
                            Date = first.Date,
                            Time = first.Time,
                            SportMainCat = first.SportMainCat,
                            Region = first.Region,
                            Abbreviation = first.Abbreviation,
                            RegionID = first.RegionID,
                            PlayerID = first.PlayerID,
                            PlayerName = first.PlayerName
                        };
                    })
                    .OrderBy(e => e.EventStage?.Equals("Completed", StringComparison.OrdinalIgnoreCase) == true ? 1 : 0)
                    .ThenBy(e => e.EventStage?.Equals("Scheduled", StringComparison.OrdinalIgnoreCase) == true ? 0 : 1)
                    .ThenBy(e => e.Gender)
                    .ThenBy(e => e.Level)
                    .ThenBy(e => e.Subcategory)
                    .ToList();

                _eventParticipantCount.Clear();
                foreach (var evt in _allEvents)
                    _eventParticipantCount[evt.ID] = trackEventsOnly.Count(p => p.ID == evt.ID);

                // rebuild (same as your old logic)
                _eventHeats.Clear();
                _eventRankings.Clear();

                foreach (var evt in _allEvents)
                {
                    try
                    {
                        var savedData = await LoadSavedScoringData(evt.ID);

                        if (savedData != null)
                        {
                            // heats summary
                            if (savedData.Heats != null && savedData.Heats.Any())
                            {
                                var heatInfos = new List<HeatData>();

                                foreach (var savedHeat in savedData.Heats.OrderBy(h => h.HeatOrder))
                                {
                                    var heatData = new HeatData
                                    {
                                        HeatName = savedHeat.HeatName,
                                        HeatOrder = savedHeat.HeatOrder,
                                        LaneCount = savedHeat.Lanes?.Count ?? 0
                                    };

                                    if (savedHeat.Lanes != null && savedHeat.Lanes.Any())
                                    {
                                        var validResults = savedHeat.Lanes
                                            .Where(l => !string.IsNullOrEmpty(l.Result))
                                            .Select(l => l.Result!)
                                            .ToList();

                                        if (validResults.Any())
                                            heatData.FastestTime = GetFastestResult(validResults);
                                    }

                                    heatInfos.Add(heatData);
                                }

                                _eventHeats[evt.ID] = heatInfos;
                            }

                            // rankings
                            var rankings = CalculateRankingsFromSavedData(savedData);
                            if (rankings.Any())
                                _eventRankings[evt.ID] = rankings;
                        }
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"Error loading saved data for event {evt.ID}: {ex.Message}");
                    }
                }
            }
            else
            {
                _allEvents = new();
                _eventParticipantCount.Clear();
                _eventHeats.Clear();
                _eventRankings.Clear();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading track events: {ex.Message}");
        }
        finally
        {
            _isLoading = false;      // stays false after first load (Chess-like)
            _isRefreshing = false;   // release lock
            StateHasChanged();
        }
    }

    private async Task<SavedScoringData?> LoadSavedScoringData(string eventId)
    {
        try
        {
            var savedData = await apiService.GetSingleAsync<SavedScoringData>($"TimeDistanceEvents/Sports/AthleticsSwimming/{eventId}");
            return savedData ?? new SavedScoringData();
        }
        catch
        {
            return new SavedScoringData();
        }
    }

    private List<RankingResult> CalculateRankingsFromSavedData(SavedScoringData savedData)
    {
        var rankings = new List<RankingResult>();
        if (savedData.Heats == null || !savedData.Heats.Any()) return rankings;

        var allResults = new List<(string RegionName, string PlayerName, string Result, string Lane, double NumericResult)>();

        foreach (var heat in savedData.Heats)
        {
            if (heat.Lanes == null) continue;

            foreach (var lane in heat.Lanes)
            {
                if (!string.IsNullOrEmpty(lane.Result) &&
                    !string.IsNullOrEmpty(lane.RegionAbbreviation) &&
                    TryParseResult(lane.Result, out double numericResult))
                {
                    allResults.Add((
                        lane.RegionAbbreviation!,
                        lane.PlayerName ?? "",
                        lane.Result!,
                        $"{heat.HeatName}-{lane.LaneName}",
                        numericResult
                    ));
                }
            }
        }

        if (!allResults.Any()) return rankings;

        var sortedResults = allResults.OrderBy(r => r.NumericResult).ToList();

        for (int i = 0; i < sortedResults.Count; i++)
        {
            var r = sortedResults[i];
            rankings.Add(new RankingResult
            {
                RegionName = r.RegionName,
                PlayerName = r.PlayerName,
                Result = r.Result,
                AssignedLane = r.Lane,
                Rank = i + 1,
                NumericResult = r.NumericResult
            });
        }

        return rankings;
    }

    private string GetFastestResult(List<string> results)
    {
        if (!results.Any()) return "";
        var parsed = new List<(string Original, double Numeric)>();

        foreach (var r in results)
            if (TryParseResult(r, out var n)) parsed.Add((r, n));

        if (!parsed.Any()) return "";
        return parsed.OrderBy(x => x.Numeric).First().Original;
    }

    private bool TryParseResult(string result, out double numericResult)
    {
        numericResult = 0;
        if (string.IsNullOrWhiteSpace(result)) return false;

        if (result.Contains(":") || result.Contains("."))
        {
            if (TimeSpan.TryParse(result, out var t))
            {
                numericResult = t.TotalSeconds;
                return true;
            }
        }

        return double.TryParse(result, out numericResult);
    }

    private string FormatResultDisplay(string? result, string? subcategory)
    {
        if (string.IsNullOrEmpty(result)) return "--:--";
        if (result.Contains(":") || result.Contains(".")) return result;

        if (double.TryParse(result, out double seconds) && seconds > 0)
        {
            var timeSpan = TimeSpan.FromSeconds(seconds);
            if (timeSpan.TotalMinutes >= 1) return timeSpan.ToString(@"m\:ss\.ff");
            return timeSpan.ToString(@"s\.ff");
        }

        return result;
    }

    private string GetTrackIcon(string? subcategory)
    {
        if (string.IsNullOrEmpty(subcategory)) return Icons.Material.Filled.DirectionsRun;

        var s = subcategory.ToLower();
        if (s.Contains("100") || s.Contains("200") || s.Contains("400")) return Icons.Material.Filled.FlashOn;
        if (s.Contains("800") || s.Contains("1500") || s.Contains("5000") || s.Contains("10000")) return Icons.Material.Filled.Timeline;
        if (s.Contains("hurdle") || s.Contains("steeple")) return Icons.Material.Filled.Timeline;
        if (s.Contains("relay") || s.Contains("x") || s.Contains("medley")) return Icons.Material.Filled.Groups;
        if (s.Contains("walk")) return Icons.Material.Filled.DirectionsWalk;
        return Icons.Material.Filled.TrackChanges;
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
        _refreshTimer = null;
    }

    // --- MODELS ---
    public class EventInfo
    {
        public string ID { get; set; } = "";
        public string? Sport { get; set; }
        public string? Subcategory { get; set; }
        public string? Gender { get; set; }
        public string? Level { get; set; }
        public string? EventStage { get; set; }
        public string? SportMainCat { get; set; }
        public DateTime? Date { get; set; }
        public string? Time { get; set; }
        public string? Region { get; set; }
        public string? Abbreviation { get; set; }
        public int? RegionID { get; set; }
        public string? PlayerID { get; set; }
        public string? PlayerName { get; set; }
    }

    public class HeatData
    {
        public string HeatName { get; set; } = "";
        public int HeatOrder { get; set; }
        public int LaneCount { get; set; }
        public string? FastestTime { get; set; }
    }

    public class RankingResult
    {
        public string RegionName { get; set; } = "";
        public string? PlayerName { get; set; }
        public string Result { get; set; } = "";
        public string AssignedLane { get; set; } = "";
        public int Rank { get; set; }
        public double NumericResult { get; set; }
    }

    public class SavedScoringData
    {
        public List<SavedHeat> Heats { get; set; } = new();
        public List<SavedAssignment> Assignments { get; set; } = new();
    }

    public class SavedHeat
    {
        public string HeatName { get; set; } = "";
        public int HeatOrder { get; set; }
        public List<SavedLane> Lanes { get; set; } = new();
    }

    public class SavedLane
    {
        public string LaneName { get; set; } = "";
        public int LaneOrder { get; set; }
        public string? Result { get; set; }
        public int? RegionID { get; set; }
        public string? PlayerID { get; set; }
        public string? PlayerName { get; set; }
        public string? RegionAbbreviation { get; set; }
    }

    public class SavedAssignment
    {
        public int RegionID { get; set; }
        public string? PlayerID { get; set; }
        public string RegionAbbreviation { get; set; } = "";
        public string AssignedTable { get; set; } = "";
    }
}