@page "/scoreboard/swimming"
@using System.Threading
@using System.Linq
@using Client.Palaro2026.Services
@inject APIService apiService
@inject NavigationManager Navigation
@implements IDisposable
@layout NoMainLayout

<PageTitle>Swimming Dashboard | Palaro tu AgSur 2026</PageTitle>

<style>
    /* --- THEME IMPORTS (MATCHING CHESS) --- */
    @@import url('https://fonts.cdnfonts.com/css/evil-empire');
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&family=Chakra+Petch:wght@600;700;800&display=swap');

    :root {
        /* PALARO COLOR PALETTE */
        --pal-blue: #023E8A;
        --pal-dark-blue: #001845;
        --pal-gold: #FFB400;
        --pal-red: #EA0000;
        --pal-white: #ffffff;

        /* LIGHT THEME VARS */
        --bg-gradient-start: #f8f9fa;
        --card-bg: rgba(255, 255, 255, 0.95);

        /* FONTS */
        --font-header: 'Evil Empire', sans-serif;
        --font-subheader: 'Chakra Petch', sans-serif;
        --font-body: 'Nunito', sans-serif;
    }

    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #f1f1f1; }
    ::-webkit-scrollbar-thumb { background: #ccc; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--pal-blue); }

    body {
        background-color: var(--bg-gradient-start);
        margin: 0;
        font-family: var(--font-body);
        overflow-x: hidden;
    }

    .tv-screen-bg {
        min-height: 100vh;
        width: 100vw;
        background: radial-gradient(circle at 50% 30%, #ffffff 0%, #e0e7ff 100%);
        padding-bottom: 50px;
    }

    /* --- HEADER (PILL STYLE) --- */
    .dashboard-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin: 10px 0 30px 0;
    }

    .header-pill {
        background: var(--pal-dark-blue);
        border: 3px solid var(--pal-gold);
        padding: 20px 60px;
        border-radius: 50px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    .main-event-title {
        font-family: var(--font-header);
        color: white;
        font-size: clamp(2rem, 4vw, 3.5rem);
        letter-spacing: 2px;
        margin: 0;
        line-height: 1;
        text-shadow: 2px 2px 0px black;
        text-transform: uppercase;
    }

    .sub-header-text {
        font-family: var(--font-subheader);
        color: var(--pal-gold);
        font-size: 1.1rem;
        letter-spacing: 3px;
        font-weight: 700;
        text-transform: uppercase;
        margin-top: 5px;
    }

    /* --- SEARCH BAR (same as chess) --- */
    .search-wrapper {
        display: flex;
        justify-content: center;
        margin-bottom: 30px;
        padding: 0 20px;
    }

    .tv-search-field {
        width: 100%;
        max-width: 600px;
    }

        .tv-search-field .mud-input-control-input-container {
            background-color: white !important;
            border-radius: 50px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }

        .tv-search-field .mud-input-slot {
            font-family: var(--font-body);
            font-weight: 700;
            color: var(--pal-dark-blue) !important;
            padding-left: 10px;
        }

        .tv-search-field .mud-icon-root {
            color: var(--pal-blue) !important;
        }

    /* --- TABS (same as chess) --- */
    .mud-tabs-tabbar { background: transparent !important; }

    .mud-tab {
        font-family: var(--font-header) !important;
        font-size: 1.5rem !important;
        letter-spacing: 1px;
        color: #adb5bd !important;
        text-transform: uppercase;
    }

    .mud-tab-active {
        color: var(--pal-blue) !important;
        text-shadow: 0 0 1px rgba(2, 62, 138, 0.5);
    }

    .mud-tabs-indicator {
        background-color: var(--pal-gold) !important;
        height: 4px;
        border-radius: 4px;
    }

    /* --- SECTION (same as chess sport-section) --- */
    .sport-section {
        margin-bottom: 40px;
        background: white;
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        border: 1px solid #e9ecef;
    }

    .sport-title-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 2px solid var(--pal-gold);
        gap: 12px;
    }

    .sport-name {
        font-family: var(--font-header);
        font-size: 1.8rem;
        color: var(--pal-dark-blue);
        display: flex;
        align-items: center;
        gap: 10px;
        letter-spacing: 1px;
        min-width: 0;
        width: 100%;
    }

    /* --- CARD (same as chess tv-card) --- */
    .event-link {
        text-decoration: none;
        display: block;
        height: 100%;
    }

    .tv-card {
        background-color: white;
        border: 1px solid #dee2e6;
        border-top: 5px solid var(--pal-blue);
        border-radius: 15px;
        padding: 15px;
        position: relative;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

        .tv-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.15);
            border-top-color: var(--pal-gold);
        }

    .card-status-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
        border-bottom: 1px solid #f1f1f1;
        padding-bottom: 8px;
        gap: 10px;
    }

    .live-badge {
        font-family: var(--font-subheader);
        font-weight: 800;
        font-size: 0.75rem;
        padding: 3px 12px;
        background: var(--pal-red);
        color: white;
        border-radius: 20px;
        letter-spacing: 1px;
        box-shadow: 0 2px 5px rgba(234, 0, 0, 0.3);
        white-space: nowrap;
    }

    .final-badge {
        font-family: var(--font-subheader);
        font-weight: 800;
        font-size: 0.75rem;
        padding: 3px 12px;
        background: #343a40;
        color: white;
        border-radius: 20px;
        letter-spacing: 1px;
        white-space: nowrap;
    }

    .phase-text {
        font-family: var(--font-subheader);
        color: #6c757d;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 70%;
        text-align: right;
        margin-left: auto;
    }

    .card-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 10px;
        min-width: 0;
    }

    .icon-circle {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: #fff;
        border: 2px solid #e9ecef;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 3px 8px rgba(0,0,0,0.06);
        flex: 0 0 auto;
    }

    .title-block {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
        width: 100%;
    }

    .evt-title {
        font-family: var(--font-subheader);
        font-size: 1.05rem;
        font-weight: 900;
        color: var(--pal-dark-blue);
        text-transform: uppercase;
        letter-spacing: .5px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .evt-sub {
        font-family: var(--font-body);
        font-weight: 800;
        color: #6b7280;
        font-size: 0.85rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        text-transform: uppercase;
        letter-spacing: .5px;
    }

    .divider {
        height: 1px;
        background: #f0f0f0;
        margin: 12px 0;
    }

    .meta-row {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 10px;
        width: 100%;
    }

    .meta-badge {
        display: inline-flex;
        align-items: center;
        padding: 4px 10px;
        border-radius: 999px;
        background: rgba(2, 62, 138, 0.08);
        border: 1px solid rgba(2, 62, 138, 0.18);
        color: var(--pal-blue);
        font-family: var(--font-subheader);
        font-weight: 900;
        font-size: 0.75rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .big-number {
        font-family: var(--font-subheader);
        font-weight: 900;
        font-size: 2.2rem;
        color: var(--pal-blue);
        text-align: center;
        line-height: 1;
        margin-top: 6px;
    }

    .muted { color: rgba(0, 24, 69, 0.55) !important; opacity: .85; }

    .card-footer {
        text-align: center;
        margin-top: 12px;
        color: #6c757d;
        font-family: var(--font-subheader);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        border-top: 1px solid #f1f1f1;
        padding-top: 8px;
    }

    .panel-state {
        text-align: center;
        padding: 52px 18px;
        color: #999;
        border: 2px dashed rgba(2, 62, 138, 0.18);
        border-radius: 22px;
        background: rgba(255,255,255,0.6);
        margin-top: 10px;
    }

    .panel-title {
        font-family: var(--font-header);
        font-size: 1.6rem;
        color: var(--pal-dark-blue);
        text-transform: uppercase;
        margin-top: 10px;
    }

    .panel-sub {
        font-family: var(--font-body);
        font-weight: 700;
        color: #777;
        margin-top: 8px;
    }

    .loading-spinner { color: var(--pal-blue); }

    @@media (max-width: 600px) {
        .header-pill { padding: 18px 20px; }
    }
</style>

<div class="tv-screen-bg">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge">

        <!-- HEADER -->
        <div class="dashboard-header">
            <div class="header-pill">
                <h1 class="main-event-title">SWIMMING</h1>
                <div class="sub-header-text">OFFICIAL DASHBOARD</div>
            </div>
        </div>

    

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="mt-16">
                <MudProgressCircular Indeterminate="true" Class="loading-spinner" Size="Size.Large" />
                <MudText Typo="Typo.h6" Class="mt-4" Style="font-family:var(--font-header); color:var(--pal-blue);">
                    INITIALIZING SYSTEM...
                </MudText>
            </MudStack>
        }
        else if (_swimmingEvents == null || !_swimmingEvents.Any())
        {
            <MudPaper Class="pa-16 d-flex flex-column align-center justify-center mt-8"
                      Style="background-color:white; border-radius:20px; box-shadow:0 4px 10px rgba(0,0,0,0.05);">
                <MudIcon Icon="@Icons.Material.Filled.Pool" Size="Size.Large" Style="color:#dee2e6; width:80px; height:80px;" />
                <MudText Typo="Typo.h5" Class="mt-4" Style="color:#adb5bd; font-family:var(--font-header)">
                    NO SWIMMING EVENTS
                </MudText>
                <MudText Style="color:#9aa0a6; font-family:var(--font-body); font-weight:700;">
                    Waiting for event data to be available.
                </MudText>
            </MudPaper>
        }
        else
        {
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="mt-4" Centered="true">

                <!-- LIVE -->
                <MudTabPanel Text="LIVE MATCHES">
                    @{
                        var liveEvents = _swimmingEvents
                            .Where(e => !IsCompleted(e))
                            .Where(e => FilterFunction(e))
                            .ToList();
                    }

                    @if (!liveEvents.Any())
                    {
                        <MudPaper Class="pa-16 d-flex flex-column align-center justify-center mt-8"
                                  Style="background-color:white; border-radius:20px; box-shadow:0 4px 10px rgba(0,0,0,0.05);">
                            <MudIcon Icon="@Icons.Material.Filled.HistoryToggleOff" Size="Size.Large" Style="color:#dee2e6; width:80px; height:80px;" />
                            <MudText Typo="Typo.h5" Class="mt-4" Style="color:#adb5bd; font-family:var(--font-header)">
                                @(_searchString == "" ? "NO LIVE EVENTS" : "NO EVENTS FOUND")
                            </MudText>
                        </MudPaper>
                    }
                    else
                    {
                        @foreach (var group in liveEvents.GroupBy(e => $"{(e.Gender ?? "Mixed")} • {(e.Level ?? "Open")}"))
                        {
                            <div class="sport-section">
                                <div class="sport-title-row">
                                    <div class="sport-name" title="@group.Key">
                                        <MudIcon Icon="@Icons.Material.Filled.Pool" Style="color: var(--pal-gold);" />
                                        <span style="min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@group.Key</span>
                                    </div>
                                </div>

                                <MudGrid Spacing="3">
                                    @foreach (var evt in group.OrderBy(x => x.Subcategory))
                                    {
                                        <MudItem xs="12" sm="6" lg="4" xl="3">
                                            <a href="@GetEventUrl(evt)" target="_blank" class="event-link">
                                                <div class="tv-card">

                                                    <div class="card-status-bar">
                                                        <div class="live-badge">LIVE</div>
                                                        <div class="phase-text">@($"{evt.Level ?? "OPEN"}")</div>
                                                    </div>

                                                    <div class="card-header">
                                                        <div class="icon-circle">
                                                            <MudIcon Icon="@GetSwimmingIcon(evt.SportMainCat, evt.Subcategory)" Style="color:var(--pal-blue)" />
                                                        </div>
                                                        <div class="title-block">
                                                            <div class="evt-title">@(evt.Subcategory ?? "SWIMMING")</div>
                                                            <div class="evt-sub">@GetStrokeType(evt.SportMainCat, evt.Subcategory)</div>
                                                        </div>
                                                    </div>

                                                    <div class="divider"></div>

                                                    <div class="big-number">
                                                        @GetParticipantCount(evt.ID)
                                                        <span class="muted" style="font-size:.85rem;"> SWIMMERS</span>
                                                    </div>

                                                    <div class="meta-row">
                                                        <span class="meta-badge">@((evt.Gender ?? "MIXED").ToUpper())</span>
                                                        <span class="meta-badge">@((evt.EventStage ?? "ONGOING").ToUpper())</span>
                                                    </div>

                                                    <div class="card-footer">VIEW EVENT</div>
                                                </div>
                                            </a>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </div>
                        }
                    }
                </MudTabPanel>

                <!-- RESULTS -->
                <MudTabPanel Text="PARTIAL RESULTS">
                    @{
                        var finishedEvents = _swimmingEvents
                            .Where(e => IsCompleted(e))
                            .Where(e => FilterFunction(e))
                            .ToList();
                    }

                    @if (!finishedEvents.Any())
                    {
                        <MudPaper Class="pa-16 d-flex flex-column align-center justify-center mt-8"
                                  Style="background-color:white; border-radius:20px; box-shadow:0 4px 10px rgba(0,0,0,0.05);">
                            <MudIcon Icon="@Icons.Material.Filled.HistoryToggleOff" Size="Size.Large" Style="color:#dee2e6; width:80px; height:80px;" />
                            <MudText Typo="Typo.h5" Class="mt-4" Style="color:#adb5bd; font-family:var(--font-header)">
                                @(_searchString == "" ? "NO RESULTS YET" : "NO EVENTS FOUND")
                            </MudText>
                        </MudPaper>
                    }
                    else
                    {
                        @foreach (var group in finishedEvents.GroupBy(e => $"{(e.Gender ?? "Mixed")} • {(e.Level ?? "Open")}"))
                        {
                            <div class="sport-section">
                                <div class="sport-title-row">
                                    <div class="sport-name" title="@group.Key">
                                        <MudIcon Icon="@Icons.Material.Filled.MilitaryTech" Style="color: var(--pal-gold);" />
                                        <span style="min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@group.Key</span>
                                    </div>
                                </div>

                                <MudGrid Spacing="3">
                                    @foreach (var evt in group.OrderBy(x => x.Subcategory))
                                    {
                                        <MudItem xs="12" sm="6" lg="4" xl="3">
                                            <a href="@GetEventUrl(evt)" target="_blank" class="event-link">
                                                <div class="tv-card" style="border-top-color:#6c757d; opacity:.92;">

                                                    <div class="card-status-bar">
                                                        <div class="final-badge">FINAL</div>
                                                        <div class="phase-text">@($"{evt.Level ?? "OPEN"} • {GetStrokeType(evt.SportMainCat, evt.Subcategory)}")</div>
                                                    </div>

                                                    <div class="card-header">
                                                        <div class="icon-circle" style="border-color: rgba(0,0,0,.12);">
                                                            <MudIcon Icon="@Icons.Material.Filled.MilitaryTech" Style="color:#6c757d" />
                                                        </div>
                                                        <div class="title-block">
                                                            <div class="evt-title">@(evt.Subcategory ?? "SWIMMING")</div>
                                                            <div class="evt-sub">FASTEST TIME</div>
                                                        </div>
                                                    </div>

                                                    <div class="divider"></div>

                                                    <div class="big-number" style="color:#495057;">
                                                        @GetFastestTime(evt.ID)
                                                    </div>

                                                    <div class="meta-row">
                                                        <span class="meta-badge">@((evt.Gender ?? "MIXED").ToUpper())</span>
                                                        <span class="meta-badge">@((evt.EventStage ?? "COMPLETED").ToUpper())</span>
                                                    </div>

                                                    <div class="card-footer">VIEW RESULTS</div>
                                                </div>
                                            </a>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </div>
                        }
                    }
                </MudTabPanel>

                <!-- BY STROKE -->
                <MudTabPanel Text="BY STROKE">
                    @{
                        var strokeOrder = new List<(string Key, string Title, string Icon)>
                        {
                            ("freestyle", "FREESTYLE", Icons.Material.Filled.DirectionsRun),
                            ("backstroke", "BACKSTROKE", Icons.Material.Filled.RotateLeft),
                            ("breaststroke", "BREASTSTROKE", Icons.Material.Filled.Waves),
                            ("butterfly", "BUTTERFLY", Icons.Material.Filled.Flight),
                            ("medley", "MEDLEY", Icons.Material.Filled.AutoAwesome),
                            ("relay", "RELAY", Icons.Material.Filled.Groups),
                            ("other", "OTHER", Icons.Material.Filled.Pool),
                        };

                        string StrokeKey(EventInfo e)
                        {
                            var combined = $"{e.SportMainCat} {e.Subcategory}".ToLower();
                            if (combined.Contains("freestyle")) return "freestyle";
                            if (combined.Contains("backstroke")) return "backstroke";
                            if (combined.Contains("breaststroke")) return "breaststroke";
                            if (combined.Contains("butterfly")) return "butterfly";
                            if (combined.Contains("medley")) return "medley";
                            if (combined.Contains("relay")) return "relay";
                            return "other";
                        }

                        var byStroke = _swimmingEvents
                            .GroupBy(e => StrokeKey(e))
                            .ToDictionary(g => g.Key, g => g.ToList());
                    }

                    @foreach (var stroke in strokeOrder)
                    {
                        if (!byStroke.TryGetValue(stroke.Key, out var list) || list == null || !list.Any())
                            continue;

                        <div class="sport-section">
                            <div class="sport-title-row">
                                <div class="sport-name" title="@stroke.Title">
                                    <MudIcon Icon="@stroke.Icon" Style="color: var(--pal-gold);" />
                                    <span style="min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@stroke.Title</span>
                                </div>
                            </div>

                            <MudGrid Spacing="3">
                                @foreach (var evt in list
                                    .OrderBy(x => IsCompleted(x) ? 1 : 0)
                                    .ThenBy(x => x.Gender)
                                    .ThenBy(x => x.Level)
                                    .ThenBy(x => x.Subcategory))
                                {
                                    <MudItem xs="12" sm="6" lg="4" xl="3">
                                        <a href="@GetEventUrl(evt)" target="_blank" class="event-link">
                                            <div class="tv-card" style="border-top-color:@(IsCompleted(evt) ? "#6c757d" : "var(--pal-blue)"); opacity:@(IsCompleted(evt) ? ".92" : "1");">

                                                <div class="card-status-bar">
                                                    <div class="@(IsCompleted(evt) ? "final-badge" : "live-badge")">
                                                        @(IsCompleted(evt) ? "FINAL" : "LIVE")
                                                    </div>
                                                    <div class="phase-text">@($"{evt.Level ?? "OPEN"}")</div>
                                                </div>

                                                <div class="card-header">
                                                    <div class="icon-circle" style="border-color:@(IsCompleted(evt) ? "rgba(0,0,0,.12)" : "#e9ecef");">
                                                        <MudIcon Icon="@(IsCompleted(evt) ? Icons.Material.Filled.MilitaryTech : GetSwimmingIcon(evt.SportMainCat, evt.Subcategory))"
                                                                  />
                                                    </div>
                                                    <div class="title-block">
                                                        <div class="evt-title">@(evt.Subcategory ?? "SWIMMING")</div>
                                                        <div class="evt-sub">@GetStrokeType(evt.SportMainCat, evt.Subcategory)</div>
                                                    </div>
                                                </div>

                                                <div class="divider"></div>

                                                @if (IsCompleted(evt))
                                                {
                                                    <div class="big-number" style="color:#495057;">@GetFastestTime(evt.ID)</div>
                                                }
                                                else
                                                {
                                                    <div class="big-number">
                                                        @GetParticipantCount(evt.ID)
                                                        <span class="muted" style="font-size:.85rem;"> SWIMMERS</span>
                                                    </div>
                                                }

                                                <div class="meta-row">
                                                    <span class="meta-badge">@((evt.Gender ?? "MIXED").ToUpper())</span>
                                                    <span class="meta-badge">@((evt.EventStage ?? "ONGOING").ToUpper())</span>
                                                </div>

                                                <div class="card-footer">
                                                    @(IsCompleted(evt) ? "VIEW RESULTS" : "VIEW EVENT")
                                                </div>
                                            </div>
                                        </a>
                                    </MudItem>
                                }
                            </MudGrid>
                        </div>
                    }
                </MudTabPanel>

            </MudTabs>
        }

    </MudContainer>
</div>

@code {
    /* ===================== MODELS ===================== */
    public class EventInfo
    {
        public string ID { get; set; } = "";
        public string? Sport { get; set; }
        public string? Subcategory { get; set; }
        public string? Level { get; set; }
        public string? Gender { get; set; }
        public string? EventStage { get; set; }
        public string? SportMainCat { get; set; }
        public DateTime? Date { get; set; }
        public string? Time { get; set; }
    }

    public class RankingResult
    {
        public string Result { get; set; } = "";
    }

    public class SavedScoringData
    {
        public List<SavedHeat> Heats { get; set; } = new();
    }

    public class SavedHeat
    {
        public List<SavedLane> Lanes { get; set; } = new();
    }

    public class SavedLane
    {
        public string? Result { get; set; }
    }

    /* ===================== STATE ===================== */
    private string _searchString = "";
    private List<EventInfo> _swimmingEvents = new();
    private Dictionary<string, List<EventInfo>> _eventParticipants = new();
    private Dictionary<string, List<RankingResult>> _eventRankings = new();

    private bool _isLoading = true;          // only for initial load
    private bool _isRefreshing = false;      // prevents overlapping timer calls
    private Timer? _refreshTimer;

    /* ===================== INIT ===================== */
    protected override async Task OnInitializedAsync()
    {
        await LoadData(showLoader: true);

        // same refresh behavior as chess: every 5 seconds
        _refreshTimer = new Timer(async _ =>
        {
            await InvokeAsync(() => LoadData(showLoader: false));
        }, null, 5000, 5000);
    }

    /* ===================== FILTER (for search) ===================== */
    private bool FilterFunction(EventInfo e)
    {
        if (string.IsNullOrWhiteSpace(_searchString)) return true;

        string combined = $"{e.Subcategory} {e.Level} {e.Gender} {e.EventStage} {e.SportMainCat}";
        return combined.Contains(_searchString, StringComparison.OrdinalIgnoreCase);
    }

    /* ===================== DATA ===================== */
    private async Task LoadData(bool showLoader)
    {
        // prevent overlapping refreshes
        if (_isRefreshing) return;
        _isRefreshing = true;

        try
        {
            if (showLoader)
            {
                _isLoading = true;
                StateHasChanged();
            }

            var participants = await apiService.GetAsync<EventInfo>("TimeDistanceEvents/Sports/AthleticsSwimming");

            if (participants != null && participants.Any())
            {
                var swimmingParticipants = participants
                    .Where(p => p.Sport == "Swimming")
                    .ToList();

                _swimmingEvents = swimmingParticipants
                    .GroupBy(x => x.ID)
                    .Select(g => g.First())
                    .OrderBy(x => IsCompleted(x) ? 1 : 0)
                    .ThenBy(x => x.Gender)
                    .ThenBy(x => x.Level)
                    .ThenBy(x => x.Subcategory)
                    .ToList();

                _eventParticipants.Clear();
                foreach (var evt in _swimmingEvents)
                    _eventParticipants[evt.ID] = swimmingParticipants.Where(p => p.ID == evt.ID).ToList();

                // keep your ranking logic as-is (still heavy, but refresh behavior now matches chess)
                foreach (var evt in _swimmingEvents)
                {
                    var rankings = await CalculateRankingsForEvent(evt.ID);
                    if (rankings.Any()) _eventRankings[evt.ID] = rankings;
                    else _eventRankings.Remove(evt.ID);
                }
            }
            else
            {
                _swimmingEvents = new();
                _eventParticipants = new();
                _eventRankings = new();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            _isLoading = false; // after first load, stays false (chess-like)
            _isRefreshing = false;
            StateHasChanged();
        }
    }

    private async Task<List<RankingResult>> CalculateRankingsForEvent(string eventId)
    {
        var rankings = new List<RankingResult>();
        try
        {
            var savedData = await apiService.GetSingleAsync<SavedScoringData>($"TimeDistanceEvents/Sports/AthleticsSwimming/{eventId}");
            if (savedData?.Heats != null)
            {
                var allResults = new List<(string Result, double NumericResult)>();

                foreach (var heat in savedData.Heats)
                {
                    if (heat?.Lanes == null) continue;

                    foreach (var lane in heat.Lanes)
                    {
                        if (!string.IsNullOrWhiteSpace(lane?.Result) &&
                            TryParseResult(lane.Result!, out double numericResult))
                        {
                            allResults.Add((lane.Result!, numericResult));
                        }
                    }
                }

                var sorted = allResults.OrderBy(r => r.NumericResult).ToList();
                rankings = sorted.Select(r => new RankingResult { Result = r.Result }).ToList();
            }
        }
        catch { }

        return rankings;
    }

    private bool TryParseResult(string result, out double numericResult)
    {
        numericResult = 0;
        if (string.IsNullOrWhiteSpace(result)) return false;

        if (result.Contains(":") || result.Contains("."))
        {
            if (TimeSpan.TryParse(result, out var t))
            {
                numericResult = t.TotalSeconds;
                return true;
            }
        }

        return double.TryParse(result, out numericResult);
    }

    /* ===================== HELPERS ===================== */
    private bool IsCompleted(EventInfo e)
        => (e.EventStage ?? "").Equals("Completed", StringComparison.OrdinalIgnoreCase);

    private string GetEventUrl(EventInfo evt) => $"/scoreboard/swimming/{evt.ID}";

    private int GetParticipantCount(string eventId)
        => _eventParticipants.TryGetValue(eventId, out var list) ? list.Count : 0;

    private string GetFastestTime(string eventId)
    {
        if (_eventRankings.TryGetValue(eventId, out var list) && list != null && list.Any())
            return list.First().Result;

        return "--:--";
    }

    private string GetStrokeType(string? sportMainCat, string? subcategory)
    {
        var combined = $"{sportMainCat} {subcategory}".ToLower();
        if (combined.Contains("freestyle")) return "FREESTYLE";
        if (combined.Contains("backstroke")) return "BACKSTROKE";
        if (combined.Contains("breaststroke")) return "BREASTSTROKE";
        if (combined.Contains("butterfly")) return "BUTTERFLY";
        if (combined.Contains("medley")) return "MEDLEY";
        if (combined.Contains("relay")) return "RELAY";
        return "SWIMMING";
    }

    private string GetSwimmingIcon(string? sportMainCat, string? subcategory)
    {
        var combined = $"{sportMainCat} {subcategory}".ToLower();
        if (combined.Contains("freestyle")) return Icons.Material.Filled.DirectionsRun;
        if (combined.Contains("backstroke")) return Icons.Material.Filled.RotateLeft;
        if (combined.Contains("breaststroke")) return Icons.Material.Filled.Waves;
        if (combined.Contains("butterfly")) return Icons.Material.Filled.Flight;
        if (combined.Contains("relay")) return Icons.Material.Filled.Groups;
        if (combined.Contains("medley")) return Icons.Material.Filled.AutoAwesome;
        return Icons.Material.Filled.Pool;
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
        _refreshTimer = null;
    }
}