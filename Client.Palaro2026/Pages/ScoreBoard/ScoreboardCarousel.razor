@page "/scoreboard/carousel"
@page "/scoreboard/carousel/{TargetSport}"
@using System.Threading
@using System.Linq
@using Client.Palaro2026.Services
@inject APIService apiService
@inject NavigationManager Navigation
@implements IDisposable
@layout ClientLayout

<PageTitle>TV Broadcast Loop | Palaro tu AgSur 2026</PageTitle>

<style>
    @@import url('https://fonts.cdnfonts.com/css/evil-empire');

    :root {
        --pal-blue: #023E8A;
        --pal-dark-blue: #001845;
        --pal-gold: #FFB400;
        --pal-red: #D90429;
        --bg-gradient: radial-gradient(circle at 50% 50%, #f8fafc 0%, #cbd5e1 100%);
    }

    body, html {
        height: 100vh;
        width: 100vw;
        margin: 0;
        padding: 0;
        overflow: hidden;
        background: var(--bg-gradient);
    }

    /* --- LAYOUT WRAPPERS --- */
    .tv-container {
        width: 100vw;
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .mud-carousel {
        height: 90vh !important;
        width: 100% !important;
    }

    .mud-carousel-item {
        height: 100%;
        width: 100%;
    }

    .tv-scoreboard-wrapper {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        height: 100%;
        width: 100%;
        padding: 2vh 0;
    }

    /* --- MATCH INFO (HEADER BLUE BOX) --- */
    .match-info-container {
        text-align: center;
        margin-top: 0;
        margin-bottom: 2vh;
        padding: 3vh 4vw;
        border-radius: 40px;
        background: var(--pal-dark-blue);
        border: 3px solid var(--pal-gold);
        flex-shrink: 0;
        box-shadow: 0 8px 20px rgba(0,0,0,0.3);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 1.5vh;
        position: relative;
    }

    .sport-title {
        font-family: 'Evil Empire', sans-serif;
        font-size: clamp(24px, 5vh, 60px);
        font-weight: 900;
        color: white;
        text-transform: uppercase;
        letter-spacing: 2px;
        line-height: 1;
        text-shadow: 2px 2px 0px #000000;
    }

    .match-meta {
        font-family: Arial, Helvetica, sans-serif;
        font-size: clamp(14px, 2.2vh, 22px);
        color: var(--pal-gold);
        letter-spacing: 2px;
        font-weight: bold;
        text-transform: uppercase;
    }

    /* --- PHASE TEXT (4TH QUARTER / SET / INNING) --- */
    .phase-container {
        display: flex;
        justify-content: center;
        margin-top: 1vh;
        margin-bottom: 3vh;
        z-index: 100;
        position: relative;
    }

    .phase-header-text {
        font-family: Arial, Helvetica, sans-serif;
        font-size: clamp(14px, 2.8vh, 30px);
        font-weight: 900;
        color: white;
        background: var(--pal-red);
        padding: 1vh 3vw;
        border-radius: 50px;
        text-transform: uppercase;
        letter-spacing: 3px;
        box-shadow: 0 6px 15px rgba(0,0,0,0.4);
        border: 4px solid white;
    }

    /* --- MATCH CARD (FLOATING STYLE) --- */
    .match-card {
        display: grid;
        grid-template-columns: 1fr 1fr 0.4fr 1fr 1fr;
        grid-template-rows: 1fr auto;
        grid-template-areas:
            "teamA scoreA center scoreB teamB"
            "history history history history history";
        align-items: center;
        width: 100%;
        max-width: 1800px;
        background: transparent;
        border: none;
        box-shadow: none;
        padding: 1vh 1vw;
    }

    .area-team-a {
        grid-area: teamA;
    }

    .area-score-a {
        grid-area: scoreA;
    }

    .area-center {
        grid-area: center;
    }

    .area-score-b {
        grid-area: scoreB;
    }

    .area-team-b {
        grid-area: teamB;
    }

    .area-history {
        grid-area: history;
    }

    .team-col {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    /* BAG-O NGA LOGO STYLE (NO BACKGROUND) */
    .logo-container {
        width: clamp(100px, 20vh, 260px);
        height: clamp(100px, 20vh, 260px);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

        .logo-container img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            /* Subtle shadow para mu-pop up sa background ang logo */
            filter: drop-shadow(0 8px 15px rgba(0,0,0,0.15));
            transition: filter 0.3s ease;
        }

    /* GLOWING EFFECT NGA MU-TRACE SA LOGO SHAPE */
    .winner-glow img {
        filter: drop-shadow(0 0 25px rgba(255, 180, 0, 0.8)) drop-shadow(0 0 10px rgba(255, 180, 0, 0.5));
    }

    .team-name {
        font-family: 'Evil Empire', sans-serif;
        font-size: clamp(18px, 3.5vh, 40px);
        font-weight: normal;
        color: var(--pal-dark-blue);
        line-height: 1.2;
        letter-spacing: 1px;
        margin-top: 2vh;
        margin-bottom: 0.5vh;
        width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        z-index: 2;
    }

    .team-region {
        font-family: Arial, Helvetica, sans-serif;
        font-size: clamp(12px, 2vh, 24px);
        color: var(--pal-blue);
        text-transform: uppercase;
        font-weight: bold;
        margin-top: 0.5vh;
    }

    .score-col {
        display: flex;
        justify-content: center;
        align-items: center;
        position: relative;
        height: 100%;
    }

    .main-score {
        font-family: Arial, Helvetica, sans-serif;
        font-size: clamp(80px, 12vw, 350px);
        font-weight: 800;
        color: #0018459c;
        line-height: 0.8;
        letter-spacing: -2px;
        z-index: 10;
    }

    .score-winner {
        color: #ffb400;
        text-shadow: 4px 4px 0px rgba(0, 24, 69, 0.1);
    }

    .center-col {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1vh;
    }

    .sets-score {
        font-family: Arial, sans-serif;
        font-size: clamp(30px, 5vh, 65px);
        color: var(--pal-dark-blue);
        font-weight: 900;
        white-space: nowrap;
    }

    .vs-text {
        font-family: 'Evil Empire', sans-serif;
        font-size: 3vh;
        color: #90a4ae;
        font-style: normal;
        font-weight: normal;
        letter-spacing: 2px;
    }

    /* HISTORY STRIP */
    .history-strip {
        grid-area: history;
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        margin-top: 2vh;
        border-top: 2px solid rgba(2, 62, 138, 0.1);
        padding-top: 2vh;
    }

    .history-table {
        border-collapse: collapse;
        text-align: center;
    }

        .history-table th {
            padding: 0 1.5vw 1vh 1.5vw;
            color: #000;
            font-family: Arial, Helvetica, sans-serif;
            font-size: clamp(14px, 2vh, 20px);
            font-weight: bold;
            text-transform: uppercase;
            border-bottom: 2px solid var(--pal-gold);
            letter-spacing: 1px;
        }

        .history-table td {
            padding: 1vh 1.5vw 0 1.5vw;
            color: #757575;
            font-family: Arial, Helvetica, sans-serif;
            font-size: clamp(16px, 2.5vh, 26px);
            font-weight: 800;
        }

    .team-abbr {
        text-align: right;
        padding-right: 2vw;
        color: #757575 !important;
        font-family: Arial, Helvetica, sans-serif !important;
        font-weight: bold !important;
        letter-spacing: 1px;
    }

    .set-win {
        color: var(--pal-gold) !important;
    }

    /* FOOTER */
    .ticker-footer {
        height: 10vh;
        background: white;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 4vw;
        border-top: 4px solid var(--pal-gold);
        box-shadow: 0 -5px 20px rgba(0,0,0,0.1);
        z-index: 20;
    }

    .footer-logo {
        height: 6vh;
        width: auto;
    }

    @@media (max-width: 1024px) {
        .match-card {
            grid-template-columns: 1fr 1fr;
            grid-template-areas: "center center" "teamA teamB" "scoreA scoreB" "history history";
        }

        .main-score {
            font-size: 140px;
        }
    }
</style>

@if (_isLoading)
{
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height:90vh;">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" Style="color: #023E8A;" />
        <h1 style="font-family:'Evil Empire'; font-size:3rem; margin-top:20px; color:#001845;">LOADING BROADCAST...</h1>
    </MudStack>
}
else if (_activeMatches.Count == 0)
{
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height:90vh;">
        <MudIcon Icon="@Icons.Material.Filled.TvOff" Style="color: #b0bec5; width: 15vh; height: 15vh;" />
        <MudText Typo="Typo.h3" Style="color:#001845; font-family:'Evil Empire'; margin-top:2vh;">NO LIVE MATCHES</MudText>
        <MudText Typo="Typo.h5" Style="color:#64748b; font-family:Arial; font-weight:bold;">PLEASE STAND BY</MudText>
    </MudStack>
}
else
{
    <MudCarousel Class="mud-carousel"
                 ShowArrows="false"
                 ShowBullets="false"
                 EnableSwipeGesture="false"
                 AutoCycle="true"
                 CycleTime="@TimeSpan.FromSeconds(15)"
                 TData="object">

        @foreach (var match in _activeMatches)
        {
            <MudCarouselItem Transition="Transition.Fade" Color="@Color.Transparent">

                <div class="tv-scoreboard-wrapper">
                    <!-- HEADER CONTAINER (Blue Box) -->
                    <div class="match-info-container">
                        <div class="sport-title">@GetCleanSportName(match.EventData.Sport)</div>
                        <div class="match-meta">
                            @GetSchoolLevel(match.EventData.Sport) • @match.EventData.Gender • @match.EventData.EventStage
                        </div>
                    </div>

                    <!-- PHASE TEXT -->
                    @if (!string.IsNullOrEmpty(match.PhaseText))
                    {
                        <div class="phase-container">
                            <div class="phase-header-text">@match.PhaseText</div>
                        </div>
                    }

                    <div class="match-card">
                        <!-- Center Column (VS and Sets) -->
                        <div class="center-col area-center">
                            <div class="vs-text">VS</div>
                            @if (match.IsSetGame)
                            {
                                <div class="sets-container">
                                    <div class="sets-score">@match.SetsA - @match.SetsB</div>
                                </div>
                            }
                        </div>

                        <!-- Team A -->
                        <div class="team-col area-team-a">
                            <div class="logo-container @(match.IsWinnerA ? "winner-glow" : "")">
                                <img src="@($"https://palarongpambansa2026.com/attachments/media/regions/team_logo/{match.TeamA.Region}.webp")" onerror="this.src='/media/images/2031.png'" />
                            </div>
                            <div class="team-name">@match.TeamA.Abbreviation</div>
                            <div class="team-region">@match.TeamA.Region</div>
                        </div>

                        <!-- Score A -->
                        <div class="score-col area-score-a">
                            <div class="main-score @(match.IsWinnerA ? "score-winner" : "")">@match.DisplayScoreA</div>
                        </div>

                        <!-- Score B -->
                        <div class="score-col area-score-b">
                            <div class="main-score @(match.IsWinnerB ? "score-winner" : "")">@match.DisplayScoreB</div>
                        </div>

                        <!-- Team B -->
                        <div class="team-col area-team-b">
                            <div class="logo-container @(match.IsWinnerB ? "winner-glow" : "")">
                                <img src="@($"https://palarongpambansa2026.com/attachments/media/regions/team_logo/{match.TeamB.Region}.webp")" onerror="this.src='/media/images/2031.png'" />
                            </div>
                            <div class="team-name">@match.TeamB.Abbreviation</div>
                            <div class="team-region">@match.TeamB.Region</div>
                        </div>

                        <!-- HISTORY -->
                        <div class="history-strip area-history">
                            @if (match.MatchHistory != null && match.MatchHistory.Any())
                            {
                                <table class="history-table">
                                    <thead>
                                        <tr>
                                            <th class="team-head">TEAM</th>
                                            @foreach (var set in match.MatchHistory)
                                            {
                                                <th>@GetTableColumnHeader(match.EventData.Sport, set.PhaseNumber)</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td class="team-abbr">@match.TeamA.Abbreviation</td>
                                            @foreach (var set in match.MatchHistory)
                                            {
                                                <td class="@(set.ScoreA > set.ScoreB ? "set-win" : "")">@set.ScoreA</td>
                                            }
                                        </tr>
                                        <tr>
                                            <td class="team-abbr">@match.TeamB.Abbreviation</td>
                                            @foreach (var set in match.MatchHistory)
                                            {
                                                <td class="@(set.ScoreB > set.ScoreA ? "set-win" : "")">@set.ScoreB</td>
                                            }
                                        </tr>
                                    </tbody>
                                </table>
                            }
                        </div>
                    </div>
                </div>

            </MudCarouselItem>
        }
    </MudCarousel>
}

@code {
    [Parameter] public string? TargetSport { get; set; }

    /* ================= DATA MODELS ================= */
    public class CarouselMatchViewModel
    {
        public string EventID { get; set; } = "";
        public EventModel EventData { get; set; } = new();
        public EventVersusTeams TeamA { get; set; } = new();
        public EventVersusTeams TeamB { get; set; } = new();
        public int DisplayScoreA { get; set; }
        public int DisplayScoreB { get; set; }
        public int SetsA { get; set; }
        public int SetsB { get; set; }
        public bool IsSetGame { get; set; }
        public string PhaseText { get; set; } = "";
        public bool IsWinnerA { get; set; }
        public bool IsWinnerB { get; set; }
        public List<PhaseScoreModel> MatchHistory { get; set; } = new();
    }
    public class PhaseScoreModel { public int PhaseNumber { get; set; } public int ScoreA { get; set; } public int ScoreB { get; set; } }
    public class EventModel { public string ID { get; set; } = ""; public string? Sport { get; set; } public string? Gender { get; set; } public string? EventStage { get; set; } public bool? IsFinished { get; set; } public List<EventVersusTeams>? EventVersusList { get; set; } }
    public class EventVersusTeams { public string? Region { get; set; } public string? Abbreviation { get; set; } }
    public class ClientTeamMatchDTO { public string? EventID { get; set; } public string? Region { get; set; } public int Phase { get; set; } public int Score { get; set; } }

    /* ================= LOGIC ================= */
    private List<CarouselMatchViewModel> _activeMatches = new();
    private bool _isLoading = true;
    private Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadCarouselData();
        _timer = new Timer(async _ => await InvokeAsync(RefreshScoresOnly), null, 5000, 5000);
    }

    private async Task LoadCarouselData()
    {
        try
        {
            var allEvents = await apiService.GetAsync<EventModel>("/Events/Details");
            if (allEvents != null)
            {
                var teamMatches = allEvents
                    .Where(e => e.EventVersusList?.Count == 2)
                    .Where(e => IsAllowedTeamSport(e.Sport))
                    .Where(e => e.IsFinished != true)
                    .ToList();

                if (!string.IsNullOrEmpty(TargetSport))
                {
                    string target = TargetSport.ToLower().Trim();
                    teamMatches = teamMatches.Where(e =>
                    {
                        string sportName = (e.Sport ?? "").ToLower();
                        if (target == "tennis" && sportName.Contains("table")) return false;
                        return sportName.Contains(target);
                    }).ToList();
                }

                var viewModels = new List<CarouselMatchViewModel>();
                foreach (var evt in teamMatches)
                {
                    var scores = await apiService.GetAsync<ClientTeamMatchDTO>($"score/TeamMatch?eventId={evt.ID}");
                    viewModels.Add(ProcessMatchData(evt, scores ?? new List<ClientTeamMatchDTO>()));
                }
                _activeMatches = viewModels;
            }
        }
        catch (Exception ex) { Console.WriteLine($"Error: {ex.Message}"); }
        finally { _isLoading = false; StateHasChanged(); }
    }

    private async Task RefreshScoresOnly()
    {
        if (_activeMatches.Count == 0) return;
        foreach (var match in _activeMatches)
        {
            try
            {
                var scores = await apiService.GetAsync<ClientTeamMatchDTO>($"score/TeamMatch?eventId={match.EventID}");
                if (scores != null)
                {
                    var updated = ProcessMatchData(match.EventData, scores);
                    match.DisplayScoreA = updated.DisplayScoreA; match.DisplayScoreB = updated.DisplayScoreB;
                    match.SetsA = updated.SetsA; match.SetsB = updated.SetsB;
                    match.PhaseText = updated.PhaseText; match.MatchHistory = updated.MatchHistory;
                    match.IsWinnerA = updated.IsWinnerA; match.IsWinnerB = updated.IsWinnerB;
                }
            }
            catch { }
        }
        StateHasChanged();
    }

    private CarouselMatchViewModel ProcessMatchData(EventModel evt, List<ClientTeamMatchDTO> scores)
    {
        var vm = new CarouselMatchViewModel
        {
            EventID = evt.ID,
            EventData = evt,
            TeamA = evt.EventVersusList![0],
            TeamB = evt.EventVersusList![1],
            IsSetGame = IsSetBasedSport(evt.Sport)
        };
        if (!scores.Any()) return vm;

        int maxPhase = scores.Max(s => s.Phase);
        vm.PhaseText = GetPhaseText(evt.Sport, maxPhase);

        for (int i = 1; i <= maxPhase; i++)
        {
            var sA = scores.FirstOrDefault(s => s.Region == vm.TeamA.Region && s.Phase == i)?.Score ?? 0;
            var sB = scores.FirstOrDefault(s => s.Region == vm.TeamB.Region && s.Phase == i)?.Score ?? 0;
            if (sA > 0 || sB > 0 || i == maxPhase) vm.MatchHistory.Add(new PhaseScoreModel { PhaseNumber = i, ScoreA = sA, ScoreB = sB });
        }

        if (vm.IsSetGame)
        {
            for (int i = 1; i < maxPhase; i++)
            {
                var sA = scores.FirstOrDefault(s => s.Region == vm.TeamA.Region && s.Phase == i)?.Score ?? 0;
                var sB = scores.FirstOrDefault(s => s.Region == vm.TeamB.Region && s.Phase == i)?.Score ?? 0;
                if (sA > sB) vm.SetsA++; else if (sB > sA) vm.SetsB++;
            }
            vm.DisplayScoreA = scores.FirstOrDefault(s => s.Region == vm.TeamA.Region && s.Phase == maxPhase)?.Score ?? 0;
            vm.DisplayScoreB = scores.FirstOrDefault(s => s.Region == vm.TeamB.Region && s.Phase == maxPhase)?.Score ?? 0;
        }
        else
        {
            vm.DisplayScoreA = scores.Where(s => s.Region == vm.TeamA.Region).Sum(s => s.Score);
            vm.DisplayScoreB = scores.Where(s => s.Region == vm.TeamB.Region).Sum(s => s.Score);
        }
        vm.IsWinnerA = vm.DisplayScoreA > vm.DisplayScoreB; vm.IsWinnerB = vm.DisplayScoreB > vm.DisplayScoreA;
        return vm;
    }

    /* ================= HELPERS ================= */
    private bool IsAllowedTeamSport(string? sport)
    {
        if (string.IsNullOrEmpty(sport)) return false;
        var s = sport.ToLower();
        return s.Contains("basket") || s.Contains("volley") || s.Contains("badminton") ||
               s.Contains("sepak") || s.Contains("futsal") || s.Contains("ball") ||
               s.Contains("tennis") || s.Contains("pong");
    }

    private bool IsSetBasedSport(string? s) => !string.IsNullOrEmpty(s) && (s.ToLower().Contains("volley") || s.ToLower().Contains("tennis") || s.ToLower().Contains("badminton") || s.ToLower().Contains("sepak") || s.ToLower().Contains("pong"));

    private string GetPhaseText(string? s, int p)
    {
        if ((s ?? "").ToLower().Contains("basket")) return p <= 4 ? $"Q{p}" : "OT";
        if ((s ?? "").ToLower().Contains("base")) return $"INN {p}";
        return $"SET {p}";
    }

    private string GetTableColumnHeader(string? s, int p) => (s ?? "").ToLower().Contains("basket") ? (p <= 4 ? $"Q{p}" : "OT") : $"{p}";

    private string GetSchoolLevel(string? s) => (s ?? "").ToUpper().Contains("ELEM") ? "ELEMENTARY" : "SECONDARY";

    private string GetCleanSportName(string? s)
    {
        if (string.IsNullOrEmpty(s)) return "";
        return s.Replace("(Elementary)", "")
                .Replace("(Secondary)", "")
                .Replace("Boys", "")
                .Replace("Girls", "")
                .Replace("Elementary", "")
                .Replace("Secondary", "")
                .Trim().ToUpper();
    }

    public void Dispose() => _timer?.Dispose();
}