@page "/scoreboard/chess/{EventID}"
@using Client.Palaro2026.Services
@using System.Threading
@using System.Linq
@inject ISnackbar Snackbar
@inject APIService apiService
@inject NavigationManager Navigation
@implements IDisposable
@layout NoMainLayout

<PageTitle>@_eventDetails?.Subcategory - Chess Scoreboard | Palaro tu AgSur 2026</PageTitle>

<style>
    /* --- THEME IMPORTS (Same as Billiards) --- */
    @@import url('https://fonts.cdnfonts.com/css/evil-empire');
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&family=Chakra+Petch:wght@600;700;800&display=swap');

    :root {
        --pal-blue: #023E8A;
        --pal-dark-blue: #001845;
        --pal-gold: #FFB400;
        --pal-red: #EA0000;
        --pal-white: #ffffff;
        --bg-gradient-start: #f8f9fa;
        --font-header: 'Evil Empire', sans-serif;
        --font-subheader: 'Chakra Petch', sans-serif;
        --font-body: 'Nunito', sans-serif;
    }

    body {
        background-color: var(--bg-gradient-start);
        margin: 0;
        font-family: var(--font-body);
        overflow-x: hidden;
    }

    .tv-screen-bg {
        min-height: 100vh;
        width: 100vw;
        background: radial-gradient(circle at 50% 30%, #ffffff 0%, #e0e7ff 100%);
        padding-bottom: 50px;
    }

    /* --- HEADER (Same as Billiards) --- */
    .dashboard-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin: 0px 0 18px 0;
    }

    .header-pill {
        background: var(--pal-dark-blue);
        border: 3px solid var(--pal-gold);
        padding: 18px 50px;
        border-radius: 50px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    .main-event-title {
        font-family: var(--font-header);
        color: white;
        font-size: clamp(1.9rem, 4vw, 3.2rem);
        letter-spacing: 2px;
        margin: 0;
        line-height: 1;
        text-shadow: 2px 2px 0px black;
        text-transform: uppercase;
    }

    .sub-header-text {
        font-family: var(--font-subheader);
        color: var(--pal-gold);
        font-size: 1.05rem;
        letter-spacing: 3px;
        font-weight: 800;
        text-transform: uppercase;
        margin-top: 6px;
    }

    /* --- BACK BUTTON --- */
    .back-row {
        display: flex;
        justify-content: flex-start;
        padding: 0 10px;
        margin-bottom: 16px;
    }

    /* --- SECTION CARDS (Billiards-like) --- */
    .section-card {
        background: white;
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        border: 1px solid #e9ecef;
        margin-bottom: 22px;
    }

    .section-title {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        font-family: var(--font-header);
        color: var(--pal-dark-blue);
        font-size: 1.9rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin: 0 0 10px 0;
    }

    .section-subtitle {
        text-align: center;
        font-family: var(--font-subheader);
        color: #6c757d;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-top: -6px;
        margin-bottom: 14px;
    }

    .section-footer {
        text-align: center;
        margin-top: 14px;
        color: #6c757d;
        font-family: var(--font-subheader);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        border-top: 1px solid #f1f1f1;
        padding-top: 10px;
    }

    /* --- EVENT HEADER INSIDE CARD --- */
    .event-name {
        font-family: var(--font-header);
        font-size: 2rem;
        color: var(--pal-dark-blue);
        letter-spacing: 1px;
        text-transform: uppercase;
        margin: 0;
        line-height: 1.1;
    }

    .event-meta {
        font-family: var(--font-subheader);
        color: #6c757d;
        font-size: 0.95rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-top: 6px;
    }

    .badge-live {
        font-family: var(--font-subheader);
        font-weight: 900;
        font-size: 0.75rem;
        padding: 6px 14px;
        background: var(--pal-red);
        color: white;
        border-radius: 999px;
        letter-spacing: 1px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 8px 18px rgba(234, 0, 0, 0.22);
    }

    .badge-final {
        font-family: var(--font-subheader);
        font-weight: 900;
        font-size: 0.75rem;
        padding: 6px 14px;
        background: #343a40;
        color: white;
        border-radius: 999px;
        letter-spacing: 1px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 8px 18px rgba(0,0,0,0.18);
    }

    /* --- DETAILS GRID --- */
    .details-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 12px;
        margin-top: 14px;
    }

    .detail-item {
        background: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 14px;
        padding: 14px;
    }

    .detail-label {
        font-family: var(--font-subheader);
        color: var(--pal-blue);
        font-weight: 900;
        font-size: 0.75rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 4px;
    }

    .detail-value {
        font-family: var(--font-body);
        font-size: 1.05rem;
        font-weight: 800;
        color: #212529;
    }

    /* --- STANDINGS TABLE (Clean, Billiards vibe) --- */
    .standings-wrap {
        overflow-x: auto;
        border-radius: 16px;
        border: 1px solid #e9ecef;
    }

    .standings {
        width: 100%;
        min-width: 820px;
        border-collapse: collapse;
        background: white;
    }

        .standings thead th {
            font-family: var(--font-subheader);
            color: var(--pal-dark-blue);
            font-weight: 900;
            font-size: 0.78rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 12px 10px;
            border-bottom: 2px solid var(--pal-gold);
            background: #fbfbfd;
            text-align: center;
            white-space: nowrap;
        }

        .standings tbody td {
            padding: 12px 10px;
            border-bottom: 1px solid #f1f1f1;
            text-align: center;
            font-family: var(--font-body);
            font-weight: 700;
            color: #495057;
            white-space: nowrap;
        }

        .standings tbody tr:hover {
            background: rgba(255, 180, 0, 0.10);
        }

    .col-region {
        text-align: left !important;
        white-space: normal !important;
        min-width: 260px;
    }

    .rank-pill {
        display: inline-flex;
        width: 36px;
        height: 36px;
        border-radius: 999px;
        align-items: center;
        justify-content: center;
        font-family: var(--font-subheader);
        font-weight: 900;
        border: 2px solid #e9ecef;
        background: white;
        color: var(--pal-dark-blue);
    }

    .rank-1 {
        border-color: #FFD700;
        box-shadow: 0 0 0 3px rgba(255,215,0,0.18);
    }

    .rank-2 {
        border-color: #C0C0C0;
        box-shadow: 0 0 0 3px rgba(192,192,192,0.18);
    }

    .rank-3 {
        border-color: #CD7F32;
        box-shadow: 0 0 0 3px rgba(205,127,50,0.18);
    }

    .points-cell {
        font-family: var(--font-subheader);
        font-weight: 900;
        color: var(--pal-blue);
    }

    /* --- LOADING/REFRESH INDICATOR (Billiards-ish) --- */
    .refresh-indicator {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 1000;
        background: rgba(2, 62, 138, 0.92);
        color: white;
        padding: 8px 14px;
        border-radius: 999px;
        font-family: var(--font-subheader);
        font-size: 0.78rem;
        letter-spacing: 1px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        display: none;
    }

        .refresh-indicator.active {
            display: block;
        }

    .page-content {
        opacity: 1;
        transition: opacity 0.25s ease-in-out;
    }

        .page-content.loading {
            opacity: 0.65;
            pointer-events: none;
        }

 
</style>

<!-- Refresh Indicator -->
<div class="refresh-indicator @(_isRefreshing ? "active" : "")">
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
        <MudIcon Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" Class="mud-spin" />
        <span>Updating...</span>
    </MudStack>
</div>

<div class="tv-screen-bg">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge">

        <!-- HEADER -->
        <div class="dashboard-header">
            <div class="header-pill">
                <h1 class="main-event-title">CHESS SCOREBOARD</h1>
                <div class="sub-header-text">OFFICIAL RESULTS</div>
            </div>
        </div>

        <div class="back-row">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="NavigateBack">
                Back to Chess Events
            </MudButton>
        </div>

        <div class="page-content @(_isLoading ? "loading" : "")">

            @if (_isLoading && _eventDetails == null)
            {
                <div class="section-card">
                    <MudStack Spacing="2" AlignItems="AlignItems.Center">
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                        <MudText Typo="Typo.h6" Style="font-family:var(--font-header); color:var(--pal-blue);">
                            LOADING CHESS EVENT DATA...
                        </MudText>
                    </MudStack>
                </div>
            }
            else if (_eventDetails == null)
            {
                <div class="section-card">
                    <MudStack Spacing="2" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.SportsEsports" Size="Size.Large" Style="color:#adb5bd; width:70px; height:70px;" />
                        <MudText Typo="Typo.h5" Style="font-family:var(--font-header); color:#adb5bd;">EVENT NOT FOUND</MudText>
                        <MudText Typo="Typo.body2" Style="color:#6c757d;">The requested chess event could not be found.</MudText>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.ArrowBack"
                                   OnClick="NavigateBack">
                            Back to Chess Events
                        </MudButton>
                    </MudStack>
                </div>
            }
            else
            {
                <!-- EVENT DETAILS -->
                <div class="section-card">
                    <MudGrid AlignItems="AlignItems.Center">
                        <MudItem xs="12" md="8">
                            <div class="event-name">@(_eventDetails.Subcategory ?? "Chess")</div>
                            <div class="event-meta">
                                @(_eventDetails.Level ?? "Open") - @(_eventDetails.Gender ?? "Mixed") • @(_eventDetails.EventStage ?? "Round")
                            </div>
                        </MudItem>

                        <MudItem xs="12" md="4" Style="display:flex; justify-content:flex-end;">
                            @if (_eventDetails.IsFinished == true)
                            {
                                <span class="badge-final">
                                  
                                    FINAL
                                </span>
                            }
                            else
                            {
                            @*     <span class="badge-live">
                                   
                                    LIVE
                                </span> *@
                            }
                        </MudItem>
                    </MudGrid>

                    <div class="details-grid">
                        <div class="detail-item">
                            <div class="detail-label">Sport</div>
                            <div class="detail-value">@(_eventDetails.Sport ?? "Chess")</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Category</div>
                            <div class="detail-value">@(_eventDetails.SportMainCat ?? "—")</div>
                        </div>
                    </div>

                    <div class="section-footer">
                        @(_eventDetails.Level ?? "Open") • @(_eventDetails.Subcategory ?? "Chess")
                    </div>
                </div>

                <!-- STANDINGS TABLE -->
                <div class="section-card">
                    <div class="section-title">
                        <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Style="color: var(--pal-gold);" />
                        OVERALL STANDINGS
                        <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Style="color: var(--pal-gold);" />
                    </div>
                    <div class="section-subtitle">
                        Updated: @_lastUpdated.ToString("MMM dd, yyyy hh:mm tt")
                    </div>

                    @if (!_standings.Any())
                    {
                        <MudText Align="Align.Center" Style="color:#6c757d; padding: 24px;">
                            No standings data available yet.
                        </MudText>
                    }
                    else
                    {
                        <div class="standings-wrap">
                            <table class="standings">
                                <thead>
                                    <tr>
                                        <th>Rank</th>
                                        <th style="text-align:left;">Region</th>
                                        <th>Wins</th>
                                        <th>Draws</th>
                                        <th>Losses</th>
                                        <th>Games</th>
                                        <th>Points</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var standing in _standings)
                                    {
                                        <tr>
                                            <td>
                                                <span class="rank-pill @GetRankClass(standing.Rank)">@standing.Rank</span>
                                            </td>

                                            <td class="col-region">
                                                <MudStack Spacing="0">
                                                    <span style="font-weight:900; color:#212529;">@standing.RegionName</span>
                                                    @if (!string.IsNullOrEmpty(standing.PlayerName))
                                                    {
                                                        <span style="font-size:0.82rem; color:#6c757d; font-weight:800; font-family:var(--font-subheader); text-transform:uppercase; letter-spacing:1px;">
                                                            @standing.PlayerName
                                                        </span>
                                                    }
                                                </MudStack>
                                            </td>

                                            <td>@standing.Wins</td>
                                            <td>@standing.Draws</td>
                                            <td>@standing.Losses</td>
                                            <td>@standing.GamesPlayed</td>
                                            <td class="points-cell">@standing.TotalPoints.ToString("F1")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    <div class="section-footer">
                        @(_eventDetails.Level ?? "Open") • @(_eventDetails.Subcategory ?? "Chess") • Standings
                    </div>
                </div>
            }
        </div>
     
    </MudContainer>


</div>


@code {
    /* ===================== PARAMETERS ===================== */
    [Parameter] public string EventID { get; set; } = "";

    /* ===================== MODELS ===================== */
    public class EventDetailsDTO
    {
        public class Event
        {
            public string ID { get; set; } = null!;
            public string? EventStage { get; set; }
            public List<EventVersus>? EventVersusList { get; set; }
            public string? SportMainCat { get; set; }
            public string? Category { get; set; }
            public string? Sport { get; set; }
            public string? GamePhase { get; set; }
            public int? SubCategoryID { get; set; }
            public string? Subcategory { get; set; }
            public string? Gender { get; set; }
            public string? Level { get; set; }
            public string? Venue { get; set; }
            public decimal? Latitude { get; set; }
            public decimal? Longitude { get; set; }
            public DateTime? Date { get; set; }
            public TimeSpan? Time { get; set; }
            public bool? OnStream { get; set; }
            public string? StreamService { get; set; }
            public string? StreamURL { get; set; }
            public bool? IsFinished { get; set; }
            public bool? Archived { get; set; }
            public bool? Deleted { get; set; }
            public string? FirstName { get; set; }
            public string? LastName { get; set; }
        }

        public class EventVersus
        {
            public int ID { get; set; }
            public string? Score { get; set; }
            public string? Region { get; set; }
            public string? Abbreviation { get; set; }
            public List<EventVersusTeamPlayers>? EventVersusTeamPlayersList { get; set; }
            public string? Rank { get; set; }
            public DateTime? RecentUpdateAt { get; set; }
        }

        public class EventVersusTeamPlayers
        {
            public int ID { get; set; }
            public int? EventVersusID { get; set; }
            public string? FirstName { get; set; }
            public string? LastName { get; set; }
            public string? School { get; set; }
        }
    }

    public class EventDetails
    {
        public string ID { get; set; } = "";
        public string? Sport { get; set; }
        public string? Subcategory { get; set; }
        public string? Level { get; set; }
        public string? Gender { get; set; }
        public string? EventStage { get; set; }
        public string? SportMainCat { get; set; }
        public bool? IsFinished { get; set; }
    }

    public class ChessStanding
    {
        public int Rank { get; set; }
        public string RegionName { get; set; } = "";
        public decimal TotalPoints { get; set; }
        public int GamesPlayed { get; set; }
        public int Wins { get; set; }
        public int Draws { get; set; }
        public int Losses { get; set; }
        public string? PlayerName { get; set; }
    }

    /* ===================== STATE ===================== */
    private EventDetails? _eventDetails;
    private List<ChessStanding> _standings = new();
    private bool _isLoading = true;
    private bool _isRefreshing = false;
    private Timer? _refreshTimer;
    private DateTime _lastUpdated = DateTime.Now;

    /* ===================== LIFECYCLE ===================== */
    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(EventID))
        {
            Snackbar.Add("Event ID is required", Severity.Error);
            Navigation.NavigateTo("/scoreboard/chess");
            return;
        }

        await LoadEventData(isInitialLoad: true);

        // Auto-refresh every 10 seconds
        _refreshTimer = new Timer(async _ => await RefreshData(), null, 10000, 10000);
    }

    /* ===================== DATA LOADING ===================== */
    private async Task LoadEventData(bool isInitialLoad = false)
    {
        if (_isRefreshing) return;

        try
        {
            if (isInitialLoad) _isLoading = true;
            else _isRefreshing = true;

            StateHasChanged();

            var allEvents = await apiService.GetAsync<EventDetailsDTO.Event>("/Events/Details");

            if (allEvents != null)
            {
                var eventDetails = allEvents.FirstOrDefault(e =>
                    e.ID == EventID &&
                    e.Sport?.Equals("Chess", StringComparison.OrdinalIgnoreCase) == true);

                if (eventDetails != null)
                {
                    _eventDetails = new EventDetails
                    {
                        ID = eventDetails.ID,
                        Sport = eventDetails.Sport,
                        Subcategory = eventDetails.Subcategory,
                        Level = eventDetails.Level,
                        Gender = eventDetails.Gender,
                        EventStage = eventDetails.EventStage,
                        SportMainCat = eventDetails.SportMainCat,
                        IsFinished = eventDetails.IsFinished
                    };
                }
                else
                {
                    await LoadEventFromFallback();
                }
            }
            else
            {
                await LoadEventFromFallback();
            }

            if (_eventDetails != null)
            {
                await LoadStandings();
                _lastUpdated = DateTime.Now;
            }

            _isLoading = false;
            _isRefreshing = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading event data: {ex.Message}", Severity.Error);
            _isLoading = false;
            _isRefreshing = false;
            StateHasChanged();
        }
    }

    private async Task LoadEventFromFallback()
    {
        try
        {
            var events = await apiService.GetAsync<EventDetails>("/ChessScoring/events");
            if (events != null && events.Any())
            {
                _eventDetails = events.FirstOrDefault(e => e.ID == EventID);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fallback API error: {ex.Message}");
        }
    }

    private async Task RefreshData()
    {
        if (_isLoading || _isRefreshing) return;

        try
        {
            await InvokeAsync(async () =>
            {
                await LoadEventData(isInitialLoad: false);
            });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Refresh error: {ex.Message}");
        }
    }

    private async Task LoadStandings()
    {
        try
        {
            var scoringRecords = await apiService.GetAsync<ChessScoringDTO>($"/ChessScoring/event/{EventID}");

            if (scoringRecords != null && scoringRecords.Any())
            {
                var regionGroups = scoringRecords
                    .Where(r => !string.IsNullOrEmpty(r.Region))
                    .GroupBy(r => r.Region!);

                var standingsList = new List<ChessStanding>();

                foreach (var group in regionGroups)
                {
                    var regionName = group.Key;
                    var regionRecords = group.ToList();

                    var standing = new ChessStanding
                    {
                        RegionName = regionName,
                        TotalPoints = regionRecords.Sum(r => r.Score ?? 0),
                        Wins = regionRecords.Count(r => r.Score == 1.0m),
                        Draws = regionRecords.Count(r => r.Score == 0.5m),
                        Losses = regionRecords.Count(r => r.Score == 0.0m),
                        GamesPlayed = regionRecords.Count(r => r.Score.HasValue),
                        PlayerName = regionRecords.FirstOrDefault()?.PlayerName
                    };

                    standingsList.Add(standing);
                }

                _standings = standingsList
                    .OrderByDescending(s => s.TotalPoints)
                    .ThenByDescending(s => s.Wins)
                    .ThenBy(s => s.Losses)
                    .Select((s, index) =>
                    {
                        s.Rank = index + 1;
                        return s;
                    })
                    .ToList();
            }
            else
            {
                _standings = new List<ChessStanding>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading standings: {ex.Message}");
            _standings = new List<ChessStanding>();
        }
    }

    private string GetRankClass(int rank)
    {
        return rank switch
        {
            1 => "rank-1",
            2 => "rank-2",
            3 => "rank-3",
            _ => ""
        };
    }

    private void NavigateBack() => Navigation.NavigateTo("/scoreboard/chess");

    /* ===================== SUPPORTING MODELS ===================== */
    public class ChessScoringDTO
    {
        public int ID { get; set; }
        public int? SportsID { get; set; }
        public string? EventID { get; set; }
        public int? EventVersusID { get; set; }
        public int RegionID { get; set; }
        public int SetNo { get; set; }
        public int TableNo { get; set; }
        public string? ColorGroup { get; set; }
        public decimal? Score { get; set; }
        public DateTime? CreatedAt { get; set; }
        public DateTime? UpdatedAt { get; set; }
        public string? Region { get; set; }
        public string? Abbreviation { get; set; }
        public string? Sport { get; set; }
        public string? Subcategory { get; set; }
        public string? Gender { get; set; }
        public string? Level { get; set; }
        public string? EventStage { get; set; }
        public string? PlayerID { get; set; }
        public string? PlayerName { get; set; }
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
        _refreshTimer = null;
    }
}