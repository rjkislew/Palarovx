@page "/scoreboard/chess/{EventID}"
@using Client.Palaro2026.Services
@using System.Threading
@using System.Linq
@inject ISnackbar Snackbar
@inject APIService apiService
@inject NavigationManager Navigation
@implements IDisposable
@layout ClientLayout

<PageTitle>@_eventDetails?.Subcategory - Chess Scoreboard | Palaro tu AgSur 2026</PageTitle>

<style>
    /* --- THEME IMPORTS (Same as Swimming) --- */
    @@import url('https://fonts.cdnfonts.com/css/evil-empire');
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&family=Chakra+Petch:wght@600;700;800&display=swap');

    :root {
        --pal-blue: #023E8A;
        --pal-dark-blue: #001845;
        --pal-gold: #FFB400;
        --pal-red: #EA0000;
        --pal-white: #ffffff;
        --bg-gradient-start: #f8f9fa;
        --font-header: 'Evil Empire', sans-serif;
        --font-subheader: 'Chakra Petch', sans-serif;
        --font-body: 'Nunito', sans-serif;
    }

    body {
        background-color: var(--bg-gradient-start);
        margin: 0;
        font-family: var(--font-body);
        overflow-x: hidden;
    }

    .tv-screen-bg {
        min-height: 100vh;
        width: 100vw;
        background: radial-gradient(circle at 50% 30%, #ffffff 0%, #e0e7ff 100%);
        padding: 22px 0 14vh 0;
        position: relative;
    }

    /* --- HEADER (Same as Swimming) --- */
    .dashboard-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin: 0px 0 16px 0;
    }

    .header-pill {
        background: var(--pal-dark-blue);
        border: 3px solid var(--pal-gold);
        padding: 20px 60px;
        border-radius: 50px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        max-width: calc(100% - 40px);
    }

    .main-event-title {
        font-family: var(--font-header);
        color: white;
        font-size: clamp(2rem, 4vw, 3.5rem);
        letter-spacing: 2px;
        margin: 0;
        line-height: 1;
        text-shadow: 2px 2px 0px black;
        text-transform: uppercase;
    }

    .sub-header-text {
        font-family: var(--font-subheader);
        color: var(--pal-gold);
        font-size: 1.05rem;
        letter-spacing: 3px;
        font-weight: 800;
        text-transform: uppercase;
        margin-top: 6px;
        opacity: 0.95;
    }

    /* --- BACK ROW --- */
    .back-row {
        width: min(1400px, calc(100% - 40px));
        margin: 0 auto 16px auto;
        display: flex;
        justify-content: flex-start;
    }

    /* --- RESULTS WRAP (Same as Swimming) --- */
    .results-wrap {
        width: min(1400px, calc(100% - 40px));
        margin: 0 auto;
        background: white;
        border-radius: 20px;
        border: 1px solid #e9ecef;
        box-shadow: 0 8px 18px rgba(0,0,0,0.06);
        overflow: hidden;
    }

    .results-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 14px 16px;
        border-bottom: 2px solid var(--pal-gold);
        flex-wrap: wrap;
    }

    .results-title {
        font-family: var(--font-header);
        font-size: 1.6rem;
        color: var(--pal-dark-blue);
        text-transform: uppercase;
        letter-spacing: 1px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .results-note {
        font-family: var(--font-subheader);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #6c757d;
        font-size: 0.78rem;
    }

    /* ✅ pager-carousel controls (Same as Swimming) */
    .pager-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 10px 12px;
        border-bottom: 1px solid #f1f1f1;
        background: #ffffff;
    }

    .pager-dots {
        display: inline-flex;
        gap: 6px;
        align-items: center;
        flex-wrap: wrap;
        justify-content: center;
    }

    .dot {
        width: 9px;
        height: 9px;
        border-radius: 999px;
        background: #dee2e6;
        display: inline-block;
    }

        .dot.active {
            background: var(--pal-gold);
            box-shadow: 0 0 0 3px rgba(255, 180, 0, 0.18);
        }

    /* --- TABLE (Same as Swimming) --- */
    .tv-table .mud-table-container {
        background: white !important;
    }

    .tv-table thead th {
        font-family: var(--font-subheader) !important;
        font-weight: 900 !important;
        text-transform: uppercase !important;
        letter-spacing: 1px !important;
        color: var(--pal-dark-blue) !important;
        background: #fbfbfd !important;
        border-bottom: 1px solid #f1f1f1 !important;
        padding-top: 14px !important;
        padding-bottom: 14px !important;
        font-size: 0.82rem !important;
        white-space: nowrap;
        text-align: center;
    }

    .tv-table tbody td {
        border-bottom: 1px solid #f1f1f1 !important;
        padding-top: 14px !important;
        padding-bottom: 14px !important;
        text-align: center;
        white-space: nowrap;
    }

    .rank-pill {
        font-family: var(--font-subheader);
        font-weight: 900;
        border-radius: 999px;
        border: 2px solid #e9ecef;
        padding: 6px 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 64px;
        background: white;
        color: var(--pal-dark-blue);
    }

    .rank-1 {
        border-color: #FFD700;
        box-shadow: 0 0 0 3px rgba(255,215,0,0.18);
    }

    .rank-2 {
        border-color: #C0C0C0;
        box-shadow: 0 0 0 3px rgba(192,192,192,0.16);
    }

    .rank-3 {
        border-color: #CD7F32;
        box-shadow: 0 0 0 3px rgba(205,127,50,0.16);
    }

    .col-region {
        text-align: left !important;
        white-space: normal !important;
        min-width: 320px;
    }

    .points-cell {
        font-family: var(--font-subheader);
        font-weight: 900;
        color: var(--pal-blue);
    }

    /* --- LOADING/REFRESH INDICATOR --- */
    .refresh-indicator {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 1000;
        background: rgba(2, 62, 138, 0.92);
        color: white;
        padding: 8px 14px;
        border-radius: 999px;
        font-family: var(--font-subheader);
        font-size: 0.78rem;
        letter-spacing: 1px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        display: none;
    }

        .refresh-indicator.active {
            display: block;
        }

    .page-content {
        opacity: 1;
        transition: opacity 0.25s ease-in-out;
    }

        .page-content.loading {
            opacity: 0.65;
            pointer-events: none;
        }

    @@media (max-width: 900px) {
        .header-pill {
            padding: 18px 22px;
        }

        .col-region {
            min-width: 260px;
        }
    }
</style>

<!-- Refresh Indicator -->
<div class="refresh-indicator @(_isRefreshing ? "active" : "")">
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
        <MudIcon Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" Class="mud-spin" />
        <span>Updating...</span>
    </MudStack>
</div>

<div class="tv-screen-bg">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge">

        <!-- HEADER -->
        <div class="dashboard-header">
            <div class="header-pill">
                <h1 class="main-event-title">CHESS SCOREBOARD</h1>
                <div class="sub-header-text">
                    @_eventDetails?.Level • @_eventDetails?.Gender • @_eventDetails?.EventStage
                </div>
            </div>
        </div>

       

        <div class="page-content @(_isLoading ? "loading" : "")">

            @if (_isLoading && _eventDetails == null)
            {
                <div class="results-wrap">
                    <div class="results-header">
                        <div class="results-title">
                            <MudIcon Icon="@Icons.Material.Filled.SportsEsports" Style="color: var(--pal-gold);" />
                            LOADING
                        </div>
                        <div class="results-note">PLEASE WAIT</div>
                    </div>

                    <MudStack Spacing="2" AlignItems="AlignItems.Center" Class="pa-10">
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                        <MudText Typo="Typo.h6" Style="font-family:var(--font-header); color:var(--pal-blue);">
                            LOADING CHESS EVENT DATA...
                        </MudText>
                    </MudStack>
                </div>
            }
            else if (_eventDetails == null)
            {
                <div class="results-wrap">
                    <div class="results-header">
                        <div class="results-title">
                            <MudIcon Icon="@Icons.Material.Filled.SportsEsports" Style="color: var(--pal-gold);" />
                            EVENT NOT FOUND
                        </div>
                        <div class="results-note">CHECK EVENT ID</div>
                    </div>

                    <MudStack Spacing="2" AlignItems="AlignItems.Center" Class="pa-10">
                        <MudIcon Icon="@Icons.Material.Filled.SportsEsports" Size="Size.Large" Style="color:#adb5bd; width:70px; height:70px;" />
                        <MudText Typo="Typo.h5" Style="font-family:var(--font-header); color:#adb5bd;">EVENT NOT FOUND</MudText>
                        <MudText Typo="Typo.body2" Style="color:#6c757d;">The requested chess event could not be found.</MudText>
                    </MudStack>
                </div>
            }
            else
            {
                <div class="results-wrap">
                    <div class="results-header">
                        <div class="results-title">
                            <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Style="color: var(--pal-gold);" />
                            OVERALL STANDINGS
                        </div>
                       @*  <div class="results-note">
                            Updated: @_lastUpdated.ToString("MMM dd, yyyy hh:mm tt")
                        </div> *@
                    </div>

                    @if (!_standings.Any())
                    {
                        <MudStack AlignItems="AlignItems.Center" Class="pa-10">
                            <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty"
                                     Size="Size.Large"
                                     Style="color:#dee2e6; width:70px; height:70px;" />
                            <MudText Typo="Typo.h6" Style="color:#adb5bd; font-family:var(--font-header);">
                                NO STANDINGS YET...
                            </MudText>
                        </MudStack>
                    }
                    else
                    {
                        BuildSlides(_standings);  // ✅ carousel pages for chess standings

                        <div class="pager-bar">
                            <MudStack Row Spacing="1" AlignItems="AlignItems.Center">
                                <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                                               Color="Color.Primary"
                                               Variant="Variant.Outlined"
                                               Size="Size.Small"
                                               OnClick="@PrevSlide" />

                                <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                                               Color="Color.Primary"
                                               Variant="Variant.Outlined"
                                               Size="Size.Small"
                                               OnClick="@NextSlide" />
                            </MudStack>

                            <div class="results-note">
                                PAGE @(_currentSlide + 1) / @(_slides.Count == 0 ? 1 : _slides.Count) • AUTO SLIDE
                            </div>
                        </div>

                        <MudTable Class="tv-table"
                                  Items="@CurrentSlideRows"
                                  Dense="true"
                                  Hover="true"
                                  Elevation="0">
                            <HeaderContent>
                                <MudTh>Rank</MudTh>
                                <MudTh style="text-align:left;">Region</MudTh>
                                <MudTh>Wins</MudTh>
                                <MudTh>Draws</MudTh>
                                <MudTh>Losses</MudTh>
                                <MudTh>Games</MudTh>
                                <MudTh>Points</MudTh>
                            </HeaderContent>

                            <RowTemplate>
                                @{
                                    var rankClass = context.Rank switch
                                    {
                                        1 => "rank-1",
                                        2 => "rank-2",
                                        3 => "rank-3",
                                        _ => ""
                                    };
                                }

                                <MudTd>
                                    <span class="rank-pill @rankClass">#@context.Rank</span>
                                </MudTd>

                                <MudTd Class="col-region">
                                    <MudStack Spacing="0">
                                        <span style="font-weight:900; color:#212529;">@context.RegionName</span>
                                        @if (!string.IsNullOrEmpty(context.PlayerName))
                                        {
                                            <span style="font-size:0.82rem; color:#6c757d; font-weight:800; font-family:var(--font-subheader); text-transform:uppercase; letter-spacing:1px;">
                                                @context.PlayerName
                                            </span>
                                        }
                                    </MudStack>
                                </MudTd>

                                <MudTd>@context.Wins</MudTd>
                                <MudTd>@context.Draws</MudTd>
                                <MudTd>@context.Losses</MudTd>
                                <MudTd>@context.GamesPlayed</MudTd>
                                <MudTd Class="points-cell">@context.TotalPoints.ToString("F1")</MudTd>
                            </RowTemplate>
                        </MudTable>

                        <MudStack Row Justify="Justify.Center" Class="pa-3">
                            <div class="pager-dots">
                                @for (int i = 0; i < (_slides.Count == 0 ? 1 : _slides.Count); i++)
                                {
                                    <span class="dot @(i == _currentSlide ? "active" : "")"></span>
                                }
                            </div>
                        </MudStack>
                    }
                </div>
            }
        </div>

    </MudContainer>
</div>

@code {
    /* ===================== PARAMETERS ===================== */
    [Parameter] public string EventID { get; set; } = "";

    /* ===================== MODELS ===================== */
    public class EventDetailsDTO
    {
        public class Event
        {
            public string ID { get; set; } = null!;
            public string? EventStage { get; set; }
            public List<EventVersus>? EventVersusList { get; set; }
            public string? SportMainCat { get; set; }
            public string? Category { get; set; }
            public string? Sport { get; set; }
            public string? GamePhase { get; set; }
            public int? SubCategoryID { get; set; }
            public string? Subcategory { get; set; }
            public string? Gender { get; set; }
            public string? Level { get; set; }
            public string? Venue { get; set; }
            public decimal? Latitude { get; set; }
            public decimal? Longitude { get; set; }
            public DateTime? Date { get; set; }
            public TimeSpan? Time { get; set; }
            public bool? OnStream { get; set; }
            public string? StreamService { get; set; }
            public string? StreamURL { get; set; }
            public bool? IsFinished { get; set; }
            public bool? Archived { get; set; }
            public bool? Deleted { get; set; }
            public string? FirstName { get; set; }
            public string? LastName { get; set; }
        }

        public class EventVersus
        {
            public int ID { get; set; }
            public string? Score { get; set; }
            public string? Region { get; set; }
            public string? Abbreviation { get; set; }
            public List<EventVersusTeamPlayers>? EventVersusTeamPlayersList { get; set; }
            public string? Rank { get; set; }
            public DateTime? RecentUpdateAt { get; set; }
        }

        public class EventVersusTeamPlayers
        {
            public int ID { get; set; }
            public int? EventVersusID { get; set; }
            public string? FirstName { get; set; }
            public string? LastName { get; set; }
            public string? School { get; set; }
        }
    }

    public class EventDetails
    {
        public string ID { get; set; } = "";
        public string? Sport { get; set; }
        public string? Subcategory { get; set; }
        public string? Level { get; set; }
        public string? Gender { get; set; }
        public string? EventStage { get; set; }
        public string? SportMainCat { get; set; }
        public bool? IsFinished { get; set; }
    }

    public class ChessStanding
    {
        public int Rank { get; set; }
        public string RegionName { get; set; } = "";
        public decimal TotalPoints { get; set; }
        public int GamesPlayed { get; set; }
        public int Wins { get; set; }
        public int Draws { get; set; }
        public int Losses { get; set; }
        public string? PlayerName { get; set; }
    }

    /* ===================== STATE ===================== */
    private EventDetails? _eventDetails;
    private List<ChessStanding> _standings = new();

    private bool _isLoading = true;
    private bool _isRefreshing = false;

    private Timer? _refreshTimer;
    private DateTime _lastUpdated = DateTime.Now;

    // ✅ Carousel (same behavior as Swimming)
    private int _rowsPerSlide = 8;
    private int _autoSlideMs = 4500;

    private int _currentSlide = 0;
    private List<List<ChessStanding>> _slides = new();
    private Timer? _carouselTimer;

    /* ===================== LIFECYCLE ===================== */
    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(EventID))
        {
            Snackbar.Add("Event ID is required", Severity.Error);
            Navigation.NavigateTo("/scoreboard/chess");
            return;
        }

        await LoadEventData(isInitialLoad: true);

        // Auto-refresh every 10 seconds
        _refreshTimer = new Timer(async _ => await RefreshData(), null, 1000, 1000);

        // Auto-slide
        _carouselTimer = new Timer(async _ =>
        {
            await InvokeAsync(() =>
            {
                NextSlide();
                StateHasChanged();
            });
        }, null, _autoSlideMs, _autoSlideMs);
    }

    /* ===================== DATA LOADING ===================== */
    private async Task LoadEventData(bool isInitialLoad = false)
    {
        if (_isRefreshing) return;

        try
        {
            if (isInitialLoad) _isLoading = true;
            else _isRefreshing = true;

            StateHasChanged();

            var allEvents = await apiService.GetAsync<EventDetailsDTO.Event>("/Events/Details");

            if (allEvents != null)
            {
                var eventDetails = allEvents.FirstOrDefault(e =>
                    e.ID == EventID &&
                    e.Sport?.Equals("Chess", StringComparison.OrdinalIgnoreCase) == true);

                if (eventDetails != null)
                {
                    _eventDetails = new EventDetails
                    {
                        ID = eventDetails.ID,
                        Sport = eventDetails.Sport,
                        Subcategory = eventDetails.Subcategory,
                        Level = eventDetails.Level,
                        Gender = eventDetails.Gender,
                        EventStage = eventDetails.EventStage,
                        SportMainCat = eventDetails.SportMainCat,
                        IsFinished = eventDetails.IsFinished
                    };
                }
                else
                {
                    await LoadEventFromFallback();
                }
            }
            else
            {
                await LoadEventFromFallback();
            }

            if (_eventDetails != null)
            {
                await LoadStandings();
                _lastUpdated = DateTime.Now;
            }

            _isLoading = false;
            _isRefreshing = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading event data: {ex.Message}", Severity.Error);
            _isLoading = false;
            _isRefreshing = false;
            StateHasChanged();
        }
    }

    private async Task LoadEventFromFallback()
    {
        try
        {
            var events = await apiService.GetAsync<EventDetails>("/ChessScoring/events");
            if (events != null && events.Any())
                _eventDetails = events.FirstOrDefault(e => e.ID == EventID);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fallback API error: {ex.Message}");
        }
    }

    private async Task RefreshData()
    {
        if (_isLoading || _isRefreshing) return;

        try
        {
            await InvokeAsync(async () =>
            {
                await LoadEventData(isInitialLoad: false);
            });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Refresh error: {ex.Message}");
        }
    }

    private async Task LoadStandings()
    {
        try
        {
            var scoringRecords = await apiService.GetAsync<ChessScoringDTO>($"/ChessScoring/event/{EventID}");

            if (scoringRecords != null && scoringRecords.Any())
            {
                var regionGroups = scoringRecords
                    .Where(r => !string.IsNullOrEmpty(r.Region))
                    .GroupBy(r => r.Region!);

                var standingsList = new List<ChessStanding>();

                foreach (var group in regionGroups)
                {
                    var regionName = group.Key;
                    var regionRecords = group.ToList();

                    standingsList.Add(new ChessStanding
                    {
                        RegionName = regionName,
                        TotalPoints = regionRecords.Sum(r => r.Score ?? 0),
                        Wins = regionRecords.Count(r => r.Score == 1.0m),
                        Draws = regionRecords.Count(r => r.Score == 0.5m),
                        Losses = regionRecords.Count(r => r.Score == 0.0m),
                        GamesPlayed = regionRecords.Count(r => r.Score.HasValue),
                        PlayerName = regionRecords.FirstOrDefault()?.PlayerName
                    });
                }

                _standings = standingsList
                    .OrderByDescending(s => s.TotalPoints)
                    .ThenByDescending(s => s.Wins)
                    .ThenBy(s => s.Losses)
                    .Select((s, index) =>
                    {
                        s.Rank = index + 1;
                        return s;
                    })
                    .ToList();

                // ✅ rebuild slides after standings change
                BuildSlides(_standings);
            }
            else
            {
                _standings = new List<ChessStanding>();
                BuildSlides(_standings);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading standings: {ex.Message}");
            _standings = new List<ChessStanding>();
            BuildSlides(_standings);
        }
    }

    /* ===================== CAROUSEL HELPERS ===================== */
    private List<ChessStanding> CurrentSlideRows
    {
        get
        {
            if (_slides.Count == 0) return new List<ChessStanding>();
            if (_currentSlide < 0) _currentSlide = 0;
            if (_currentSlide >= _slides.Count) _currentSlide = 0;
            return _slides[_currentSlide];
        }
    }

    private void BuildSlides(List<ChessStanding> ordered)
    {
        _slides = Chunk(ordered, _rowsPerSlide).ToList();
        if (_slides.Count == 0) _slides = new List<List<ChessStanding>> { new List<ChessStanding>() };
        if (_currentSlide >= _slides.Count) _currentSlide = 0;
    }

    private void NextSlide()
    {
        if (_slides.Count <= 1) return;
        _currentSlide = (_currentSlide + 1) % _slides.Count;
    }

    private void PrevSlide()
    {
        if (_slides.Count <= 1) return;
        _currentSlide = (_currentSlide - 1 + _slides.Count) % _slides.Count;
    }

    private IEnumerable<List<T>> Chunk<T>(List<T> source, int size)
    {
        if (size <= 0) size = 1;
        for (int i = 0; i < source.Count; i += size)
            yield return source.Skip(i).Take(size).ToList();
    }

    private void NavigateBack() => Navigation.NavigateTo("/scoreboard/chess");

    /* ===================== SUPPORTING MODELS ===================== */
    public class ChessScoringDTO
    {
        public int ID { get; set; }
        public int? SportsID { get; set; }
        public string? EventID { get; set; }
        public int? EventVersusID { get; set; }
        public int RegionID { get; set; }
        public int SetNo { get; set; }
        public int TableNo { get; set; }
        public string? ColorGroup { get; set; }
        public decimal? Score { get; set; }
        public DateTime? CreatedAt { get; set; }
        public DateTime? UpdatedAt { get; set; }
        public string? Region { get; set; }
        public string? Abbreviation { get; set; }
        public string? Sport { get; set; }
        public string? Subcategory { get; set; }
        public string? Gender { get; set; }
        public string? Level { get; set; }
        public string? EventStage { get; set; }
        public string? PlayerID { get; set; }
        public string? PlayerName { get; set; }
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
        _refreshTimer = null;

        _carouselTimer?.Dispose();
        _carouselTimer = null;
    }
}