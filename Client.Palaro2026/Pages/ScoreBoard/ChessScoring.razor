@page "/scoreboard/chess"
@using System.Threading
@using System.Linq
@using Client.Palaro2026.Services
@inject ISnackbar Snackbar
@inject APIService apiService
@inject NavigationManager Navigation
@implements IDisposable
@layout NoMainLayout

<PageTitle>Chess Dashboard | Palaro tu AgSur 2026</PageTitle>

<style>
    /* --- THEME IMPORTS (MATCHING TEAMMATCH-LIVE / ARCHERY) --- */
    @@import url('https://fonts.cdnfonts.com/css/evil-empire');
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&family=Chakra+Petch:wght@600;700;800&display=swap');

    :root {
        /* PALARO COLOR PALETTE */
        --pal-blue: #023E8A;
        --pal-dark-blue: #001845;
        --pal-gold: #FFB400;
        --pal-red: #EA0000;
        --pal-white: #ffffff;
        /* LIGHT THEME VARS */
        --bg-gradient-start: #f8f9fa;
        --card-bg: rgba(255, 255, 255, 0.95);
        /* FONTS */
        --font-header: 'Evil Empire', sans-serif;
        --font-subheader: 'Chakra Petch', sans-serif;
        --font-body: 'Nunito', sans-serif;
    }

    ::-webkit-scrollbar {
        width: 8px;
    }

    ::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    ::-webkit-scrollbar-thumb {
        background: #ccc;
        border-radius: 4px;
    }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--pal-blue);
        }

    body {
        background-color: var(--bg-gradient-start);
        margin: 0;
        font-family: var(--font-body);
        overflow-x: hidden;
    }

    .tv-screen-bg {
        min-height: 100vh;
        width: 100vw;
        background: radial-gradient(circle at 50% 30%, #ffffff 0%, #e0e7ff 100%);
        padding-bottom: 50px;
    }

    /* --- HEADER (PILL STYLE) --- */
    .dashboard-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin: 10px 0 30px 0;
    }

    .header-pill {
        background: var(--pal-dark-blue);
        border: 3px solid var(--pal-gold);
        padding: 20px 60px;
        border-radius: 50px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    .main-event-title {
        font-family: var(--font-header);
        color: white;
        font-size: clamp(2rem, 4vw, 3.5rem);
        letter-spacing: 2px;
        margin: 0;
        line-height: 1;
        text-shadow: 2px 2px 0px black;
    }

    .sub-header-text {
        font-family: var(--font-subheader);
        color: var(--pal-gold);
        font-size: 1.1rem;
        letter-spacing: 3px;
        font-weight: 700;
        text-transform: uppercase;
        margin-top: 5px;
    }

    /* --- SEARCH BAR --- */
    .search-wrapper {
        display: flex;
        justify-content: center;
        margin-bottom: 30px;
        padding: 0 20px;
    }

    .tv-search-field {
        width: 100%;
        max-width: 600px;
    }

        .tv-search-field .mud-input-control-input-container {
            background-color: white !important;
            border-radius: 50px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }

        .tv-search-field .mud-input-slot {
            font-family: var(--font-body);
            font-weight: 700;
            color: var(--pal-dark-blue) !important;
            padding-left: 10px;
        }

        .tv-search-field .mud-icon-root {
            color: var(--pal-blue) !important;
        }

    /* --- TABS --- */
    .mud-tabs-tabbar {
        background: transparent !important;
    }

    .mud-tab {
        font-family: var(--font-header) !important;
        font-size: 1.5rem !important;
        letter-spacing: 1px;
        color: #adb5bd !important;
        text-transform: uppercase;
    }

    .mud-tab-active {
        color: var(--pal-blue) !important;
        text-shadow: 0 0 1px rgba(2, 62, 138, 0.5);
    }

    .mud-tabs-indicator {
        background-color: var(--pal-gold) !important;
        height: 4px;
        border-radius: 4px;
    }

    /* --- SPORT SECTION --- */
    .sport-section {
        margin-bottom: 40px;
        background: white;
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        border: 1px solid #e9ecef;
    }

    .sport-title-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 2px solid var(--pal-gold);
        gap: 12px;
    }

    .sport-name {
        font-family: var(--font-header);
        font-size: 1.8rem;
        color: var(--pal-dark-blue);
        display: flex;
        align-items: center;
        gap: 10px;
        letter-spacing: 1px;
        min-width: 0;
    }

    /* --- CARD (same tv-card style) --- */
    .event-link {
        text-decoration: none;
        display: block;
        height: 100%;
    }

    .tv-card {
        background-color: white;
        border: 1px solid #dee2e6;
        border-top: 5px solid var(--pal-blue);
        border-radius: 15px;
        padding: 15px;
        position: relative;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

        .tv-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.15);
            border-top-color: var(--pal-gold);
        }

    .card-status-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
        border-bottom: 1px solid #f1f1f1;
        padding-bottom: 8px;
        gap: 10px;
    }

    .live-badge {
        font-family: var(--font-subheader);
        font-weight: 800;
        font-size: 0.75rem;
        padding: 3px 12px;
        background: var(--pal-red);
        color: white;
        border-radius: 20px;
        letter-spacing: 1px;
        box-shadow: 0 2px 5px rgba(234, 0, 0, 0.3);
        white-space: nowrap;
    }

    .final-badge {
        font-family: var(--font-subheader);
        font-weight: 800;
        font-size: 0.75rem;
        padding: 3px 12px;
        background: #343a40;
        color: white;
        border-radius: 20px;
        letter-spacing: 1px;
        white-space: nowrap;
    }

    .phase-text {
        font-family: var(--font-subheader);
        color: #6c757d;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 70%;
        text-align: right;
        margin-left: auto;
    }

    .card-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 10px;
    }

    .icon-circle {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: #fff;
        border: 2px solid #e9ecef;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 3px 8px rgba(0,0,0,0.06);
        flex: 0 0 auto;
    }

    .title-block {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
        width: 100%;
    }

    .evt-title {
        font-family: var(--font-subheader);
        font-size: 1.05rem;
        font-weight: 900;
        color: var(--pal-dark-blue);
        text-transform: uppercase;
        letter-spacing: .5px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .evt-sub {
        font-family: var(--font-body);
        font-weight: 800;
        color: #6b7280;
        font-size: 0.85rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .divider {
        height: 1px;
        background: #f0f0f0;
        margin: 12px 0;
    }

    /* Chess preview board (aligned to new style) */
    .board-preview {
        display: flex;
        justify-content: center;
        margin-top: 8px;
    }

    .mini-board {
        display: grid;
        grid-template-columns: repeat(8, 1fr);
        grid-template-rows: repeat(8, 1fr);
        width: 132px;
        height: 132px;
        border-radius: 14px;
        overflow: hidden;
        border: 2px solid rgba(2, 62, 138, 0.22);
        box-shadow: 0 10px 22px rgba(0,0,0,0.06);
    }

    .board-square {
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
    }

    .board-square-white {
        background: rgba(2, 62, 138, 0.06);
    }

    .board-square-black {
        background: rgba(0, 24, 69, 0.16);
    }

    .meta-row {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 10px;
        width: 100%;
    }

    .meta-badge {
        display: inline-flex;
        align-items: center;
        padding: 4px 10px;
        border-radius: 999px;
        background: rgba(2, 62, 138, 0.08);
        border: 1px solid rgba(2, 62, 138, 0.18);
        color: var(--pal-blue);
        font-family: var(--font-subheader);
        font-weight: 900;
        font-size: 0.75rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .card-footer {
        text-align: center;
        margin-top: 12px;
        color: #6c757d;
        font-family: var(--font-subheader);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        border-top: 1px solid #f1f1f1;
        padding-top: 8px;
    }

    .panel-state {
        text-align: center;
        padding: 52px 18px;
        color: #999;
        border: 2px dashed rgba(2, 62, 138, 0.18);
        border-radius: 22px;
        background: rgba(255,255,255,0.6);
        margin-top: 10px;
    }

    .panel-title {
        font-family: var(--font-header);
        font-size: 1.6rem;
        color: var(--pal-dark-blue);
        text-transform: uppercase;
        margin-top: 10px;
    }

    .panel-sub {
        font-family: var(--font-body);
        font-weight: 700;
        color: #777;
        margin-top: 8px;
    }

    .loading-spinner {
        color: var(--pal-blue);
    }

    @@media (max-width: 600px) {
        .header-pill {
            padding: 18px 20px;
        }

        .mini-board {
            width: 124px;
            height: 124px;
        }
    }
</style>

<div class="tv-screen-bg">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge">

        <!-- HEADER -->
        <div class="dashboard-header">
            <div class="header-pill">
                <h1 class="main-event-title">CHESS</h1>
                <div class="sub-header-text">OFFICIAL DASHBOARD</div>
            </div>
        </div>

   

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="mt-16">
                <MudProgressCircular Indeterminate="true" Class="loading-spinner" Size="Size.Large" />
                <MudText Typo="Typo.h6" Class="mt-4" Style="font-family:var(--font-header); color:var(--pal-blue);">
                    INITIALIZING SYSTEM...
                </MudText>
            </MudStack>
        }
        else if (!_chessEvents.Any())
        {
            <MudPaper Class="pa-16 d-flex flex-column align-center justify-center mt-8"
                      Style="background-color:white; border-radius:20px; box-shadow:0 4px 10px rgba(0,0,0,0.05);">
                <MudIcon Icon="@Icons.Material.Filled.SportsEsports" Size="Size.Large" Style="color:#dee2e6; width:80px; height:80px;" />
                <MudText Typo="Typo.h5" Class="mt-4" Style="color:#adb5bd; font-family:var(--font-header)">
                    NO CHESS EVENTS
                </MudText>
                <MudText Style="color:#9aa0a6; font-family:var(--font-body); font-weight:700;">
                    Waiting for event data to be available.
                </MudText>
            </MudPaper>
        }
        else
        {
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="mt-4" Centered="true">

                <!-- LIVE -->
                <MudTabPanel Text="LIVE MATCHES">
                    @{
                        var liveEvents = _chessEvents
                        .Where(e => e.IsFinished != true)
                        .Where(e => FilterFunction(e))
                        .ToList();
                    }

                    @if (!liveEvents.Any())
                    {
                        <MudPaper Class="pa-16 d-flex flex-column align-center justify-center mt-8"
                                  Style="background-color:white; border-radius:20px; box-shadow:0 4px 10px rgba(0,0,0,0.05);">
                            <MudIcon Icon="@Icons.Material.Filled.HistoryToggleOff" Size="Size.Large" Style="color:#dee2e6; width:80px; height:80px;" />
                            <MudText Typo="Typo.h5" Class="mt-4" Style="color:#adb5bd; font-family:var(--font-header)">
                                @(_searchString == "" ? "NO LIVE MATCHES" : "NO MATCHES FOUND")
                            </MudText>
                        </MudPaper>
                    }
                    else
                    {
                        @foreach (var group in liveEvents.GroupBy(e => $"{(e.Gender ?? "Mixed")} • {(e.Subcategory ?? "Classical")}"))
                        {
                            <div class="sport-section">
                                <div class="sport-title-row">
                                    <div class="sport-name" title="@group.Key" style="width:100%">
                                        <MudIcon Icon="@Icons.Material.Filled.SportsEsports" Style="color: var(--pal-gold);" />
                                        <span style="min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@group.Key</span>
                                    </div>
                                </div>

                                <MudGrid Spacing="3">
                                    @foreach (var evt in group.OrderBy(x => x.Level).ThenBy(x => x.EventStage))
                                    {
                                        <MudItem xs="12" sm="6" lg="4" xl="3">
                                            <a href="@GetEventUrl(evt)" target="_blank" class="event-link">
                                                <div class="tv-card">

                                                    <div class="card-status-bar">
                                                        <div class="live-badge">LIVE</div>
                                                        <div class="phase-text">@($"{evt.Level ?? "OPEN"} ")</div>
                                                    </div>

                                                    <div class="card-header">
                                                        <div class="icon-circle">
                                                            <MudIcon Icon="@Icons.Material.Filled.PsychologyAlt" Style="color:var(--pal-blue)" />
                                                        </div>
                                                        <div class="title-block">
                                                            <div class="evt-title">@(evt.EventStage ?? "ROUND")</div>
                                                            <div class="evt-sub">@($"{evt.Subcategory ?? "Classical"} • {evt.Gender ?? "Mixed"}")</div>
                                                        </div>
                                                    </div>

                                                    <div class="divider"></div>

                                                  

                                                    <div class="board-preview">
                                                        <div class="mini-board">
                                                            @for (int i = 0; i < 64; i++)
                                                            {
                                                                int row = i / 8;
                                                                int col = i % 8;
                                                                bool isWhite = (row + col) % 2 == 0;

                                                                <div class="board-square @(isWhite ? "board-square-white" : "board-square-black")">
                                                                    @if ((row == 0 && col == 0) || (row == 7 && col == 7))
                                                                    {
                                                                        <MudIcon Icon="@Icons.Material.Filled.Circle" Size="Size.Small" Style="color: rgba(255,180,0,0.65);" />
                                                                    }
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>

                                                    <div class="card-footer">
                                                        VIEW EVENT
                                                    </div>
                                                </div>
                                            </a>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </div>
                        }
                    }
                </MudTabPanel>

                <!-- RESULTS -->
                <MudTabPanel Text="PARTIAL RESULTS">
                    @{
                        var finishedEvents = _chessEvents
                        .Where(e => e.IsFinished == true)
                        .Where(e => FilterFunction(e))
                        .ToList();
                    }

                    @if (!finishedEvents.Any())
                    {
                        <MudPaper Class="pa-16 d-flex flex-column align-center justify-center mt-8"
                                  Style="background-color:white; border-radius:20px; box-shadow:0 4px 10px rgba(0,0,0,0.05);">
                            <MudIcon Icon="@Icons.Material.Filled.HistoryToggleOff" Size="Size.Large" Style="color:#dee2e6; width:80px; height:80px;" />
                            <MudText Typo="Typo.h5" Class="mt-4" Style="color:#adb5bd; font-family:var(--font-header)">
                                @(_searchString == "" ? "NO RESULTS YET" : "NO MATCHES FOUND")
                            </MudText>
                        </MudPaper>
                    }
                    else
                    {
                        @foreach (var group in finishedEvents.GroupBy(e => $"{(e.Gender ?? "Mixed")} • {(e.Subcategory ?? "Classical")}"))
                        {
                            <div class="sport-section">
                                <div class="sport-title-row">
                                    <div class="sport-name" title="@group.Key" style="width:100%">
                                        <MudIcon Icon="@Icons.Material.Filled.MilitaryTech" Style="color: var(--pal-gold);" />
                                        <span style="min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@group.Key</span>
                                    </div>
                                </div>

                                <MudGrid Spacing="3">
                                    @foreach (var evt in group.OrderBy(x => x.Level).ThenBy(x => x.EventStage))
                                    {
                                        <MudItem xs="12" sm="6" lg="4" xl="3">
                                            <a href="@GetEventUrl(evt)" target="_blank" class="event-link">
                                                <div class="tv-card" style="border-top-color:#6c757d; opacity:.92;">

                                                    <div class="card-status-bar">
                                                        <div class="final-badge">FINAL</div>
                                                        <div class="phase-text">@($"{evt.Level ?? "OPEN"} • {GetChessFormat(evt.Subcategory)}")</div>
                                                    </div>

                                                    <div class="card-header">
                                                        <div class="icon-circle" style="border-color: rgba(0,0,0,.12);">
                                                            <MudIcon Icon="@Icons.Material.Filled.MilitaryTech" Style="color:#6c757d" />
                                                        </div>
                                                        <div class="title-block">
                                                            <div class="evt-title">@(evt.EventStage ?? "ROUND")</div>
                                                            <div class="evt-sub">@($"{evt.Subcategory ?? "Classical"} • {evt.Gender ?? "Mixed"}")</div>
                                                        </div>
                                                    </div>

                                                    <div class="divider"></div>

                                                    <div class="meta-row">
                                                        <span class="meta-badge">LEVEL: @(evt.Level ?? "OPEN")</span>
                                                        <span class="meta-badge">@GetChessFormat(evt.Subcategory)</span>
                                                    </div>

                                                    <div class="board-preview">
                                                        <div class="mini-board" style="border-color: rgba(108,117,125,0.35);">
                                                            @for (int i = 0; i < 64; i++)
                                                            {
                                                                int row = i / 8;
                                                                int col = i % 8;
                                                                bool isWhite = (row + col) % 2 == 0;

                                                                <div class="board-square @(isWhite ? "board-square-white" : "board-square-black")"></div>
                                                            }
                                                        </div>
                                                    </div>

                                                    <div class="card-footer">
                                                        VIEW RESULTS
                                                    </div>
                                                </div>
                                            </a>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </div>
                        }
                    }
                </MudTabPanel>

            </MudTabs>
        }

    </MudContainer>
</div>

@code {
    public class EventsDTO
    {
        public class EventDetails
        {
            public class Event
            {
                public string ID { get; set; } = null!;
                public string? EventStage { get; set; }
                public List<EventVersusTeams>? EventVersusList { get; set; }
                public string? SportMainCat { get; set; }
                public string? Category { get; set; }
                public string? Sport { get; set; }
                public string? GamePhase { get; set; }
                public int? SubCategoryID { get; set; }
                public string? Subcategory { get; set; }
                public string? Gender { get; set; }
                public string? Level { get; set; }
                public string? Venue { get; set; }
                public bool? IsFinished { get; set; }
            }

            public class EventVersusTeams
            {
                public int ID { get; set; }
                public string? Score { get; set; }
                public string? Region { get; set; }
                public string? Abbreviation { get; set; }
            }
        }
    }

    private string _searchString = "";
    private List<EventsDTO.EventDetails.Event> _chessEvents = new();
    private bool _isLoading = true;
    private Timer? _refreshTimer;

    private bool FilterFunction(EventsDTO.EventDetails.Event element)
    {
        if (string.IsNullOrWhiteSpace(_searchString)) return true;

        if (element.EventStage?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (element.Subcategory?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (element.Gender?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (element.Level?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true) return true;

        return false;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        _refreshTimer = new Timer(async _ => await InvokeAsync(LoadData), null, 5000, 5000);
    }

    private async Task LoadData()
    {
        try
        {
            var allEvents = await apiService.GetAsync<EventsDTO.EventDetails.Event>("/Events/Details");

            if (allEvents != null)
            {
                _chessEvents = allEvents
                    .Where(e => e.Sport != null && e.Sport.Equals("Chess", StringComparison.OrdinalIgnoreCase))
                    .OrderByDescending(x => x.IsFinished == false)
                    .ThenBy(x => x.Level)
                    .ThenBy(x => x.Gender)
                    .ThenBy(x => x.Subcategory)
                    .ThenBy(x => x.EventStage)
                    .ToList();
            }
            else
            {
                _chessEvents = new();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading chess events: {ex.Message}");
            Snackbar.Add($"Error loading events: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private string GetChessFormat(string? subcategory)
    {
        if (string.IsNullOrEmpty(subcategory)) return "Classical";
        var s = subcategory.ToLower();
        if (s.Contains("rapid")) return "Rapid";
        if (s.Contains("blitz")) return "Blitz";
        if (s.Contains("bullet")) return "Bullet";
        if (s.Contains("team")) return "Team";
        if (s.Contains("individual")) return "Individual";
        return "Classical";
    }

    private string GetEventUrl(EventsDTO.EventDetails.Event evt)
    {
        if (evt == null) return "#";
        return $"/scoreboard/chess/{evt.ID}";
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
        _refreshTimer = null;
    }
}