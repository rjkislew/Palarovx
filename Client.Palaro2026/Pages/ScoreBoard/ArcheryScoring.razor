@page "/scoreboard/archery"
@using System.Threading
@using System.Linq
@using Client.Palaro2026.Services
@inject APIService apiService
@inject NavigationManager Navigation
@implements IDisposable
@layout NoMainLayout

<PageTitle>Archery Dashboard | Palaro tu AgSur 2026</PageTitle>

<style>
    /* --- THEME IMPORTS (MATCHING TEAMMATCH-LIVE) --- */
    @@import url('https://fonts.cdnfonts.com/css/evil-empire');
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&family=Chakra+Petch:wght@600;700;800&display=swap');

    :root {
        /* PALARO COLOR PALETTE */
        --pal-blue: #023E8A;
        --pal-dark-blue: #001845;
        --pal-gold: #FFB400;
        --pal-red: #EA0000;
        --pal-white: #ffffff;
        /* LIGHT THEME VARS */
        --bg-gradient-start: #f8f9fa;
        --card-bg: rgba(255, 255, 255, 0.95);
        /* FONTS */
        --font-header: 'Evil Empire', sans-serif;
        --font-subheader: 'Chakra Petch', sans-serif;
        --font-body: 'Nunito', sans-serif;
    }

    ::-webkit-scrollbar {
        width: 8px;
    }

    ::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    ::-webkit-scrollbar-thumb {
        background: #ccc;
        border-radius: 4px;
    }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--pal-blue);
        }

    body {
        background-color: var(--bg-gradient-start);
        margin: 0;
        font-family: var(--font-body);
        overflow-x: hidden;
    }

    .tv-screen-bg {
        min-height: 100vh;
        width: 100vw;
        background: radial-gradient(circle at 50% 30%, #ffffff 0%, #e0e7ff 100%);
        padding-bottom: 50px;
    }

    /* --- HEADER (PILL STYLE) --- */
    .dashboard-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin: 10px 0 30px 0;
    }

    .header-pill {
        background: var(--pal-dark-blue);
        border: 3px solid var(--pal-gold);
        padding: 20px 60px;
        border-radius: 50px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    .main-event-title {
        font-family: var(--font-header);
        color: white;
        font-size: clamp(2rem, 4vw, 3.5rem);
        letter-spacing: 2px;
        margin: 0;
        line-height: 1;
        text-shadow: 2px 2px 0px black;
    }

    .sub-header-text {
        font-family: var(--font-subheader);
        color: var(--pal-gold);
        font-size: 1.1rem;
        letter-spacing: 3px;
        font-weight: 700;
        text-transform: uppercase;
        margin-top: 5px;
    }

    /* --- SEARCH BAR --- */
    .search-wrapper {
        display: flex;
        justify-content: center;
        margin-bottom: 30px;
        padding: 0 20px;
    }

    .tv-search-field {
        width: 100%;
        max-width: 600px;
    }

        .tv-search-field .mud-input-control-input-container {
            background-color: white !important;
            border-radius: 50px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }

        .tv-search-field .mud-input-slot {
            font-family: var(--font-body);
            font-weight: 700;
            color: var(--pal-dark-blue) !important;
            padding-left: 10px;
        }

        .tv-search-field .mud-icon-root {
            color: var(--pal-blue) !important;
        }

    /* --- TABS --- */
    .mud-tabs-tabbar {
        background: transparent !important;
    }

    .mud-tab {
        font-family: var(--font-header) !important;
        font-size: 1.5rem !important;
        letter-spacing: 1px;
        color: #adb5bd !important;
        text-transform: uppercase;
    }

    .mud-tab-active {
        color: var(--pal-blue) !important;
        text-shadow: 0 0 1px rgba(2, 62, 138, 0.5);
    }

    .mud-tabs-indicator {
        background-color: var(--pal-gold) !important;
        height: 4px;
        border-radius: 4px;
    }

    /* --- SECTION --- */
    .sport-section {
        margin-bottom: 40px;
        background: white;
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        border: 1px solid #e9ecef;
    }

    .sport-title-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 2px solid var(--pal-gold);
        gap: 12px;
    }

    .sport-name {
        font-family: var(--font-header);
        font-size: 1.6rem;
        color: var(--pal-dark-blue);
        display: flex;
        align-items: center;
        gap: 10px;
        letter-spacing: 1px;
        min-width: 0;
    }

    /* --- CARD --- */
    .match-link {
        text-decoration: none;
        display: block;
        height: 100%;
    }

    .tv-card {
        background-color: white;
        border: 1px solid #dee2e6;
        border-top: 5px solid var(--pal-blue);
        border-radius: 15px;
        padding: 15px;
        position: relative;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

        .tv-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.15);
            border-top-color: var(--pal-gold);
        }

    .card-status-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
        border-bottom: 1px solid #f1f1f1;
        padding-bottom: 8px;
        gap: 10px;
    }

    .live-badge {
        font-family: var(--font-subheader);
        font-weight: 800;
        font-size: 0.75rem;
        padding: 3px 12px;
        background: var(--pal-red);
        color: white;
        border-radius: 20px;
        letter-spacing: 1px;
        box-shadow: 0 2px 5px rgba(234, 0, 0, 0.3);
        white-space: nowrap;
    }

    .final-badge {
        font-family: var(--font-subheader);
        font-weight: 800;
        font-size: 0.75rem;
        padding: 3px 12px;
        background: #343a40;
        color: white;
        border-radius: 20px;
        letter-spacing: 1px;
        white-space: nowrap;
    }

    .phase-text {
        font-family: var(--font-subheader);
        color: #6c757d;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 70%;
        text-align: right;
        margin-left: auto;
    }

    .card-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-grow: 1;
        gap: 8px;
    }

    .team-col {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        flex: 1;
        text-align: center;
        min-width: 0;
    }

    /* --- LOGO CIRCLE (replaces score) --- */
    .logo-box {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: white;
        border: 2px solid #e9ecef;
        padding: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 3px 8px rgba(0,0,0,0.06);
    }

    .winner-border {
        border-color: var(--pal-gold);
        box-shadow: 0 0 12px rgba(255, 180, 0, 0.35);
    }

    .abbr {
        margin-top: 8px;
        font-family: var(--font-subheader);
        font-weight: 900;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: var(--pal-blue);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 100%;
    }

    .winner-text {
        color: var(--pal-dark-blue) !important;
        transform: scale(1.05);
        text-shadow: 0 0 1px rgba(0,0,0,0.10);
    }

    .vs-col {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: 30px;
        flex: 0 0 auto;
    }

    .vs-text {
        font-family: var(--font-subheader);
        font-size: 1rem;
        font-weight: 900;
        font-style: italic;
        color: #adb5bd;
        white-space: nowrap;
    }

    .card-footer {
        text-align: center;
        margin-top: 12px;
        color: #6c757d;
        font-family: var(--font-subheader);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        border-top: 1px solid #f1f1f1;
        padding-top: 8px;
    }

    .loading-spinner {
        color: var(--pal-blue);
    }

    @@media (max-width: 600px) {
        .header-pill {
            padding: 18px 20px;
        }

        .logo-box {
            width: 58px;
            height: 58px;
        }
    }
</style>

<div class="tv-screen-bg">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge">

        <!-- HEADER -->
        <div class="dashboard-header">
            <div class="header-pill">
                <h1 class="main-event-title">ARCHERY</h1>
                <div class="sub-header-text">OFFICIAL DASHBOARD</div>
            </div>
        </div>


        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="mt-16">
                <MudProgressCircular Indeterminate="true" Class="loading-spinner" Size="Size.Large" />
                <MudText Typo="Typo.h6" Class="mt-4" Style="font-family:var(--font-header); color:var(--pal-blue);">
                    INITIALIZING SYSTEM...
                </MudText>
            </MudStack>
        }
        else
        {
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="mt-4" Centered="true">

                <!-- LIVE MATCHES -->
                <MudTabPanel Text="LIVE MATCHES">
                    @{
                        var matchPlay = _archeryEvents
                        .Where(e => e.IsFinished != true && IsOlympic(e))
                        .Where(e => FilterFunction(e))
                        .ToList();
                    }

                    @if (!matchPlay.Any())
                    {
                        <MudPaper Class="pa-16 d-flex flex-column align-center justify-center mt-8"
                                  Style="background-color:white; border-radius:20px; box-shadow:0 4px 10px rgba(0,0,0,0.05);">
                            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Style="color:#dee2e6; width:80px; height:80px;" />
                            <MudText Typo="Typo.h5" Class="mt-4" Style="color:#adb5bd; font-family:var(--font-header)">
                                @(_searchString == "" ? "NO LIVE EVENTS" : "NO MATCHES FOUND")
                            </MudText>
                        </MudPaper>
                    }
                    else
                    {
                        @foreach (var group in matchPlay.GroupBy(e => $"{e.Gender} • {e.EventStage}"))
                        {
                            <div class="sport-section">
                                <div class="sport-title-row">
                                    <div class="sport-name" title="@group.Key" style="width:100%">
                                        <MudIcon Icon="@Icons.Material.Filled.CenterFocusStrong" Style="color: var(--pal-gold);" />
                                        <span style="min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@group.Key</span>
                                    </div>
                                </div>

                                <MudGrid Spacing="3">
                                    @foreach (var evt in group)
                                    {
                                        @if (evt.EventVersusList != null && evt.EventVersusList.Any())
                                        {
                                            int totalArchers = evt.EventVersusList.Count;
                                            int pairs = (int)Math.Ceiling(totalArchers / 2.0);

                                            for (int i = 0; i < pairs; i++)
                                            {
                                                var archerA = evt.EventVersusList.ElementAtOrDefault(i * 2);
                                                var archerB = evt.EventVersusList.ElementAtOrDefault(i * 2 + 1);

                                                int scoreA = GetScore(evt.ID, archerA?.Region);
                                                int scoreB = GetScore(evt.ID, archerB?.Region);

                                                bool leadA = scoreA > scoreB;
                                                bool leadB = scoreB > scoreA;

                                                <MudItem xs="12" sm="6" lg="4" xl="3">
                                                    <a href="/scoreboard/archery/@evt.ID?pair=@i" target="_blank" class="match-link">
                                                        <div class="tv-card">
                                                            <div class="card-status-bar">
                                                                <div class="live-badge">LIVE</div>
                                                                <div class="phase-text">@((evt.Level ?? "OPEN").ToUpper())</div>
                                                            </div>

                                                            <div class="card-content">
                                                                <div class="team-col">
                                                                    <div class="logo-box @(leadA ? "winner-border" : "")"
                                                                         style="@(archerA == null ? "opacity:.55; filter:grayscale(1);" : "")">
                                                                        @if (archerA == null || string.IsNullOrWhiteSpace(archerA.Region))
                                                                        {
                                                                            <MudIcon Icon="@Icons.Material.Filled.PersonOff" Style="color:#adb5bd;" />
                                                                        }
                                                                        else
                                                                        {
                                                                            <MudImage Src="@($"https://palarongpambansa2026.com/attachments/media/regions/team_logo/{archerA.Region}.webp")"
                                                                                      ObjectFit="ObjectFit.Contain"
                                                                                      Style="width:90%; height:90%;" />
                                                                        }
                                                                    </div>
                                                                    <div class="abbr @(leadA ? "winner-text" : "")" style="@(archerA == null ? "color:#adb5bd;" : "")">
                                                                        @(archerA?.Abbreviation ?? "BYE")
                                                                    </div>
                                                                </div>

                                                                <div class="vs-col">
                                                                    <div class="vs-text">VS</div>
                                                                </div>

                                                                <div class="team-col">
                                                                    <div class="logo-box @(leadB ? "winner-border" : "")"
                                                                         style="@(archerB == null ? "opacity:.55; filter:grayscale(1);" : "")">
                                                                        @if (archerB == null || string.IsNullOrWhiteSpace(archerB.Region))
                                                                        {
                                                                            <MudIcon Icon="@Icons.Material.Filled.PersonOff" Style="color:#adb5bd;" />
                                                                        }
                                                                        else
                                                                        {
                                                                            <MudImage Src="@($"https://palarongpambansa2026.com/attachments/media/regions/team_logo/{archerB.Region}.webp")"
                                                                                      ObjectFit="ObjectFit.Contain"
                                                                                      Style="width:90%; height:90%;" />
                                                                        }
                                                                    </div>
                                                                    <div class="abbr @(leadB ? "winner-text" : "")" style="@(archerB == null ? "color:#adb5bd;" : "")">
                                                                        @(archerB?.Abbreviation ?? "BYE")
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            <div class="card-footer">
                                                                @((evt.SportMainCat ?? "MATCH PLAY").ToUpper()) • PAIR @(i + 1)
                                                            </div>
                                                        </div>
                                                    </a>
                                                </MudItem>
                                            }
                                        }
                                    }
                                </MudGrid>
                            </div>
                        }
                    }
                </MudTabPanel>

                <!-- QUALIFYING / 1440 -->
                <MudTabPanel Text="QUALIFYING / 1440">
                    @{
                        var rankingEvents = _archeryEvents
                        .Where(e => e.IsFinished != true && !IsOlympic(e))
                        .Where(e => FilterFunction(e))
                        .ToList();
                    }

                    @if (!rankingEvents.Any())
                    {
                        <MudPaper Class="pa-16 d-flex flex-column align-center justify-center mt-8"
                                  Style="background-color:white; border-radius:20px; box-shadow:0 4px 10px rgba(0,0,0,0.05);">
                            <MudIcon Icon="@Icons.Material.Filled.Scoreboard" Size="Size.Large" Style="color:#dee2e6; width:80px; height:80px;" />
                            <MudText Typo="Typo.h5" Class="mt-4" Style="color:#adb5bd; font-family:var(--font-header)">
                                @(_searchString == "" ? "NO LIVE QUALIFYING" : "NO EVENTS FOUND")
                            </MudText>
                        </MudPaper>
                    }
                    else
                    {
                        @foreach (var group in rankingEvents.GroupBy(e => $"{e.Gender} • Target {e.Subcategory}"))
                        {
                            <div class="sport-section">
                                <div class="sport-title-row">
                                    <div class="sport-name" title="@group.Key" style="width:100%">
                                        <MudIcon Icon="@Icons.Material.Filled.Scoreboard" Style="color: var(--pal-gold);" />
                                        <span style="min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@group.Key</span>
                                    </div>
                                </div>

                                <MudGrid Spacing="3">
                                    @foreach (var evt in group)
                                    {
                                        <MudItem xs="12" sm="6" lg="4" xl="3">
                                            <a href="/scoreboard/archery/@evt.ID" target="_blank" class="match-link">
                                                <div class="tv-card">
                                                    <div class="card-status-bar">
                                                        <div class="live-badge">LIVE</div>
                                                        <div class="phase-text">@((evt.Level ?? "OPEN").ToUpper())</div>
                                                    </div>

                                                    <MudText Typo="Typo.subtitle2"
                                                             Style="font-family:var(--font-subheader); font-weight:900; color:var(--pal-dark-blue); text-transform:uppercase;">
                                                        @((evt.SportMainCat ?? "RANKING").ToUpper())
                                                    </MudText>

                                                    <MudText Typo="Typo.body2" Style="color:#6c757d; font-weight:800;">
                                                        @(evt.Gender ?? "MIXED") • Target @(evt.Subcategory ?? "-")
                                                    </MudText>

                                                    <div class="card-footer">
                                                        VIEW RANKINGS
                                                    </div>
                                                </div>
                                            </a>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </div>
                        }
                    }
                </MudTabPanel>

                <!-- PARTIAL RESULTS -->
                <MudTabPanel Text="PARTIAL RESULTS">
                    @{
                        var finished = _archeryEvents
                        .Where(e => e.IsFinished == true)
                        .Where(e => FilterFunction(e))
                        .ToList();
                    }

                    @if (!finished.Any())
                    {
                        <MudPaper Class="pa-16 d-flex flex-column align-center justify-center mt-8"
                                  Style="background-color:white; border-radius:20px; box-shadow:0 4px 10px rgba(0,0,0,0.05);">
                            <MudIcon Icon="@Icons.Material.Filled.HistoryToggleOff" Size="Size.Large" Style="color:#dee2e6; width:80px; height:80px;" />
                            <MudText Typo="Typo.h5" Class="mt-4" Style="color:#adb5bd; font-family:var(--font-header)">
                                @(_searchString == "" ? "NO RESULTS" : "NO EVENTS FOUND")
                            </MudText>
                        </MudPaper>
                    }
                    else
                    {
                        @foreach (var group in finished.GroupBy(e => $"{e.Gender} • {e.EventStage ?? "RESULTS"}"))
                        {
                            <div class="sport-section">
                                <div class="sport-title-row">
                                    <div class="sport-name" title="@group.Key" style="width:100%">
                                        <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Style="color: var(--pal-gold);" />
                                        <span style="min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@group.Key</span>
                                    </div>
                                </div>

                                <MudGrid Spacing="3">
                                    @foreach (var evt in group)
                                    {
                                        bool isMatch = IsOlympic(evt) && evt.EventVersusList != null && evt.EventVersusList.Any();

                                        if (isMatch)
                                        {
                                            int pairs = (int)Math.Ceiling(evt.EventVersusList!.Count / 2.0);

                                            for (int i = 0; i < pairs; i++)
                                            {
                                                var archerA = evt.EventVersusList.ElementAtOrDefault(i * 2);
                                                var archerB = evt.EventVersusList.ElementAtOrDefault(i * 2 + 1);

                                                int scoreA = GetScore(evt.ID, archerA?.Region);
                                                int scoreB = GetScore(evt.ID, archerB?.Region);

                                                bool winA = scoreA > scoreB;
                                                bool winB = scoreB > scoreA;

                                                <MudItem xs="12" sm="6" lg="4" xl="3">
                                                    <a href="/scoreboard/archery/@evt.ID?pair=@i" target="_blank" class="match-link">
                                                        <div class="tv-card" style="border-top-color:#6c757d; opacity:.92;">
                                                            <div class="card-status-bar">
                                                                <div class="final-badge">FINAL</div>
                                                                <div class="phase-text">@($"{(evt.Level ?? "OPEN").ToUpper()} • Target {evt.Subcategory}")</div>
                                                            </div>

                                                            <div class="card-content">
                                                                <div class="team-col">
                                                                    <div class="logo-box @(winA ? "winner-border" : "")"
                                                                         style="@(!winA ? "filter:grayscale(1); opacity:.6" : "")">
                                                                        @if (archerA == null || string.IsNullOrWhiteSpace(archerA.Region))
                                                                        {
                                                                            <MudIcon Icon="@Icons.Material.Filled.PersonOff" Style="color:#adb5bd;" />
                                                                        }
                                                                        else
                                                                        {
                                                                            <MudImage Src="@($"https://palarongpambansa2026.com/attachments/media/regions/team_logo/{archerA.Region}.webp")"
                                                                                      ObjectFit="ObjectFit.Contain"
                                                                                      Style="width:90%; height:90%;" />
                                                                        }
                                                                    </div>
                                                                    <div class="abbr @(winA ? "winner-text" : "")" style="@(!winA ? "color:#adb5bd" : "")">
                                                                        @(archerA?.Abbreviation ?? "BYE")
                                                                    </div>
                                                                </div>

                                                                <div class="vs-col"><div class="vs-text">VS</div></div>

                                                                <div class="team-col">
                                                                    <div class="logo-box @(winB ? "winner-border" : "")"
                                                                         style="@(!winB ? "filter:grayscale(1); opacity:.6" : "")">
                                                                        @if (archerB == null || string.IsNullOrWhiteSpace(archerB.Region))
                                                                        {
                                                                            <MudIcon Icon="@Icons.Material.Filled.PersonOff" Style="color:#adb5bd;" />
                                                                        }
                                                                        else
                                                                        {
                                                                            <MudImage Src="@($"https://palarongpambansa2026.com/attachments/media/regions/team_logo/{archerB.Region}.webp")"
                                                                                      ObjectFit="ObjectFit.Contain"
                                                                                      Style="width:90%; height:90%;" />
                                                                        }
                                                                    </div>
                                                                    <div class="abbr @(winB ? "winner-text" : "")" style="@(!winB ? "color:#adb5bd" : "")">
                                                                        @(archerB?.Abbreviation ?? "BYE")
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            <div class="card-footer">
                                                                FINAL • PAIR @(i + 1)
                                                            </div>
                                                        </div>
                                                    </a>
                                                </MudItem>
                                            }
                                        }
                                        else
                                        {
                                            <MudItem xs="12" sm="6" lg="4" xl="3">
                                                <a href="/scoreboard/archery/@evt.ID" target="_blank" class="match-link">
                                                    <div class="tv-card" style="border-top-color:#6c757d; opacity:.92;">
                                                        <div class="card-status-bar">
                                                            <div class="final-badge">FINAL</div>
                                                            <div class="phase-text">@((evt.Level ?? "OPEN").ToUpper())</div>
                                                        </div>

                                                        <MudText Typo="Typo.subtitle2"
