            </HeaderContent>

                    <RowTemplate>
                @{
                            var standing = context;
                            var rankClass = standing.Rank switch
                            {
                                1 => "rank-1",
                                2 => "rank-2",
                                3 => "rank-3",
                                _ => ""
                            };
                        }

                        <MudTd>
                            @if (standing.MatchesWon > 0 || standing.SetsWon > 0)
                            {
                                <span class="rank-pill @rankClass">#@standing.Rank</span>
