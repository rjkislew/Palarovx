@page "/score/martialarts/{EventID}"
@using System.Threading
@using System.Linq
@using Client.Palaro2026.Services
@inject APIService apiService
@inject NavigationManager Navigation
@implements IDisposable
@layout ClientLayout

<PageTitle>Martial Arts | Palaro tu AgSur 2026</PageTitle>

<style>
    @@import url('https://fonts.cdnfonts.com/css/evil-empire');
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&family=Chakra+Petch:wght@600;700;800&display=swap');

    :root {
        --pal-blue: #023E8A;
        --pal-dark-blue: #001845;
        --pal-gold: #FFB400;
        --pal-red: #EA0000;
        --pal-white: #ffffff;
        --font-header: 'Evil Empire', sans-serif;
        --font-subheader: 'Chakra Petch', sans-serif;
        --font-body: 'Nunito', sans-serif;
    }

    body {
        background: #f8f9fa;
        margin: 0;
        font-family: var(--font-body);
        overflow-x: hidden;
    }

    /* ===== SAME TV BACKGROUND AS FIELD EVENTS ===== */
    .tv-screen-bg {
        min-height: 100vh;
        width: 100vw;
        background: radial-gradient(circle at 50% 30%, #ffffff 0%, #e0e7ff 100%);
        padding: 22px 0 14vh 0;
        position: relative;
    }

    .back-button {
        position: fixed;
        top: 16px;
        left: 16px;
        z-index: 3000;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: white;
        color: var(--pal-dark-blue);
        border: 2px solid #e9ecef;
        padding: 10px 14px;
        border-radius: 999px;
        cursor: pointer;
        font-family: var(--font-subheader);
        font-weight: 900;
        letter-spacing: 1px;
        text-transform: uppercase;
        box-shadow: 0 6px 18px rgba(0,0,0,0.08);
        transition: all .2s ease;
    }

        .back-button:hover {
            border-color: var(--pal-gold);
            box-shadow: 0 10px 25px rgba(0,0,0,0.12);
            transform: translateY(-1px);
        }

    /* ===== HEADER PILL (MATCH FIELD EVENTS) ===== */
    .dashboard-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin: 0px 0 16px 0;
    }

    .header-pill {
        background: var(--pal-dark-blue);
        border: 3px solid var(--pal-gold);
        padding: 20px 60px;
        border-radius: 50px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        max-width: calc(100% - 40px);
    }

    .main-event-title {
        font-family: var(--font-header);
        color: white;
        font-size: clamp(2rem, 4vw, 3.5rem);
        letter-spacing: 2px;
        margin: 0;
        line-height: 1;
        text-shadow: 2px 2px 0px black;
        text-transform: uppercase;
    }

    .sub-header-text {
        font-family: var(--font-subheader);
        color: var(--pal-gold);
        font-size: 1.05rem;
        letter-spacing: 3px;
        font-weight: 800;
        text-transform: uppercase;
        margin-top: 6px;
        opacity: 0.95;
    }

    /* ===== TOP INFO CARD (MATCH FIELD EVENTS) ===== */
    .top-info {
        width: min(1400px, calc(100% - 40px));
        margin: 18px auto;
        background: white;
        border-radius: 20px;
        border: 1px solid #e9ecef;
        box-shadow: 0 8px 18px rgba(0,0,0,0.06);
        overflow: hidden;
    }

    .top-info-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        padding: 14px 16px;
        border-bottom: 1px solid #f1f1f1;
        background: #fbfbfd;
        flex-wrap: wrap;
    }

    .badge-live, .badge-final {
        font-family: var(--font-subheader);
        font-weight: 900;
        font-size: 0.78rem;
        padding: 4px 12px;
        color: white;
        border-radius: 999px;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .badge-live {
        background: var(--pal-red);
    }

    .badge-final {
        background: #343a40;
    }

    .pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-family: var(--font-subheader);
        font-weight: 900;
        font-size: 0.78rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #6c757d;
        padding: 6px 12px;
        border-radius: 999px;
        background: white;
        border: 1px solid #e9ecef;
        max-width: 100%;
    }

    .event-title-block {
        padding: 14px 16px 12px 16px;
    }

    .event-name {
        font-family: var(--font-header);
        font-size: 1.8rem;
        color: var(--pal-dark-blue);
        letter-spacing: 1px;
        text-transform: uppercase;
        line-height: 1.1;
        margin-bottom: 6px;
    }

    .event-sub {
        font-family: var(--font-subheader);
        color: #6c757d;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.9rem;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
    }

    .category-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 6px 12px;
        border-radius: 999px;
        font-family: var(--font-subheader);
        font-size: 0.78rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: white;
    }

    .category-team {
        background: var(--pal-blue);
    }

    .category-sparring {
        background: var(--pal-red);
    }

    .category-kata {
        background: linear-gradient(90deg, var(--pal-gold), var(--pal-blue));
    }

    .category-forms {
        background: #198754;
    }

    /* ===== RESULTS WRAP (MATCH FIELD EVENTS) ===== */
    .results-wrap {
        width: min(1400px, calc(100% - 40px));
        margin: 0 auto;
        background: white;
        border-radius: 20px;
        border: 1px solid #e9ecef;
        box-shadow: 0 8px 18px rgba(0,0,0,0.06);
        overflow: hidden;
    }

    .results-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 14px 16px;
        border-bottom: 2px solid var(--pal-gold);
        flex-wrap: wrap;
    }

    .results-title {
        font-family: var(--font-header);
        font-size: 1.6rem;
        color: var(--pal-dark-blue);
        text-transform: uppercase;
        letter-spacing: 1px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .results-note {
        font-family: var(--font-subheader);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #6c757d;
        font-size: 0.78rem;
    }

    /* ===== TABLE (MATCH FIELD EVENTS) ===== */
    .tv-table .mud-table-container {
        background: white !important;
    }

    .tv-table table {
        width: 100%;
    }

    .tv-table thead th {
        font-family: var(--font-subheader) !important;
        font-weight: 900 !important;
        text-transform: uppercase !important;
        letter-spacing: 1px !important;
        color: var(--pal-dark-blue) !important;
        background: #fbfbfd !important;
        border-bottom: 1px solid #f1f1f1 !important;
        padding-top: 14px !important;
        padding-bottom: 14px !important;
        font-size: 0.82rem !important;
        white-space: nowrap;
    }

    .tv-table tbody td {
        border-bottom: 1px solid #f1f1f1 !important;
        padding-top: 14px !important;
        padding-bottom: 14px !important;
    }

    /* ===== RANK PILL (MATCH FIELD EVENTS) ===== */
    .rank-pill {
        font-family: var(--font-subheader);
        font-weight: 900;
        border-radius: 999px;
        border: 2px solid #e9ecef;
        padding: 6px 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 64px;
        background: white;
        color: var(--pal-dark-blue);
    }

    .rank-1 {
        border-color: #FFD700;
        box-shadow: 0 0 0 3px rgba(255,215,0,0.18);
    }

    .rank-2 {
        border-color: #C0C0C0;
        box-shadow: 0 0 0 3px rgba(192,192,192,0.16);
    }

    .rank-3 {
        border-color: #CD7F32;
        box-shadow: 0 0 0 3px rgba(205,127,50,0.16);
    }

    /* ===== TEAM MATCH CARDS (RESTYLED TO MATCH FIELD EVENTS) ===== */
    .pairings-container {
        width: min(1400px, calc(100% - 40px));
        margin: 14px auto 0 auto;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(560px, 1fr));
        gap: 16px;
    }

    .pairing-card {
        background: white;
        border-radius: 20px;
        border: 1px solid #e9ecef;
        box-shadow: 0 8px 18px rgba(0,0,0,0.06);
        overflow: hidden;
    }

    .pairing-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        padding: 14px 16px;
        background: #fbfbfd;
        border-bottom: 1px solid #f1f1f1;
        font-family: var(--font-subheader);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--pal-dark-blue);
    }

    .match-status {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 900;
        letter-spacing: 1px;
        border: 1px solid #e9ecef;
        background: white;
        color: #6c757d;
        white-space: nowrap;
    }

    .status-active {
        background: rgba(255, 180, 0, 0.18);
        border-color: rgba(255, 180, 0, 0.35);
        color: var(--pal-dark-blue);
    }

    .status-completed {
        background: rgba(25, 135, 84, 0.15);
        border-color: rgba(25, 135, 84, 0.35);
        color: #198754;
    }

    .status-pending {
        background: #f8f9fa;
        color: #adb5bd;
    }

    .pairing-body {
        padding: 16px;
    }

    .match-vs-match {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 12px;
        align-items: center;
    }

    .vs-separator {
        font-family: var(--font-header);
        font-size: 1.4rem;
        color: var(--pal-red);
        text-transform: uppercase;
        letter-spacing: 2px;
        text-shadow: 1px 1px 0 #000;
    }

    .competitor-display {
        background: #ffffff;
        border: 1px solid #e9ecef;
        border-radius: 16px;
        padding: 14px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        min-height: 140px;
    }

    .winning-competitor {
        border-color: rgba(25,135,84,0.55);
        box-shadow: 0 0 0 3px rgba(25,135,84,0.10);
        background: rgba(25,135,84,0.06);
    }

    .losing-competitor {
        border-color: rgba(234,0,0,0.45);
        box-shadow: 0 0 0 3px rgba(234,0,0,0.08);
        background: rgba(234,0,0,0.05);
    }

    .competitor-logo {
        width: 54px;
        height: 54px;
        border-radius: 50%;
        background: white;
        border: 2px solid #e9ecef;
        padding: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 3px 6px rgba(0,0,0,0.05);
    }

        .competitor-logo img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

    .competitor-name {
        font-family: var(--font-subheader);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--pal-dark-blue);
        text-align: center;
        line-height: 1.1;
    }

    .competitor-player {
        font-family: var(--font-body);
        font-weight: 800;
        color: #6c757d;
        font-size: .9rem;
        text-align: center;
    }

    .competitor-score {
        font-family: var(--font-header);
        font-size: 2.2rem;
        color: var(--pal-dark-blue);
        line-height: 1;
        margin-top: 2px;
        text-shadow: 1px 1px 0 #000;
    }

    .sets-container {
        display: flex;
        justify-content: center;
        gap: 6px;
        flex-wrap: wrap;
        margin-top: 4px;
    }

    .set-indicator {
        width: 26px;
        height: 26px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-subheader);
        font-weight: 900;
        font-size: 0.8rem;
        border: 1px solid #e9ecef;
        background: white;
        color: #6c757d;
    }

    .set-won {
        background: rgba(25,135,84,0.18);
        border-color: rgba(25,135,84,0.35);
        color: #198754;
    }

    .set-lost {
        background: rgba(234,0,0,0.14);
        border-color: rgba(234,0,0,0.30);
        color: var(--pal-red);
    }

    .set-pending {
        background: #f8f9fa;
        color: #adb5bd;
    }

    .pairing-result {
        margin-top: 12px;
        text-align: center;
        font-family: var(--font-subheader);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        padding: 10px 12px;
        border-radius: 12px;
        border: 1px solid rgba(255,180,0,0.35);
        background: rgba(255,180,0,0.15);
        color: var(--pal-dark-blue);
    }

    .pairing-status {
        margin-top: 10px;
        text-align: center;
        font-family: var(--font-subheader);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #6c757d;
        font-size: 0.78rem;
    }

    .format-info {
        width: min(1400px, calc(100% - 40px));
        margin: 16px auto 0 auto;
        text-align: center;
        color: #6c757d;
        font-family: var(--font-subheader);
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        border-top: 1px solid #f1f1f1;
        padding-top: 12px;
        letter-spacing: 1px;
    }

    .region-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
    }

    .region-flag {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: white;
        border: 2px solid #e9ecef;
        padding: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 3px 6px rgba(0,0,0,0.05);
        flex: 0 0 auto;
    }

    .region-name {
        font-family: var(--font-subheader);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--pal-dark-blue);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 320px;
    }

    @@media (max-width: 900px) {
        .header-pill {
            padding: 18px 22px;
        }

        .pairings-container {
            grid-template-columns: 1fr;
        }

        .region-name {
            max-width: 220px;
        }
    }

    @@media (max-width: 600px) {
        .region-name {
            max-width: 160px;
        }

        .rank-pill {
            min-width: 56px;
            padding: 6px 10px;
        }

        .match-vs-match {
            grid-template-columns: 1fr;
        }

        .vs-separator {
            text-align: center;
        }
    }
</style>

<div class="tv-screen-bg">
    <button class="back-button" onclick="history.back()">← Back</button>

    @if (_isLoading)
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height:70vh;">
            <MudProgressCircular Indeterminate Color="Color.Primary" Size="Size.Large" />
            <MudText Typo="Typo.h6" Class="mt-4" Style="font-family:var(--font-header); color:var(--pal-blue);">
                LOADING MARTIAL ARTS...
            </MudText>
        </MudStack>
    }
    else if (_event == null)
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height:70vh;">
            <MudText Typo="Typo.h4" Style="font-family:var(--font-header); color: var(--pal-red);">
                EVENT NOT FOUND
            </MudText>
        </MudStack>
    }
    else
    {
        <div class="dashboard-header">
            <div class="header-pill">
                <h1 class="main-event-title">MARTIAL ARTS</h1>
                <div class="sub-header-text">
                    @_event.Level - @_event.Gender • @_event.Sport • @_event.EventStage
                </div>
            </div>
        </div>

     

        @if (IsTeamEvent)
        {
            <!-- TEAM MATCH CARDS -->
            <div class="pairings-container">
                @foreach (var match in GetActiveMatches())
                {
                    var redCompetitor = GetCompetitorAssignedToMatch(match.Id, "RegionA");
                    var blueCompetitor = GetCompetitorAssignedToMatch(match.Id, "RegionB");
                    var matchWinner = GetMatchWinner(match.Id);
                    var redSets = GetTotalSetsWon(match.Id, "RegionA");
                    var blueSets = GetTotalSetsWon(match.Id, "RegionB");

                    <div class="pairing-card">
                        <div class="pairing-header">
                            <div>
                                @if (!string.IsNullOrEmpty(_event.EventStage))
                                {
                                    <text>@_event.EventStage</text>
                                }
                                else
                                {
                                    <text>MATCH @match.Id</text>
                                }
                            </div>
                            <div class="match-status @GetMatchStatusClass(match.Id)">
                                @GetMatchStatus(match.Id)
                            </div>
                        </div>

                        <div class="pairing-body">
                            <div class="match-vs-match">
                                <!-- Red -->
                                <div class="competitor-display @(matchWinner == redCompetitor?.Name ? "winning-competitor" : matchWinner == blueCompetitor?.Name ? "losing-competitor" : "")">
                                    <div class="competitor-logo">
                                        <img src="@($"https://palarongpambansa2026.com/attachments/media/regions/team_logo/{redCompetitor?.Name.ToUpper()}.webp")"
                                             onerror="this.style.display='none'" />
                                    </div>

                                    <div class="competitor-name">
                                        @(redCompetitor?.Name ?? "TBD")
                                    </div>

                                    @if (!string.IsNullOrEmpty(redCompetitor?.PlayerName))
                                    {
                                        <div class="competitor-player">@redCompetitor.PlayerName</div>
                                    }

                                    <div class="competitor-score">@redSets</div>

                                    @if (redCompetitor != null && blueCompetitor != null)
                                    {
                                        <div class="sets-container">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                var setResult = GetSetResult(match.Id, i);
                                                <div class="set-indicator @(setResult == "RegionA" ? "set-won" : setResult == "RegionB" ? "set-lost" : "set-pending")">
                                                    @if (setResult == "RegionA")
                                                    {
                                                        <text>W</text>
                                                    }
                                                    else if (setResult == "RegionB")
                                                    {
                                                        <text>L</text>
                                                    }
                                                    else
                                                    {
                                                        <text>@i</text>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>

                                <div class="vs-separator">VS</div>

                                <!-- Blue -->
                                <div class="competitor-display @(matchWinner == blueCompetitor?.Name ? "winning-competitor" : matchWinner == redCompetitor?.Name ? "losing-competitor" : "")">
                                    <div class="competitor-logo">
                                        <img src="@($"https://palarongpambansa2026.com/attachments/media/regions/team_logo/{blueCompetitor?.Name.ToUpper()}.webp")"
                                             onerror="this.style.display='none'" />
                                    </div>

                                    <div class="competitor-name">
                                        @(blueCompetitor?.Name ?? "TBD")
                                    </div>

                                    @if (!string.IsNullOrEmpty(blueCompetitor?.PlayerName))
                                    {
                                        <div class="competitor-player">@blueCompetitor.PlayerName</div>
                                    }

                                    <div class="competitor-score">@blueSets</div>

                                    @if (redCompetitor != null && blueCompetitor != null)
                                    {
                                        <div class="sets-container">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                var setResult = GetSetResult(match.Id, i);
                                                <div class="set-indicator @(setResult == "RegionB" ? "set-won" : setResult == "RegionA" ? "set-lost" : "set-pending")">
                                                    @if (setResult == "RegionB")
                                                    {
                                                        <text>W</text>
                                                    }
                                                    else if (setResult == "RegionA")
                                                    {
                                                        <text>L</text>
                                                    }
                                                    else
                                                    {
                                                        <text>@i</text>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>

                            @if (redCompetitor != null && blueCompetitor != null && matchWinner != null)
                            {
                                <div class="pairing-result">@matchWinner WINS</div>
                            }

                            <div class="pairing-status">
                                @if (_event.IsFinished == true)
                                {
                                    <text>FINAL</text>
                                }
                                else if (redCompetitor != null && blueCompetitor != null)
                                {
                                    <text>LIVE • Set @GetCurrentSet(match.Id)</text>
                                }
                                else
                                {
                                    <text>PENDING</text>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- TEAM STANDINGS -->
            <div class="results-wrap" style="margin-top:16px;">
                <div class="results-header">
                    <div class="results-title">
                        <MudIcon Icon="@Icons.Material.Filled.Leaderboard" Style="color: var(--pal-gold);" />
                        STANDINGS
                    </div>
                    <div class="results-note">TEAM</div>
                </div>

                <MudTable Class="tv-table"
                          Items="_standings
                                                            .OrderBy(r => r.Rank == 0)
                                                            .ThenBy(r => r.Rank)
                                                            .ThenByDescending(r => r.WinRate)
                                                            .ThenByDescending(r => r.MatchesWon)
                                                            .ToList()"
                  Dense="true" Hover="true" Elevation="0">
            <HeaderContent>
                <MudTh>Rank</MudTh>
                <MudTh>Team</MudTh>
                <MudTh>Player</MudTh>
                <MudTh style="text-align:center;">Matches</MudTh>
                <MudTh style="text-align:center;">Sets</MudTh>
                <MudTh style="text-align:center;">Win Rate</MudTh>
            </HeaderContent>

                    <RowTemplate>
                @{
                            var standing = context;
                            var rankClass = standing.Rank switch
