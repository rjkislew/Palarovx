@page "/scoreboard/martialarts/{EventID}"
@using System.Threading
@using System.Linq
@using Client.Palaro2026.Services
@inject APIService apiService
@inject NavigationManager Navigation
@implements IDisposable

@layout ClientLayout

<PageTitle>Martial Arts Live | Palaro tu AgSur 2026</PageTitle>

<style>
    /* --- FONTS & VARS --- */
    @@import url('https://fonts.cdnfonts.com/css/evil-empire');
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&family=Chakra+Petch:wght@600;700;800&display=swap');

    :root {
        --pal-blue: #023E8A;
        --pal-dark-blue: #001845;
        --pal-gold: #FFB400;
        --pal-red: #EA0000;
        --ma-blue: #3A86FF;
        --bg-gradient-start: #f8f9fa;
        --card-bg: rgba(255, 255, 255, 0.98);
        --font-header: 'Evil Empire', sans-serif;
        --font-body: 'Nunito', sans-serif;
    }

    body, html {
        margin: 0;
        padding: 0;
        background: radial-gradient(circle at 50% 30%, #ffffff 0%, #e0e7ff 100%);
        min-height: 100vh;
        overflow-x: hidden;
    }

    ::deep header, ::deep .mud-appbar, ::deep .layout-header, ::deep footer, ::deep .layout-footer {
        display: none !important;
    }

    ::deep .mud-main-content {
        padding: 0 !important;
        margin: 0 !important;
    }

    .tv-screen {
        width: 100vw;
        height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        box-sizing: border-box;
    }

    /* --- HEADER --- */
    .match-info-container {
        text-align: center;
        margin-top: 2vh;
        margin-bottom: 2vh;
        padding: 15px 50px;
        border-radius: 50px;
        background: var(--pal-dark-blue);
        border: 4px solid var(--pal-gold);
        box-shadow: 0 10px 25px rgba(0,0,0,0.3);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        z-index: 10;
        min-width: 45%;
    }

    .sport-title {
        font-family: var(--font-header);
        font-size: clamp(2.5rem, 5vh, 4.5rem);
        color: white;
        text-transform: uppercase;
        letter-spacing: 2px;
        line-height: 1;
        text-shadow: 3px 3px 0px #000000;
    }

    /* Parehas sa Archery Format (Yellow Text ra, Walay Pill) */
    .event-details-text {
        font-family: 'Chakra Petch', sans-serif;
        font-size: clamp(1rem, 2vh, 1.4rem);
        color: var(--pal-gold);
        letter-spacing: 2px;
        font-weight: 700;
        text-transform: uppercase;
        margin-top: 8px;
    }

    /* --- CUSTOM PURE CSS SLIDER --- */
    .custom-slider-container {
        position: relative;
        width: 100vw;
        height: 75vh;
        overflow: hidden;
    }

    .custom-slide {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.6s ease-in-out, visibility 0.6s ease-in-out;
        z-index: 1;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding-top: 15px;
    }

        .custom-slide.active {
            opacity: 1;
            visibility: visible;
            z-index: 2;
        }

    /* --- CONTENT WRAPPER --- */
    .content-wrapper {
        width: 98%;
        max-width: 1800px;
        display: flex;
        justify-content: center;
    }

    /* --- LARGE SINGLE MATCH CARD --- */
    .match-card {
        width: 100%;
        max-width: 1600px;
        background: var(--card-bg);
        border: 1px solid #d1d9e6;
        border-top: 10px solid var(--pal-gold);
        border-bottom: 10px solid var(--pal-blue);
        box-shadow: 0 20px 50px rgba(0,0,0,0.15);
        border-radius: 25px;
        padding: 50px 60px 40px 60px;
        position: relative;
        display: flex;
        flex-direction: column;
    }

    .match-stage-label {
        position: absolute;
        top: -20px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--pal-red);
        color: white;
        padding: 8px 40px;
        border-radius: 40px;
        font-family: 'Chakra Petch';
        font-weight: 800;
        font-size: 1.5rem;
        text-transform: uppercase;
        border: 3px solid white;
        box-shadow: 0 6px 15px rgba(234, 0, 0, 0.3);
        letter-spacing: 2px;
        white-space: nowrap;
        z-index: 5;
    }

    .teams-grid {
        display: grid;
        grid-template-columns: 1fr 0.1fr 1fr;
        align-items: center;
        margin-bottom: 30px;
        margin-top: 10px;
    }

    .team-display {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    /* TRANSPARENT LOGO CONTAINER */
    .logo-container {
        width: clamp(160px, 22vh, 260px);
        height: clamp(160px, 22vh, 260px);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 15px;
        transition: transform 0.3s;
        z-index: 2;
    }

        .logo-container img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            filter: drop-shadow(0 12px 20px rgba(0,0,0,0.15));
            transition: all 0.3s ease;
        }

    .winning-glow-red img {
        filter: drop-shadow(0 0 35px rgba(234, 0, 0, 0.85));
        transform: scale(1.15);
    }

    .winning-glow-blue img {
        filter: drop-shadow(0 0 35px rgba(58, 134, 255, 0.85));
        transform: scale(1.15);
    }

    .team-name {
        font-family: var(--font-header);
        font-size: clamp(2.2rem, 4.5vh, 3.5rem);
        color: var(--pal-dark-blue);
        line-height: 1;
        margin-bottom: 8px;
        margin-top: 8px;
    }

    .team-region {
        font-size: 1.4rem;
        font-weight: 800;
        color: #555;
        background: #f1f3f5;
        padding: 6px 20px;
        border-radius: 10px;
        text-transform: uppercase;
    }

    .team-points {
        font-family: 'Chakra Petch', sans-serif;
        font-size: clamp(5rem, 10vh, 8rem);
        font-weight: 800;
        color: #0018459c;
        line-height: 1;
        margin-top: 20px;
    }

    .points-lead {
        color: var(--pal-gold);
        text-shadow: 5px 5px 0px rgba(0, 24, 69, 0.1);
    }

    .vs-separator {
        font-family: var(--font-header);
        font-size: clamp(3rem, 6vh, 5rem);
        color: #cbd5e1;
        text-align: center;
        font-style: italic;
    }

    /* HISTORY TABLE */
    .history-section {
        border-top: 4px dashed #e9ecef;
        padding-top: 20px;
        margin-top: auto;
    }

    .set-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 8px;
        text-align: center;
        table-layout: fixed;
    }

        .set-table th {
            font-family: 'Chakra Petch';
            color: #000;
            font-size: 1.4rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding-bottom: 12px;
            border-bottom: 4px solid var(--pal-gold);
        }

        .set-table tr.score-row {
            background: white;
            box-shadow: 0 3px 8px rgba(0,0,0,0.06);
        }

        .set-table td {
            font-family: 'Nunito';
            font-weight: 900;
            font-size: 1.8rem;
            color: #757575;
            padding: 12px 6px;
            border-top: 2px solid #f8f9fa;
            border-bottom: 2px solid #f8f9fa;
        }

            .set-table td:first-child {
                border-left: 2px solid #f8f9fa;
                border-radius: 10px 0 0 10px;
            }

            .set-table td:last-child {
                border-right: 2px solid #f8f9fa;
                border-radius: 0 10px 10px 0;
            }

        .set-table .team-col {
            text-align: left;
            font-size: 1.6rem;
            font-weight: 900;
            padding-left: 20px;
            width: 30%;
        }

        .set-table .total-col {
            background: #f8f9fa;
            color: var(--pal-dark-blue);
            font-size: 2.2rem;
            border: 2px solid #e9ecef !important;
            width: 20%;
        }

    .score-win {
        color: var(--pal-gold) !important;
        transform: scale(1.3);
        display: inline-block;
        text-shadow: 2px 2px 3px rgba(0,0,0,0.15);
    }

    .score-lose {
        color: #d1d9e6 !important;
        font-size: 0.8em;
    }

    /* --- CAROUSEL INDICATORS & CONTROLS --- */
    .carousel-wrapper {
        position: fixed;
        bottom: clamp(15px, 3vh, 30px);
        left: 0;
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 100;
        pointer-events: none;
    }

    .carousel-indicators {
        display: flex;
        gap: clamp(8px, 1.5vw, 15px);
        pointer-events: auto;
    }

    .carousel-dot {
        width: clamp(12px, 2vh, 20px);
        height: clamp(12px, 2vh, 20px);
        border-radius: 50%;
        background-color: rgba(2, 62, 138, 0.3);
        border: 2px solid var(--pal-blue);
        transition: all 0.4s ease;
        cursor: pointer;
    }

        .carousel-dot.active {
            background-color: var(--pal-gold);
            border-color: var(--pal-gold);
            transform: scale(1.4);
            box-shadow: 0 0 10px rgba(255, 180, 0, 0.8);
        }

    .carousel-controls {
        position: absolute;
        right: clamp(20px, 4vw, 50px);
        display: flex;
        gap: 10px;
        pointer-events: auto;
    }

    .control-btn {
        background: var(--pal-dark-blue);
        color: white;
        border: 2px solid rgba(255,255,255,0.2);
        border-radius: 50%;
        width: clamp(35px, 5vh, 50px);
        height: clamp(35px, 5vh, 50px);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }

        .control-btn:hover {
            background: var(--pal-gold);
            color: var(--pal-dark-blue);
            border-color: var(--pal-gold);
            transform: scale(1.1);
        }

        .control-btn.active-play {
            border-color: var(--pal-gold);
            color: var(--pal-gold);
        }

</style>

<div class="tv-screen">
    <!-- HEADER -->
    <div class="match-info-container">
        @if (_isLoading)
        {
            <div class="sport-title">LOADING...</div>
        }
        else if (_event == null)
        {
            <div class="sport-title" style="color:var(--pal-red);">EVENT NOT FOUND</div>
        }
        else
        {
            <div class="sport-title">@(_event.Sport?.ToUpper() ?? "MARTIAL ARTS")</div>

            <!-- Parehas sa Archery Formater: YELLOW FONT AND BULLET SEPARATORS -->
            <div class="event-details-text">
                @{
                    var details = new List<string>();

                    // Combine Level and Gender
                    if (!string.IsNullOrWhiteSpace(_event.Level) && !string.IsNullOrWhiteSpace(_event.Gender))
                    {
                        details.Add($"{_event.Level} - {_event.Gender}");
                    }
                    else
                    {
                        if (!string.IsNullOrWhiteSpace(_event.Level)) details.Add(_event.Level);
                        if (!string.IsNullOrWhiteSpace(_event.Gender)) details.Add(_event.Gender);
                    }

                    // Add Subcategory, Category and Event Stage dynamically
                    if (!string.IsNullOrWhiteSpace(_event.Subcategory)) details.Add(_event.Subcategory);
                    if (!string.IsNullOrWhiteSpace(_event.Category)) details.Add(_event.Category);
                    if (!string.IsNullOrWhiteSpace(_event.EventStage)) details.Add(_event.EventStage);

                    string finalString = details.Any() ? string.Join(" • ", details).ToUpper() : "MARTIAL ARTS COMPETITION";
                }
                @finalString
            </div>
        }
    </div>

    @if (!_isLoading && _event != null)
    {
        <!-- CUSTOM SLIDER (1 MATCH PER PAGE) -->
        <div class="custom-slider-container">
            @{
                var activeMatches = GetActiveMatches();
                int totalPages = activeMatches.Count;

                if (totalPages > 0 && _currentPage >= totalPages) _currentPage = 0;
            }

            @if (totalPages == 0)
            {
                <MudText Typo="Typo.h4" Align="Align.Center" Style="color:var(--pal-dark-blue); font-family: 'Evil Empire'; margin-top:10vh; width: 100%;">
                    NO ACTIVE MATCHES YET
                </MudText>
            }
            else
            {
                <!-- 1 MATCH PER SLIDE -->
                @foreach (var item in activeMatches.Select((match, idx) => new { match, idx }))
                {
                    int slideIndex = item.idx;
                    var match = item.match;
                    var redCompetitor = GetCompetitorAssignedToMatch(match.Id, "RegionA");
                    var blueCompetitor = GetCompetitorAssignedToMatch(match.Id, "RegionB");

                    var redLogo = GetCompetitorLogo(redCompetitor);
                    var blueLogo = GetCompetitorLogo(blueCompetitor);

                    var matchWinner = GetMatchWinner(match.Id);
                    var redSets = GetTotalSetsWon(match.Id, "RegionA");
                    var blueSets = GetTotalSetsWon(match.Id, "RegionB");
                    var status = GetMatchStatus(match.Id);

                    int displayRounds = GetDisplayRounds(match.Id);

                    <div class="custom-slide @(slideIndex == _currentPage ? "active" : "")">
                        <div class="content-wrapper">

                            <!-- DAKO NGA MATCH CARD -->
                            <div class="match-card">
                                <div class="match-stage-label">
                                    @(string.IsNullOrEmpty(_event.EventStage) ? $"BOUT {match.Id}" : $"{_event.EventStage} • BOUT {match.Id}")
                                    • @status
                                </div>

                                <div class="teams-grid">
                                    <!-- RED CORNER -->
                                    <div class="team-display">
                                        <div class="logo-container @(matchWinner == redCompetitor?.Name ? "winning-glow-red" : "")">
                                            <img src="@($"https://palarongpambansa2026.com/attachments/media/regions/team_logo/{Uri.EscapeDataString(redLogo)}.webp")" onerror="this.src='/media/images/2031.png'" />
                                        </div>
                                        <div class="team-name" style="color:var(--pal-red);">@(redCompetitor?.Name ?? "TBD")</div>
                                        @if (!string.IsNullOrEmpty(redCompetitor?.PlayerName))
                                        {
                                            <span class="team-region">@redCompetitor.PlayerName</span>
                                        }
                                        <div class="team-points @(matchWinner == redCompetitor?.Name ? "points-lead" : "")">@redSets</div>
                                    </div>

                                    <div class="vs-separator">VS</div>

                                    <!-- BLUE CORNER -->
                                    <div class="team-display">
                                        <div class="logo-container @(matchWinner == blueCompetitor?.Name ? "winning-glow-blue" : "")">
                                            <img src="@($"https://palarongpambansa2026.com/attachments/media/regions/team_logo/{Uri.EscapeDataString(blueLogo)}.webp")" onerror="this.src='/media/images/2031.png'" />
                                        </div>
                                        <div class="team-name" style="color:var(--ma-blue);">@(blueCompetitor?.Name ?? "TBD")</div>
                                        @if (!string.IsNullOrEmpty(blueCompetitor?.PlayerName))
                                        {
                                            <span class="team-region">@blueCompetitor.PlayerName</span>
                                        }
                                        <div class="team-points @(matchWinner == blueCompetitor?.Name ? "points-lead" : "")">@blueSets</div>
                                    </div>
                                </div>

                                <!-- DYNAMIC ROUNDS HISTORY -->
                                <div class="history-section">
                                    <table class="set-table">
                                        <thead>
                                            <tr>
                                                <th class="team-col">CORNER</th>
                                                @for (int i = 1; i <= displayRounds; i++)
                                                {
                                                    <th>RND @i</th>
                                                }
                                                <th class="total-col">WINS</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr class="score-row">
                                                <td class="team-col" style="color:var(--pal-red) !important;">RED</td>
                                                @for (int i = 1; i <= displayRounds; i++)
                                                {
                                                    var res = GetSetResult(match.Id, i);
                                                    bool isWin = res == "RegionA";
                                                    bool isLoss = res == "RegionB";
                                                    <td><span class="@(isWin ? "score-win" : (isLoss ? "score-lose" : ""))">@(isWin ? "W" : (isLoss ? "L" : "-"))</span></td>
                                                }
                                                <td class="total-col" style="font-weight:900;">@redSets</td>
                                            </tr>
                                            <tr class="score-row">
                                                <td class="team-col" style="color:var(--ma-blue) !important;">BLUE</td>
                                                @for (int i = 1; i <= displayRounds; i++)
                                                {
                                                    var res = GetSetResult(match.Id, i);
                                                    bool isWin = res == "RegionB";
                                                    bool isLoss = res == "RegionA";
                                                    <td><span class="@(isWin ? "score-win" : (isLoss ? "score-lose" : ""))">@(isWin ? "W" : (isLoss ? "L" : "-"))</span></td>
                                                }
                                                <td class="total-col" style="font-weight:900;">@blueSets</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <!-- CAROUSEL INDICATORS & CONTROLS -->
                @if (totalPages > 1)
                {
                    <div class="carousel-wrapper">
                        <div class="carousel-indicators">
                            @for (int i = 0; i < totalPages; i++)
                            {
                                int pageIndex = i;
                                <div class="carousel-dot @(pageIndex == _currentPage ? "active" : "")" @onclick="() => SetPage(pageIndex)"></div>
                            }
                        </div>

                        <!-- PLAYBACK CONTROLS -->
                        <div class="carousel-controls">
                            <button class="control-btn" @onclick="PrevPage" title="Previous Page">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowBackIosNew" Size="Size.Small" />
                            </button>
                            <button class="control-btn @(_isAutoPlay ? "active-play" : "")" @onclick="ToggleAutoPlay" title="Play/Pause Carousel">
                                <MudIcon Icon="@(_isAutoPlay? Icons.Material.Filled.Pause : Icons.Material.Filled.PlayArrow)" Size="Size.Small" />
                            </button>
                            <button class="control-btn" @onclick="NextPage" title="Next Page">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForwardIos" Size="Size.Small" />
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    [Parameter] public string EventID { get; set; } = "";

    // --- CAROUSEL VARIABLES ---
    private int _currentPage = 0;
    private bool _isAutoPlay = true;
    private System.Timers.Timer? _carouselTimer;
    private System.Timers.Timer? _dataTimer;

    // --- MODELS ---
    public class EventInfo
    {
        public string ID { get; set; } = "";
        public string? Sport { get; set; }
        public string? Subcategory { get; set; }
        public string? Category { get; set; }
        public string? Level { get; set; }
        public string? Gender { get; set; }
        public string? EventStage { get; set; }
        public string? SportMainCat { get; set; }
        public bool? IsFinished { get; set; }
        public int? RegionID { get; set; }
        public string? Abbreviation { get; set; }
        public string? PlayerID { get; set; }
        public string? PlayerName { get; set; }
    }

    public class SchoolRegions
    {
        public int ID { get; set; }
        public string? Region { get; set; }
        public string? Abbreviation { get; set; }
    }

    public class CompetitorItem
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string AssignedMatch { get; set; } = "Unassigned";
        public string? PlayerName { get; set; }
        public string MatchPosition { get; set; } = "";
        public int GameNo { get; set; } = 1;
    }

    public class MatchCard
    {
        public int Id { get; set; }
        public int GameNo { get; set; }
        public string RegionA { get; set; } = "";
        public string RegionB { get; set; } = "";
        public int CurrentSet { get; set; } = 1;
        public int MaxSet { get; set; } = 1;
    }

    public class MartialArtsScoringDTO
    {
        public int MatchId { get; set; }
        public int GameNo { get; set; }
        public int RegionID { get; set; }
        public string? MatchPosition { get; set; }
        public int SetNo { get; set; }
        public string? Result { get; set; }
        public string? PlayerName { get; set; }
    }

    private EventInfo? _event;
    private List<SchoolRegions>? _allRegions;
    private List<CompetitorItem>? _allCompetitors;
    private List<MatchCard> _matchCards = new();
    private bool _isLoading = true;

    private int? _selectedGameNo = 1;
    private List<int> _availableGameNos = new List<int> { 1 };

    private Dictionary<int, List<CompetitorItem>> _gameCompetitors = new();
    private Dictionary<int, Dictionary<string, Dictionary<int, string>>> _gameMatchSetResults = new();
    private Dictionary<int, Dictionary<string, int>> _gameMatchCurrentSets = new();
    private Dictionary<int, List<int>> _gameMatches = new();
    private Dictionary<int, int> _gameNextMatchId = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();

        // Data poll every 3 seconds
        _dataTimer = new System.Timers.Timer(3000);
        _dataTimer.Elapsed += async (s, e) => { await InvokeAsync(LoadData); };
        _dataTimer.Start();

        // Carousel Timer every 7 seconds
        _carouselTimer = new System.Timers.Timer(7000);
        _carouselTimer.Elapsed += (s, e) =>
        {
            if (!_isAutoPlay) return;

            InvokeAsync(() =>
            {
                NextPageLogic();
                StateHasChanged();
            });
        };
        _carouselTimer.Start();
    }

    // --- CAROUSEL LOGIC ---
    private void ToggleAutoPlay()
    {
        _isAutoPlay = !_isAutoPlay;
        RestartCarouselTimer();
    }

    private void SetPage(int index)
    {
        _currentPage = index;
        RestartCarouselTimer();
    }

    private void NextPage()
    {
        NextPageLogic();
        RestartCarouselTimer();
    }

    private void PrevPage()
    {
        int totalPages = GetActiveMatches().Count;
        if (totalPages > 1)
        {
            _currentPage = (_currentPage - 1 + totalPages) % totalPages;
        }
        RestartCarouselTimer();
    }

    private void NextPageLogic()
    {
        int totalPages = GetActiveMatches().Count;
        if (totalPages > 1)
        {
            _currentPage = (_currentPage + 1) % totalPages;
        }
    }

    private void RestartCarouselTimer()
    {
        if (_carouselTimer != null)
        {
            _carouselTimer.Stop();
            _carouselTimer.Start();
        }
    }

    public void Dispose()
    {
        _dataTimer?.Stop();
        _dataTimer?.Dispose();
        _carouselTimer?.Stop();
        _carouselTimer?.Dispose();
    }

    /* --- DYNAMIC ROUNDS CALCULATOR --- */
    private int GetDisplayRounds(int matchId)
    {
        int standardRounds = 3; // Default for Taekwondo, Arnis, Boxing, Wushu, etc.
        var s = _event?.Sport?.ToLower() ?? "";
        var sub = _event?.Subcategory?.ToLower() ?? "";

        if (s.Contains("wrestling")) standardRounds = 2;
        else if (s.Contains("judo") || s.Contains("jujitsu") || s.Contains("kurash") || s.Contains("sambo")) standardRounds = 1;
        else if (s.Contains("karatedo") || s.Contains("karate")) standardRounds = 1;
        else if (sub.Contains("poomsae") || sub.Contains("anyo") || sub.Contains("taolu") || sub.Contains("seni") || sub.Contains("kata")) standardRounds = 1;

        // Check if actual score inputs exceed the standard round (e.g. tiebreakers)
        var matchKey = $"Match{matchId}";
        int maxScoredSet = 0;
        if (_selectedGameNo.HasValue && _gameMatchSetResults.ContainsKey(_selectedGameNo.Value) && _gameMatchSetResults[_selectedGameNo.Value].ContainsKey(matchKey))
        {
            if (_gameMatchSetResults[_selectedGameNo.Value][matchKey].Keys.Any())
            {
                maxScoredSet = _gameMatchSetResults[_selectedGameNo.Value][matchKey].Keys.Max();
            }
        }

        // Return standard round vs actual played max round (whichever is higher)
        return Math.Max(standardRounds, maxScoredSet);
    }

    /* --- GET EXACT REGION LOGO --- */
    private string GetCompetitorLogo(CompetitorItem? comp)
    {
        if (comp == null) return "Default";

        // Pangitaon niya ang ID o ang Abbreviation sa sulod sa Schools/Regions API
        var reg = _allRegions?.FirstOrDefault(r => r.ID == comp.Id || r.Abbreviation == comp.Name);

        // Pag na match, iyang i-return ang tibuok Region Name para mugawas ang image
        return reg?.Region ?? comp.Name;
    }

    /* --- DATA FETCHING & PROCESSING --- */
    private async Task LoadData()
    {
        try
        {
            if (_allRegions == null)
            {
                _allRegions = await apiService.GetAsync<SchoolRegions>("/Schools/Regions");
            }

            if (_event == null)
            {
                var events = await apiService.GetAsync<EventInfo>("/MartialArtsScoring/events");
                _event = events?.FirstOrDefault(e => e.ID == EventID);
            }

            if (_event == null) { _isLoading = false; return; }

            await LoadCompetitors();
            await LoadScores();

            _isLoading = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
            _isLoading = false;
        }
    }

    private async Task LoadCompetitors()
    {
        if (_allCompetitors != null) return;

        var queryParams = new List<string>();
        if (!string.IsNullOrEmpty(_event?.Subcategory)) queryParams.Add($"subcategory={Uri.EscapeDataString(_event.Subcategory)}");
        if (!string.IsNullOrEmpty(_event?.Level)) queryParams.Add($"level={Uri.EscapeDataString(_event.Level)}");
        if (!string.IsNullOrEmpty(_event?.Gender)) queryParams.Add($"gender={Uri.EscapeDataString(_event.Gender)}");
        if (!string.IsNullOrEmpty(_event?.EventStage)) queryParams.Add($"eventStage={Uri.EscapeDataString(_event.EventStage)}");

        var queryString = queryParams.Any() ? "?" + string.Join("&", queryParams) : "";
        var events = await apiService.GetAsync<EventInfo>($"/MartialArtsScoring/events{queryString}");

        if (events != null && events.Any())
        {
            _allCompetitors = events
                .Where(evt => !string.IsNullOrEmpty(evt.Abbreviation))
                .GroupBy(evt => evt.Abbreviation)
                .Select(group =>
                {
                    var firstEvent = group.First();
                    return new CompetitorItem
                    {
                        Id = firstEvent.RegionID ?? 0,
                        Name = group.Key!,
                        AssignedMatch = "Unassigned",
                        PlayerName = firstEvent.PlayerName,
                        MatchPosition = "",
                        GameNo = 1
                    };
                }).ToList();

            InitializeGame(1);
        }
    }

    private async Task LoadScores()
    {
        if (_event == null) return;
        var existingAssignments = await apiService.GetAsync<MartialArtsScoringDTO>($"/MartialArtsScoring/event/{_event.ID}");

        if (existingAssignments != null && existingAssignments.Any())
        {
            var allGameNos = existingAssignments.Select(a => a.GameNo).Distinct().ToList();
            _availableGameNos = allGameNos.Any() ? allGameNos : new List<int> { 1 };
            _availableGameNos.Sort();
            _selectedGameNo = _availableGameNos.First();

            foreach (var gameNo in _availableGameNos)
            {
                await InitializeGameFromDatabase(gameNo, existingAssignments);
            }
        }
    }

    private void InitializeGame(int gameNo)
    {
        if (_allCompetitors != null && !_gameCompetitors.ContainsKey(gameNo))
        {
            _gameCompetitors[gameNo] = _allCompetitors.Select(r => new CompetitorItem
            {
                Id = r.Id,
                Name = r.Name,
                AssignedMatch = r.AssignedMatch,
                PlayerName = r.PlayerName,
                MatchPosition = r.MatchPosition,
                GameNo = gameNo
            }).ToList();
        }

        if (!_gameMatches.ContainsKey(gameNo)) _gameMatches[gameNo] = new List<int>();
        if (!_gameNextMatchId.ContainsKey(gameNo)) _gameNextMatchId[gameNo] = 1;
        if (!_gameMatchSetResults.ContainsKey(gameNo)) _gameMatchSetResults[gameNo] = new Dictionary<string, Dictionary<int, string>>();
        if (!_gameMatchCurrentSets.ContainsKey(gameNo)) _gameMatchCurrentSets[gameNo] = new Dictionary<string, int>();
    }

    private async Task InitializeGameFromDatabase(int gameNo, IEnumerable<MartialArtsScoringDTO> existingAssignments)
    {
        InitializeGame(gameNo);
        var matchesForGame = existingAssignments.Where(a => a.GameNo == gameNo).ToList();
        if (!matchesForGame.Any()) return;

        var matchIds = matchesForGame.Select(a => a.MatchId).Distinct().ToList();
        _gameNextMatchId[gameNo] = (matchIds.Any() ? matchIds.Max() : 0) + 1;

        var existingMatchCards = _matchCards.Where(m => m.GameNo == gameNo).ToList();
        foreach (var match in existingMatchCards) _matchCards.Remove(match);
        _gameMatches[gameNo].Clear();

        foreach (var matchId in matchIds.OrderBy(id => id))
        {
            _matchCards.Add(new MatchCard { Id = matchId, GameNo = gameNo });
            _gameMatches[gameNo].Add(matchId);
        }

        await LoadGameDataFromDatabase(gameNo, matchesForGame);
    }

    private async Task LoadGameDataFromDatabase(int gameNo, List<MartialArtsScoringDTO> assignmentsForGame)
    {
        if (_allCompetitors != null && _gameCompetitors.ContainsKey(gameNo))
        {
            _gameCompetitors[gameNo] = _allCompetitors.Select(r => new CompetitorItem
            { Id = r.Id, Name = r.Name, AssignedMatch = "Unassigned", PlayerName = r.PlayerName, MatchPosition = "", GameNo = gameNo }).ToList();
        }

        if (_gameMatchSetResults.ContainsKey(gameNo)) _gameMatchSetResults[gameNo].Clear();
        if (_gameMatchCurrentSets.ContainsKey(gameNo)) _gameMatchCurrentSets[gameNo].Clear();

        foreach (var assignment in assignmentsForGame)
        {
            var matchId = assignment.MatchId;
            var matchKey = $"Match{matchId}";

            if (!_gameMatchSetResults[gameNo].ContainsKey(matchKey)) _gameMatchSetResults[gameNo][matchKey] = new Dictionary<int, string>();

            if (_gameCompetitors.ContainsKey(gameNo))
            {
                var competitor = _gameCompetitors[gameNo].FirstOrDefault(r => r.Id == assignment.RegionID);
                if (competitor != null)
                {
                    competitor.AssignedMatch = $"Match{matchId}_{assignment.MatchPosition}";
                    competitor.MatchPosition = assignment.MatchPosition;
                    if (!string.IsNullOrEmpty(assignment.PlayerName)) competitor.PlayerName = assignment.PlayerName;
                }
            }

            if (!string.IsNullOrEmpty(assignment.Result) && assignment.Result == "W")
            {
                _gameMatchSetResults[gameNo][matchKey][assignment.SetNo] = assignment.MatchPosition;
            }

            if (!_gameMatchCurrentSets[gameNo].ContainsKey(matchKey) || assignment.SetNo >= _gameMatchCurrentSets[gameNo][matchKey])
            {
                _gameMatchCurrentSets[gameNo][matchKey] = assignment.SetNo + 1;
            }
        }
    }

    private List<MatchCard> GetActiveMatches()
    {
        if (!_selectedGameNo.HasValue || !_gameMatches.ContainsKey(_selectedGameNo.Value)) return new List<MatchCard>();
        var matchIds = _gameMatches[_selectedGameNo.Value];
        return _matchCards.Where(m => m.GameNo == _selectedGameNo.Value && matchIds.Contains(m.Id)).OrderBy(m => m.Id).ToList();
    }

    private CompetitorItem? GetCompetitorAssignedToMatch(int matchId, string position)
    {
        if (!_selectedGameNo.HasValue || !_gameCompetitors.ContainsKey(_selectedGameNo.Value)) return null;
        return _gameCompetitors[_selectedGameNo.Value].FirstOrDefault(r => r.AssignedMatch == $"Match{matchId}_{position}");
    }

    private string? GetSetResult(int matchId, int setNo)
    {
        if (!_selectedGameNo.HasValue) return null;
        var matchKey = $"Match{matchId}";
        if (_gameMatchSetResults.ContainsKey(_selectedGameNo.Value) && _gameMatchSetResults[_selectedGameNo.Value].ContainsKey(matchKey) && _gameMatchSetResults[_selectedGameNo.Value][matchKey].ContainsKey(setNo))
        {
            return _gameMatchSetResults[_selectedGameNo.Value][matchKey][setNo];
        }
        return null;
    }

    private int GetTotalSetsWon(int matchId, string position)
    {
        if (!_selectedGameNo.HasValue) return 0;
        var matchKey = $"Match{matchId}";
        if (_gameMatchSetResults.ContainsKey(_selectedGameNo.Value) && _gameMatchSetResults[_selectedGameNo.Value].ContainsKey(matchKey))
        {
            return _gameMatchSetResults[_selectedGameNo.Value][matchKey].Count(kvp => kvp.Value == position);
        }
        return 0;
    }

    private string? GetMatchWinner(int matchId)
    {
        var redCompetitor = GetCompetitorAssignedToMatch(matchId, "RegionA");
        var blueCompetitor = GetCompetitorAssignedToMatch(matchId, "RegionB");

        if (redCompetitor == null || blueCompetitor == null || !_selectedGameNo.HasValue) return null;

        var matchKey = $"Match{matchId}";
        if (!_gameMatchSetResults.ContainsKey(_selectedGameNo.Value) || !_gameMatchSetResults[_selectedGameNo.Value].ContainsKey(matchKey)) return null;

        var redWins = _gameMatchSetResults[_selectedGameNo.Value][matchKey].Count(kvp => kvp.Value == "RegionA");
        var blueWins = _gameMatchSetResults[_selectedGameNo.Value][matchKey].Count(kvp => kvp.Value == "RegionB");

        if (redWins > blueWins) return redCompetitor.Name;
        if (blueWins > redWins) return blueCompetitor.Name;
        return null;
    }

    private string GetMatchStatus(int matchId)
    {
        if (!string.IsNullOrEmpty(GetMatchWinner(matchId))) return "COMPLETED";
        var r = GetCompetitorAssignedToMatch(matchId, "RegionA");
        var b = GetCompetitorAssignedToMatch(matchId, "RegionB");
        if (r != null && b != null) return "FIGHTING";
        return "PENDING";
    }
}