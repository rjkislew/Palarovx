                        <MudTd>
                            <div class="region-wrap">
                                <div class="region-flag">
                                    <MudImage Src="@($"https://palarongpambansa2026.com/attachments/media/regions/team_logo/{standing.RegionName.ToUpper()}.webp")"
                                              ObjectFit="ObjectFit.Contain"
                                              Alt="@standing.RegionName"
                                              Style="width:100%; height:100%;"
                                              OnError="this.style.display='none'" />
                                </div>
                                <div class="region-name">@standing.RegionName</div>
                            </div>
                        </MudTd>

                        <MudTd style="text-align:center; font-family:var(--font-subheader); font-weight:900;">
                            <span style="color:#198754;">@standing.MatchesWon</span>
                            <span style="color:#adb5bd;">/</span>
                            <span style="color:var(--pal-red);">@standing.MatchesLost</span>
                        </MudTd>

                        <MudTd style="text-align:center; font-family:var(--font-subheader); font-weight:900;">
                            <span style="color:#198754;">@standing.SetsWon</span>
                            <span style="color:#adb5bd;">/</span>
                            <span style="color:var(--pal-red);">@standing.SetsLost</span>
                        </MudTd>

                        <MudTd style="text-align:center; font-family:var(--font-subheader); font-weight:900; color:var(--pal-blue);">
