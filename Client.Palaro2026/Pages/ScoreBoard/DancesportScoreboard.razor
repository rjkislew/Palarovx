@page "/scoreboard/dancesport"
@layout NoMainLayout
@using System.Threading
@using System.Linq
@using Client.Palaro2026.Services
@inject APIService apiService
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Dancesport Dashboard | Palaro tu AgSur 2026</PageTitle>

<style>
    /* --- THEME IMPORTS (MATCH ARCHERY) --- */
    @@import url('https://fonts.cdnfonts.com/css/evil-empire');
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&display=swap');

    :root {
        /* PALARO COLOR PALETTE */
        --pal-blue: #023E8A;
        --pal-dark-blue: #001845;
        --pal-gold: #FFB400;
        --pal-red: #EA0000;
        --pal-white: #ffffff;
        /* LIGHT THEME VARS */
        --bg-gradient-start: #f8f9fa;
        --card-bg: rgba(255, 255, 255, 0.95);
        /* FONTS (MATCH ARCHERY) */
        --font-header: 'Evil Empire', sans-serif;
        --font-body: 'Nunito', Arial, Helvetica, sans-serif;
    }

    ::-webkit-scrollbar {
        width: 8px;
    }

    ::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    ::-webkit-scrollbar-thumb {
        background: #ccc;
        border-radius: 4px;
    }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--pal-blue);
        }

    body {
        background-color: var(--bg-gradient-start);
        margin: 0;
        font-family: var(--font-body);
        overflow-x: hidden;
    }

    .tv-screen-bg {
        min-height: 100vh;
        width: 100vw;
        background: radial-gradient(circle at 50% 30%, #ffffff 0%, #e0e7ff 100%);
        padding-bottom: 50px;
    }

    /* --- HEADER (PILL STYLE) --- */
    .dashboard-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin: 10px 0 30px 0;
    }

    .header-pill {
        background: var(--pal-dark-blue);
        border: 3px solid var(--pal-gold);
        padding: 20px 60px;
        border-radius: 50px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    .main-event-title {
        font-family: var(--font-header);
        color: white;
        font-size: clamp(2rem, 4vw, 3.5rem);
        letter-spacing: 2px;
        margin: 0;
        line-height: 1;
        text-shadow: 2px 2px 0px black;
        text-transform: uppercase;
    }

    /* --- SEARCH BAR (MATCH ARCHERY) --- */
    .search-wrapper {
        display: flex;
        justify-content: center;
        margin-bottom: 22px;
        padding: 0 20px;
    }

    .tv-search-field {
        width: 100%;
        max-width: 600px;
    }

        .tv-search-field .mud-input-control-input-container {
            background-color: white !important;
            border-radius: 50px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }

        .tv-search-field .mud-input-slot {
            font-family: var(--font-body);
            font-weight: 800;
            color: var(--pal-dark-blue) !important;
            padding-left: 10px;
            letter-spacing: .4px;
        }

        .tv-search-field .mud-icon-root {
            color: var(--pal-blue) !important;
        }

    /* --- TABS (MATCH ARCHERY) --- */
    .mud-tabs-tabbar {
        background: transparent !important;
    }

    .mud-tab {
        font-family: var(--font-body) !important;
        font-weight: 800;
        font-size: 1.2rem !important;
        letter-spacing: 1px;
        color: #adb5bd !important;
        text-transform: uppercase;
    }

    .mud-tab-active {
        color: var(--pal-blue) !important;
        text-shadow: 0 0 1px rgba(2, 62, 138, 0.5);
    }

    .mud-tabs-indicator {
        background-color: var(--pal-gold) !important;
        height: 4px;
        border-radius: 4px;
    }

    /* --- SECTION (MATCH ARCHERY) --- */
    .sport-section {
        margin-bottom: 40px;
        background: white;
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        border: 1px solid #e9ecef;
    }

    .sport-title-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 2px solid var(--pal-gold);
        gap: 12px;
    }

    .sport-name {
        font-family: var(--font-body);
        font-weight: 800;
        font-size: 1.5rem;
        color: var(--pal-dark-blue);
        display: flex;
        align-items: center;
        gap: 10px;
        letter-spacing: 1px;
        text-transform: uppercase;
        min-width: 0;
        width: 100%;
    }

    /* --- CARD (MATCH ARCHERY tv-card) --- */
    .match-link {
        text-decoration: none;
        display: block;
        height: 100%;
    }

    .tv-card {
        background-color: white;
        border: 1px solid #dee2e6;
        border-top: 5px solid var(--pal-blue);
        border-radius: 15px;
        padding: 15px;
        position: relative;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

        .tv-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.15);
            border-top-color: var(--pal-gold);
        }

    .card-status-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
        border-bottom: 1px solid #f1f1f1;
        padding-bottom: 8px;
        gap: 10px;
    }

    .live-badge {
        font-family: var(--font-body);
        font-weight: 800;
        font-size: 0.75rem;
        padding: 3px 12px;
        background: var(--pal-red);
        color: white;
        border-radius: 20px;
        letter-spacing: 1px;
        box-shadow: 0 2px 5px rgba(234, 0, 0, 0.3);
        white-space: nowrap;
    }

    .final-badge {
        font-family: var(--font-body);
        font-weight: 800;
        font-size: 0.75rem;
        padding: 3px 12px;
        background: #28a745; /* Green */
        color: white;
        border-radius: 20px;
        letter-spacing: 1px;
        white-space: nowrap;
    }

    .phase-text {
        font-family: var(--font-body);
        color: #6c757d;
        font-size: 0.85rem;
        font-weight: 800;
        text-transform: uppercase;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 70%;
        text-align: right;
        margin-left: auto;
    }

    .card-body {
        display: flex;
        flex-direction: column;
        gap: 10px;
        flex-grow: 1;
    }

    .leaders-label {
        font-family: var(--font-body);
        font-weight: 800;
        letter-spacing: 1px;
        text-transform: uppercase;
        font-size: 0.78rem;
        color: rgba(0,24,69,.55);
        margin: 0;
    }

    .leaderboard-mini {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .couple-row {
        display: grid;
        grid-template-columns: 34px 1fr auto;
        align-items: center;
        padding: 10px 10px;
        border-radius: 14px;
        border: 1px solid rgba(2,62,138,0.10);
        background: linear-gradient(180deg, rgba(255,180,0,0.08), rgba(2,62,138,0.03));
        position: relative;
        overflow: hidden;
    }

        .couple-row::before {
            content: "";
            position: absolute;
            left: 0;
            top: 0;
            width: 6px;
            height: 100%;
            background: rgba(0,0,0,0.12);
        }

    .rank-box {
        font-family: var(--font-body);
        font-weight: 900;
        font-size: 1.05rem;
        text-align: center;
        color: rgba(0,24,69,.75);
        z-index: 1;
    }

    .couple-info {
        padding: 0 10px;
        display: flex;
        flex-direction: column;
        min-width: 0;
        z-index: 1;
    }

    .couple-region {
        font-family: var(--font-body);
        font-weight: 900;
        color: var(--pal-dark-blue);
        font-size: 0.9rem;
        line-height: 1.1;
        text-transform: uppercase;
        letter-spacing: .5px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .couple-names {
        font-family: var(--font-body);
        font-size: 0.78rem;
        color: #666;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 100%;
        font-weight: 800;
    }

    .couple-score {
        font-family: var(--font-body);
        font-weight: 900;
        font-size: 1.0rem;
        color: var(--pal-blue);
        z-index: 1;
        white-space: nowrap;
    }

    .rank-1 {
        background: rgba(255,180,0,0.14);
        border-color: rgba(255,180,0,0.35);
    }

        .rank-1::before {
            background: var(--pal-gold);
        }

    .rank-2 {
        background: rgba(2,62,138,0.07);
        border-color: rgba(2,62,138,0.18);
    }

        .rank-2::before {
            background: rgba(192,192,192,0.9);
        }

    .rank-3 {
        background: rgba(234,102,0,0.08);
        border-color: rgba(205,127,50,0.25);
    }

        .rank-3::before {
            background: rgba(205,127,50,0.9);
        }

    .muted {
        text-align: center;
        color: #adb5bd;
        font-size: 0.85rem;
        font-weight: 900;
        letter-spacing: .5px;
        text-transform: uppercase;
        padding: 12px 0;
        font-family: var(--font-body);
    }

    .card-footer {
        text-align: center;
        margin-top: 12px;
        color: #6c757d;
        font-family: var(--font-body);
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        border-top: 1px solid #f1f1f1;
        padding-top: 8px;
    }

    .loading-spinner {
        color: var(--pal-blue);
    }

    @@media (max-width: 600px) {
        .header-pill {
            padding: 18px 20px;
        }
    }
</style>

<div class="tv-screen-bg">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge">

        <!-- HEADER -->
        <div class="dashboard-header">
            <div class="header-pill">
                <h1 class="main-event-title">DANCESPORT</h1>
            </div>
        </div>

      

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="mt-16">
                <MudProgressCircular Indeterminate="true" Class="loading-spinner" Size="Size.Large" />
                <MudText Typo="Typo.h6" Class="mt-4"
                         Style="font-family:var(--font-body); font-weight:800; color:var(--pal-blue);">
                    INITIALIZING SYSTEM...
                </MudText>
            </MudStack>
        }
        else
        {
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="mt-4" Centered="true">

                <!-- LIVE EVENTS -->
                <MudTabPanel Text="LIVE EVENTS">
                    @{
                        var liveEvents = _dancesportEvents
                        .Where(e => !e.IsFinished)
                        .Where(e => FilterFunction(e))
                        .ToList();
                    }

                    @if (!liveEvents.Any())
                    {
                        <MudPaper Class="pa-16 d-flex flex-column align-center justify-center mt-8"
                                  Style="background-color:white; border-radius:20px; box-shadow:0 4px 10px rgba(0,0,0,0.05);">
                            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Style="color:#dee2e6; width:80px; height:80px;" />
                            <MudText Typo="Typo.h5" Class="mt-4"
                                     Style="color:#adb5bd; font-family:var(--font-body); font-weight:800;">
                                @(_searchString == "" ? "NO LIVE EVENTS" : "NO MATCHES FOUND")
                            </MudText>
                        </MudPaper>
                    }
                    else
                    {
                        @foreach (var group in liveEvents.GroupBy(e => $"{GetSchoolLevelName(e.LevelID)} • {GetCategoryShort(e.MainCategory)} • {GetEventStageName(e.StageID)}"))
                        {
                            <div class="sport-section">
                                <div class="sport-title-row">
                                    <div class="sport-name" title="@group.Key" style="width:100%">
                                        <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Style="color: var(--pal-gold);" />
                                        <span style="min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@group.Key</span>
                                    </div>
                                </div>

                                <MudGrid Spacing="3">
                                    @foreach (var evt in group.OrderBy(x => x.ID))
                                    {
                                        <MudItem xs="12" sm="6" lg="4" xl="3">
                                            <a class="match-link" href="javascript:void(0)" @onclick="() => NavigateToEvent(evt.ID)">
                                                <div class="tv-card">
                                                    <div class="card-status-bar">
                                                        <div class="live-badge">LIVE</div>
                                                        <div class="phase-text">@GetEventStageName(evt.StageID)</div>
                                                    </div>

                                                    <div class="card-body">
                                                        <MudText Typo="Typo.subtitle2"
                                                                 Style="font-family:var(--font-body); font-weight:800; color:var(--pal-dark-blue); text-transform:uppercase;">
                                                            @($"{GetCategoryShort(evt.MainCategory)} • {GetSchoolLevelName(evt.LevelID)}")
                                                        </MudText>

                                                        <div style="margin-top:8px;">
                                                            <div class="leaders-label">CURRENT LEADERS</div>

                                                            @{
                                                                var top3 = GetTopCouples(evt.ID, 3);
                                                            }

                                                            @if (!top3.Any())
                                                            {
                                                                <div class="muted">WAITING FOR SCORES...</div>
                                                            }
                                                            else
                                                            {
                                                                <div class="leaderboard-mini">
                                                                    @foreach (var couple in top3)
                                                                    {
                                                                        <div class="couple-row @($"rank-{couple.Rank}")">
                                                                            <div class="rank-box"></div>
                                                                            <div class="couple-info">
                                                                                <div class="couple-region">@couple.Region</div>
                                                                                <div class="couple-names">@string.Join(" & ", couple.Dancers)</div>
                                                                            </div>
                                                                            <div class="couple-score"></div>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>

                                                    <div class="card-footer">VIEW EVENT</div>
                                                </div>
                                            </a>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </div>
                        }
                    }
                </MudTabPanel>

                <!-- FINAL RESULTS -->
                <MudTabPanel Text="PARTIAL RESULTS">
                    @{
                        var finishedEvents = _dancesportEvents
                        .Where(e => e.IsFinished)
                        .Where(e => FilterFunction(e))
                        .OrderByDescending(e => e.ID)
                        .ToList();
                    }

                    @if (!finishedEvents.Any())
                    {
                        <MudPaper Class="pa-16 d-flex flex-column align-center justify-center mt-8"
                                  Style="background-color:white; border-radius:20px; box-shadow:0 4px 10px rgba(0,0,0,0.05);">
                            <MudIcon Icon="@Icons.Material.Filled.HistoryToggleOff" Size="Size.Large" Style="color:#dee2e6; width:80px; height:80px;" />
                            <MudText Typo="Typo.h5" Class="mt-4"
                                     Style="color:#adb5bd; font-family:var(--font-body); font-weight:800;">
                                @(_searchString == "" ? "NO RESULTS" : "NO EVENTS FOUND")
                            </MudText>
                        </MudPaper>
                    }
                    else
                    {
                        @foreach (var group in finishedEvents.GroupBy(e => $"{GetSchoolLevelName(e.LevelID)} • {GetCategoryShort(e.MainCategory)} • {GetEventStageName(e.StageID)}"))
                        {
                            <div class="sport-section">
                                <div class="sport-title-row">
                                    <div class="sport-name" title="@group.Key" style="width:100%">
                                        <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Style="color: var(--pal-gold);" />
                                        <span style="min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@group.Key</span>
                                    </div>
                                </div>

                                <MudGrid Spacing="3">
                                    @foreach (var evt in group.OrderByDescending(x => x.ID))
                                    {
                                        <MudItem xs="12" sm="6" lg="4" xl="3">
                                            <a class="match-link" href="javascript:void(0)" @onclick="() => NavigateToEvent(evt.ID)">
                                                <div class="tv-card" style="border-top-color:#6c757d; opacity:.92;">
                                                    <div class="card-status-bar">
                                                        <div class="final-badge">FINISH</div>
                                                        <div class="phase-text">@GetEventStageName(evt.StageID)</div>
                                                    </div>

                                                    <div class="card-body">
                                                        <MudText Typo="Typo.subtitle2"
                                                                 Style="font-family:var(--font-body); font-weight:800; color:var(--pal-dark-blue); text-transform:uppercase;">
                                                            @($"{GetCategoryShort(evt.MainCategory)} • {GetSchoolLevelName(evt.LevelID)}")
                                                        </MudText>

                                                        <div style="margin-top:8px;">
                                                            <div class="leaders-label">TOP 3</div>

                                                            @{
                                                                var top3 = GetTopCouples(evt.ID, 3);
                                                            }

                                                            @if (!top3.Any())
                                                            {
                                                                <div class="muted">NO SCORES FOUND</div>
                                                            }
                                                            else
                                                            {
                                                                <div class="leaderboard-mini">
                                                                    @foreach (var couple in top3)
                                                                    {
                                                                        <div class="couple-row @($"rank-{couple.Rank}")">
                                                                            <div class="rank-box">@couple.Rank</div>
                                                                            <div class="couple-info">
                                                                                <div class="couple-region">@couple.Region</div>
                                                                                <div class="couple-names">@string.Join(" & ", couple.Dancers)</div>
                                                                            </div>
                                                                            <div class="couple-score">@couple.TotalScore</div>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>

                                                    <div class="card-footer">VIEW RESULTS</div>
                                                </div>
                                            </a>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </div>
                        }
                    }
                </MudTabPanel>

            </MudTabs>
        }

    </MudContainer>
</div>

@code {
    // --- MODELS ---
    public class PerformanceEvent
    {
        public int ID { get; set; }
        public string MainCategory { get; set; } = "";
        public int? LevelID { get; set; }
        public int? GenderID { get; set; }
        public int? StageID { get; set; }
        public bool IsFinished { get; set; }
    }

    public class PerformanceTeam
    {
        public int PerformanceID { get; set; }
        public int? TeamID { get; set; }
        public int RegionID { get; set; }
        public string PlayerID { get; set; } = "";
    }

    public class PerformanceScores
    {
        public int PerformanceID { get; set; }
        public int? TeamID { get; set; }
        public decimal Score { get; set; }
        public int Rank { get; set; }
        public int SportSubcategoryID { get; set; }
    }

    public class SchoolRegion
    {
        public int ID { get; set; }
        public string Region { get; set; } = "";
        public string Abbreviation { get; set; } = "";
    }

    public class Player
    {
        public string ID { get; set; } = "";
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
    }

    public class CoupleDisplay
    {
        public string Region { get; set; } = "";
        public List<string> Dancers { get; set; } = new();
        public int Rank { get; set; }
        public int TotalScore { get; set; }
    }

    // --- STATE ---
    private string _searchString = "";
    private List<PerformanceEvent> _dancesportEvents = new();
    private List<PerformanceTeam> _allOpposingTeams = new();
    private List<PerformanceScores> _allDancesportScores = new();
    private List<SchoolRegion> _schoolRegions = new();
    private List<Player> _allPlayers = new();
    private bool _isLoading = true;
    private Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadInitialData();
        _timer = new Timer(async _ => await InvokeAsync(RefreshDynamicData), null, 3000, 3000);
    }

    private async Task LoadInitialData()
    {
        _isLoading = true;
        try
        {
            var regionsTask = apiService.GetAsync<SchoolRegion>("/Schools/Regions");
            var playersTask = apiService.GetAsync<Player>("/Profiles/Player");

            await Task.WhenAll(regionsTask, playersTask);

            _schoolRegions = (await regionsTask) ?? new();
            _allPlayers = (await playersTask) ?? new();

            await RefreshDynamicData();
        }
        catch
        {
            // ignore
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task RefreshDynamicData()
    {
        try
        {
            var eventsTask = apiService.GetAsync<PerformanceEvent>("/PerformanceBased/PerformanceEvents?sportID=10");
            var teamsTask = apiService.GetAsync<PerformanceTeam>("/PerformanceBased/OpposingTeams");
            var scoresTask = apiService.GetAsync<PerformanceScores>("/PerformanceScore/Scores");

            await Task.WhenAll(eventsTask, teamsTask, scoresTask);

            var events = await eventsTask;
            _dancesportEvents = events != null ? events.OrderBy(x => x.IsFinished).ToList() : new();

            var eventIds = _dancesportEvents.Select(e => e.ID).ToHashSet();

            var teams = await teamsTask;
            _allOpposingTeams = teams != null ? teams.Where(t => eventIds.Contains(t.PerformanceID)).ToList() : new();

            var scores = await scoresTask;
            _allDancesportScores = scores != null ? scores.Where(s => eventIds.Contains(s.PerformanceID)).ToList() : new();

            StateHasChanged();
        }
        catch
        {
            // ignore
        }
    }

    private bool FilterFunction(PerformanceEvent element)
    {
        if (string.IsNullOrWhiteSpace(_searchString)) return true;

        if (element.MainCategory?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (GetSchoolLevelName(element.LevelID).Contains(_searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (GetGenderName(element.GenderID).Contains(_searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (GetEventStageName(element.StageID).Contains(_searchString, StringComparison.OrdinalIgnoreCase)) return true;

        return false;
    }

    public void Dispose() => _timer?.Dispose();

    private void NavigateToEvent(int eventId) => Navigation.NavigateTo($"/scoreboard/dancesport/{eventId}");

    // --- HELPERS ---
    private string GetCategoryShort(string cat) =>
        cat.Contains("Latin", StringComparison.OrdinalIgnoreCase) ? "LATIN AMERICAN"
        : (cat.Contains("Standard", StringComparison.OrdinalIgnoreCase) ? "MODERN STANDARD" : "DANCESPORT");

    private string GetSchoolLevelName(int? id) => id switch
    {
        1 => "ELEMENTARY",
        2 => "SECONDARY",
        _ => "OPEN"
    };

    private string GetGenderName(int? id) => id switch
    {
        1 => "MALE",
        2 => "FEMALE",
        3 => "MIXED",
        _ => "MIXED"
    };

    private string GetEventStageName(int? id) => id switch
    {
        4 => "FINALS",
        3 => "SEMI-FINALS",
        _ => "QUALIFIERS"
    };

    private List<CoupleDisplay> GetTopCouples(int eventId, int limit)
    {
        var result = new List<CoupleDisplay>();

        var couples = _allOpposingTeams
            .Where(t => t.PerformanceID == eventId)
            .GroupBy(t => new { t.RegionID, t.TeamID });

        foreach (var c in couples)
        {
            var reg = _schoolRegions.FirstOrDefault(r => r.ID == c.Key.RegionID)?.Abbreviation ?? "REG";

            var pIds = c.Select(x => x.PlayerID).ToList();
            var names = _allPlayers
                .Where(p => pIds.Contains(p.ID))
                .Select(p => $"{(string.IsNullOrEmpty(p.FirstName) ? "" : $"{p.FirstName[0]}. ")}{p.LastName}")
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .ToList();

            var teamScores = _allDancesportScores
                .Where(s => s.PerformanceID == eventId && s.TeamID == c.Key.TeamID)
                .ToList();

            int rank = teamScores.Any() ? teamScores.Min(s => s.Rank) : 99;
            int score = teamScores.Any() ? (int)Math.Round(teamScores.Sum(s => s.Score)) : 0;

            if (rank < 99)
            {
                result.Add(new CoupleDisplay
                {
                    Region = reg,
                    Dancers = names,
                    Rank = rank,
                    TotalScore = score
                });
            }
        }

        return result
            .OrderBy(x => x.Rank)
            .Take(limit)
            .ToList();
    }
}