@page "/scoreboard/field-events"
@using Client.Palaro2026.Services
@using System.Linq
@using System.Threading
@layout NoMainLayout
@inject APIService apiService
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Field Events Scoreboard | Palaro tu AgSur 2026</PageTitle>

<style>
    /* --- THEME IMPORTS (MATCH DANCESPORT) --- */
    @@import url('https://fonts.cdnfonts.com/css/evil-empire');
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&family=Chakra+Petch:wght@600;700;800&display=swap');

    :root {
        /* PALARO COLOR PALETTE */
        --pal-blue: #023E8A;
        --pal-dark-blue: #001845;
        --pal-gold: #FFB400;
        --pal-red: #EA0000;
        --pal-white: #ffffff;
        /* LIGHT THEME VARS */
        --bg-gradient-start: #f8f9fa;
        --card-bg: rgba(255, 255, 255, 0.95);
        /* FONTS */
        --font-header: 'Evil Empire', sans-serif;
        --font-subheader: 'Chakra Petch', sans-serif;
        --font-body: 'Nunito', sans-serif;
    }

    /* Scrollbar */
    ::-webkit-scrollbar {
        width: 8px;
    }

    ::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    ::-webkit-scrollbar-thumb {
        background: #ccc;
        border-radius: 4px;
    }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--pal-blue);
        }

    html, body {
        height: 100%;
        width: 100%;
        margin: 0;
        background-color: var(--bg-gradient-start);
        font-family: var(--font-body);
        overflow-x: hidden;
    }

    .tv-screen-bg {
        min-height: 100vh;
        width: 100vw;
        background: radial-gradient(circle at 50% 30%, #ffffff 0%, #e0e7ff 100%);
        padding-bottom: 50px;
    }

    /* --- HEADER (PILL STYLE) --- */
    .dashboard-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin: 10px 0 20px 0;
    }

    .header-pill {
        background: var(--pal-dark-blue);
        border: 3px solid var(--pal-gold);
        padding: 20px 60px;
        border-radius: 50px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        min-width: min(920px, 92vw);
    }

    .main-event-title {
        font-family: var(--font-header);
        color: white;
        font-size: clamp(2rem, 4vw, 3.5rem);
        letter-spacing: 2px;
        margin: 0;
        line-height: 1;
        text-shadow: 2px 2px 0px black;
        text-transform: uppercase;
    }

    .sub-header-text {
        font-family: var(--font-subheader);
        color: var(--pal-gold);
        font-size: 1.05rem;
        letter-spacing: 3px;
        font-weight: 800;
        text-transform: uppercase;
        margin-top: 6px;
    }

    /* --- TABS --- */
    .mud-tabs-tabbar {
        background: transparent !important;
    }

    .mud-tab {
        font-family: var(--font-header) !important;
        font-size: 1.5rem !important;
        letter-spacing: 1px;
        color: #adb5bd !important;
        text-transform: uppercase;
    }

    .mud-tab-active {
        color: var(--pal-blue) !important;
        text-shadow: 0 0 1px rgba(2, 62, 138, 0.5);
    }

    .mud-tabs-indicator {
        background-color: var(--pal-gold) !important;
        height: 4px;
        border-radius: 4px;
    }

    /* --- SECTION --- */
    .sport-section {
        margin-bottom: 40px;
        background: white;
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        border: 1px solid #e9ecef;
    }

    .sport-title-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 2px solid var(--pal-gold);
        gap: 12px;
    }

    .sport-name {
        font-family: var(--font-header);
        font-size: 1.6rem;
        color: var(--pal-dark-blue);
        display: flex;
        align-items: center;
        gap: 10px;
        letter-spacing: 1px;
        min-width: 0;
        width: 100%;
    }

    /* --- CARD (MATCH DANCESPORT tv-card) --- */
    .event-link {
        text-decoration: none;
        display: block;
        height: 100%;
    }

    .tv-card {
        background-color: white;
        border: 1px solid #dee2e6;
        border-top: 5px solid var(--pal-blue);
        border-radius: 15px;
        padding: 15px;
        position: relative;
        height: 520px; /* keep your fixed height */
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        overflow: hidden;
    }

        .tv-card, .tv-card * {
            min-height: 0;
        }

            .tv-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 15px 30px rgba(0,0,0,0.15);
                border-top-color: var(--pal-gold);
            }

    .card-status-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
        border-bottom: 1px solid #f1f1f1;
        padding-bottom: 8px;
        gap: 10px;
    }

    .live-badge, .final-badge {
        font-family: var(--font-subheader);
        font-weight: 900;
        font-size: 0.75rem;
        padding: 4px 12px;
        border-radius: 999px;
        letter-spacing: 1px;
        text-transform: uppercase;
        white-space: nowrap;
        line-height: 1;
    }

    .live-badge {
        background: var(--pal-red);
        color: white;
        box-shadow: 0 2px 5px rgba(234, 0, 0, 0.3);
    }

    .final-badge {
        background: #343a40;
        color: white;
    }

    .phase-text {
        font-family: var(--font-subheader);
        color: #6c757d;
        font-size: 0.85rem;
        font-weight: 800;
        text-transform: uppercase;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 70%;
        text-align: right;
        margin-left: auto;
    }

    .card-body {
        display: flex;
        flex-direction: column;
        gap: 10px;
        flex: 1;
        min-height: 0;
    }

    .evt-title {
        font-family: var(--font-subheader);
        font-weight: 900;
        color: var(--pal-dark-blue);
        text-transform: uppercase;
        letter-spacing: .5px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .evt-sub {
        font-family: var(--font-body);
        font-weight: 800;
        color: #6b7280;
        font-size: 0.85rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .leaders-label {
        font-family: var(--font-subheader);
        font-weight: 900;
        letter-spacing: 1px;
        text-transform: uppercase;
        font-size: 0.78rem;
        color: rgba(0,24,69,.55);
        margin: 6px 0 0 0;
    }

    /* --- FIELD PILL (DANCESPORT STYLE) --- */
    .field-pill {
        font-family: var(--font-subheader);
        font-weight: 900;
        letter-spacing: 1px;
        text-transform: uppercase;
        font-size: 0.78rem;
        color: var(--pal-gold);
        background: var(--pal-dark-blue);
        border-radius: 999px;
        padding: 6px 12px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        width: fit-content;
        max-width: 100%;
        border: 2px solid rgba(255,180,0,.55);
        box-shadow: 0 8px 18px rgba(0,0,0,0.08);
        margin-top: 6px;
    }

    /* --- RANKINGS PANEL (SCROLL AREA) --- */
    .rankings-container {
        flex: 1;
        min-height: 0;
        margin-top: 10px;
        border-radius: 16px;
        border: 1px solid rgba(2,62,138,0.12);
        background: linear-gradient(180deg, rgba(255,180,0,0.08), rgba(2,62,138,0.03));
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .rankings-scroll {
        flex: 1;
        min-height: 0;
        overflow-y: auto;
        padding: 10px;
        padding-right: 6px;
    }

        .rankings-scroll::-webkit-scrollbar {
            width: 6px;
        }

        .rankings-scroll::-webkit-scrollbar-track {
            background: rgba(0,0,0,0.05);
        }

        .rankings-scroll::-webkit-scrollbar-thumb {
            background: var(--pal-gold);
            border-radius: 3px;
        }

    .player-row {
        display: grid;
        grid-template-columns: 46px 1fr auto;
        align-items: center;
        gap: 10px;
        padding: 10px;
        border-radius: 14px;
        border: 1px solid rgba(2,62,138,0.10);
        background: rgba(255,255,255,0.65);
        position: relative;
        overflow: hidden;
    }

        .player-row + .player-row {
            margin-top: 8px;
        }

        .player-row::before {
            content: "";
            position: absolute;
            left: 0;
            top: 0;
            width: 6px;
            height: 100%;
            background: rgba(0,0,0,0.12);
        }

    .player-rank {
        width: 46px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-subheader);
        font-weight: 900;
        border-radius: 999px;
        border: 2px solid #e9ecef;
        background: #fff;
        color: rgba(0,24,69,.85);
        z-index: 1;
    }

    .rank-1 {
        background: rgba(255,180,0,0.14);
        border-color: rgba(255,180,0,0.35);
    }

        .rank-1::before {
            background: var(--pal-gold);
        }

    .rank-2 {
        background: rgba(2,62,138,0.07);
        border-color: rgba(2,62,138,0.18);
    }

        .rank-2::before {
            background: rgba(192,192,192,0.9);
        }

    .rank-3 {
        background: rgba(234,102,0,0.08);
        border-color: rgba(205,127,50,0.25);
    }

        .rank-3::before {
            background: rgba(205,127,50,0.9);
        }

    .player-info {
        min-width: 0;
        z-index: 1;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .player-name {
        font-family: var(--font-body);
        font-weight: 900;
        color: #212529;
        line-height: 1.1;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .player-region {
        font-family: var(--font-subheader);
        font-weight: 900;
        color: var(--pal-dark-blue);
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .player-score {
        font-family: var(--font-subheader);
        font-weight: 900;
        font-size: 1.0rem;
        color: var(--pal-blue);
        z-index: 1;
        white-space: nowrap;
    }

    .meta-row {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        padding: 10px;
        border-top: 1px solid rgba(0,0,0,0.06);
        background: rgba(255,255,255,0.65);
    }

    .meta-badge {
        display: inline-flex;
        align-items: center;
        padding: 4px 10px;
        border-radius: 999px;
        background: rgba(2, 62, 138, 0.08);
        border: 1px solid rgba(2, 62, 138, 0.18);
        color: var(--pal-blue);
        font-family: var(--font-subheader);
        font-weight: 900;
        font-size: 0.72rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        white-space: nowrap;
        max-width: 48%;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .muted {
        text-align: center;
        color: #adb5bd;
        font-size: 0.85rem;
        font-weight: 900;
        letter-spacing: .5px;
        text-transform: uppercase;
        padding: 12px 0;
    }

    .card-footer {
        text-align: center;
        margin-top: 12px;
        color: #6c757d;
        font-family: var(--font-subheader);
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        border-top: 1px solid #f1f1f1;
        padding-top: 8px;
    }

    .panel-state {
        background-color: white;
        border-radius: 20px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        padding: 60px 20px;
        text-align: center;
        margin-top: 24px;
        border: 1px solid #e9ecef;
    }

    .panel-title {
        font-family: var(--font-header);
        font-size: 1.6rem;
        color: #adb5bd;
        text-transform: uppercase;
        margin-top: 12px;
    }

    .panel-sub {
        font-family: var(--font-body);
        font-weight: 800;
        color: #6c757d;
        margin-top: 8px;
    }

    .loading-spinner {
        color: var(--pal-blue);
    }

    @@media (max-width: 600px) {
        .header-pill {
            padding: 18px 20px;
        }
    }
</style>

<div class="tv-screen-bg">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge">

        <!-- HEADER -->
        <div class="dashboard-header">
            <div class="header-pill">
                <h1 class="main-event-title">FIELD EVENTS</h1>
                <div class="sub-header-text">OFFICIAL DASHBOARD</div>
            </div>
        </div>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="mt-16">
                <MudProgressCircular Indeterminate="true" Class="loading-spinner" Size="Size.Large" />
                <MudText Typo="Typo.h6" Class="mt-4" Style="font-family:var(--font-header); color:var(--pal-blue);">
                    LOADING FIELD EVENTS...
                </MudText>
            </MudStack>
        }
        else if (!_allEvents.Any())
        {
            <div class="panel-state">
                <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Size="Size.Large" Style="font-size:80px;color:#dee2e6;" />
                <div class="panel-title">NO FIELD EVENTS</div>
                <div class="panel-sub">Waiting for event data to be available.</div>
            </div>
        }
        else
        {
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="mt-4" Centered="true">

                <!-- LIVE / ONGOING -->
                <MudTabPanel Text="LIVE EVENTS">
                    @{
                        var liveEvents = _ongoingEvents;
                    }

                    @if (!liveEvents.Any())
                    {
                        <div class="panel-state">
                            <MudIcon Icon="@Icons.Material.Filled.Stream" Size="Size.Large" Style="font-size:80px;color:#dee2e6;" />
                            <div class="panel-title">NO LIVE EVENTS</div>
                            <div class="panel-sub">Stand by for updates.</div>
                        </div>
                    }
                    else
                    {
                        @foreach (var group in liveEvents.GroupBy(e => $"{(e.Gender ?? "Mixed")} • {(e.Level ?? "Open")}"))
                        {
                            <div class="sport-section">
                                <div class="sport-title-row">
                                    <div class="sport-name" title="@group.Key">
                                        <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Style="color: var(--pal-gold);" />
                                        <span style="min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@group.Key</span>
                                    </div>
                                </div>

                                <MudGrid Spacing="3">
                                    @foreach (var evt in group.OrderBy(x => x.Subcategory))
                                    {
                                        <MudItem xs="12" sm="6" lg="4" xl="3">
                                            <a href="@GetEventUrl(evt)" target="_blank" class="event-link">
                                                <div class="tv-card">

                                                    <div class="card-status-bar">
                                                        <div class="live-badge">LIVE</div>
                                                        <div class="phase-text">@((evt.Level ?? "OPEN").ToUpper())</div>
                                                    </div>

                                                    <div class="card-body">
                                                        <div class="evt-title">@((evt.Subcategory ?? "FIELD EVENT").ToUpper())</div>
                                                        <div class="evt-sub">@($"{evt.Gender ?? "MIXED"} • {evt.Level ?? "OPEN"}")</div>

                                                        <div class="field-pill">
                                                            <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Size="Size.Small" />
                                                            @(evt.SportMainCat ?? "FIELD EVENT")
                                                        </div>

                                                        <div class="leaders-label">CURRENT LEADERS</div>

                                                        <div class="rankings-container">
                                                            <div class="rankings-scroll">
                                                                @if (_eventRankings.TryGetValue(evt.ID, out var list) && list != null && list.Any())
                                                                {
                                                                    @foreach (var p in list)
                                                                    {
                                                                        <div class="player-row @GetRankClass(p.Rank)">
                                                                            <div class="player-rank">
                                                                                @(p.Rank > 0 ? p.Rank.ToString() : "-")
                                                                            </div>
                                                                            <div class="player-info">
                                                                                <span class="player-region">@p.RegionAbbreviation</span>
                                                                                <span class="player-name">@p.PlayerName</span>
                                                                            </div>
                                                                            <div class="player-score">@p.BestResult.ToString("0.00")</div>
                                                                        </div>
                                                                    }
                                                                }
                                                                else
                                                                {
                                                                    <div class="muted">WAITING FOR PARTICIPANTS...</div>
                                                                }
                                                            </div>

                                                            <div class="meta-row">
                                                                <span class="meta-badge">@((evt.Gender ?? "MIXED").ToUpper())</span>
                                                                <span class="meta-badge">LEVEL: @((evt.Level ?? "OPEN").ToUpper())</span>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="card-footer">VIEW EVENT</div>
                                                </div>
                                            </a>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </div>
                        }
                    }
                </MudTabPanel>

                <!-- PARTIAL RESULTS -->
                <MudTabPanel Text="PARTIAL RESULTS">
                    @{
                        var finishedEvents = _finishedEvents;
                    }

                    @if (!finishedEvents.Any())
                    {
                        <div class="panel-state">
                            <MudIcon Icon="@Icons.Material.Filled.HistoryToggleOff" Size="Size.Large" Style="font-size:80px;color:#dee2e6;" />
                            <div class="panel-title">NO RESULTS YET</div>
                            <div class="panel-sub">Final standings will appear once events are completed.</div>
                        </div>
                    }
                    else
                    {
                        @foreach (var group in finishedEvents.GroupBy(e => $"{(e.Gender ?? "Mixed")} • {(e.Level ?? "Open")}"))
                        {
                            <div class="sport-section">
                                <div class="sport-title-row">
                                    <div class="sport-name" title="@group.Key">
                                        <MudIcon Icon="@Icons.Material.Filled.MilitaryTech" Style="color: var(--pal-gold);" />
                                        <span style="min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@group.Key</span>
                                    </div>
                                </div>

                                <MudGrid Spacing="3">
                                    @foreach (var evt in group.OrderBy(x => x.Subcategory))
                                    {
                                        <MudItem xs="12" sm="6" lg="4" xl="3">
                                            <a href="@GetEventUrl(evt)" target="_blank" class="event-link">
                                                <div class="tv-card" style="border-top-color:#6c757d; opacity:.92;">

                                                    <div class="card-status-bar">
                                                        <div class="final-badge">FINAL</div>
                                                        <div class="phase-text">@((evt.Level ?? "OPEN").ToUpper())</div>
                                                    </div>

                                                    <div class="card-body">
                                                        <div class="evt-title">@((evt.Subcategory ?? "FIELD EVENT").ToUpper())</div>
                                                        <div class="evt-sub">@($"{evt.Gender ?? "MIXED"} • {evt.Level ?? "OPEN"}")</div>

                                                        <div class="field-pill" style="background:#343a40; border-color: rgba(0,0,0,.10);">
                                                            <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Size="Size.Small" />
                                                            FINAL
                                                        </div>

                                                        <div class="leaders-label">TOP RESULTS</div>

                                                        <div class="rankings-container">
                                                            <div class="rankings-scroll">
                                                                @if (_eventRankings.TryGetValue(evt.ID, out var list) && list != null && list.Any())
                                                                {
                                                                    @foreach (var p in list)
                                                                    {
                                                                        <div class="player-row @GetRankClass(p.Rank)">
                                                                            <div class="player-rank">
                                                                                @(p.Rank > 0 ? p.Rank.ToString() : "-")
                                                                            </div>
                                                                            <div class="player-info">
                                                                                <span class="player-region">@p.RegionAbbreviation</span>
                                                                                <span class="player-name">@p.PlayerName</span>
                                                                            </div>
                                                                            <div class="player-score">@p.BestResult.ToString("0.00")</div>
                                                                        </div>
                                                                    }
                                                                }
                                                                else
                                                                {
                                                                    <div class="muted">NO RANKINGS AVAILABLE</div>
                                                                }
                                                            </div>

                                                            <div class="meta-row">
                                                                <span class="meta-badge">@((evt.Gender ?? "MIXED").ToUpper())</span>
                                                                <span class="meta-badge">LEVEL: @((evt.Level ?? "OPEN").ToUpper())</span>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="card-footer">VIEW RESULTS</div>
                                                </div>
                                            </a>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </div>
                        }
                    }
                </MudTabPanel>

            </MudTabs>
        }

    </MudContainer>
</div>

@code {
    public class EventsDTO
    {
        public class EventDetails
        {
            public class Event
            {
                public string ID { get; set; } = null!;
                public string? EventStage { get; set; }
                public List<EventVersusTeams>? EventVersusList { get; set; }
                public string? SportMainCat { get; set; }
                public string? Category { get; set; }
                public string? Sport { get; set; }
                public string? GamePhase { get; set; }
                public int? SubCategoryID { get; set; }
                public string? Subcategory { get; set; }
                public string? Gender { get; set; }
                public string? Level { get; set; }
                public string? Venue { get; set; }
                public decimal? Latitude { get; set; }
                public decimal? Longitude { get; set; }
                public DateTime? Date { get; set; }
                public TimeSpan? Time { get; set; }
                public bool? OnStream { get; set; }
                public string? StreamService { get; set; }
                public string? StreamURL { get; set; }
                public bool? IsFinished { get; set; }
                public bool? Archived { get; set; }
                public bool? Deleted { get; set; }
                public string? FirstName { get; set; }
                public string? LastName { get; set; }
            }

            public class EventVersusTeams
            {
                public int ID { get; set; }
                public string? Score { get; set; }
                public string? Region { get; set; }
                public string? Abbreviation { get; set; }
                public List<EventVersusTeamPlayers>? EventVersusTeamPlayersList { get; set; }
                public string? Rank { get; set; }
                public DateTime? RecentUpdateAt { get; set; }
            }

            public class EventVersusTeamPlayers
            {
                public int ID { get; set; }
                public int? EventVersusID { get; set; }
                public string? FirstName { get; set; }
                public string? LastName { get; set; }
                public string? School { get; set; }
            }
        }
    }

    public class RankingDTO
    {
        public int RegionID { get; set; }
        public string? PlayerID { get; set; }
        public decimal BestResult { get; set; }
        public string RegionAbbreviation { get; set; } = "";
        public string? PlayerName { get; set; }
        public int Rank { get; set; }
    }

    private List<EventsDTO.EventDetails.Event> _allEvents = new();
    private List<EventsDTO.EventDetails.Event> _ongoingEvents = new();
    private List<EventsDTO.EventDetails.Event> _finishedEvents = new();
    private Dictionary<string, List<RankingDTO>> _eventRankings = new();

    private bool _isLoading = true;
    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        _timer = new System.Threading.Timer(async _ => await InvokeAsync(LoadData), null, 10000, 10000);
    }

    private async Task LoadData()
    {
        try
        {
            var allEvents = await apiService.GetAsync<EventsDTO.EventDetails.Event>("/Events/Details");

            if (allEvents != null)
            {
                _allEvents = allEvents
                    .Where(e =>
                        e.Sport != null &&
                        e.Sport.Equals("Athletics", StringComparison.OrdinalIgnoreCase) &&
                        e.SportMainCat != null &&
                        e.SportMainCat.Contains("Field", StringComparison.OrdinalIgnoreCase))
                    .OrderBy(x => x.IsFinished == true)
                    .ThenBy(x => x.Level)
                    .ThenBy(x => x.Gender)
                    .ThenBy(x => x.Subcategory)
                    .ToList();

                _ongoingEvents = _allEvents.Where(e => e.IsFinished != true).ToList();
                _finishedEvents = _allEvents.Where(e => e.IsFinished == true).ToList();

                var ids = _allEvents.Select(e => e.ID).ToHashSet();
                foreach (var key in _eventRankings.Keys.ToList())
                    if (!ids.Contains(key)) _eventRankings.Remove(key);

                foreach (var evt in _allEvents)
                {
                    try
                    {
                        var rankings = await apiService.GetAsync<RankingDTO>($"FieldEvents/GetRankings/{evt.ID}");
                        _eventRankings[evt.ID] = (rankings ?? new List<RankingDTO>())
                            .OrderBy(r => r.Rank <= 0 ? int.MaxValue : r.Rank)
                            .ToList();
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"Could not load rankings for event {evt.ID}: {ex.Message}");
                        _eventRankings[evt.ID] = new List<RankingDTO>();
                    }
                }
            }
            else
            {
                _allEvents = new();
                _ongoingEvents = new();
                _finishedEvents = new();
                _eventRankings = new();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading field events: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private string GetRankClass(int rank) => rank switch
    {
        1 => "rank-1",
        2 => "rank-2",
        3 => "rank-3",
        _ => ""
    };

    private string GetEventUrl(EventsDTO.EventDetails.Event evt)
        => evt == null ? "#" : $"/scoreboard/field-events/{evt.ID}";

    public void Dispose()
    {
        _timer?.Dispose();
        _timer = null;
    }
}