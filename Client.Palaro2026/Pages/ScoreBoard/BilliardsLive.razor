@page "/scoreboard/billiards/{EventID}"
@using System.Threading
@using System.Linq
@using Client.Palaro2026.Services
@inject APIService apiService
@inject NavigationManager Navigation
@implements IDisposable
@layout ClientLayout

<PageTitle>Billiards Live | Palaro tu AgSur 2026</PageTitle>

<style>
    /* --- FONTS & VARS (SAME AS ARCHERY) --- */
    @@import url('https://fonts.cdnfonts.com/css/evil-empire');
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&family=Chakra+Petch:wght@600;700;800&display=swap');

    :root {
        --pal-blue: #023E8A;
        --pal-dark-blue: #001845;
        --pal-gold: #FFB400;
        --pal-red: #EA0000;
        --bg-gradient-start: #f8f9fa;
        --card-bg: rgba(255, 255, 255, 0.98);
        --font-header: 'Evil Empire', sans-serif;
        --font-body: 'Nunito', sans-serif;
    }

    body, html {
        margin: 0;
        padding: 0;
        overflow: hidden;
        background-color: var(--pal-dark-blue);
        font-family: var(--font-body);
    }

    ::deep header, ::deep .mud-appbar, ::deep .layout-header, ::deep footer, ::deep .layout-footer {
        display: none !important;
    }

    ::deep .mud-main-content {
        padding: 0 !important;
        margin: 0 !important;
    }

    .tv-screen {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: radial-gradient(circle at 50% 30%, #ffffff 0%, #e0e7ff 100%);
        display: flex;
        flex-direction: column;
        align-items: center;
        box-sizing: border-box;
        z-index: 999;
    }

    /* --- HEADER (ARCHERY STYLE) --- */
    .match-info-container {
        text-align: center;
        margin-top: clamp(10px, 2vh, 30px);
        margin-bottom: clamp(10px, 2vh, 20px);
        padding: clamp(8px, 1.2vh, 20px) clamp(30px, 4vw, 60px);
        border-radius: 50px;
        background: var(--pal-dark-blue);
        border: clamp(3px, 0.4vh, 6px) solid var(--pal-gold);
        box-shadow: 0 10px 25px rgba(0,0,0,0.3);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        z-index: 10;
        min-width: 30%;
        max-width: 92vw;
    }

    .sport-title {
        font-family: var(--font-header);
        font-size: clamp(2rem, 4vh, 3rem);
        color: white;
        text-transform: uppercase;
        letter-spacing: 2px;
        line-height: 1;
        text-shadow: 3px 3px 0px #000000;
    }

    .match-meta {
        font-family: 'Chakra Petch', sans-serif;
        font-size: clamp(0.9rem, 1.5vh, 1.3rem);
        color: var(--pal-gold);
        letter-spacing: 2px;
        font-weight: 700;
        text-transform: uppercase;
        margin-top: 5px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 86vw;
    }

    /* --- CUSTOM PURE CSS SLIDER --- */
    .custom-slider-container {
        position: relative;
        width: 100vw;
        height: 78vh;
        overflow: hidden;
    }

    .custom-slide {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.6s ease-in-out, visibility 0.6s ease-in-out;
        z-index: 1;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding-top: 5px;
    }

        .custom-slide.active {
            opacity: 1;
            visibility: visible;
            z-index: 2;
        }

    /* --- CARDS GRID (same feel as archery) --- */
    .pairings-container {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: clamp(10px, 1.5vh, 20px) clamp(10px, 1vw, 20px);
        width: 96%;
        max-width: none;
    }

    @@media (max-width: 1200px) {
        .pairings-container {
            grid-template-columns: 1fr;
        }
    }

    .match-card {
        width: 100%;
        background: var(--card-bg);
        border: 1px solid #d1d9e6;
        border-top: clamp(4px, 0.5vh, 8px) solid var(--pal-gold);
        border-bottom: clamp(4px, 0.5vh, 8px) solid var(--pal-blue);
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        border-radius: clamp(15px, 1.5vh, 20px);
        padding: clamp(10px, 1.5vh, 20px) clamp(8px, 1vw, 15px);
        position: relative;
        display: flex;
        flex-direction: column;
        min-height: 28vh;
    }

    .match-stage-label {
        position: absolute;
        top: calc(-1 * clamp(10px, 1.5vh, 16px));
        left: 50%;
        transform: translateX(-50%);
        background: var(--pal-red);
        color: white;
        padding: clamp(3px, 0.5vh, 5px) clamp(15px, 2vw, 25px);
        border-radius: 30px;
        font-family: 'Chakra Petch';
        font-weight: 800;
        font-size: clamp(0.7rem, 1.1vh, 1rem);
        text-transform: uppercase;
        border: 2px solid white;
        box-shadow: 0 4px 10px rgba(234, 0, 0, 0.3);
        letter-spacing: 1px;
        white-space: nowrap;
    }

    .teams-grid {
        display: grid;
        grid-template-columns: 1fr 0.15fr 1fr;
        align-items: center;
        margin-bottom: clamp(5px, 1vh, 10px);
        margin-top: clamp(10px, 2vh, 18px);
    }

    .team-display {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        min-width: 0;
    }

    .logo-circle {
        width: clamp(48px, 7vh, 90px);
        height: clamp(48px, 7vh, 90px);
        background: white;
        border-radius: 50%;
        border: clamp(2px, 0.3vh, 4px) solid #e9ecef;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: clamp(4px, 0.6vh, 8px);
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
        margin-bottom: clamp(4px, 0.6vh, 8px);
        transition: transform 0.3s;
        box-sizing: border-box;
    }

    .winning-glow {
        border-color: var(--pal-gold);
        box-shadow: 0 0 clamp(8px, 1.5vh, 20px) rgba(255, 180, 0, 0.6);
        transform: scale(1.05);
    }

    .team-name {
        font-family: var(--font-header);
        font-size: clamp(1rem, 2.3vh, 2rem);
        color: var(--pal-dark-blue);
        line-height: 1;
        margin-bottom: 2px;
        width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        text-transform: uppercase;
    }

    .team-region {
        font-size: clamp(0.65rem, 1.2vh, 1rem);
        font-weight: 800;
        color: #888;
        background: #f1f3f5;
        padding: clamp(2px, 0.3vh, 4px) clamp(6px, 1vw, 10px);
        border-radius: 8px;
        text-transform: uppercase;
    }

    .team-points {
        font-family: 'Chakra Petch', sans-serif;
        font-size: clamp(2.2rem, 6vh, 5.2rem);
        font-weight: 900;
        color: #0018459c;
        line-height: 1;
        margin-top: clamp(2px, 0.5vh, 8px);
    }

    .points-lead {
        color: var(--pal-gold);
        text-shadow: 4px 4px 0px rgba(0, 24, 69, 0.1);
    }

    .vs-separator {
        font-family: var(--font-header);
        font-size: clamp(1.2rem, 2.8vh, 2.8rem);
        color: #e0e0e0;
        text-align: center;
        font-style: italic;
    }

    .history-section {
        border-top: 2px dashed #e9ecef;
        padding-top: clamp(6px, 1vh, 10px);
        margin-top: auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
    }

    .mini-meta {
        font-family: 'Chakra Petch';
        font-weight: 800;
        color: #555;
        letter-spacing: 1px;
        text-transform: uppercase;
        font-size: clamp(0.7rem, 1.2vh, 1rem);
    }

    .mini-badge {
        background: var(--pal-dark-blue);
        color: var(--pal-gold);
        padding: 6px 12px;
        border-radius: 10px;
        font-family: 'Chakra Petch';
        font-weight: 900;
        font-size: clamp(0.75rem, 1.3vh, 1.05rem);
        text-transform: uppercase;
        white-space: nowrap;
    }

    /* --- CAROUSEL INDICATORS & CONTROLS (ARCHERY STYLE) --- */
    .carousel-wrapper {
        position: fixed;
        bottom: clamp(15px, 3vh, 30px);
        left: 0;
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 100;
        pointer-events: none;
    }

    .carousel-indicators {
        display: flex;
        gap: clamp(8px, 1.5vw, 15px);
        pointer-events: auto;
    }

    .carousel-dot {
        width: clamp(12px, 2vh, 20px);
        height: clamp(12px, 2vh, 20px);
        border-radius: 50%;
        background-color: rgba(2, 62, 138, 0.3);
        border: 2px solid var(--pal-blue);
        transition: all 0.4s ease;
        cursor: pointer;
    }

        .carousel-dot.active {
            background-color: var(--pal-gold);
            border-color: var(--pal-gold);
            transform: scale(1.4);
            box-shadow: 0 0 10px rgba(255, 180, 0, 0.8);
        }

    .carousel-controls {
        position: absolute;
        right: clamp(20px, 4vw, 50px);
        display: flex;
        gap: 10px;
        pointer-events: auto;
    }

    .control-btn {
        background: var(--pal-dark-blue);
        color: white;
        border: 2px solid rgba(255,255,255,0.2);
        border-radius: 50%;
        width: clamp(35px, 5vh, 50px);
        height: clamp(35px, 5vh, 50px);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }

        .control-btn:hover {
            background: var(--pal-gold);
            color: var(--pal-dark-blue);
            border-color: var(--pal-gold);
            transform: scale(1.1);
        }

        .control-btn.active-play {
            border-color: var(--pal-gold);
            color: var(--pal-gold);
        }
</style>

<div class="tv-screen">

    <!-- HEADER -->
    <div class="match-info-container">
        @if (_isLoading)
        {
            <div class="sport-title" style="font-size:clamp(1.5rem, 3vh, 2.5rem);">LOADING...</div>
        }
        else if (_event == null)
        {
            <div class="sport-title" style="font-size:clamp(1.5rem, 3vh, 2.5rem); color:var(--pal-red);">EVENT NOT FOUND</div>
        }
        else
        {
            <div class="sport-title">BILLIARDS</div>
            <div class="match-meta">@_event.Level • @_event.Gender @_event.Subcategory</div>
        }
    </div>

    @if (!_isLoading && _event != null)
    {
        <div class="custom-slider-container">

            @{
                var pages = _allMatches.Chunk(_itemsPerPage).ToList();
            }

            @if (!pages.Any())
            {
                <MudText Typo="Typo.h4" Align="Align.Center" Style="color:var(--pal-dark-blue); font-family: 'Evil Empire'; margin-top:10vh;">
                    WAITING FOR MATCHES...
                </MudText>
            }
            else
            {
                @foreach (var item in pages.Select((page, idx) => new { page, idx }))
                {
                    <div class="custom-slide @(item.idx == _pageIndex ? "active" : "")">
                        <div class="pairings-container">
                            @foreach (var match in item.page)
                            {
                                bool p1Win = match.Player1IsWinner == true;
                                bool p2Win = match.Player2IsWinner == true;

                                <div class="match-card">
                                    <div class="match-stage-label">
                                        TABLE @match.TableNo
                                    </div>

                                    <div class="teams-grid">
                                        <!-- P1 -->
                                        <div class="team-display">
                                            <div class="logo-circle @(p1Win ? "winning-glow" : "")">
                                                <MudImage Src="@GetRegionLogo(match.Player1Region)" ObjectFit="ObjectFit.Contain" Style="width:100%; height:100%;" />
                                            </div>
                                            <div class="team-name">@GetShortName(match.Player1Name, match.Player1Region)</div>
                                            <span class="team-region">@match.Player1Region</span>
                                            <div class="team-points @(p1Win ? "points-lead" : "")">@match.Player1Score</div>
                                        </div>

                                        <div class="vs-separator">VS</div>

                                        <!-- P2 -->
                                        <div class="team-display">
                                            <div class="logo-circle @(p2Win ? "winning-glow" : "")">
                                                <MudImage Src="@GetRegionLogo(match.Player2Region)" ObjectFit="ObjectFit.Contain" Style="width:100%; height:100%;" />
                                            </div>
                                            <div class="team-name">@GetShortName(match.Player2Name, match.Player2Region)</div>
                                            <span class="team-region">@match.Player2Region</span>
                                            <div class="team-points @(p2Win ? "points-lead" : "")">@match.Player2Score</div>
                                        </div>
                                    </div>

                                    <div class="history-section">
                                        <div class="mini-meta">LIVE SCORE</div>
                                        <div class="mini-badge">SET @match.SetNo</div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- CAROUSEL INDICATORS & CONTROLS -->
                @if (pages.Count > 1)
                {
                    <div class="carousel-wrapper">
                        <div class="carousel-indicators">
                            @for (int i = 0; i < pages.Count; i++)
                            {
                                int idx = i;
                                <div class="carousel-dot @(idx == _pageIndex ? "active" : "")" @onclick="() => SetPage(idx)"></div>
                            }
                        </div>

                        <div class="carousel-controls">
                            <button class="control-btn" @onclick="PrevPage" title="Previous Page">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowBackIosNew" Size="Size.Small" />
                            </button>
                            <button class="control-btn @(_isAutoPlay ? "active-play" : "")" @onclick="ToggleAutoPlay" title="Play/Pause Carousel">
                                <MudIcon Icon="@(_isAutoPlay? Icons.Material.Filled.Pause : Icons.Material.Filled.PlayArrow)" Size="Size.Small" />
                            </button>
                            <button class="control-btn" @onclick="NextPage" title="Next Page">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForwardIos" Size="Size.Small" />
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    [Parameter] public string EventID { get; set; } = "";

    // MODELS (same as your billiards)
    public class EventInfo { public string ID { get; set; } = ""; public string Subcategory { get; set; } = ""; public string Level { get; set; } = ""; public string Gender { get; set; } = ""; public string Sport { get; set; } = ""; }
    public class MatchInfo
    {
        public int TableNo { get; set; }
        public int SetNo { get; set; }
        public string Player1Name { get; set; } = "";
        public string Player1Region { get; set; } = "";
        public int Player1Score { get; set; }
        public bool? Player1IsWinner { get; set; }
        public string Player2Name { get; set; } = "";
        public string Player2Region { get; set; } = "";
        public int Player2Score { get; set; }
        public bool? Player2IsWinner { get; set; }
        public bool IsCompleted { get; set; }
    }
    public class SchoolRegions { public string Region { get; set; } = ""; public string Abbreviation { get; set; } = ""; }
    public class BilliardsResult
    {
        public int SetNo { get; set; }
        public int TableNo { get; set; }
        public string PlayerPosition { get; set; } = "";
        public int? Score { get; set; }
        public bool? IsWinner { get; set; }
        public string Region { get; set; } = "";
        public string Abbreviation { get; set; } = "";
        public string PlayerName { get; set; } = "";
    }

    private EventInfo? _event;
    private List<MatchInfo> _allMatches = new();
    private List<SchoolRegions>? _regions;
    private bool _isLoading = true;

    // Carousel State (archery style)
    private int _pageIndex = 0;
    private bool _isAutoPlay = true;
    private int _itemsPerPage = 4;

    private System.Timers.Timer? _dataTimer;
    private System.Timers.Timer? _carouselTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();

        _dataTimer = new System.Timers.Timer(1000);
        _dataTimer.Elapsed += async (s, e) => { await InvokeAsync(LoadData); };
        _dataTimer.Start();

        _carouselTimer = new System.Timers.Timer(12000);
        _carouselTimer.Elapsed += (s, e) =>
        {
            if (!_isAutoPlay) return;
            InvokeAsync(() =>
            {
                NextPageLogic();
                StateHasChanged();
            });
        };
        _carouselTimer.Start();
    }

    private void ToggleAutoPlay()
    {
        _isAutoPlay = !_isAutoPlay;
        RestartCarouselTimer();
    }

    private void SetPage(int index)
    {
        _pageIndex = index;
        RestartCarouselTimer();
    }

    private void NextPage()
    {
        NextPageLogic();
        RestartCarouselTimer();
    }

    private void PrevPage()
    {
        int totalPages = (int)Math.Ceiling(_allMatches.Count / (double)_itemsPerPage);
        if (totalPages <= 1) return;

        _pageIndex = (_pageIndex - 1 + totalPages) % totalPages;
        RestartCarouselTimer();
    }

    private void NextPageLogic()
    {
        int totalPages = (int)Math.Ceiling(_allMatches.Count / (double)_itemsPerPage);
        if (totalPages <= 1) return;

        _pageIndex = (_pageIndex + 1) % totalPages;
    }

    private void RestartCarouselTimer()
    {
        if (_carouselTimer == null) return;
        _carouselTimer.Stop();
        _carouselTimer.Start();
    }

    private async Task LoadData()
    {
        try
        {
            if (_regions == null) _regions = await apiService.GetAsync<SchoolRegions>("/Schools/Regions");

            var evts = await apiService.GetAsync<EventInfo>("/Events/Details");
            _event = evts?.FirstOrDefault(e => e.ID == EventID && (e.Sport ?? "").Contains("Billiard", StringComparison.OrdinalIgnoreCase));

            if (_event != null)
            {
                var results = await apiService.GetAsync<BilliardsResult>($"/BilliardsScoring/event/{EventID}");
                if (results != null)
                {
                    var matchDict = new Dictionary<(int setNo, int tableNo), MatchInfo>();

                    foreach (var r in results)
                    {
                        var key = (r.SetNo, r.TableNo);
                        if (!matchDict.ContainsKey(key))
                            matchDict[key] = new MatchInfo { SetNo = r.SetNo, TableNo = r.TableNo };

                        var m = matchDict[key];
                        string reg = r.Abbreviation ?? r.Region ?? "";

                        if (r.PlayerPosition == "Player1")
                        {
                            m.Player1Name = r.PlayerName;
                            m.Player1Region = reg;
                            m.Player1Score = r.Score ?? 0;
                            m.Player1IsWinner = r.IsWinner;
                        }
                        else
                        {
                            m.Player2Name = r.PlayerName;
                            m.Player2Region = reg;
                            m.Player2Score = r.Score ?? 0;
                            m.Player2IsWinner = r.IsWinner;
                        }

                        if (r.IsWinner.HasValue) m.IsCompleted = true;
                    }

                    // Latest set only (same as your old logic)
                    int maxSet = matchDict.Values.Any() ? matchDict.Values.Max(x => x.SetNo) : 0;

                    _allMatches = matchDict.Values
                        .Where(m => m.SetNo == maxSet)
                        .Where(m => !string.IsNullOrEmpty(m.Player1Region) && !string.IsNullOrEmpty(m.Player2Region))
                        .OrderBy(m => m.TableNo)
                        .ToList();

                    int totalPages = (int)Math.Ceiling(_allMatches.Count / (double)_itemsPerPage);
                    if (totalPages <= 0) totalPages = 1;
                    if (_pageIndex >= totalPages) _pageIndex = 0;
                }
            }

            _isLoading = false;
            StateHasChanged();
        }
        catch
        {
            _isLoading = false;
        }
    }

    public void Dispose()
    {
        _dataTimer?.Stop(); _dataTimer?.Dispose();
        _carouselTimer?.Stop(); _carouselTimer?.Dispose();
    }

    private string GetRegionLogo(string reg)
    {
        var r = _regions?.FirstOrDefault(x => x.Abbreviation == reg || x.Region == reg);
        string name = r?.Region ?? reg ?? "Default";
        return $"https://palarongpambansa2026.com/attachments/media/regions/team_logo/{Uri.EscapeDataString(name)}.webp";
    }

    private string GetShortName(string name, string reg) => string.IsNullOrEmpty(name) ? (reg ?? "PLAYER") : name;
}