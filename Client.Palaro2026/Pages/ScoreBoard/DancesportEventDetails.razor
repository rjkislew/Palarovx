@page "/scoreboard/dancesport/{EventID:int}"
@layout ClientLayout
@using System.Threading
@using System.Linq
@using Client.Palaro2026.Services
@inject APIService apiService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Dancesport Event Details | Palaro tu AgSur 2026</PageTitle>

<style>
    @@import url('https://fonts.cdnfonts.com/css/evil-empire');
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&family=Chakra+Petch:wght@600;700;800&display=swap');

    :root {
        --pal-blue: #023E8A;
        --pal-dark-blue: #001845;
        --pal-gold: #FFB400;
        --pal-red: #EA0000;
        --font-header: 'Evil Empire', sans-serif;
        --font-subheader: 'Chakra Petch', sans-serif;
        --font-body: 'Nunito', sans-serif;
        --wrapMax: 2400px;
    }

    body {
        background: #f8f9fa;
        margin: 0;
        font-family: var(--font-body);
        overflow-x: hidden;
    }

    .tv-screen-bg {
        min-height: 100vh;
        width: 100vw;
        background: radial-gradient(circle at 50% 30%, #ffffff 0%, #e0e7ff 100%);
        padding: 26px 0 12vh 0;
        position: relative;
    }

    .wrap, .summary-strip, .page-footer {
        width: min(var(--wrapMax), 96vw);
        margin-left: auto;
        margin-right: auto;
    }

    .back-button {
        position: fixed;
        top: 16px;
        left: 16px;
        z-index: 3000;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: white;
        color: var(--pal-dark-blue);
        border: 2px solid #e9ecef;
        padding: 10px 16px;
        border-radius: 999px;
        cursor: pointer;
        font-family: var(--font-subheader);
        font-weight: 900;
        letter-spacing: 1px;
        text-transform: uppercase;
        box-shadow: 0 6px 18px rgba(0,0,0,0.08);
        transition: all .2s ease;
        font-size: 0.95rem;
    }

        .back-button:hover {
            border-color: var(--pal-gold);
            box-shadow: 0 10px 25px rgba(0,0,0,0.12);
            transform: translateY(-1px);
        }

    /* HEADER */
    .dashboard-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin: 60px 0 18px 0;
    }

    .header-pill {
        background: var(--pal-dark-blue);
        border: 4px solid var(--pal-gold);
        padding: 18px 64px;
        border-radius: 50px;
        text-align: center;
        box-shadow: 0 12px 28px rgba(0,0,0,0.2);
        max-width: calc(100% - 60px);
    }

    .main-event-title {
        font-family: var(--font-header);
        color: white;
        font-size: clamp(2.6rem, 3.6vw, 4.6rem);
        letter-spacing: 3px;
        margin: 0;
        line-height: 1;
        text-shadow: 3px 3px 0px black;
        text-transform: uppercase;
    }

    .sub-header-text {
        font-family: var(--font-subheader);
        color: var(--pal-gold);
        font-size: clamp(0.95rem, 1.2vw, 1.35rem);
        letter-spacing: 4px;
        font-weight: 900;
        text-transform: uppercase;
        margin-top: 10px;
        opacity: 0.98;
    }

    /* ===== CARDS GRID (FINALS) ===== */
    .cards-grid {
        margin-top: 14px;
        display: grid;
        grid-template-columns: repeat(12, minmax(0, 1fr));
        gap: 16px;
        align-items: stretch;
    }

    .dance-card {
        grid-column: span 3; /* 4 per row */
        background: white;
        border-radius: 18px;
        border: 1px solid #e9ecef;
        box-shadow: 0 10px 22px rgba(0,0,0,0.06);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        min-width: 0;
        height: 100%;
    }

    /* 6 cards => last row fill */
    .cards-grid .dance-card:nth-child(5),
    .cards-grid .dance-card:nth-child(6) {
        grid-column: span 6;
    }

    .dance-card-head {
        padding: 14px 16px;
        background: #fbfbfd;
        border-bottom: 3px solid var(--pal-gold);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    .dance-title {
        font-family: var(--font-header);
        color: var(--pal-dark-blue);
        letter-spacing: 2px;
        text-transform: uppercase;
        font-size: 1.4rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        min-width: 0;
    }

    .badge-final, .badge-live {
        font-family: var(--font-subheader);
        font-weight: 900;
        font-size: 0.9rem;
        padding: 6px 12px;
        color: white;
        border-radius: 999px;
        letter-spacing: 1px;
        text-transform: uppercase;
        white-space: nowrap;
        flex: 0 0 auto;
    }

    .badge-live { background: var(--pal-red); }
    .badge-final { background: #343a40; }

    .dance-card-body {
        padding: 10px 12px 12px 12px;
        flex: 1 1 auto;
        display: flex;
        flex-direction: column;
        min-height: 0;
    }

    .card-carousel-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 6px 4px 10px 4px;
    }

    .card-page {
        font-family: var(--font-subheader);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #6c757d;
        font-size: 0.78rem;
        white-space: nowrap;
    }

    .dance-table thead th {
        font-family: var(--font-subheader) !important;
        font-weight: 900 !important;
        text-transform: uppercase !important;
        letter-spacing: 2px !important;
        color: var(--pal-dark-blue) !important;
        background: #ffffff !important;
        border-bottom: 1px solid #f1f1f1 !important;
        padding: 12px 12px !important;
        font-size: 0.9rem !important;
        white-space: nowrap;
    }

    .dance-table tbody td {
        border-bottom: 1px solid #f1f1f1 !important;
        padding: 12px 12px !important;
        vertical-align: middle;
        font-size: 1.05rem !important;
        font-weight: 800;
    }

    .rank-pill {
        min-width: 44px;
        height: 34px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-header);
        font-size: 1.2rem;
        color: var(--pal-dark-blue);
        background: #fff;
        border: 2px solid #e9ecef;
    }

    .rank1 { border-color: #FFD700; box-shadow: 0 0 12px rgba(255,215,0,.45); }
    .rank2 { border-color: #C0C0C0; box-shadow: 0 0 10px rgba(192,192,192,.35); }
    .rank3 { border-color: #CD7F32; box-shadow: 0 0 10px rgba(205,127,50,.35); }

    .couple-cell {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
    }

    .mini-logo {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: #fff;
        border: 2px solid #e9ecef;
        padding: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 10px rgba(0,0,0,.08);
        flex: 0 0 auto;
    }

    .couple-text {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .couple-name {
        font-weight: 900;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .couple-region {
        font-family: var(--font-subheader);
        font-weight: 900;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #6c757d;
        font-size: 0.8rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .dot {
        width: 9px;
        height: 9px;
        border-radius: 999px;
        background: #dee2e6;
        display: inline-block;
        margin: 0 3px;
    }
        .dot.active {
            background: var(--pal-gold);
            box-shadow: 0 0 0 4px rgba(255, 180, 0, 0.14);
        }

    .page-footer {
        margin: 16px auto 0 auto;
        text-align: center;
        color: #6c757d;
        font-family: var(--font-subheader);
        font-size: 1.0rem;
        font-weight: 900;
        text-transform: uppercase;
        border-top: 1px solid #f1f1f1;
        padding-top: 14px;
        letter-spacing: 2px;
    }

    @@media (max-width: 1400px) {
        .dance-card { grid-column: span 6; }
        .cards-grid .dance-card:nth-child(5),
        .cards-grid .dance-card:nth-child(6) { grid-column: span 6; }
    }

    @@media (max-width: 800px) {
        .dance-card { grid-column: span 12; }
        .cards-grid .dance-card:nth-child(5),
        .cards-grid .dance-card:nth-child(6) { grid-column: span 12; }
    }

    /* ===== ELIMINATION VIEW ===== */
    .elim-wrap {
        margin-top: 14px;
        display: grid;
        grid-template-columns: repeat(12, minmax(0, 1fr));
        gap: 16px;
    }

    .elim-couples {
        grid-column: span 12;
        background: #ffffff;
        border: 1px solid #e9ecef;
        border-radius: 18px;
        box-shadow: 0 10px 22px rgba(0,0,0,0.06);
        overflow: hidden;
    }

    .elim-couples-head {
        padding: 14px 18px;
        background: #fbfbfd;
        border-bottom: 3px solid var(--pal-gold);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    .elim-couples-title {
        font-family: var(--font-header);
        color: var(--pal-dark-blue);
        letter-spacing: 2px;
        text-transform: uppercase;
        font-size: 1.6rem;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

    .elim-couples-body { padding: 14px 16px 16px 16px; }

    .elim-panels {
        grid-column: span 12;
        display: grid;
        grid-template-columns: repeat(12, minmax(0, 1fr));
        gap: 16px;
    }

    .elim-panel {
        grid-column: span 6;
        border-radius: 18px;
        overflow: hidden;
        border: 1px solid #e9ecef;
        box-shadow: 0 10px 22px rgba(0,0,0,0.06);
        background: #fff;
        min-width: 0;
    }

    .elim-panel.qualified {
        background: linear-gradient(180deg, rgba(76,175,80,0.10) 0%, #ffffff 55%);
        border-color: rgba(76,175,80,0.35);
    }

    .elim-panel.eliminated {
        background: linear-gradient(180deg, rgba(234,0,0,0.08) 0%, #ffffff 55%);
        border-color: rgba(234,0,0,0.28);
    }

    .elim-panel-head {
        padding: 14px 16px;
        background: rgba(255,255,255,0.75);
        border-bottom: 1px solid #f1f1f1;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .elim-panel-title {
        font-family: var(--font-header);
        letter-spacing: 2px;
        text-transform: uppercase;
        font-size: 1.35rem;
        color: #212529;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

    .elim-chip-wrap {
        padding: 14px 16px 16px 16px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .elim-chip {
        border-radius: 999px;
        padding: 10px 18px;
        background: var(--pal-dark-blue);
        color: #fff;
        font-family: var(--font-subheader);
        font-weight: 900;
        letter-spacing: 1px;
        text-transform: uppercase;
        border: 2px solid rgba(255,255,255,0.18);
        box-shadow: 0 8px 16px rgba(0,0,0,0.08);
        font-size: 0.95rem;
    }

    .elim-empty {
        padding: 24px 16px;
        color: #adb5bd;
        font-family: var(--font-subheader);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    @@media (max-width: 1100px) {
        .elim-panel { grid-column: span 12; }
    }

 .rank-wrap {
    min-width: 160px;
    height: 64px;
    padding: 0 20px;
    border-radius: 999px;

    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-align: center;

    /* 👇 MATCH REGION HEADER FONT */
    font-family: var(--font-subheader);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;

    color: var(--pal-dark-blue);
    background: #ffffff;
    border: 2px solid #e9ecef;

    white-space: nowrap;
}

        /* optional variants */
        .rank-wrap.qualified {
            border-color: var(--pal-gold);
            background: #fff8e1;
        }

        .rank-wrap.eliminated {
            border-color: #dee2e6;
            background: #f8f9fa;
            color: #6c757d;
        }
</style>

<div class="tv-screen-bg">
    <button class="back-button" @onclick="GoBack">← Back</button>

    @if (_isLoading)
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height:70vh;">
            <MudProgressCircular Indeterminate Color="Color.Primary" Size="Size.Large" />
            <MudText Typo="Typo.h6" Class="mt-4" Style="font-family:var(--font-header); color:var(--pal-blue);">
                LOADING DANCESPORT EVENT...
            </MudText>
        </MudStack>
    }
    else if (_event == null)
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height:70vh;">
            <MudText Typo="Typo.h4" Style="font-family:var(--font-header); color: var(--pal-red);">
                EVENT NOT FOUND
            </MudText>
        </MudStack>
    }
    else
    {
        <div class="dashboard-header">
            <div class="header-pill">
                <h1 class="main-event-title">DANCESPORT</h1>
                <div class="sub-header-text">
                    @GetSchoolLevelName(_event.LevelID) -  @GetCategoryShort(_event.MainCategory) - @GetEventStageName(_event.StageID)
                </div>
            </div>
        </div>

        <div class="wrap">

            @if (IsFinalStage)
            {
                <!-- ✅ FINALS VIEW -->
                <div class="cards-grid">
                    @foreach (var dk in _danceOrder)
                    {
                        var full = GetRowsForDance(dk);
                        var pageRows = GetPageRows(dk, full);

                        <div class="dance-card">
                            <div class="dance-card-head">
                                <div class="dance-title">@DanceLabel(dk)</div>
                              @*   <div class="@(_event.IsFinished ? "badge-final" : "badge-live")">
                                    @(_event.IsFinished ? "FINAL" : "LIVE")
                                </div> *@
                            </div>

                            <div class="dance-card-body">
                                @if (full.Count == 0)
                                {
                                    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="padding:22px 10px;">
                                        <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty" Style="color:#dee2e6; width:56px; height:56px;" />
                                        <MudText Typo="Typo.subtitle1" Style="color:#adb5bd; font-family:var(--font-header);">
                                            WAITING FOR SCORES
                                        </MudText>
                                    </MudStack>
                                }
                                else
                                {
                                    <div class="card-carousel-bar">
                                        <div class="card-page">
                                            PAGE @(GetPageIndex(dk) + 1) / @Math.Max(1, GetPageCount(full))
                                        </div>
                                        <div>
                                            @for (int i = 0; i < Math.Max(1, GetPageCount(full)); i++)
                                            {
                                                <span class="dot @(i == GetPageIndex(dk) ? "active" : "")"></span>
                                            }
                                        </div>
                                    </div>

                                    <MudTable Class="dance-table"
                                              Items="pageRows"
                                              Dense="false"
                                              Hover="true"
                                              Elevation="0">
                                        <HeaderContent>
                                            <MudTh Style="width: 20%;">Rank</MudTh>
                                            <MudTh Style="width: 80%;">Couple</MudTh>
                                        </HeaderContent>

                                        <RowTemplate>
                                            @{
                                                var cls = context.Rank switch
                                                {
                                                    1 => "rank1",
                                                    2 => "rank2",
                                                    3 => "rank3",
                                                    _ => ""
                                                };
                                            }

                                            <MudTd>
                                                <span class="rank-pill @cls">@context.Rank</span>
                                            </MudTd>

                                            <MudTd>
                                                <div class="couple-cell">
                                                    <div class="mini-logo">
                                                        <MudImage Src="@GetRegionLogo(context.RegionName)"
                                                                  Alt="@context.RegionName"
                                                                  ObjectFit="ObjectFit.Contain"
                                                                  Style="width:100%; height:100%;" />
                                                    </div>

                                                    <div class="couple-text">
                                                        <div class="couple-name">@context.CoupleName</div>
                                                        <div class="couple-region">@context.RegionName</div>
                                                    </div>
                                                </div>
                                            </MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <!-- ✅ ELIMINATION / QF / SF VIEW -->
                <div class="elim-wrap">

                    <div class="elim-couples">
                        <div class="elim-couples-head">
                            <div class="elim-couples-title">
                                <MudIcon Icon="@Icons.Material.Filled.People" />
                                QUALIFIED COUPLES
                            </div>

                            <div class="card-page">
                                @GetEventStageName(_event.StageID)
                            </div>
                        </div>

                        <div class="elim-couples-body">
                            @if (_qualifiedCouples.Count == 0)
                            {
                                <div class="elim-empty">No qualified couples yet</div>
                            }
                            else
                            {
                                <MudTable Class="dance-table"
                                          Items="_qualifiedCouples"
                                          Dense="false"
                                          Hover="true"
                                          Elevation="0">
                                    <HeaderContent>
                                        <MudTh Style="width: 20%;">Region</MudTh>
                                        <MudTh Style="width: 40%; text-align:center">Couple</MudTh>
                                        <MudTh Style="width: 40%; text-align:center">Status</MudTh>
                                    </HeaderContent>

                                    <RowTemplate>
                                        <!-- REGION -->
                                        <MudTd style="width:20%;">
                                            <div class="couple-cell">
                                                <div class="mini-logo">
                                                    <MudImage Src="@GetRegionLogo(context.RegionName)"
                                                              Alt="@context.RegionName"
                                                              ObjectFit="ObjectFit.Contain"
                                                              Style="width:100%; height:100%;" />
                                                </div>
                                                <div class="couple-text">
                                                    <div class="couple-name">@context.RegionName</div>
                                                </div>
                                            </div>
                                        </MudTd>

                                        <!-- COUPLE NAME -->
                                        <MudTd style="width:40%; text-align:center;">
                                            <div class="rank-wrap">
                                                @context.CoupleName
                                            </div>
                                        </MudTd>

                                        <!-- STATUS -->
                                        <MudTd style="width:40%; text-align:center;">
                                            <div class="rank-wrap qualified">
                                                Qualified
                                            </div>
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                        </div>
                    </div>

                </div>
            }

        </div>
    }
</div>

<Brand />

@code {
    [Parameter] public int EventID { get; set; }

    private const int RowsPerPage = 4;
    private const int AutoMs = 4500;
    private const int RefreshMs = 8000;

    private Timer? _autoTimer;
    private Timer? _refreshTimer;
    private readonly SemaphoreSlim _lock = new(1, 1);

    private bool _isLoading = true;

    // ===== API models =====
    public class PerformanceEvent
    {
        public int ID { get; set; }
        public int? SportID { get; set; }
        public string MainCategory { get; set; } = "";
        public int? LevelID { get; set; }
        public int? GenderID { get; set; }
        public int? StageID { get; set; }
        public bool IsFinished { get; set; }
    }

    public class PerformanceTeam
    {
        public int ID { get; set; }
        public int PerformanceID { get; set; }
        public int? TeamID { get; set; }
        public int RegionID { get; set; }
        public string PlayerID { get; set; } = "";
    }

    public class PerformanceScore
    {
        public int ID { get; set; }
        public int PerformanceID { get; set; }
        public int SportSubcategoryID { get; set; }
        public decimal Score { get; set; }
        public int Rank { get; set; }
        public int? TeamID { get; set; }
    }

    public class SchoolRegion
    {
        public int ID { get; set; }
        public string Region { get; set; } = "";
        public string? Abbreviation { get; set; }
    }

    public class Player
    {
        public string ID { get; set; } = "";
        public string? FirstName { get; set; }
        public string? LastName { get; set; }
    }

    public class SportSubcategory
    {
        public int ID { get; set; }
        public string? Subcategory { get; set; }
        public int? SportID { get; set; }
        public int? SchoolLevelID { get; set; }
        public string? MainCategory { get; set; }
    }

    public class TabulationResultDTO
    {
        public int? SportID { get; set; }
        public int? PerformanceID { get; set; }
        public int SportSubcategoryID { get; set; }
        public int? TeamID { get; set; }
        public int? SchoolRegionID { get; set; }
        public string? TeamRank { get; set; }
        public int? EventStageID { get; set; }
    }

    public class DanceRow
    {
        public int Rank { get; set; }
        public int RegionID { get; set; }
        public string RegionName { get; set; } = "";
        public int? TeamID { get; set; }
        public List<string> PlayerIDs { get; set; } = new();
        public string CoupleName { get; set; } = "";
    }

    // ===== Elimination status row =====
    public class CoupleStatusRow
    {
        public int RegionID { get; set; }
        public string RegionName { get; set; } = "";
        public int TeamID { get; set; }
        public string CoupleName { get; set; } = "";
        public string Status { get; set; } = "Pending"; // Qualified / Eliminated / Pending
    }

    private List<CoupleStatusRow> _allCouples = new();
    private List<string> _qualifiedRegions = new();
    private List<string> _eliminatedRegions = new();

    private PerformanceEvent? _event;
    private List<PerformanceTeam> _opposingTeams = new();
    private List<PerformanceScore> _scoresForEvent = new();
    private List<SchoolRegion> _regions = new();
    private List<Player> _players = new();
    private List<SportSubcategory> _sportSubcategories = new();
    private List<TabulationResultDTO> _tabulation = new();

    private Dictionary<DanceKey, List<DanceRow>> _danceRows = new();
    private Dictionary<DanceKey, int> _pageIndex = new();

    private enum DanceKey
    {
        Chachacha, Jive, PasoDoble, Rumba, Samba,
        Tango, Foxtrot, Quickstep, VienneseWaltz, Waltz,
        GradeAOverall
    }

    private List<CoupleStatusRow> _qualifiedCouples => _allCouples
    .Where(x => x.Status == "Qualified")
    .ToList();

    private readonly List<DanceKey> _latinOrder = new()
    {
        DanceKey.Chachacha, DanceKey.Jive, DanceKey.PasoDoble, DanceKey.Rumba, DanceKey.Samba, DanceKey.GradeAOverall
    };

    private readonly List<DanceKey> _standardOrder = new()
    {
        DanceKey.Tango, DanceKey.Foxtrot, DanceKey.Quickstep, DanceKey.VienneseWaltz, DanceKey.Waltz, DanceKey.GradeAOverall
    };

    private List<DanceKey> _danceOrder = new();

    private bool IsLatinEvent =>
        (_event?.MainCategory ?? "").Contains("Latin", StringComparison.OrdinalIgnoreCase);

    private bool IsFinalStage => (_event?.StageID ?? 0) == 4;

    protected override async Task OnInitializedAsync()
    {
        await LoadInitialData();

        _refreshTimer = new Timer(async _ => await InvokeAsync(RefreshScoresOnly), null, RefreshMs, RefreshMs);

        _autoTimer = new Timer(async _ =>
        {
            if (_event == null) return;

            await InvokeAsync(() =>
            {
                // Rotate pages only when finals (cards are shown)
                if (IsFinalStage)
                {
                    foreach (var dk in _danceOrder)
                    {
                        var full = GetRowsForDance(dk);
                        var pages = Math.Max(1, GetPageCount(full));
                        var idx = GetPageIndex(dk);
                        _pageIndex[dk] = (idx + 1) % pages;
                    }
                }

                StateHasChanged();
            });
        }, null, AutoMs, AutoMs);
    }

    private async Task LoadInitialData()
    {
        _isLoading = true;

        try
        {
            var events = await apiService.GetAsync<PerformanceEvent>("/PerformanceBased/PerformanceEvents?sportID=10");
            _event = events?.FirstOrDefault(e => e.ID == EventID);

            if (_event == null)
            {
                _isLoading = false;
                return;
            }

            _danceOrder = IsLatinEvent ? _latinOrder : _standardOrder;

            var regionsTask = apiService.GetAsync<SchoolRegion>("/Schools/Regions");
            var playersTask = apiService.GetAsync<Player>("/Profiles/Player");
            var teamsTask = apiService.GetAsync<PerformanceTeam>("/PerformanceBased/OpposingTeams");
            var subcatsTask = apiService.GetAsync<SportSubcategory>("/Sports/Subcategories");
            var tabTask = apiService.GetAsync<TabulationResultDTO>("/Tabulation/result");

            await Task.WhenAll(regionsTask, playersTask, teamsTask, subcatsTask, tabTask);

            _regions = (await regionsTask) ?? new();
            _players = (await playersTask) ?? new();

            var allTeams = await teamsTask;
            _opposingTeams = allTeams?.Where(t => t.PerformanceID == EventID).ToList() ?? new();

            _sportSubcategories = (await subcatsTask) ?? new();
            _tabulation = (await tabTask) ?? new();

            _pageIndex = _danceOrder.ToDictionary(d => d, _ => 0);

            await RefreshScoresOnly();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading event: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task RefreshScoresOnly()
    {
        if (_event == null) return;

        await _lock.WaitAsync();
        try
        {
            var allScoresTask = apiService.GetAsync<PerformanceScore>("/PerformanceScore/Scores");
            var tabTask = apiService.GetAsync<TabulationResultDTO>("/Tabulation/result");

            await Task.WhenAll(allScoresTask, tabTask);

            var all = (await allScoresTask) ?? new();
            _scoresForEvent = all.Where(s => s.PerformanceID == EventID).ToList();

            _tabulation = (await tabTask) ?? new();

            // Build per-dance rows for finals view
            _danceRows = new();
            foreach (var dk in _danceOrder)
                _danceRows[dk] = BuildRowsForDance(dk);

            foreach (var dk in _danceOrder)
            {
                var pages = Math.Max(1, GetPageCount(GetRowsForDance(dk)));
                if (GetPageIndex(dk) >= pages) _pageIndex[dk] = 0;
            }

            // Build Qualified/Eliminated lists for elimination stages
            BuildQualificationLists();

            StateHasChanged();
        }
        finally
        {
            _lock.Release();
        }
    }

    private int GetPageIndex(DanceKey dk) => _pageIndex.TryGetValue(dk, out var v) ? v : 0;

    private int GetPageCount(List<DanceRow> full)
        => (int)Math.Ceiling((full.Count == 0 ? 1 : full.Count) / (double)RowsPerPage);

    private List<DanceRow> GetPageRows(DanceKey dk, List<DanceRow> full)
    {
        if (full.Count == 0) return new();
        var idx = GetPageIndex(dk);
        return full.Skip(idx * RowsPerPage).Take(RowsPerPage).ToList();
    }

    private List<DanceRow> GetRowsForDance(DanceKey key)
    {
        if (_danceRows.TryGetValue(key, out var list)) return list;
        var built = BuildRowsForDance(key);
        _danceRows[key] = built;
        return built;
    }

    private static string Norm(string? s)
        => new string((s ?? "").ToLowerInvariant().Where(char.IsLetterOrDigit).ToArray());

    private string DanceLabel(DanceKey k) => k switch
    {
        DanceKey.Chachacha => "Chachacha",
        DanceKey.Jive => "Jive",
        DanceKey.PasoDoble => "Paso Doble",
        DanceKey.Rumba => "Rumba",
        DanceKey.Samba => "Samba",

        DanceKey.Tango => "Tango",
        DanceKey.Foxtrot => "Foxtrot",
        DanceKey.Quickstep => "Quickstep",
        DanceKey.VienneseWaltz => "Viennese Waltz",
        DanceKey.Waltz => "Waltz",

        DanceKey.GradeAOverall => IsLatinEvent ? "Grade A - 5 dance" : "Overall Ranking (Grade A)",
        _ => "—"
    };

    private int ResolveSubcatIdForDance(DanceKey key)
    {
        if (_event == null) return 0;

        var list = _sportSubcategories
            .Where(sc =>
                sc.SportID == 10 &&
                sc.SchoolLevelID == _event.LevelID &&
                string.Equals(sc.MainCategory ?? "", _event.MainCategory ?? "", StringComparison.OrdinalIgnoreCase))
            .ToList();

        if (!list.Any()) return 0;

        if (key == DanceKey.GradeAOverall)
        {
            var candidates = IsLatinEvent
                ? new List<string> { "Grade A - 5 dance", "Grade A - 5 Dance", "Grade A 5 dance", "Grade A 5 Dance" }
                : new List<string> { "Overall Ranking (Grade A)", "Overall Ranking Grade A", "Overall (Grade A)", "Grade A Overall" };

            foreach (var c in candidates)
            {
                var t = Norm(c);
                var hit = list.FirstOrDefault(sc =>
                    Norm(sc.Subcategory) == t ||
                    Norm(sc.Subcategory).Contains(t) ||
                    t.Contains(Norm(sc.Subcategory)));

                if (hit != null) return hit.ID;
            }

            var fb = list.FirstOrDefault(sc =>
            {
                var n = Norm(sc.Subcategory);
                return n.Contains("overall") || (n.Contains("grade") && n.Contains("a") && n.Contains("dance"));
            });

            return fb?.ID ?? 0;
        }

        var target = Norm(DanceLabel(key));
        var match = list.FirstOrDefault(sc =>
            Norm(sc.Subcategory) == target ||
            Norm(sc.Subcategory).Contains(target) ||
            target.Contains(Norm(sc.Subcategory)));

        return match?.ID ?? 0;
    }

    private List<DanceRow> BuildRowsForDance(DanceKey key)
    {
        if (_event == null) return new();

        int subcatId = ResolveSubcatIdForDance(key);
        if (subcatId == 0) return new();

        var couples = _opposingTeams
            .Where(t => t.TeamID.HasValue)
            .GroupBy(t => new { t.RegionID, TeamID = t.TeamID!.Value })
            .ToList();

        var rows = new List<DanceRow>();

        foreach (var c in couples)
        {
            var region = _regions.FirstOrDefault(r => r.ID == c.Key.RegionID);
            var playerIds = c.Select(x => x.PlayerID).Distinct().ToList();

            var score = _scoresForEvent
                .Where(s => s.TeamID.HasValue
                         && s.TeamID.Value == c.Key.TeamID
                         && s.SportSubcategoryID == subcatId
                         && s.Rank > 0)
                .OrderBy(s => s.Rank)
                .FirstOrDefault();

            if (score == null) continue;

            var names = _players
                .Where(p => playerIds.Contains(p.ID))
                .OrderBy(p => p.LastName).ThenBy(p => p.FirstName)
                .Select(p => $"{(p.FirstName ?? "").Trim()} {(p.LastName ?? "").Trim()}".Trim())
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .Take(2)
                .ToList();

            var coupleName = names.Count > 0 ? string.Join(" & ", names) : "COUPLE";

            rows.Add(new DanceRow
            {
                Rank = score.Rank,
                RegionID = c.Key.RegionID,
                RegionName = region?.Abbreviation ?? region?.Region ?? "REGION",
                TeamID = c.Key.TeamID,
                PlayerIDs = playerIds,
                CoupleName = coupleName
            });
        }

        return rows.OrderBy(r => r.Rank).Take(3).ToList();
    }

    // ✅ Qualified/Eliminated computation (Tabulation-first, fallback-second)
    private void BuildQualificationLists()
    {
        _allCouples = new();
        _qualifiedRegions = new();
        _eliminatedRegions = new();

        if (_event == null) return;

        // Use OVERALL / GradeA subcategory for qualification
        var overallSubcatId = ResolveSubcatIdForDance(DanceKey.GradeAOverall);
        if (overallSubcatId == 0) return;

        // All couples (team-based)
        var couples = _opposingTeams
            .Where(t => t.TeamID.HasValue)
            .GroupBy(t => new { t.RegionID, TeamID = t.TeamID!.Value })
            .ToList();

        // --- 1) TABULATION BASED (Preferred) ---
        // Expecting TeamRank values like: "Qualified" / "Eliminated"
        var tab = _tabulation
            .Where(x => x.SportID == 10
                     && x.PerformanceID == EventID
                     && x.SportSubcategoryID == overallSubcatId
                     && x.EventStageID == _event.StageID
                     && x.TeamID.HasValue
                     && !string.IsNullOrWhiteSpace(x.TeamRank))
            .ToList();

        bool hasQualiData = tab.Any(x =>
            x.TeamRank!.Equals("Qualified", StringComparison.OrdinalIgnoreCase) ||
            x.TeamRank!.Equals("Eliminated", StringComparison.OrdinalIgnoreCase));

        HashSet<int> qualifiedTeamIds = new();
        HashSet<int> eliminatedTeamIds = new();

        if (hasQualiData)
        {
            foreach (var x in tab)
            {
                if (!x.TeamID.HasValue) continue;

                if (x.TeamRank!.Equals("Qualified", StringComparison.OrdinalIgnoreCase))
                    qualifiedTeamIds.Add(x.TeamID.Value);

                if (x.TeamRank!.Equals("Eliminated", StringComparison.OrdinalIgnoreCase))
                    eliminatedTeamIds.Add(x.TeamID.Value);
            }
        }
        else
        {
            // --- 2) FALLBACK: based on overall ranks ---
            // Change this if your rule is different (top 6, top 10, etc.)
            const int QUALIFY_COUNT = 8;

            var overallScores = _scoresForEvent
                .Where(s => s.SportSubcategoryID == overallSubcatId
                         && s.TeamID.HasValue
                         && s.Rank > 0)
                .OrderBy(s => s.Rank)
                .ToList();

            qualifiedTeamIds = overallScores.Select(s => s.TeamID!.Value).Distinct().Take(QUALIFY_COUNT).ToHashSet();

            var allTeams = overallScores.Select(s => s.TeamID!.Value).Distinct().ToHashSet();
            eliminatedTeamIds = allTeams.Except(qualifiedTeamIds).ToHashSet();
        }

        foreach (var c in couples)
        {
            var region = _regions.FirstOrDefault(r => r.ID == c.Key.RegionID);
            var playerIds = c.Select(x => x.PlayerID).Distinct().ToList();

            var names = _players
                .Where(p => playerIds.Contains(p.ID))
                .OrderBy(p => p.LastName).ThenBy(p => p.FirstName)
                .Select(p => $"{(p.FirstName ?? "").Trim()} {(p.LastName ?? "").Trim()}".Trim())
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .Take(2)
                .ToList();

            var coupleName = names.Count > 0 ? string.Join(" & ", names) : "COUPLE";
            var teamId = c.Key.TeamID;

            string status =
                qualifiedTeamIds.Contains(teamId) ? "Qualified" :
                eliminatedTeamIds.Contains(teamId) ? "Eliminated" :
                "Pending";

            _allCouples.Add(new CoupleStatusRow
            {
                RegionID = c.Key.RegionID,
                RegionName = region?.Abbreviation ?? region?.Region ?? "REGION",
                TeamID = teamId,
                CoupleName = coupleName,
                Status = status
            });
        }

        _allCouples = _allCouples
            .OrderBy(x => x.Status == "Qualified" ? 0 : x.Status == "Pending" ? 1 : 2)
            .ThenBy(x => x.RegionName)
            .ToList();

        _qualifiedRegions = _allCouples
            .Where(x => x.Status == "Qualified")
            .Select(x => x.RegionName)
            .Distinct()
            .OrderBy(x => x)
            .ToList();

        _eliminatedRegions = _allCouples
            .Where(x => x.Status == "Eliminated")
            .Select(x => x.RegionName)
            .Distinct()
            .OrderBy(x => x)
            .ToList();
    }

    private void GoBack() => Navigation.NavigateTo("/scoreboard/dancesport");

    public void Dispose()
    {
        _refreshTimer?.Dispose();
        _autoTimer?.Dispose();
        _lock.Dispose();
    }

    private string GetCategoryShort(string cat)
        => string.IsNullOrWhiteSpace(cat) ? "DANCESPORT"
        : (cat.Contains("Latin", StringComparison.OrdinalIgnoreCase) ? "LATIN AMERICAN"
        : (cat.Contains("Standard", StringComparison.OrdinalIgnoreCase) || cat.Contains("Modern", StringComparison.OrdinalIgnoreCase) ? "MODERN STANDARD" : "DANCESPORT"));

    private string GetSchoolLevelName(int? id) => id switch
    {
        1 => "ELEMENTARY",
        2 => "SECONDARY",
        _ => "OPEN"
    };

    private string GetGenderName(int? id) => id switch
    {
        1 => "MALE",
        2 => "FEMALE",
        3 => "MIXED",
        _ => "GENDER"
    };

    private string GetEventStageName(int? id) => id switch
    {
        1 => "ELIMINATION ROUND",
        2 => "QUARTERFINALS",
        3 => "SEMI-FINALS",
        4 => "FINALS",
        _ => "QUALIFIERS"
    };

    private string GetRegionLogo(string regionName)
    {
        if (string.IsNullOrWhiteSpace(regionName))
            return "/images/region-placeholder.png";

        var r = _regions.FirstOrDefault(x =>
            (x.Abbreviation ?? "").Equals(regionName, StringComparison.OrdinalIgnoreCase) ||
            (x.Region ?? "").Equals(regionName, StringComparison.OrdinalIgnoreCase));

        var actual = (r?.Region ?? regionName).Trim();
        var encoded = Uri.EscapeDataString(actual);

        return $"https://palarongpambansa2026.com/attachments/media/regions/team_logo/{encoded}.webp";
    }
