@page "/scoreboard/field-events/{EventID}"
@using System.Threading
@using System.Linq
@using Client.Palaro2026.Services
@inject APIService apiService
@inject NavigationManager Navigation
@implements IDisposable
@layout NoMainLayout

<PageTitle>Field Events TV View | Palaro tu AgSur 2026</PageTitle>

<style>
    @@import url('https://fonts.cdnfonts.com/css/evil-empire');
    @@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&family=Chakra+Petch:wght@600;700;800&display=swap');

    :root {
        --pal-blue: #023E8A;
        --pal-dark-blue: #001845;
        --pal-gold: #FFB400;
        --pal-red: #EA0000;
        --pal-white: #ffffff;

        --font-header: 'Evil Empire', sans-serif;
        --font-subheader: 'Chakra Petch', sans-serif;
        --font-body: 'Nunito', sans-serif;
    }

    body {
        background: #f8f9fa;
        margin: 0;
        font-family: var(--font-body);
        overflow-x: hidden;
    }

    .tv-screen-bg {
        min-height: 100vh;
        width: 100vw;
        background: radial-gradient(circle at 50% 30%, #ffffff 0%, #e0e7ff 100%);
        padding: 22px 0 14vh 0; /* IMPORTANT: space for fixed footer */
        position: relative;
    }

    .back-button {
        position: fixed;
        top: 16px;
        left: 16px;
        z-index: 3000;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: white;
        color: var(--pal-dark-blue);
        border: 2px solid #e9ecef;
        padding: 10px 14px;
        border-radius: 999px;
        cursor: pointer;
        font-family: var(--font-subheader);
        font-weight: 900;
        letter-spacing: 1px;
        text-transform: uppercase;
        box-shadow: 0 6px 18px rgba(0,0,0,0.08);
        transition: all .2s ease;
    }

    .back-button:hover {
        border-color: var(--pal-gold);
        box-shadow: 0 10px 25px rgba(0,0,0,0.12);
        transform: translateY(-1px);
    }

    .dashboard-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin: 26px 0 16px 0;
    }

    .header-pill {
        background: var(--pal-dark-blue);
        border: 3px solid var(--pal-gold);
        padding: 20px 60px;
        border-radius: 50px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        max-width: calc(100% - 40px);
    }

    .main-event-title {
        font-family: var(--font-header);
        color: white;
        font-size: clamp(2rem, 4vw, 3.5rem);
        letter-spacing: 2px;
        margin: 0;
        line-height: 1;
        text-shadow: 2px 2px 0px black;
        text-transform: uppercase;
    }

    .sub-header-text {
        font-family: var(--font-subheader);
        color: var(--pal-gold);
        font-size: 1.05rem;
        letter-spacing: 3px;
        font-weight: 800;
        text-transform: uppercase;
        margin-top: 6px;
        opacity: 0.95;
    }

    .top-info {
        width: min(1400px, calc(100% - 40px));
        margin: 18px auto;
        background: white;
        border-radius: 20px;
        border: 1px solid #e9ecef;
        box-shadow: 0 8px 18px rgba(0,0,0,0.06);
        overflow: hidden;
    }

    .top-info-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        padding: 14px 16px;
        border-bottom: 1px solid #f1f1f1;
        background: #fbfbfd;
        flex-wrap: wrap;
    }

    .badge-live,
    .badge-final {
        font-family: var(--font-subheader);
        font-weight: 900;
        font-size: 0.78rem;
        padding: 4px 12px;
        color: white;
        border-radius: 999px;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .badge-live { background: var(--pal-red); }
    .badge-final { background: #343a40; }

    .pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-family: var(--font-subheader);
        font-weight: 900;
        font-size: 0.78rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #6c757d;
        padding: 6px 12px;
        border-radius: 999px;
        background: white;
        border: 1px solid #e9ecef;
        max-width: 100%;
    }

    .event-title-block {
        padding: 14px 16px 12px 16px;
    }

    .event-name {
        font-family: var(--font-header);
        font-size: 1.8rem;
        color: var(--pal-dark-blue);
        letter-spacing: 1px;
        text-transform: uppercase;
        line-height: 1.1;
        margin-bottom: 6px;
    }

    .event-sub {
        font-family: var(--font-subheader);
        color: #6c757d;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.9rem;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
    }

    .category-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 6px 12px;
        border-radius: 999px;
        font-family: var(--font-subheader);
        font-size: 0.78rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: white;
    }

    .category-team { background: var(--pal-blue); }
    .category-mixed { background: linear-gradient(90deg, var(--pal-gold), var(--pal-blue)); }
    .category-individual { background: #198754; }

    .results-wrap {
        width: min(1400px, calc(100% - 40px));
        margin: 0 auto;
        background: white;
        border-radius: 20px;
        border: 1px solid #e9ecef;
        box-shadow: 0 8px 18px rgba(0,0,0,0.06);
        overflow: hidden;
    }

    .results-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 14px 16px;
        border-bottom: 2px solid var(--pal-gold);
        flex-wrap: wrap;
    }

    .results-title {
        font-family: var(--font-header);
        font-size: 1.6rem;
        color: var(--pal-dark-blue);
        text-transform: uppercase;
        letter-spacing: 1px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .results-note {
        font-family: var(--font-subheader);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #6c757d;
        font-size: 0.78rem;
    }

    .tv-table .mud-table-container { background: white !important; }
    .tv-table table { width: 100%; }

    .tv-table thead th {
        font-family: var(--font-subheader) !important;
        font-weight: 900 !important;
        text-transform: uppercase !important;
        letter-spacing: 1px !important;
        color: var(--pal-dark-blue) !important;
        background: #fbfbfd !important;
        border-bottom: 1px solid #f1f1f1 !important;
        padding-top: 14px !important;
        padding-bottom: 14px !important;
        font-size: 0.82rem !important;
        white-space: nowrap;
    }

    .tv-table tbody td {
        border-bottom: 1px solid #f1f1f1 !important;
        padding-top: 14px !important;
        padding-bottom: 14px !important;
    }

    .rank-pill {
        font-family: var(--font-subheader);
        font-weight: 900;
        border-radius: 999px;
        border: 2px solid #e9ecef;
        padding: 6px 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 64px;
        background: white;
        color: var(--pal-dark-blue);
    }

    .rank-1 { border-color: #FFD700; box-shadow: 0 0 0 3px rgba(255,215,0,0.18); }
    .rank-2 { border-color: #C0C0C0; box-shadow: 0 0 0 3px rgba(192,192,192,0.16); }
    .rank-3 { border-color: #CD7F32; box-shadow: 0 0 0 3px rgba(205,127,50,0.16); }

    .athlete-name {
        font-family: var(--font-body);
        font-weight: 900;
        color: #212529;
        font-size: 1rem;
        line-height: 1.1;
    }

    .region-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
    }

    .region-flag {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: white;
        border: 2px solid #e9ecef;
        padding: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 3px 6px rgba(0,0,0,0.05);
        flex: 0 0 auto;
    }

    .region-name {
        font-family: var(--font-subheader);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--pal-dark-blue);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 320px;
    }

    .attempt-cell {
        font-family: var(--font-subheader);
        font-weight: 900;
        text-align: center;
        color: #495057;
        white-space: nowrap;
    }

    .best-result {
        font-family: var(--font-subheader);
        font-weight: 900;
        text-align: center;
        color: var(--pal-gold);
        white-space: nowrap;
        font-size: 1.05rem;
    }

    .gold-row { background: linear-gradient(90deg, rgba(255,215,0,0.12), rgba(255,215,0,0.03)) !important; }
    .silver-row { background: linear-gradient(90deg, rgba(192,192,192,0.12), rgba(192,192,192,0.03)) !important; }
    .bronze-row { background: linear-gradient(90deg, rgba(205,127,50,0.12), rgba(205,127,50,0.03)) !important; }

    .page-footer {
        width: min(1400px, calc(100% - 40px));
        margin: 16px auto 0 auto;
        text-align: center;
        color: #6c757d;
        font-family: var(--font-subheader);
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        border-top: 1px solid #f1f1f1;
        padding-top: 12px;
        letter-spacing: 1px;
    }

    @@media (max-width: 900px) {
        .header-pill { padding: 18px 22px; }
        .event-name { font-size: 1.5rem; }
        .region-name { max-width: 220px; }
    }

    @@media (max-width: 600px) {
        .region-name { max-width: 160px; }
        .rank-pill { min-width: 56px; padding: 6px 10px; }
    }
</style>

<div class="tv-screen-bg">
    <button class="back-button" onclick="history.back()">← Back</button>

    @if (_isLoading)
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height:70vh;">
            <MudProgressCircular Indeterminate Color="Color.Primary" Size="Size.Large" />
            <MudText Typo="Typo.h6" Class="mt-4" Style="font-family:var(--font-header); color:var(--pal-blue);">
                LOADING FIELD EVENT...
            </MudText>
        </MudStack>
    }
    else if (_event == null)
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height:70vh;">
            <MudText Typo="Typo.h4" Style="font-family:var(--font-header); color: var(--pal-red);">
                EVENT NOT FOUND
            </MudText>
        </MudStack>
    }
    else
    {
        <div class="dashboard-header">
            <div class="header-pill">
                <h1 class="main-event-title">FIELD EVENTS TV</h1>
                <div class="sub-header-text">OFFICIAL SCOREBOARD</div>
            </div>
        </div>

        <div class="top-info">
            <div class="top-info-bar">
                <div class="@(_event.IsFinished == true ? "badge-final" : "badge-live")">
                    @(_event.IsFinished == true ? "FINAL" : "LIVE")
                </div>

                <div class="pill">
                    <MudIcon Icon="@Icons.Material.Filled.Sports" Size="Size.Small" />
                    @(_event.Sport ?? "ATHLETICS")
                </div>

                <div class="pill">
                    <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Size="Size.Small" />
                    @(_event.Level ?? "LEVEL")
                </div>

                <div class="pill">
                    <MudIcon Icon="@Icons.Material.Filled.Wc" Size="Size.Small" />
                    @(_event.Gender ?? "GENDER")
                </div>

                <div class="pill">
                    <MudIcon Icon="@Icons.Material.Filled.Flag" Size="Size.Small" />
                    @(_event.EventStage ?? "STAGE")
                </div>
            </div>

            <div class="event-title-block">
                <div class="event-name">@_event.Subcategory</div>

                <div class="event-sub">
                    <span>@_event.Level • @_event.Gender</span>
                    @{
                        var categoryType = GetCategoryType(_event.Subcategory);
                    }
                    <span class="category-badge @GetCategoryClass(categoryType)">
                        @categoryType
                    </span>
                </div>
            </div>
        </div>

        @if (_scoringRows.Any())
        {
            <div class="results-wrap">
                <div class="results-header">
                    <div class="results-title">
                        <MudIcon Icon="@Icons.Material.Filled.Leaderboard" Style="color: var(--pal-gold);" />
                        RESULTS
                    </div>
                    <div class="results-note">BEST RESULT • 3 ATTEMPTS</div>
                </div>

                <MudTable Class="tv-table"
                          Items="_scoringRows
                                    .OrderByDescending(r => r.BestResult)
                                    .ThenBy(r => r.Rank)
                                    .ToList()"
                          Dense="true"
                          Hover="true"
                          Elevation="0">

                    <HeaderContent>
                        <MudTh>Rank</MudTh>
                        <MudTh>Athlete</MudTh>
                        <MudTh>Region</MudTh>
                        <MudTh style="text-align:center;">Attempt 1</MudTh>
                        <MudTh style="text-align:center;">Attempt 2</MudTh>
                        <MudTh style="text-align:center;">Attempt 3</MudTh>
                        <MudTh style="text-align:center;">Best Result</MudTh>
                    </HeaderContent>

                    <RowTemplate>
                        @{
                            var rankClass = context.Rank switch
                            {
                                1 => "rank-1",
                                2 => "rank-2",
                                3 => "rank-3",
                                _ => ""
                            };
                        }

                        <MudTd>
                            @if (context.Rank > 0)
                            {
                                <span class="rank-pill @rankClass">#@context.Rank</span>
                            }
                            else
                            {
                                <span class="rank-pill" style="opacity:.55;">-</span>
                            }
                        </MudTd>

                        <MudTd>
                            <div class="athlete-name">@context.PlayerName</div>
                        </MudTd>

                        <MudTd>
                            <div class="region-wrap">
                                <div class="region-flag">
                                    <MudImage Src="@GetRegionLogo(context.RegionName)"
                                              ObjectFit="ObjectFit.Contain"
                                              Alt="@context.RegionName"
                                              Style="width:100%; height:100%;" />
                                </div>
                                <div class="region-name">@context.RegionName</div>
                            </div>
                        </MudTd>

                        <MudTd Class="attempt-cell">
                            @(context.AttemptResults[0].HasValue ? context.AttemptResults[0]!.Value.ToString("F2") : "-")
                        </MudTd>

                        <MudTd Class="attempt-cell">
                            @(context.AttemptResults[1].HasValue ? context.AttemptResults[1]!.Value.ToString("F2") : "-")
                        </MudTd>

                        <MudTd Class="attempt-cell">
                            @(context.AttemptResults[2].HasValue ? context.AttemptResults[2]!.Value.ToString("F2") : "-")
                        </MudTd>

                        <MudTd Class="best-result">
                            @if (context.BestResult > 0)
                            {
                                @context.BestResult.ToString("F2")
                            }
                            else
                            {
                                <text>-</text>
                            }
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </div>

            <div class="page-footer">
                @(_event.Level ?? "") • @(_event.Subcategory ?? "") • PALARONG PAMBANSA 2026
            </div>
        }
        else
        {
            <div class="results-wrap">
                <div class="results-header">
                    <div class="results-title">
                        <MudIcon Icon="@Icons.Material.Filled.Leaderboard" Style="color: var(--pal-gold);" />
                        RESULTS
                    </div>
                    <div class="results-note">NO DATA YET</div>
                </div>

                <MudStack AlignItems="AlignItems.Center" Class="pa-10">
                    <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty"
                             Size="Size.Large"
                             Style="color:#dee2e6; width:70px; height:70px;" />
                    <MudText Typo="Typo.h6" Style="color:#adb5bd; font-family:var(--font-header);">
                        WAITING FOR RESULTS...
                    </MudText>
                </MudStack>
            </div>
        }
    }
</div>

