@* Shared/FieldEventsFooter.razor *@

<style>
    :root {
        --pal-blue: #2B5592;
        --pal-dark-blue: #001845;
        --pal-gold: #FFB400;
        --pal-red: #EA0000;
    }

    /* --- GLOBAL FOOTER --- */
    .ticker-footer {
        position: fixed; /* works even without a Layout */
        bottom: 0;
        left: 0;
        width: 100%;
        height: 11vh;
        display: flex;
        align-items: center;
        z-index: 2000;
        pointer-events: none; /* so it won't block clicks */
    }

    /* Solid Dark Blue Background */
    .footer-bg {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: var(--pal-dark-blue);
        z-index: 1;
        box-shadow: none; /* 🔥 shadow removed */
    }

    /* Ribbons */
    .brand-waves-svg {
        position: absolute;
        bottom: 0;
        right: 0;
        width: 45vw;
        height: 15vh;
        z-index: 2;
        pointer-events: none;
        display: block;
    }

    .ticker-track {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 1.2vw;
        padding-left: 2vw;
        width: 100%;
        height: 100%;
        z-index: 10;
        position: relative;
        pointer-events: none;
    }

    .footer-logo {
        width: auto;
        object-fit: contain;
        filter: drop-shadow(0 3px 5px rgba(0,0,0,0.4));
        transition: transform 0.3s ease;
        pointer-events: none;
    }

    /* LOGO SIZES */
    .logo-agsur {
        height: 7.5vh;
    }

    .logo-deped {
        height: 10.5vh;
    }

    .logo-bagong {
        height: 9.5vh;
    }

    .logo-palaro {
        height: 14vh;
    }

    .logo-pgas {
        height: 9.5vh;
    }

    @@media (max-width: 1024px) {
        .ticker-footer {
            height: 9vh;
        }

        .brand-waves-svg {
            height: 12vh;
            width: 75vw;
        }

        .ticker-track {
            gap: 2vw;
            padding-left: 2vw;
        }

        .logo-agsur {
            height: 5.5vh;
        }

        .logo-deped {
            height: 4vh;
        }

        .logo-bagong {
            height: 5vh;
        }

        .logo-palaro {
            height: 4.5vh;
        }

        .logo-pgas {
            height: 5.5vh;
        }
    }
</style>

<div class="ticker-footer">
    <div class="footer-bg"></div>

    <svg class="brand-waves-svg" viewBox="0 0 1000 300" preserveAspectRatio="none">
        <path d="M 0,300 L 200,300 C 500,300 650,-20 1000,20 L 1000,300 Z" fill="var(--pal-gold)" />
        <path d="M 0,300 L 300,300 C 600,300 750,40 1000,70 L 1000,300 Z" fill="var(--pal-blue)" />
        <path d="M 0,300 L 400,300 C 700,300 800,100 1000,120 L 1000,300 Z" fill="var(--pal-dark-blue)" />
    </svg>

    <div class="ticker-track">
        <img src="/media/images/Agsurwhite.png" class="footer-logo logo-agsur" alt="Agsur Logo" />
        <img src="/media/images/depedwhite.png" class="footer-logo logo-deped" alt="DepEd" />
        <img src="/media/images/bagongwhite.png" class="footer-logo logo-bagong" alt="Bagong Pilipinas" />
        <img src="/media/images/palarongwhite.png" class="footer-logo logo-palaro" alt="Palaro Logo" />
        <img src="/media/images/pgaswhite.png" class="footer-logo logo-pgas" alt="LGU Agusan" />
    </div>
</div>