@inherits LayoutComponentBase

<style>
    :root {
        --pal-blue: #023E8A;
        --pal-dark-blue: #001845;
        --pal-gold: #FFB400;
        --pal-red: #EA0000;
        --bg-gradient-start: #f8f9fa;
        --font-header: 'Evil Empire', sans-serif;
        --font-body: 'Avenir Book', 'Avenir', 'Nunito', sans-serif;
    }

    html, body {
        height: 100vh;
        width: 100vw;
        margin: 0;
        padding: 0;
        overflow: hidden;
        background-color: var(--bg-gradient-start);
        font-family: var(--font-body);
    }

    .layout-wrapper {
        height: 100vh;
        width: 100vw;
        background: radial-gradient(circle at 50% 30%, #ffffff 0%, #e0e7ff 100%);
        position: relative;
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
    }

    .page-content {
        flex-grow: 1;
        padding: 4vh 8vw 13vh 8vw;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
    }

    /* --- GLOBAL FOOTER --- */
    .ticker-footer {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 11vh;
        background-color: var(--pal-dark-blue); /* This ensures the left side is solid dark blue */
        display: flex;
        align-items: center;
        z-index: 100;
        overflow: hidden;
        box-shadow: 0 -8px 30px rgba(0,0,0,0.4);
    }

    /* THE RIBBON WAVES */
    .brand-waves-svg {
        position: absolute;
        bottom: 0;
        right: 0;
        width: 55vw; /* Covers more than half the footer */
        height: 120%; /* Slightly taller to prevent top-edge clipping */
        z-index: 1;
        pointer-events: none;
        display: block;
    }

    .ticker-track {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 1.2vw;
        padding-left: 2vw;
        width: 100%;
        height: 100%;
        z-index: 10; /* Ensures logos are ALWAYS on top of the waves */
        position: relative;
    }

    .footer-logo {
        width: auto;
        object-fit: contain;
        filter: drop-shadow(0 3px 5px rgba(0,0,0,0.4));
        transition: transform 0.3s ease;
    }

    /* LOGO SIZES */
    .logo-agsur {
        height: 7.5vh;
    }

    .logo-deped {
        height: 10.5vh;
    }

    .logo-bagong {
        height: 9.5vh;
    }

    .logo-palaro {
        height: 14vh;
    }

    .logo-pgas {
        height: 9.5vh;
    }

    /* RESPONSIVE LAYOUT */
    @@media (max-width: 1024px) {
        .page-content {
            padding: 2vh 3vw 14vh 3vw;
        }

        .ticker-footer {
            height: 9vh;
        }

        .brand-waves-svg {
            width: 80vw;
        }
        /* More wave coverage on mobile */
        .ticker-track {
            gap: 2vw;
            padding-left: 2vw;
        }
        /* MOBILE LOGO SIZES */
        .logo-agsur {
            height: 5.5vh;
        }

        .logo-deped {
            height: 4vh;
        }

        .logo-bagong {
            height: 5vh;
        }

        .logo-palaro {
            height: 4.5vh;
        }

        .logo-pgas {
            height: 5.5vh;
        }
    }
</style>

<div class="layout-wrapper">
    <main class="page-content">
        @Body
    </main>

    <!-- Global Footer -->
    <div class="ticker-footer">
        <!--
            Custom SVG paths designed to mimic the overlapping ribbons
            from your reference images.
        -->
        <svg class="brand-waves-svg" viewBox="0 0 1000 150" preserveAspectRatio="none">
            <!-- Background Layer (Blends with footer) -->
            <path d="M0,150 C200,150 400,130 550,70 C650,30 850,10 1000,40 L1000,150 Z" fill="var(--pal-blue)" opacity="0.4" />

            <!-- Mid Blue Ribbon -->
            <path d="M150,150 C350,150 500,110 650,60 C800,10 950,20 1000,50 L1000,150 Z" fill="var(--pal-blue)" />

            <!-- Gold Ribbon (Top Highlight) -->
            <path d="M350,150 C500,150 650,120 750,70 C850,20 950,40 1000,80 L1000,150 Z" fill="var(--pal-gold)" />

            <!-- Dark Blue Accent (Bottom taper) -->
            <path d="M500,150 C650,150 800,135 900,110 C950,95 1000,105 1000,125 L1000,150 Z" fill="var(--pal-dark-blue)" />
        </svg>

        <div class="ticker-track">
            <img src="/media/images/Agsurwhite.png" class="footer-logo logo-agsur" alt="Agsur Logo" />
            <img src="/media/images/depedwhite.png" class="footer-logo logo-deped" alt="DepEd" />
            <img src="/media/images/bagongwhite.png" class="footer-logo logo-bagong" alt="Bagong Pilipinas" />
            <img src="/media/images/palarongwhite.png" class="footer-logo logo-palaro" alt="Palaro Logo" />
            <img src="/media/images/pgaswhite.png" class="footer-logo logo-pgas" alt="LGU Agusan" />
        </div>
    </div>
</div>