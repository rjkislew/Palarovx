@inherits LayoutComponentBase

<style>
    :root {
        --pal-blue: #023E8A;
        --pal-dark-blue: #001845;
        --pal-gold: #FFB400;
        --pal-red: #EA0000;
        --bg-gradient-start: #f8f9fa;
        --font-header: 'Evil Empire', sans-serif;
        --font-body: 'Avenir Book', 'Avenir', 'Nunito', sans-serif;
        --card-bg: rgba(255, 255, 255, 0.95);
    }

    html, body {
        height: 100vh;
        width: 100vw;
        margin: 0;
        padding: 0;
        overflow: hidden;
        background-color: var(--bg-gradient-start);
        font-family: var(--font-body);
    }

    .layout-wrapper {
        height: 100vh;
        width: 100vw;
        background: radial-gradient(circle at 50% 30%, #ffffff 0%, #e0e7ff 100%);
        position: relative;
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
    }

    .page-content {
        flex-grow: 1;
        padding: 4vh 8vw 13vh 8vw;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
    }

    /* --- GLOBAL FOOTER --- */
    .ticker-footer {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 11vh;
        background-color: var(--pal-dark-blue);
        display: flex;
        align-items: center;
        z-index: 100;
        overflow: hidden;
        box-shadow: 0 -5px 25px rgba(0,0,0,0.3);
    }

    .brand-waves-svg {
        position: absolute;
        bottom: 0;
        right: 0;
        width: 45vw;
        height: 100%;
        z-index: 1;
        pointer-events: none;
    }

    .ticker-track {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        /* GIDUG-OL ANG LOGO DIRI (Gikan sa 3vw, gihimong 1vw) */
        gap: 1vw;
        padding-left: 1.5vw;
        width: 100%;
        height: 100%;
        z-index: 5;
        position: relative;
    }

    .footer-logo {
        width: auto;
        object-fit: contain;
        filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
    }

    /* LOGO SIZES */
    .logo-agsur {
        height: 7vh;
    }

    .logo-deped {
        height: 15vh;
    }

    .logo-bagong {
        height: 15vh;
    }

    .logo-palaro {
        height: 15vh;
    }

    .logo-pgas {
        height: 9vh;
    }

    /* RESPONSIVE LAYOUT */
    @@media (max-width: 1024px) {
        .page-content {
            padding: 2vh 3vw 14vh 3vw;
        }

        .ticker-footer {
            height: 8vh;
        }

        .ticker-track {
            /* DUG-OL PUD PARA MOBILE (Gikan sa 4vw, gihimong 2vw) */
            gap: 2vw;
            padding-left: 2vw;
        }
        /* MOBILE LOGO SIZES */
        .logo-agsur {
            height: 5vh;
        }

        .logo-deped {
            height: 3.5vh;
        }

        .logo-bagong {
            height: 4.5vh;
        }

        .logo-palaro {
            height: 4vh;
        }

        .logo-pgas {
            height: 5vh;
        }
    }
</style>

<div class="layout-wrapper">
    <main class="page-content">
        @Body
    </main>

    <!-- Global Footer -->
    <div class="ticker-footer">
        <svg class="brand-waves-svg" viewBox="0 0 1000 200" preserveAspectRatio="none">
            <path d="M1000,200 L1000,-100 C650,-100 350,200 0,200 Z" fill="var(--pal-gold)" />
            <path d="M1000,200 L1000,0 C700,0 450,200 80,200 Z" fill="var(--pal-blue)" />
            <path d="M1000,200 L1000,80 C750,80 550,200 200,200 Z" fill="var(--pal-dark-blue)" />
        </svg>

        <div class="ticker-track">
            <img src="/media/images/Agsurwhite.png" class="footer-logo logo-agsur" alt="Agsur Logo" />
            <img src="/media/images/depedwhite.png" class="footer-logo logo-deped" alt="DepEd" />
            <img src="/media/images/bagongwhite.png" class="footer-logo logo-bagong" alt="Bagong Pilipinas" />
            <img src="/media/images/palarongwhite.png" class="footer-logo logo-palaro" alt="Palaro Logo" />
            <img src="/media/images/pgaswhite.png" class="footer-logo logo-pgas" alt="LGU Agusan" />
        </div>
    </div>
</div>