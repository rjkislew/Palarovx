@inherits LayoutComponentBase

<style>
    :root {
        --pal-blue: #2B5592;
        --pal-dark-blue: #001845;
        --pal-gold: #FFB400;
        --pal-red: #EA0000;
        --bg-gradient-start: #f8f9fa;
        --font-header: 'Evil Empire', sans-serif;
        --font-body: 'Avenir Book', 'Avenir', 'Nunito', sans-serif;
    }

    html, body {
        height: 100vh;
        width: 100vw;
        margin: 0;
        padding: 0;
        overflow: hidden;
        background-color: var(--bg-gradient-start);
        font-family: var(--font-body);
    }

    .layout-wrapper {
        height: 100vh;
        width: 100vw;
        background: radial-gradient(circle at 50% 30%, #ffffff 0%, #e0e7ff 100%);
        position: relative;
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
    }

    .page-content {
        flex-grow: 1;
        padding: 4vh 8vw 13vh 8vw;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
        z-index: 5;
    }

    /* --- GLOBAL FOOTER --- */
    .ticker-footer {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 11vh;
        display: flex;
        align-items: center;
        z-index: 100;
    }

    /* Solid Dark Blue Background para sa Footer */
    .footer-bg {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: var(--pal-dark-blue);
        z-index: 1;
        box-shadow: 0 -8px 30px rgba(0,0,0,0.4);
    }

    /* THE RIBBON WAVES - GIGAMAYAN ANG WIDTH UG HEIGHT */
    .brand-waves-svg {
        position: absolute;
        bottom: 0;
        right: 0; /* Gibalhin sa right side */
        width: 45vw; /* GIKAN 100vw, GIHIMO NAKONG 45vw PARA MUGAMAY ANG GILAPDON */
        height: 15vh;
        z-index: 2;
        pointer-events: none;
        display: block;
    }

    .ticker-track {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 1.2vw;
        padding-left: 2vw;
        width: 100%;
        height: 100%;
        z-index: 10;
        position: relative;
    }

    .footer-logo {
        width: auto;
        object-fit: contain;
        filter: drop-shadow(0 3px 5px rgba(0,0,0,0.4));
        transition: transform 0.3s ease;
    }

    /* LOGO SIZES */
    .logo-agsur {
        height: 7.5vh;
    }

    .logo-deped {
        height: 10.5vh;
    }

    .logo-bagong {
        height: 9.5vh;
    }

    .logo-palaro {
        height: 14vh;
    }

    .logo-pgas {
        height: 9.5vh;
    }

    /* RESPONSIVE LAYOUT */
    @@media (max-width: 1024px) {
        .page-content {
            padding: 2vh 3vw 12vh 3vw;
        }

        .ticker-footer {
            height: 9vh;
        }

        .brand-waves-svg {
            height: 12vh;
            width: 75vw; /* Gihimong 75vw sa mobile para dili mahanaw kaayo */
        }

        .ticker-track {
            gap: 2vw;
            padding-left: 2vw;
        }
        /* MOBILE LOGO SIZES */
        .logo-agsur {
            height: 5.5vh;
        }

        .logo-deped {
            height: 4vh;
        }

        .logo-bagong {
            height: 5vh;
        }

        .logo-palaro {
            height: 4.5vh;
        }

        .logo-pgas {
            height: 5.5vh;
        }
    }
</style>

<div class="layout-wrapper">
    <main class="page-content">
        @Body
    </main>

    <!-- Global Footer Container -->
    <div class="ticker-footer">

        <!-- 1. Solid base background (Dark Blue) -->
        <div class="footer-bg"></div>

        <!-- 2. The Ribbons -->
        <svg class="brand-waves-svg" viewBox="0 0 1000 300" preserveAspectRatio="none">
            <!-- Top Gold Ribbon -->
            <path d="M 0,300 L 200,300 C 500,300 650,-20 1000,20 L 1000,300 Z" fill="var(--pal-gold)" />

            <!-- Middle Blue Ribbon -->
            <path d="M 0,300 L 300,300 C 600,300 750,40 1000,70 L 1000,300 Z" fill="var(--pal-blue)" />

            <!-- Bottom Dark Blue Ribbon -->
            <path d="M 0,300 L 400,300 C 700,300 800,100 1000,120 L 1000,300 Z" fill="var(--pal-dark-blue)" />
        </svg>

        <!-- 3. Ang mga Logos -->
        <div class="ticker-track">
            <img src="/media/images/Agsurwhite.png" class="footer-logo logo-agsur" alt="Agsur Logo" />
            <img src="/media/images/depedwhite.png" class="footer-logo logo-deped" alt="DepEd" />
            <img src="/media/images/bagongwhite.png" class="footer-logo logo-bagong" alt="Bagong Pilipinas" />
            <img src="/media/images/palarongwhite.png" class="footer-logo logo-palaro" alt="Palaro Logo" />
            <img src="/media/images/pgaswhite.png" class="footer-logo logo-pgas" alt="LGU Agusan" />
        </div>
    </div>
</div>