    private async Task ProceedToNextStage()
    {
        try
        {
            // Validate that we have a selected event
            if (SelectedEvent == null || string.IsNullOrEmpty(SelectedEvent.ID))
            {
                Snackbar.Add("No event selected", Severity.Warning);
                return;
            }

            // First, ensure rankings are calculated
            CalculateAllRankings();

            // Get the top 8 players (those with rank 1-8)
            var top8Players = ScoringRows
                .Where(r => r.Rank >= 1 && r.Rank <= 8 && r.BestResult > 0)
                .OrderBy(r => r.Rank)
                .ToList();

            if (!top8Players.Any())
            {
                Snackbar.Add("No ranked players found. Please calculate rankings first.", Severity.Warning);
                return;
            }

            if (top8Players.Count < 8)
            {
                Snackbar.Add($"Only {top8Players.Count} players have valid results. Need at least 8 to proceed to finals.", Severity.Warning);
                return;
            }

            // Get current stage ID and next stage ID
            var currentStageId = await GetCurrentEventStageId();
            if (!currentStageId.HasValue)
            {
                Snackbar.Add("Could not determine current event stage.", Severity.Error);
                return;
            }

            var nextStageId = GetNextStageId(currentStageId.Value);
            if (nextStageId == 0)
            {
                Snackbar.Add("No next stage available for progression.", Severity.Warning);
                return;
            }

            // Get the next stage name
            var nextStage = _eventStages?.FirstOrDefault(s => s.ID == nextStageId);
            if (nextStage == null)
            {
                Snackbar.Add($"Could not find stage with ID {nextStageId}", Severity.Error);
                return;
            }

            // Get EventVersusTeams for the current event to get original team data
            var progressionTeams = new List<Dictionary<string, object>>();

            // Get ALL EventVersusTeams for the current event
            var versusTeams = await apiService.GetAsync<EventsDTO.EventVersusTeams>(
                $"/Events/VersusTeams?eventID={SelectedEvent.ID}");

            if (versusTeams != null && versusTeams.Any())
            {
                // Filter to only include top 8 players
                foreach (var topPlayer in top8Players)
                {
                    // Find the matching team for this region and player
                    var matchingTeam = versusTeams.FirstOrDefault(t =>
                        t.SchoolRegionID == topPlayer.RegionID);

                    if (matchingTeam != null)
                    {
                        // Get players for this team
                        var teamPlayers = await apiService.GetAsync<EventsDTO.EventVersusTeamPlayers>(
                            $"/Events/VersusTeams/Players?eventVersusID={matchingTeam.ID}");

                        var selectedPlayerIds = new List<string>();
                        var playerNames = new List<string>();

                        if (teamPlayers != null && teamPlayers.Any())
                        {
                            // For field events, we need to match the specific player
                            var matchingPlayer = teamPlayers.FirstOrDefault(p =>
                                p.ProfilePlayerID == topPlayer.PlayerID);

                            if (matchingPlayer != null)
                            {
                                selectedPlayerIds.Add(matchingPlayer.ProfilePlayerID!);

                                // Build full name
                                var fullName = "";
                                if (!string.IsNullOrEmpty(matchingPlayer.FirstName) && !string.IsNullOrEmpty(matchingPlayer.LastName))
                                    fullName = $"{matchingPlayer.FirstName} {matchingPlayer.LastName}";
                                else if (!string.IsNullOrEmpty(matchingPlayer.FirstName))
                                    fullName = matchingPlayer.FirstName;
                                else if (!string.IsNullOrEmpty(matchingPlayer.LastName))
                                    fullName = matchingPlayer.LastName;
                                else
                                    fullName = matchingPlayer.ProfilePlayerID;

                                playerNames.Add(fullName);
                            }
                        }

                        // Add to progression teams
                        var teamData = new Dictionary<string, object>
                            {
                                ["SelectedRegionID"] = matchingTeam.SchoolRegionID,
                                ["ExistingVersusTeamID"] = matchingTeam.ID,
                                ["Score"] = topPlayer.BestResult.ToString("F2"),
                                ["Rank"] = topPlayer.Rank.ToString(),
                                ["SelectedPlayerIDs"] = selectedPlayerIds,
                                ["PlayerNames"] = playerNames,
                                ["RegionName"] = topPlayer.RegionName,
                                ["IsWinner"] = true,
                                ["PlayerSpecificInfo"] = new
                                {
                                    PlayerID = topPlayer.PlayerID,
                                    PlayerName = topPlayer.PlayerName
                                }
                            };

                        progressionTeams.Add(teamData);
                    }
                    else
                    {
                        // If no matching team found, create from ScoringRow
                        var teamData = new Dictionary<string, object>
                            {
                                ["SelectedRegionID"] = topPlayer.RegionID,
                                ["ExistingVersusTeamID"] = null,
                                ["Score"] = topPlayer.BestResult.ToString("F2"),
                                ["Rank"] = topPlayer.Rank.ToString(),
                                ["SelectedPlayerIDs"] = !string.IsNullOrEmpty(topPlayer.PlayerID) ?
                                    new List<string> { topPlayer.PlayerID } : new List<string>(),
                                ["PlayerNames"] = !string.IsNullOrEmpty(topPlayer.PlayerName) ?
                                    new List<string> { topPlayer.PlayerName } : new List<string>(),
                                ["RegionName"] = topPlayer.RegionName,
                                ["IsWinner"] = true,
                                ["PlayerSpecificInfo"] = new
                                {
                                    PlayerID = topPlayer.PlayerID,
                                    PlayerName = topPlayer.PlayerName
                                }
                            };

                        progressionTeams.Add(teamData);
                    }
                }
            }
            else
            {
                // Fallback: If no EventVersusTeams found, use ScoringRows data
                foreach (var topPlayer in top8Players)
                {
                    var teamData = new Dictionary<string, object>
                        {
                            ["SelectedRegionID"] = topPlayer.RegionID,
                            ["ExistingVersusTeamID"] = null,
                            ["Score"] = topPlayer.BestResult.ToString("F2"),
                            ["Rank"] = topPlayer.Rank.ToString(),
                            ["SelectedPlayerIDs"] = !string.IsNullOrEmpty(topPlayer.PlayerID) ?
                                new List<string> { topPlayer.PlayerID } : new List<string>(),
                            ["PlayerNames"] = !string.IsNullOrEmpty(topPlayer.PlayerName) ?
                                new List<string> { topPlayer.PlayerName } : new List<string>(),
                            ["RegionName"] = topPlayer.RegionName,
                            ["IsWinner"] = true,
                            ["PlayerSpecificInfo"] = new
                            {
                                PlayerID = topPlayer.PlayerID,
                                PlayerName = topPlayer.PlayerName
                            }
                        };

                    progressionTeams.Add(teamData);
                }
            }

            if (!progressionTeams.Any())
            {
                Snackbar.Add("No qualified participants found to proceed to next stage.", Severity.Warning);
                return;
            }

            // Prepare dialog parameters for creating new event
            var parameters = new DialogParameters<AddEditDialog>
        {
            { x => x.IsProgressionMode, true },
            { x => x.PreviousEventID, SelectedEvent.ID },
            { x => x.ProgressionTeams, progressionTeams },
            { x => x.SelectedEventStage, nextStage.Stage } // Using SelectedEventStage instead of SelectedEventStagesIDValue
        };

            // Open the dialog
            var options = new DialogOptions
                {
                    CloseButton = true,
                    MaxWidth = MaxWidth.Medium,
                    FullWidth = true,
                    CloseOnEscapeKey = true,
                    BackdropClick = false
                };

            var dialog = await DialogService.ShowAsync<AddEditDialog>("Create Finals Event", parameters, options);
            var result = await dialog.Result;

            if (!result!.Canceled)
            {
                Snackbar.Add("Finals event created successfully with top 8 players!", Severity.Success);

                // Optionally navigate to the new finals event
                // var newEventId = result.Data?.ToString();
                // if (!string.IsNullOrEmpty(newEventId))
                // {
                //     Navigation.NavigateTo($"/score/field-events?eventId={newEventId}");
                // }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error proceeding to next stage: {ex.Message}", Severity.Error);
        }
    }

    // Add this helper method to get the current event stage ID
    private async Task<int?> GetCurrentEventStageId()
    {
        if (SelectedEvent?.ID == null) return null;

        try
        {
            if (!string.IsNullOrEmpty(SelectedEvent.EventStage) && _eventStages != null)
            {
                var stage = _eventStages.FirstOrDefault(s =>
                    s.Stage != null && s.Stage.Equals(SelectedEvent.EventStage, StringComparison.OrdinalIgnoreCase));
                return stage?.ID;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error getting current event stage ID: {ex.Message}", Severity.Warning);
        }

        return null;
    }

    // Add this helper method to get the next stage ID
    private int GetNextStageId(int currentStageId)
    {
        if (_eventStages != null)
        {
            // Get all stage IDs in order
            var stagesOrdered = _eventStages.OrderBy(s => s.ID).ToList();
            var currentIndex = stagesOrdered.FindIndex(s => s.ID == currentStageId);

            if (currentIndex >= 0 && currentIndex < stagesOrdered.Count - 1)
            {
                return stagesOrdered[currentIndex + 1].ID;
            }
        }

        return 0;
    }


    private async Task<bool> IsEventFinalsAndFinished()
    {
        if (SelectedEvent == null || string.IsNullOrEmpty(SelectedEvent.ID))
            return false;

        try
        {
            // Check if event stage is Finals
            bool isFinals = SelectedEvent.EventStage?.Equals("Finals", StringComparison.OrdinalIgnoreCase) == true;

            if (!isFinals)
                return false;

            // Check if event is finished
            var eventDetails = await apiService.GetAsync<EventsDTO.EventDetails>($"/Events?id={SelectedEvent.ID}");
            return eventDetails?.FirstOrDefault()?.IsFinished == true;
        }
        catch
        {
            return false;
        }
    }


    private async Task MarkMedalsInEventVersusTeams(List<ScoringRow> rankedRows)
    {
        try
        {
            if (SelectedEvent == null || string.IsNullOrEmpty(SelectedEvent.ID))
                return;

            // Get all EventVersusTeams for this event
            var versusTeams = await apiService.GetAsync<EventsDTO.EventVersusTeams>(
                $"/Events/VersusTeams?eventID={SelectedEvent.ID}");

            if (versusTeams == null || !versusTeams.Any())
            {
                Snackbar.Add("No EventVersusTeams found for this event", Severity.Warning);
                return;
            }

            // Mark Gold, Silver, Bronze for top 3
            var medalRanks = new[] { "Gold", "Silver", "Bronze" };

            for (int i = 0; i < Math.Min(rankedRows.Count, 3); i++)
            {
                var row = rankedRows[i];

                // Find the matching team - try multiple matching strategies
                var team = versusTeams.FirstOrDefault(t => t.SchoolRegionID == row.RegionID);

                // If not found by RegionID, try by region name/abbreviation
                if (team == null)
                {
                    team = versusTeams.FirstOrDefault(t =>
                        !string.IsNullOrEmpty(t.Abbreviation) &&
                        t.Abbreviation.Equals(row.RegionName, StringComparison.OrdinalIgnoreCase));
                }

                if (team != null)
                {
                    try
                    {
                        // Create update object with ALL properties from the original team
                        var updateDto = new
                        {
                            ID = team.ID,
                            EventID = team.EventID,
                            SchoolRegionID = team.SchoolRegionID,
                            Score = row.BestResult.ToString("F2"),
                            Rank = medalRanks[i],
                            // Include any other properties that might be required
                            Region = team.Region,
                            Abbreviation = team.Abbreviation
                        };

                        // Use a more specific endpoint or ensure the API accepts partial updates
                        await apiService.PutAsync($"/Events/VersusTeams/{team.ID}", updateDto);

                        // Also update in ScoringRows for display
                        row.Rank = i + 1; // Keep numeric rank for sorting

                        Snackbar.Add($"Marked {row.RegionName} as {medalRanks[i]}", Severity.Info);
                    }
                    catch (Exception ex)
                    {
                        Snackbar.Add($"Error updating team {team.ID}: {ex.Message}", Severity.Error);
                    }
                }
                else
                {
                    Snackbar.Add($"Could not find EventVersusTeam for region {row.RegionName} (ID: {row.RegionID})", Severity.Warning);
                }
            }

            // Mark remaining participants as "Finalist"
            for (int i = 3; i < rankedRows.Count; i++)
            {
                var row = rankedRows[i];
                var team = versusTeams.FirstOrDefault(t => t.SchoolRegionID == row.RegionID);

                if (team == null)
                {
                    team = versusTeams.FirstOrDefault(t =>
                        !string.IsNullOrEmpty(t.Abbreviation) &&
                        t.Abbreviation.Equals(row.RegionName, StringComparison.OrdinalIgnoreCase));
                }

                if (team != null)
                {
                    try
                    {
                        var updateDto = new
                        {
                            ID = team.ID,
                            EventID = team.EventID,
                            SchoolRegionID = team.SchoolRegionID,
                            Score = row.BestResult.ToString("F2"),
                            Rank = "Finalist",
                            Region = team.Region,
                            Abbreviation = team.Abbreviation
                        };

                        await apiService.PutAsync($"/Events/VersusTeams/{team.ID}", updateDto);
                    }
                    catch (Exception ex)
                    {
                        Snackbar.Add($"Error updating team {team.ID}: {ex.Message}", Severity.Error);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error marking medals: {ex.Message}", Severity.Error);
        }
    }
}