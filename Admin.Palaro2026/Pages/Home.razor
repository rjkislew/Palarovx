    <MudItem xs="12">
        <MudDivider />
    </MudItem>

    <MudItem xs="12">
        <MudPaper Outlined Style="height: 45vh">
            <MudStack Row Class="rounded-t pa-3" AlignItems="AlignItems.Center">
                <MudText>Logs</MudText>
                <MudSpacer />
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" Class="pa-1" />
            </MudStack>
            <MudDivider/>
            <MudStack Style="height: 100%" Class="pa-3">
            </MudStack>
        </MudPaper>
    </MudItem>
</MudGrid>

@code
{
    [CascadingParameter]
    private IMudDialogInstance? MudDialog { get; set; }

    private EventsDTO.EventCount? _eventCounts;
    private bool _privacyDialogShown;

    private string? UserRole;

    public class EventsDTO
    {
        public class EventCount
        {
            // Events
            public int? NumberOfEvents { get; set; }
            public int? NumberOfFinishedEvents { get; set; }
            public int? NumberofOngoingEvents { get; set; }
            public int? NumberOfEventsThatLacksPlayers { get; set; }

            // News
            public int? NumberOfNewsPublished { get; set; }

            // Streams
            public int? NumberOfEventStreamServices { get; set; }
            public int? NumberOfEventStreams { get; set; }

            // Venues and Billeting Quarters
            public int? NumberOfVenues { get; set; }
            public int? NumberOfBilletingQuarters { get; set; }

            // Participants
            public int? NumberOfRegionalTeamsParticipating { get; set; }
            public int? NumberOfSchoolDivisionsParticipating { get; set; }
            public int? NumberOfSchoolsParticipating { get; set; }
            public int? NumberOfPlayers { get; set; }
            public int? NumberOfMalePlayers { get; set; }
            public int? NumberOfFemalePlayers { get; set; }
            public int? NumberOfCoaches { get; set; }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        UserRole = await cookieService.GetCookie("userRole");
        await GetCounterAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Already shown? stop.
        if (_privacyDialogShown)
            return;

        // Role not loaded yet? wait for next render.
        if (string.IsNullOrWhiteSpace(UserRole))
            return;

        // ✅ Only show for Regional Representative (case-insensitive + trimmed)
        if (!string.Equals(UserRole.Trim(), "Regional Representative", StringComparison.OrdinalIgnoreCase))
            return;

        var agreed = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "agreeAdminPrivacyPolicy");
        if (string.Equals(agreed, "true", StringComparison.OrdinalIgnoreCase))
            return;

        _privacyDialogShown = true;
        await OpenAdminPrivacyDialog();
    }

    private async Task OpenAdminPrivacyDialog()
    {
        var options = new DialogOptions
        {
            NoHeader = true,
            BackdropClick = false,
            CloseButton = false,
            CloseOnEscapeKey = false,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<PrivacyPolicy>("Privacy Policy", options);
        var result = await dialog.Result;

        // If you truly require agreement, keep them here until they agree.
        // (Since we disabled escape/backdrop, Cancel won't normally happen,
        // but this is a safe fallback.)
        if (result.Canceled)
        {
            // Example: force logout / redirect
            Navigation.NavigateTo("/login", forceLoad: true);
        }
    }

    private async Task GetCounterAsync()
    {
        string url = "/Counter";
        _eventCounts = await apiService.GetSingleAsync<EventsDTO.EventCount>(url);
    }
}
