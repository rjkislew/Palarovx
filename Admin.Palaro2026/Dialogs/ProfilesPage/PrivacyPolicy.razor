@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">

            <MudStack Spacing="0" AlignItems="AlignItems.Center">
                <MudText Typo="Typo.h6">Privacy Policy</MudText>
            </MudStack>

            <MudDivider />

            <MudPaper Class="pa-3" Style="max-height:60vh; overflow:auto;">
                <MudStack Spacing="5">

                    <MudStack>
                        <MudText Typo="Typo.subtitle2">1. Information We Collect</MudText>
                        <MudText Typo="Typo.caption">We collect the following categories of data:</MudText>
                        <MudStack Spacing="0" Style="margin-left: 12px">
                            <MudText Typo="Typo.caption">• Full names, birthdates, and school affiliations of players and coaches</MudText>
                            <MudText Typo="Typo.caption">• Team registrations and regional delegation details</MudText>
                            <MudText Typo="Typo.caption">• Event participation and results</MudText>
                            <MudText Typo="Typo.caption">• Contact information of official representatives (if submitted)</MudText>
                            <MudText Typo="Typo.caption">• Visitor data such as session activity, anonymized IPs, and preferences</MudText>
                        </MudStack>
                    </MudStack>

                    <MudStack>
                        <MudText Typo="Typo.subtitle2">2. How We Use Your Data</MudText>
                        <MudText Typo="Typo.caption">The data collected is used for:</MudText>
                        <MudStack Spacing="0" Style="margin-left: 12px">
                            <MudText Typo="Typo.caption">• Validating athlete and coach identities</MudText>
                            <MudText Typo="Typo.caption">• Managing and publishing event brackets, scores, and match results</MudText>
                            <MudText Typo="Typo.caption">• Displaying registered team rosters and categories</MudText>
                            <MudText Typo="Typo.caption">• Enhancing the user experience and site functionality</MudText>
                        </MudStack>
                    </MudStack>

                    <MudStack>
                        <MudText Typo="Typo.subtitle2">3. Public Disclosure of Information</MudText>
                        <MudText Typo="Typo.caption">
                            The following information may be made publicly accessible:
                        </MudText>
                        <MudStack Spacing="0" Style="margin-left: 12px">
                            <MudText Typo="Typo.caption">• Player and coach names and associated regions/schools</MudText>
                            <MudText Typo="Typo.caption">• Team categories, sports disciplines, and event matchups</MudText>
                            <MudText Typo="Typo.caption">• Scores, medals, and official results</MudText>
                            <MudText Typo="Typo.caption">• Media content (photos/videos) during competitions</MudText>
                        </MudStack>
                    </MudStack>

                    <MudStack>
                        <MudText Typo="Typo.subtitle2">4. Data Security</MudText>
                        <MudText Typo="Typo.caption">We implement appropriate security measures including:</MudText>
                        <MudStack Spacing="0" Style="margin-left: 12px">
                            <MudText Typo="Typo.caption">• Encrypted storage and secure transmission</MudText>
                            <MudText Typo="Typo.caption">• Access restrictions to authorized personnel only</MudText>
                            <MudText Typo="Typo.caption">• Routine audits and vulnerability assessments</MudText>
                        </MudStack>
                    </MudStack>

                    <MudStack>
                        <MudText Typo="Typo.subtitle2">5. Data Retention</MudText>
                        <MudText Typo="Typo.caption">
                            Data is retained for the duration of the Palaro tu AgSur 2026 lifecycle and archived afterward for historical/statistical purposes.
                        </MudText>
                    </MudStack>

                    <MudStack>
                        <MudText Typo="Typo.subtitle2">6. Your Rights</MudText>
                        <MudText Typo="Typo.caption">
                            You may request access, correction, or raise concerns by contacting us.
                        </MudText>
                    </MudStack>

                    <MudStack>
                        <MudText Typo="Typo.subtitle2">7. Contact Information</MudText>
                        <MudText Typo="Typo.caption">📧 mail@pgas.ph</MudText>
                        <MudText Typo="Typo.caption">📞 (085)-242-1061 / (085)-242-1064</MudText>
                    </MudStack>

                    <MudStack>
                        <MudText Typo="Typo.subtitle2">8. Updates</MudText>
                        <MudText Typo="Typo.caption">
                            Revisions will be posted with the updated effective date.
                        </MudText>
                    </MudStack>

                </MudStack>
            </MudPaper>

            <MudCheckBox T="bool" @bind-Value="_accepted" 
                         Label="I have read and understood the Privacy Policy and agree to its terms."
                         Color="Color.Primary" />

        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudStack Row Style="width:100%" Justify="Justify.Center">
            <MudButton Style="text-transform:none"
                       Size="Size.Large"
                       FullWidth
                       Disabled="!_accepted"
                       OnClick="AgreePrivacy">
                Agree
            </MudButton>
        </MudStack>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }

    private bool _accepted;

    private async Task AgreePrivacy()
    {
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "agreeAdminPrivacyPolicy", "true");
        Snackbar.Add("Thank you. Privacy Policy accepted.", Severity.Success);
        MudDialog?.Close(DialogResult.Ok(true));
    }
}